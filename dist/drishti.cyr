    # loop-restoration type CDFs (10.md): use_wiener / use_sgrproj / restoration_type.
    store64(t + (1624 * 8), 11570); store64(t + (1625 * 8), 32768); store64(t + (1626 * 8), 0);
    store64(t + (1627 * 8), 16855); store64(t + (1628 * 8), 32768); store64(t + (1629 * 8), 0);
    store64(t + (1630 * 8), 9413); store64(t + (1631 * 8), 22581);
