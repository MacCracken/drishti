fn av1_fh_delta_q_y_dc(fh): i64 { return load64(fh + AV1FH_DELTA_Q_Y_DC); }
fn av1_fh_delta_q_u_dc(fh): i64 { return load64(fh + AV1FH_DELTA_Q_U_DC); }
