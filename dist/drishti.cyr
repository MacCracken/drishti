# --- drishti.cyr ---

# @public — drishti core: error codes, DrErr record, version, stream sniffing.
# drishti (दृष्टि — sight/vision) — sovereign video codecs for AGNOS.
#
# This module is FLAT (no includes) — stdlib resolves via cyrius.cyml and
# the include chain is wired in src/main.cyr. Every symbol carries the dr_
# prefix (Cyrius has no module-private scoping; duplicate fn names silently
# shadow).
#
# DrErr struct layout (16 bytes, heap; chitra ChitraErr pattern —
# layout-compatible with mabda's GpuErr):
#   +0: code    — error code constant (one of the DR_* below)
#   +8: detail  — pointer to a detail cstring (or 0)

# ================================================================
# Error code constants
#
# Core codes are 0-9. Codec FAMILIES get reserved bands so their
# module-local enums never collide with core or each other:
#   10-29  AV1     (src/av1_*.cyr)
#   30-49  H.264   (src/h264_*.cyr)
#   50-69  H.265   (src/h265_*.cyr)
#   70-89  VP8/VP9 (src/vp8_*.cyr / src/vp9_*.cyr / src/vpx_*.cyr)
#   90-98  reserved (future families)
# Families REUSE the core codes for the generic conditions (truncation,
# bounds, oversize, ...) and mint band codes only for codec-specific
# failures. DR_ERR_OTHER = 99 is the catch-all.
# ================================================================

enum DrErrCode {
    DR_OK                = 0;   # no error
    DR_ERR_TRUNCATED     = 1;   # input ends before a field/payload completes
    DR_ERR_BOUNDS        = 2;   # out-of-bounds read/seek, bad offset, misalignment
    DR_ERR_FORBIDDEN_BIT = 3;   # forbidden/reserved bit set (e.g. H.264 7.4.1 forbidden_zero_bit)
    DR_ERR_BAD_LEB128    = 4;   # leb128 >8 bytes or value >32 bits (AV1 spec 4.10.5 conformance)
    DR_ERR_BAD_VLC       = 5;   # malformed variable-length code (uvlc / exp-Golomb overflow)
    DR_ERR_BAD_HEADER    = 6;   # malformed container/OBU/NAL header (magic, sizes, ordering)
    DR_ERR_UNSUPPORTED   = 7;   # valid stream, but the feature is out of drishti's scope
    DR_ERR_OVERSIZE      = 8;   # size field exceeds sanity cap (decompression-bomb guard)
    DR_ERR_OOM           = 9;   # allocation failed
    DR_ERR_OTHER         = 99;  # catch-all
}

# ================================================================
# Stream/container sniff kinds (dr_sniff result)
# ================================================================

enum DrSniffKind {
    DR_SNIFF_UNKNOWN = 0;   # neither IVF nor Annex-B
    DR_SNIFF_IVF     = 1;   # IVF container ("DKIF" magic)
    DR_SNIFF_ANNEXB  = 2;   # raw Annex-B byte stream (00 00 01 / 00 00 00 01)
}

# ================================================================
# FourCC constants — the u32 you get from a little-endian 32-bit read
# of the 4 ASCII bytes (byte order in file: 'D','K','I','F' etc.).
# ================================================================

enum DrFourcc {
    DR_FOURCC_DKIF = 0x46494B44;   # "DKIF" — IVF magic
    DR_FOURCC_AV01 = 0x31305641;   # "AV01" — AV1 in IVF
    DR_FOURCC_VP80 = 0x30385056;   # "VP80" — VP8 in IVF
    DR_FOURCC_VP90 = 0x30395056;   # "VP90" — VP9 in IVF
}

# ================================================================
# Version — MAJOR*10000 + MINOR*100 + PATCH (0.7.78 -> 778).
# Keep in sync with the VERSION file at each cut.
# ================================================================

fn drishti_version(): i64 {
    return 778;
}

# ================================================================
# DrErr — 16-byte error record {code, detail-ptr}
# ================================================================

# Create a DrErr with code and an optional detail cstring (0 = none).
fn dr_err_new(code, detail): i64 {
    var e = alloc(16);
    if (e == 0) { return 0; }
    store64(e, code);
    store64(e + 8, detail);
    return e;
}

# Create a DrErr with code only (no detail).
fn dr_err(code): i64 {
    return dr_err_new(code, 0);
}

# Get the error code.
fn dr_err_code(e): i64 {
    return load64(e);
}

# Get the detail string pointer (or 0).
fn dr_err_detail(e): i64 {
    return load64(e + 8);
}

# ================================================================
# Error name lookup — returns a cstring (never null). Family-band
# codes fall through to per-band names so an unmapped family code
# still prints something meaningful.
# ================================================================

fn dr_err_name(code): i64 {
    if (code == DR_OK)                { return "ok"; }
    if (code == DR_ERR_TRUNCATED)     { return "truncated input"; }
    if (code == DR_ERR_BOUNDS)        { return "out-of-bounds read"; }
    if (code == DR_ERR_FORBIDDEN_BIT) { return "forbidden bit set"; }
    if (code == DR_ERR_BAD_LEB128)    { return "bad leb128"; }
    if (code == DR_ERR_BAD_VLC)       { return "bad variable-length code"; }
    if (code == DR_ERR_BAD_HEADER)    { return "bad header"; }
    if (code == DR_ERR_UNSUPPORTED)   { return "unsupported feature"; }
    if (code == DR_ERR_OVERSIZE)      { return "oversize field"; }
    if (code == DR_ERR_OOM)           { return "out of memory"; }
    if (code == DR_ERR_OTHER)         { return "other error"; }
    if ((code >= 10) && (code <= 29)) { return "AV1 error"; }
    if ((code >= 30) && (code <= 49)) { return "H.264 error"; }
    if ((code >= 50) && (code <= 69)) { return "H.265 error"; }
    if ((code >= 70) && (code <= 89)) { return "VP8/VP9 error"; }
    return "unknown error";
}

# Print an error name to stderr (fd 2).
fn dr_err_print_name(code): i64 {
    var name = dr_err_name(code);
    syscall(1, 2, name, strlen(name));
    return 0;
}

# ================================================================
# dr_sniff — classify a byte buffer as IVF / Annex-B / unknown.
#
# IVF:     bytes 0-3 == "DKIF" (needs len >= 4). Full header
#          validation is dr_ivf_reader_init's job — sniff is cheap.
# Annex-B: 4-byte start code 00 00 00 01 checked BEFORE the 3-byte
#          00 00 01 (the 3-byte probe would match the 4-byte prefix
#          bytes 0-2 = 00 00 00 and misreport). H.264 spec Annex B /
#          H.265 Annex B byte-stream NAL unit syntax.
# Every read is bounds-checked against len; never reads past buf+len.
# ================================================================

fn dr_sniff(buf, len): i64 {
    if (len >= 4) {
        # "DKIF" byte-by-byte — no unaligned 32-bit read needed.
        if ((load8(buf) == 0x44) && (load8(buf + 1) == 0x4B)
        && (load8(buf + 2) == 0x49) && (load8(buf + 3) == 0x46)) {
            return DR_SNIFF_IVF;
        }
        if ((load8(buf) == 0) && (load8(buf + 1) == 0)
        && (load8(buf + 2) == 0) && (load8(buf + 3) == 1)) {
            return DR_SNIFF_ANNEXB;
        }
    }
    if (len >= 3) {
        if ((load8(buf) == 0) && (load8(buf + 1) == 0) && (load8(buf + 2) == 1)) {
            return DR_SNIFF_ANNEXB;
        }
    }
    return DR_SNIFF_UNKNOWN;
}

# dr_sniff_fourcc — for an IVF buffer, the codec FourCC at header
# bytes 8-11 as a little-endian u32 (compare against DR_FOURCC_*).
# Returns 0 if the buffer is not IVF or too short to carry the field.
# LE read inlined byte-by-byte: drishti.cyr is the dep-free root module
# and must not reach into bits.cyr (dr_rd_le32).
fn dr_sniff_fourcc(buf, len): i64 {
    if (dr_sniff(buf, len) != DR_SNIFF_IVF) { return 0; }
    if (len < 12) { return 0; }
    var v = load8(buf + 8);
    v = v + (load8(buf + 9) << 8);
    v = v + (load8(buf + 10) << 16);
    v = v + (load8(buf + 11) << 24);
    return v;
}

# --- bits.cyr ---

# @public — drishti bit I/O: MSB-first bitreader/bitwriter + the shared
# variable-length codes every video family parses (leb128, uvlc,
# exp-Golomb ue(v)/se(v)) + little/big-endian byte helpers.
#
# FLAT module (no includes) — stdlib resolves via cyrius.cyml; wiring in
# src/main.cyr. Depends on src/drishti.cyr (DR_ERR_* codes) only.
#
# Spec citations:
#   AV1  spec 4.10.3 uvlc(), 4.10.5 leb128()
#   H.264 spec 9.1 ue(v) / 9.1.1 se(v) exp-Golomb   (H.265 9.2 is the
#   same code family — one implementation, cross-checked against both)
#
# Every read is bounds-checked; errors are STICKY: once a reader/writer
# faults, every later call is a no-op returning 0 and the first error
# code is preserved for inspection via dr_br_err / dr_bw_err.
#
# DrBr bitreader layout (32 bytes, heap):
#   +0:  buf — byte buffer base pointer (borrowed, not owned)
#   +8:  len — buffer length in BYTES
#   +16: pos — bit cursor (bits consumed since buf[0] bit 7)
#   +24: err — sticky error code (DR_OK until first fault)
#
# DrBw bitwriter layout (32 bytes, heap):
#   +0:  buf — owned output buffer (auto-grows by doubling)
#   +8:  cap — current capacity in BYTES
#   +16: pos — bit cursor (bits written)
#   +24: err — sticky error code

# Hard cap on bitwriter growth: 1 GiB. A writer asked to exceed it
# faults with DR_ERR_OVERSIZE instead of eating the machine.
enum DrBwLimits {
    DR_BW_MAX_BYTES = 1073741824;   # 1 << 30
}

# ================================================================
# Endian byte helpers — shared by ivf.cyr and the codec families.
# LE for IVF/RIFF-style containers, BE for MP4/avcC-style boxes.
# Callers own the bounds check (these are raw pointer reads).
# ================================================================

fn dr_rd_le16(p): i64 {
    return load8(p) + (load8(p + 1) << 8);
}

fn dr_rd_le32(p): i64 {
    return load8(p) + (load8(p + 1) << 8) + (load8(p + 2) << 16)
    + (load8(p + 3) << 24);
}

fn dr_rd_le64(p): i64 {
    return dr_rd_le32(p) + (dr_rd_le32(p + 4) << 32);
}

fn dr_wr_le16(p, v): i64 {
    store8(p, v & 255);
    store8(p + 1, (v >> 8) & 255);
    return 0;
}

fn dr_wr_le32(p, v): i64 {
    store8(p, v & 255);
    store8(p + 1, (v >> 8) & 255);
    store8(p + 2, (v >> 16) & 255);
    store8(p + 3, (v >> 24) & 255);
    return 0;
}

fn dr_wr_le64(p, v): i64 {
    dr_wr_le32(p, v & 0xFFFFFFFF);
    dr_wr_le32(p + 4, (v >> 32) & 0xFFFFFFFF);
    return 0;
}

fn dr_rd_be16(p): i64 {
    return (load8(p) << 8) + load8(p + 1);
}

fn dr_rd_be32(p): i64 {
    return (load8(p) << 24) + (load8(p + 1) << 16) + (load8(p + 2) << 8)
    + load8(p + 3);
}

fn dr_wr_be16(p, v): i64 {
    store8(p, (v >> 8) & 255);
    store8(p + 1, v & 255);
    return 0;
}

fn dr_wr_be32(p, v): i64 {
    store8(p, (v >> 24) & 255);
    store8(p + 1, (v >> 16) & 255);
    store8(p + 2, (v >> 8) & 255);
    store8(p + 3, v & 255);
    return 0;
}

# ================================================================
# DrBr — MSB-first bitreader
# ================================================================

# Create a bitreader over buf[0..len). The buffer is BORROWED — the
# caller keeps it alive for the reader's lifetime. Returns the DrBr
# handle, or 0 on allocation failure / negative len.
fn dr_br_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var br = alloc(32);
    if (br == 0) { return 0; }
    store64(br, buf);
    store64(br + 8, len);
    store64(br + 16, 0);
    store64(br + 24, DR_OK);
    return br;
}

# Sticky error code (DR_OK if the reader has never faulted).
fn dr_br_err(br): i64 {
    return load64(br + 24);
}

# Latch a sticky error onto the reader from OUTSIDE this module — the
# public seam family modules use to flag domain faults with core-
# consistent sticky semantics (no DrBr layout coupling). First code
# wins: an already-faulted reader keeps its original code. Returns the
# reader's (resulting) sticky code so callers can `return` it directly.
fn dr_br_set_err(br, code): i64 {
    if (load64(br + 24) == DR_OK) { store64(br + 24, code); }
    return load64(br + 24);
}

# Bits remaining (0 when exhausted or after a fault froze the cursor).
fn dr_br_bits_left(br): i64 {
    return (load64(br + 8) << 3) - load64(br + 16);
}

# Bit cursor: bits consumed so far.
fn dr_br_bit_pos(br): i64 {
    return load64(br + 16);
}

# Byte offset of the byte holding the NEXT unread bit (pos >> 3).
fn dr_br_byte_pos(br): i64 {
    return load64(br + 16) >> 3;
}

# Read one bit, MSB-first (bit 7 of buf[0] comes out first).
# Returns 0/1; on exhaustion sets sticky DR_ERR_TRUNCATED and returns 0.
fn dr_br_read_bit(br): i64 {
    if (load64(br + 24) != DR_OK) { return 0; }
    var pos = load64(br + 16);
    if (pos >= (load64(br + 8) << 3)) {
        store64(br + 24, DR_ERR_TRUNCATED);
        return 0;
    }
    var byte = load8(load64(br) + (pos >> 3));
    store64(br + 16, pos + 1);
    return (byte >> (7 - (pos & 7))) & 1;
}

# Read n bits (0 <= n <= 32), MSB-first, returned right-aligned.
# n == 0 reads nothing and returns 0. n outside [0,32] sets sticky
# DR_ERR_BOUNDS; fewer than n bits left sets sticky DR_ERR_TRUNCATED
# WITHOUT advancing the cursor. Faulted reads return 0.
fn dr_br_read_bits(br, n): i64 {
    if (load64(br + 24) != DR_OK) { return 0; }
    if ((n < 0) || (n > 32)) {
        store64(br + 24, DR_ERR_BOUNDS);
        return 0;
    }
    if (n == 0) { return 0; }
    if (dr_br_bits_left(br) < n) {
        store64(br + 24, DR_ERR_TRUNCATED);
        return 0;
    }
    var v = 0;
    var i = 0;
    while (i < n) {
        v = (v << 1) + dr_br_read_bit(br);
        i = i + 1;
    }
    return v;
}

# Skip n bits forward (n may exceed 32, unlike dr_br_read_bits). Sets
# sticky DR_ERR_BOUNDS on negative n, DR_ERR_TRUNCATED when fewer than n
# bits remain (cursor unmoved on fault). Returns DR_OK / sticky code.
fn dr_br_skip(br, n): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    if (n < 0) {
        store64(br + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    if (dr_br_bits_left(br) < n) {
        store64(br + 24, DR_ERR_TRUNCATED);
        return DR_ERR_TRUNCATED;
    }
    store64(br + 16, load64(br + 16) + n);
    return DR_OK;
}

# Advance the cursor to the next byte boundary (no-op if aligned).
# Discarded bits are not inspected. Cannot overrun: pos lands at most
# on len*8. Returns DR_OK (or the sticky error if already faulted).
fn dr_br_byte_align(br): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    var pos = load64(br + 16);
    store64(br + 16, (pos + 7) & (0 - 8));
    return DR_OK;
}

# True (1) when the cursor sits on a byte boundary.
fn dr_br_is_aligned(br): i64 {
    if ((load64(br + 16) & 7) == 0) { return 1; }
    return 0;
}

# ================================================================
# leb128 — AV1 spec 4.10.5 leb128()
#
#   value = 0
#   for (i = 0; i < 8; i++) {
#     leb128_byte = f(8)
#     value |= (leb128_byte & 0x7f) << (i*7)
#     if (!(leb128_byte & 0x80)) break
#   }
#
# Conformance (4.10.5): at most 8 bytes, value <= (1<<32)-1, and the
# final byte has its continuation bit clear. Non-minimal encodings
# (zero-padded, e.g. 0x80 0x00) ARE legal — encoders pad obu_size.
# ================================================================

# Read a leb128 value from a BYTE-ALIGNED reader into *out (u64 store).
# Returns DR_OK, or: DR_ERR_BOUNDS (reader not byte-aligned),
# DR_ERR_TRUNCATED (buffer ends mid-value), DR_ERR_BAD_LEB128 (8th byte
# still has the continuation bit, or decoded value > 0xFFFFFFFF).
# Fault codes are also latched into the reader's sticky error.
fn dr_leb128_read(br, out): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    if (dr_br_is_aligned(br) == 0) {
        store64(br + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var value = 0;
    var i = 0;
    while (i < 8) {
        var b = dr_br_read_bits(br, 8);
        e = load64(br + 24);
        if (e != DR_OK) { return e; }
        value = value + ((b & 0x7F) << (i * 7));
        if ((b & 0x80) == 0) {
            # 4.10.5 conformance: value must fit in 32 bits.
            if (value > 0xFFFFFFFF) {
                store64(br + 24, DR_ERR_BAD_LEB128);
                return DR_ERR_BAD_LEB128;
            }
            store64(out, value);
            return DR_OK;
        }
        i = i + 1;
    }
    # 8 bytes consumed and the last one still had the continuation bit.
    store64(br + 24, DR_ERR_BAD_LEB128);
    return DR_ERR_BAD_LEB128;
}

# ================================================================
# uvlc — AV1 spec 4.10.3 uvlc()
#
#   leadingZeros = 0
#   while (1) { done = f(1); if (done) break; leadingZeros++ }
#   if (leadingZeros >= 32) return (1<<32) - 1
#   value = f(leadingZeros)
#   return value + (1 << leadingZeros) - 1
# ================================================================

# Read a uvlc value into *out. Returns DR_OK or DR_ERR_TRUNCATED
# (zero-run or suffix hits end of buffer). Per spec, leadingZeros >= 32
# is NOT an error: the value is (1<<32)-1 and only the terminating 1
# bit (no suffix) is consumed after the zero run.
fn dr_uvlc_read(br, out): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    var lz = 0;
    while (1) {
        var done = dr_br_read_bit(br);
        e = load64(br + 24);
        if (e != DR_OK) { return e; }
        if (done) { break; }
        lz = lz + 1;
    }
    if (lz >= 32) {
        store64(out, 0xFFFFFFFF);
        return DR_OK;
    }
    var suffix = dr_br_read_bits(br, lz);
    e = load64(br + 24);
    if (e != DR_OK) { return e; }
    store64(out, suffix + (1 << lz) - 1);
    return DR_OK;
}

# ================================================================
# exp-Golomb — H.264 spec 9.1 (ue(v)) / 9.1.1 (se(v)); H.265 spec 9.2
# is the identical code family.
#
#   leadingZeroBits = -1
#   for (b = 0; !b; leadingZeroBits++) b = read_bit()
#   codeNum = 2^leadingZeroBits - 1 + read_bits(leadingZeroBits)
#
# codeNum is spec-bounded to [0, 2^32 - 2] (H.264 9.1: "the bitstream
# shall not contain data that result in a value of codeNum greater than
# 2^32 - 2"), which bounds leadingZeroBits to <= 31. A longer zero run
# is a malformed stream: DR_ERR_BAD_VLC.
# ================================================================

# Read ue(v) into *out. Returns DR_OK, DR_ERR_TRUNCATED, or
# DR_ERR_BAD_VLC (more than 31 leading zeros).
fn dr_ue_read(br, out): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    var lz = 0;
    while (1) {
        var b = dr_br_read_bit(br);
        e = load64(br + 24);
        if (e != DR_OK) { return e; }
        if (b) { break; }
        lz = lz + 1;
        if (lz > 31) {
            store64(br + 24, DR_ERR_BAD_VLC);
            return DR_ERR_BAD_VLC;
        }
    }
    var suffix = dr_br_read_bits(br, lz);
    e = load64(br + 24);
    if (e != DR_OK) { return e; }
    store64(out, (1 << lz) - 1 + suffix);
    return DR_OK;
}

# Read se(v) into *out (signed, i64 store). H.264 9.1.1 mapping from
# codeNum k: value = (-1)^(k+1) * Ceil(k / 2), i.e. k odd -> (k+1)/2,
# k even -> -(k/2). Range [-(2^31 - 1), 2^31 - 1]. Same errors as ue.
fn dr_se_read(br, out): i64 {
    var k = 0;
    var rc = dr_ue_read(br, &k);
    if (rc != DR_OK) { return rc; }
    if (k & 1) {
        store64(out, (k + 1) >> 1);
    } else {
        store64(out, 0 - (k >> 1));
    }
    return DR_OK;
}

# ================================================================
# FloorLog2 + the AV1 su(n)/ns(n) descriptors (spec 4.10.6/4.10.7,
# reproduced in the spec's conventions section). su/ns are pure bit
# descriptors — not arithmetic-coder symbols — so they live in the
# shared bit-I/O core, not a family module. AV1 is the only consumer
# today (H.264/H.265 use se(v); VP8 uses sign-magnitude).
# ================================================================

# FloorLog2(x) — floor of the base-2 log of x (spec convention). Defined
# for x >= 1: returns the 0-based index of the most significant set bit
# (FloorLog2(1) = 0, FloorLog2(5) = 2). x <= 0 returns -1 (the loop runs
# zero times); callers pass x >= 1.
fn dr_floor_log2(x): i64 {
    var s = 0;
    var v = x;
    while (v != 0) {
        v = v >> 1;
        s = s + 1;
    }
    return s - 1;
}

# su(n) — signed integer from n bits, two's-complement (spec 4.10.6):
# read f(n), then if the top bit (bit n-1) is set, subtract 2^n. Stores
# the signed result (i64) at *out. n must be in [1, 32] (DR_ERR_BOUNDS
# otherwise, latched sticky). Truncation latches DR_ERR_TRUNCATED via the
# underlying reader. Returns DR_OK / sticky error code.
fn dr_su_read(br, n, out): i64 {
    var e = dr_br_err(br);
    if (e != DR_OK) { return e; }
    if ((n < 1) || (n > 32)) {
        return dr_br_set_err(br, DR_ERR_BOUNDS);
    }
    var v = dr_br_read_bits(br, n);
    e = dr_br_err(br);
    if (e != DR_OK) { return e; }
    var sign_mask = 1 << (n - 1);
    if (v & sign_mask) {
        v = v - (sign_mask << 1);   # v - 2^n
    }
    store64(out, v);
    return DR_OK;
}

# ns(n) — non-symmetric unsigned integer with n possible values, output
# range 0..n-1 (spec 4.10.7). w = FloorLog2(n) + 1; m = (1<<w) - n; read
# v = f(w-1); if v < m the value is v (one fewer bit), else read one more
# bit: (v<<1) - m + extra_bit. Stores the value at *out. n must be >= 1
# (DR_ERR_BOUNDS otherwise). For n == 1 this reads ZERO bits and yields 0.
# Returns DR_OK / sticky error code.
fn dr_ns_read(br, n, out): i64 {
    var e = dr_br_err(br);
    if (e != DR_OK) { return e; }
    if (n < 1) {
        return dr_br_set_err(br, DR_ERR_BOUNDS);
    }
    var w = dr_floor_log2(n) + 1;
    var m = (1 << w) - n;
    var v = dr_br_read_bits(br, w - 1);
    e = dr_br_err(br);
    if (e != DR_OK) { return e; }
    if (v < m) {
        store64(out, v);
        return DR_OK;
    }
    var extra = dr_br_read_bit(br);
    e = dr_br_err(br);
    if (e != DR_OK) { return e; }
    store64(out, (v << 1) - m + extra);
    return DR_OK;
}

# ================================================================
# DrBw — MSB-first bitwriter (for the encode lanes)
# ================================================================

# Create a bitwriter with an initial capacity hint in bytes (values
# < 16 are rounded up to 16). The buffer auto-grows by doubling up to
# DR_BW_MAX_BYTES. Returns the DrBw handle, or 0 on allocation failure.
fn dr_bw_init(cap_hint): i64 {
    var cap = cap_hint;
    if (cap < 16) { cap = 16; }
    if (cap > DR_BW_MAX_BYTES) { return 0; }
    var buf = alloc(cap);
    if (buf == 0) { return 0; }
    var bw = alloc(32);
    if (bw == 0) { return 0; }
    store64(bw, buf);
    store64(bw + 8, cap);
    store64(bw + 16, 0);
    store64(bw + 24, DR_OK);
    return bw;
}

# Sticky error code (DR_OK if the writer has never faulted).
fn dr_bw_err(bw): i64 {
    return load64(bw + 24);
}

# Latch a sticky error onto the writer from OUTSIDE this module — see
# dr_br_set_err. First code wins; returns the resulting sticky code.
fn dr_bw_set_err(bw, code): i64 {
    if (load64(bw + 24) == DR_OK) { store64(bw + 24, code); }
    return load64(bw + 24);
}

# Bit cursor: bits written so far.
fn dr_bw_bit_pos(bw): i64 {
    return load64(bw + 16);
}

# Bytes occupied so far, counting a trailing partial byte: (pos+7)/8.
fn dr_bw_bytes(bw): i64 {
    return (load64(bw + 16) + 7) >> 3;
}

# Output buffer pointer. OWNED by the writer; stable only until the
# next put (growth may reallocate). Snapshot after dr_bw_flush.
fn dr_bw_buf(bw): i64 {
    return load64(bw);
}

# Internal: ensure room for extra_bits more bits, doubling the buffer.
# Sets sticky DR_ERR_OVERSIZE past DR_BW_MAX_BYTES, DR_ERR_OOM on a
# failed allocation. Returns DR_OK / error code.
fn dr_bw_ensure(bw, extra_bits): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    var need_bytes = (load64(bw + 16) + extra_bits + 7) >> 3;
    var cap = load64(bw + 8);
    if (need_bytes <= cap) { return DR_OK; }
    var new_cap = cap;
    while (new_cap < need_bytes) {
        new_cap = new_cap << 1;
        if (new_cap > DR_BW_MAX_BYTES) {
            store64(bw + 24, DR_ERR_OVERSIZE);
            return DR_ERR_OVERSIZE;
        }
    }
    var new_buf = alloc(new_cap);
    if (new_buf == 0) {
        store64(bw + 24, DR_ERR_OOM);
        return DR_ERR_OOM;
    }
    memcpy(new_buf, load64(bw), dr_bw_bytes(bw));
    store64(bw, new_buf);
    store64(bw + 8, new_cap);
    return DR_OK;
}

# Append one bit (any nonzero bit value writes a 1). MSB-first: the
# first bit written lands in bit 7 of byte 0. Returns DR_OK / sticky
# error code.
fn dr_bw_put_bit(bw, bit): i64 {
    var rc = dr_bw_ensure(bw, 1);
    if (rc != DR_OK) { return rc; }
    var pos = load64(bw + 16);
    var p = load64(bw) + (pos >> 3);
    var shift = 7 - (pos & 7);
    var byte = load8(p);
    # Clear then set — the grown region is not guaranteed zeroed.
    byte = byte & (255 - (1 << shift));
    if (bit) { byte = byte + (1 << shift); }
    store8(p, byte);
    store64(bw + 16, pos + 1);
    return DR_OK;
}

# Append the low n bits of value (0 <= n <= 32), MSB-first. Bits of
# value above n are ignored (masked). n outside [0,32] sets sticky
# DR_ERR_BOUNDS. Returns DR_OK / error code.
fn dr_bw_put_bits(bw, value, n): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    if ((n < 0) || (n > 32)) {
        store64(bw + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var i = n;
    while (i > 0) {
        i = i - 1;
        var rc = dr_bw_put_bit(bw, (value >> i) & 1);
        if (rc != DR_OK) { return rc; }
    }
    return DR_OK;
}

# Zero-pad to a byte boundary. Returns the total byte length of the
# stream (dr_bw_bytes), or 0-with-sticky-error if the writer faulted.
fn dr_bw_flush(bw): i64 {
    if (load64(bw + 24) != DR_OK) { return 0; }
    while (load64(bw + 16) & 7) {
        var rc = dr_bw_put_bit(bw, 0);
        if (rc != DR_OK) { return 0; }
    }
    return dr_bw_bytes(bw);
}

# ================================================================
# VLC writers — inverses of the readers above, for the encode lanes.
# ================================================================

# Write value as leb128 (minimal-length encoding; value 0 emits one
# 0x00 byte). Requires a BYTE-ALIGNED writer (DR_ERR_BOUNDS otherwise)
# and value in [0, 0xFFFFFFFF] (DR_ERR_BAD_LEB128 otherwise, matching
# the 4.10.5 32-bit conformance bound). Returns DR_OK / error code.
fn dr_leb128_write(bw, value): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    if (load64(bw + 16) & 7) {
        store64(bw + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    if ((value < 0) || (value > 0xFFFFFFFF)) {
        store64(bw + 24, DR_ERR_BAD_LEB128);
        return DR_ERR_BAD_LEB128;
    }
    var v = value;
    while (1) {
        var b = v & 0x7F;
        v = v >> 7;
        if (v != 0) { b = b + 0x80; }
        var rc = dr_bw_put_bits(bw, b, 8);
        if (rc != DR_OK) { return rc; }
        if (v == 0) { return DR_OK; }
    }
    return DR_OK;
}

# Write ue(v). value must be in [0, 2^32 - 2] (H.264 9.1 codeNum bound);
# out of range sets sticky DR_ERR_BAD_VLC. Encoding: v+1 has exactly
# lz+1 significant bits (2^lz <= v+1 < 2^(lz+1)); emit lz zeros then
# v+1 in lz+1 bits. Returns DR_OK / error code.
fn dr_ue_write(bw, value): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    if ((value < 0) || (value > 0xFFFFFFFE)) {
        store64(bw + 24, DR_ERR_BAD_VLC);
        return DR_ERR_BAD_VLC;
    }
    var x = value + 1;
    var lz = 0;
    while ((x >> (lz + 1)) != 0) { lz = lz + 1; }
    var rc = dr_bw_put_bits(bw, 0, lz);
    if (rc != DR_OK) { return rc; }
    return dr_bw_put_bits(bw, x, lz + 1);
}

# Write se(v). value must be in [-(2^31 - 1), 2^31 - 1] (H.264 9.1.1);
# out of range sets sticky DR_ERR_BAD_VLC. Mapping: v > 0 -> 2v - 1,
# v <= 0 -> -2v. Returns DR_OK / error code.
fn dr_se_write(bw, value): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }   # sticky first — never clobber the first code
    if ((value < (0 - 2147483647)) || (value > 2147483647)) {
        store64(bw + 24, DR_ERR_BAD_VLC);
        return DR_ERR_BAD_VLC;
    }
    var k = 0;
    if (value > 0) {
        k = (value << 1) - 1;
    } else {
        k = 0 - (value << 1);
    }
    return dr_ue_write(bw, k);
}

# Write su(n) — the inverse of dr_su_read. value must fit the signed
# n-bit range [-2^(n-1), 2^(n-1) - 1] (DR_ERR_BOUNDS otherwise); the low
# n bits of value are the two's-complement encoding dr_bw_put_bits emits.
# n in [1, 32]. Returns DR_OK / error code.
fn dr_su_write(bw, value, n): i64 {
    var e = dr_bw_err(bw);
    if (e != DR_OK) { return e; }
    if ((n < 1) || (n > 32)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    var hi = 1 << (n - 1);
    if ((value < (0 - hi)) || (value > (hi - 1))) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    # put_bits masks to the low n bits, so a negative value writes its
    # two's-complement representation directly.
    return dr_bw_put_bits(bw, value, n);
}

# Write ns(n) — the inverse of dr_ns_read. value in [0, n-1], n >= 1
# (DR_ERR_BOUNDS otherwise). Emits w-1 bits when value < m, else w bits.
# Returns DR_OK / error code.
fn dr_ns_write(bw, value, n): i64 {
    var e = dr_bw_err(bw);
    if (e != DR_OK) { return e; }
    if ((n < 1) || (value < 0) || (value > (n - 1))) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    var w = dr_floor_log2(n) + 1;
    var m = (1 << w) - n;
    if (value < m) {
        return dr_bw_put_bits(bw, value, w - 1);
    }
    var t = value + m;
    var rc = dr_bw_put_bits(bw, t >> 1, w - 1);   # v = (value + m) >> 1
    if (rc != DR_OK) { return rc; }
    return dr_bw_put_bit(bw, t & 1);              # extra_bit
}

# --- ivf.cyr ---

# @public — drishti IVF container read + write. Shared by the AV1 and
# VP8/VP9 families (AV1/VP8/VP9 conformance and test vectors ship as IVF).
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*, DR_FOURCC_*) and src/bits.cyr (dr_rd_le*/
# dr_wr_le* byte helpers).
#
# IVF has no formal spec; the format is fixed by convention. Derived from
# TWO sources, cross-checked: the multimedia.cx wiki "IVF" page and
# libvpx tools/ivfenc.c + ivfdec.c (mem_put_le16/32 field order).
#
# 32-byte file header:
#   bytes  0-3   magic "DKIF" (0x44 0x4B 0x49 0x46)
#   bytes  4-5   version, u16 LE — must be 0
#   bytes  6-7   header size, u16 LE — 32 for version 0 (writers emit 32;
#                the reader accepts >= 32 and skips the extra, the libvpx
#                ivfdec tolerance)
#   bytes  8-11  codec FourCC (e.g. "AV01" / "VP80" / "VP90"), u32 LE
#   bytes 12-13  width in pixels, u16 LE
#   bytes 14-15  height in pixels, u16 LE
#   bytes 16-19  timebase DENOMINATOR (rate), u32 LE   — libvpx writes
#   bytes 20-23  timebase NUMERATOR (scale), u32 LE      cfg.g_timebase
#   bytes 24-27  frame count, u32 LE — ADVISORY: real files lie; the
#                reader iterates to end-of-buffer and never trusts it
#   bytes 28-31  unused
#
# 12-byte frame header (before each frame payload):
#   bytes  0-3   payload size in bytes, u32 LE (excludes these 12 bytes)
#   bytes  4-11  presentation timestamp, u64 LE (units of num/den)
#
# DrIvfHdr layout (64 bytes, heap) — all fields widened to i64:
#   +0:  fourcc        — u32 LE fourcc value
#   +8:  width
#   +16: height
#   +24: timebase num  (scale)
#   +32: timebase den  (rate)
#   +40: frame_count   — header field, advisory only
#   +48: hdr_size      — header field (>= 32)
#   +56: version       — header field (0)
#
# DrIvfReader layout (40 bytes, heap):
#   +0:  buf — whole-file buffer (borrowed)
#   +8:  len — buffer length in bytes
#   +16: pos — byte cursor (starts at hdr_size)
#   +24: hdr — DrIvfHdr pointer
#   +32: err — sticky error code
#
# DrIvfWriter layout (40 bytes, heap):
#   +0:  buf — owned output buffer (auto-grows by doubling)
#   +8:  cap — capacity in bytes
#   +16: len — bytes written
#   +24: frames — frames appended so far
#   +32: err — sticky error code

enum DrIvfLimits {
    # A single frame payload larger than 256 MiB is rejected as a bomb
    # (the largest real AV1/VP9 keyframes are a few MiB).
    DR_IVF_MAX_FRAME  = 268435456;    # 1 << 28
    # Whole-file writer cap, mirroring DR_BW_MAX_BYTES.
    DR_IVF_MAX_TOTAL  = 1073741824;   # 1 << 30
}

# dr_ivf_next_frame result code: no more frames (clean end of file).
# Distinct from every DR_ERR_* (those are > 0) and from DR_OK (0).
# Module-global var, not an enum member — cyrius enums don't accept
# negative literals (see lib/fdlopen.cyr:108).
var DR_IVF_END = -1;

# ================================================================
# Header parse + accessors
# ================================================================

# Parse a 32-byte IVF file header from buf[0..len). Returns a DrIvfHdr
# pointer, or 0 with the error code stored at *out_err:
#   DR_ERR_TRUNCATED   — len < 32 or hdr_size > len
#   DR_ERR_BAD_HEADER  — magic != "DKIF" or hdr_size < 32
#   DR_ERR_UNSUPPORTED — version != 0
#   DR_ERR_OOM         — allocation failure
fn dr_ivf_parse_header(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 32) {
        store64(out_err, DR_ERR_TRUNCATED);
        return 0;
    }
    if ((load8(buf) != 0x44) || (load8(buf + 1) != 0x4B)
    || (load8(buf + 2) != 0x49) || (load8(buf + 3) != 0x46)) {
        store64(out_err, DR_ERR_BAD_HEADER);
        return 0;
    }
    var version = dr_rd_le16(buf + 4);
    if (version != 0) {
        store64(out_err, DR_ERR_UNSUPPORTED);
        return 0;
    }
    var hdr_size = dr_rd_le16(buf + 6);
    if (hdr_size < 32) {
        store64(out_err, DR_ERR_BAD_HEADER);
        return 0;
    }
    if (hdr_size > len) {
        store64(out_err, DR_ERR_TRUNCATED);
        return 0;
    }
    var h = alloc(64);
    if (h == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(h, dr_rd_le32(buf + 8));            # fourcc
    store64(h + 8, dr_rd_le16(buf + 12));       # width
    store64(h + 16, dr_rd_le16(buf + 14));      # height
    store64(h + 24, dr_rd_le32(buf + 20));      # timebase num (scale)
    store64(h + 32, dr_rd_le32(buf + 16));      # timebase den (rate)
    store64(h + 40, dr_rd_le32(buf + 24));      # frame count (advisory)
    store64(h + 48, hdr_size);
    store64(h + 56, version);
    return h;
}

fn dr_ivf_hdr_fourcc(h): i64 { return load64(h); }
fn dr_ivf_hdr_width(h): i64 { return load64(h + 8); }
fn dr_ivf_hdr_height(h): i64 { return load64(h + 16); }
fn dr_ivf_hdr_tb_num(h): i64 { return load64(h + 24); }
fn dr_ivf_hdr_tb_den(h): i64 { return load64(h + 32); }
# Advisory frame count from the header — do NOT size loops with it;
# iterate dr_ivf_next_frame to DR_IVF_END instead.
fn dr_ivf_hdr_frame_count(h): i64 { return load64(h + 40); }
fn dr_ivf_hdr_size(h): i64 { return load64(h + 48); }
fn dr_ivf_hdr_version(h): i64 { return load64(h + 56); }

# ================================================================
# Reader — frame iterator over an in-memory IVF file
# ================================================================

# Create a reader over buf[0..len) (buffer BORROWED — keep it alive).
# Parses + validates the file header and positions the cursor at the
# first frame. Returns the DrIvfReader, or 0 with the error at *out_err
# (codes as dr_ivf_parse_header, plus DR_ERR_OOM).
fn dr_ivf_reader_init(buf, len, out_err): i64 {
    var h = dr_ivf_parse_header(buf, len, out_err);
    if (h == 0) { return 0; }
    var r = alloc(40);
    if (r == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(r, buf);
    store64(r + 8, len);
    store64(r + 16, dr_ivf_hdr_size(h));
    store64(r + 24, h);
    store64(r + 32, DR_OK);
    return r;
}

# The parsed DrIvfHdr (owned by the reader).
fn dr_ivf_reader_hdr(r): i64 { return load64(r + 24); }

# Sticky error code (DR_OK until a fault).
fn dr_ivf_reader_err(r): i64 { return load64(r + 32); }

# Byte offset of the next unread frame header.
fn dr_ivf_reader_pos(r): i64 { return load64(r + 16); }

# Advance to the next frame. On success stores:
#   *out_payload — pointer INTO the reader's buffer (zero-copy, borrowed)
#   *out_size    — payload size in bytes
#   *out_pts     — 64-bit presentation timestamp
# and returns 0 (DR_OK). Returns DR_IVF_END (-1) at a clean end of
# file (cursor exactly at len). Otherwise returns a sticky error:
#   DR_ERR_TRUNCATED — trailing bytes < 12, or payload runs past len
#   DR_ERR_OVERSIZE  — payload size field > DR_IVF_MAX_FRAME
fn dr_ivf_next_frame(r, out_payload, out_size, out_pts): i64 {
    var e = load64(r + 32);
    if (e != DR_OK) { return e; }
    var len = load64(r + 8);
    var pos = load64(r + 16);
    if (pos == len) { return DR_IVF_END; }
    if ((len - pos) < 12) {
        store64(r + 32, DR_ERR_TRUNCATED);
        return DR_ERR_TRUNCATED;
    }
    var buf = load64(r);
    var size = dr_rd_le32(buf + pos);
    if (size > DR_IVF_MAX_FRAME) {
        store64(r + 32, DR_ERR_OVERSIZE);
        return DR_ERR_OVERSIZE;
    }
    if (size > (len - pos - 12)) {
        store64(r + 32, DR_ERR_TRUNCATED);
        return DR_ERR_TRUNCATED;
    }
    store64(out_payload, buf + pos + 12);
    store64(out_size, size);
    store64(out_pts, dr_rd_le64(buf + pos + 4));
    store64(r + 16, pos + 12 + size);
    return DR_OK;
}

# ================================================================
# Writer — build an IVF file in memory, round-trip-able through the
# reader above
# ================================================================

# Internal: ensure the writer has room for extra bytes (doubling
# growth, DR_IVF_MAX_TOTAL cap). Returns DR_OK / sticky error.
fn dr_ivf_writer_ensure(w, extra): i64 {
    var e = load64(w + 32);
    if (e != DR_OK) { return e; }
    var need = load64(w + 16) + extra;
    if (need > DR_IVF_MAX_TOTAL) {
        store64(w + 32, DR_ERR_OVERSIZE);
        return DR_ERR_OVERSIZE;
    }
    var cap = load64(w + 8);
    if (need <= cap) { return DR_OK; }
    var new_cap = cap;
    while (new_cap < need) { new_cap = new_cap << 1; }
    if (new_cap > DR_IVF_MAX_TOTAL) { new_cap = DR_IVF_MAX_TOTAL; }
    var new_buf = alloc(new_cap);
    if (new_buf == 0) {
        store64(w + 32, DR_ERR_OOM);
        return DR_ERR_OOM;
    }
    memcpy(new_buf, load64(w), load64(w + 16));
    store64(w, new_buf);
    store64(w + 8, new_cap);
    return DR_OK;
}

# Create an IVF writer and emit the 32-byte header (version 0,
# hdr_size 32, frame count 0 — patched by dr_ivf_writer_finish).
# Validates: width/height in [0, 65535], tb_num/tb_den in
# [0, 0xFFFFFFFF] (u16/u32 fields — DR_ERR_BAD_HEADER otherwise).
# fourcc is any u32 (use DR_FOURCC_*). Returns the DrIvfWriter, or 0
# on validation/allocation failure.
fn dr_ivf_writer_init(fourcc, width, height, tb_num, tb_den): i64 {
    if ((width < 0) || (width > 65535)) { return 0; }
    if ((height < 0) || (height > 65535)) { return 0; }
    if ((tb_num < 0) || (tb_num > 0xFFFFFFFF)) { return 0; }
    if ((tb_den < 0) || (tb_den > 0xFFFFFFFF)) { return 0; }
    if ((fourcc < 0) || (fourcc > 0xFFFFFFFF)) { return 0; }
    var buf = alloc(1024);
    if (buf == 0) { return 0; }
    var w = alloc(40);
    if (w == 0) { return 0; }
    store64(w, buf);
    store64(w + 8, 1024);
    store64(w + 16, 32);
    store64(w + 24, 0);
    store64(w + 32, DR_OK);
    store8(buf, 0x44);           # 'D'
    store8(buf + 1, 0x4B);       # 'K'
    store8(buf + 2, 0x49);       # 'I'
    store8(buf + 3, 0x46);       # 'F'
    dr_wr_le16(buf + 4, 0);      # version 0
    dr_wr_le16(buf + 6, 32);     # header size
    dr_wr_le32(buf + 8, fourcc);
    dr_wr_le16(buf + 12, width);
    dr_wr_le16(buf + 14, height);
    dr_wr_le32(buf + 16, tb_den);   # rate (libvpx field order)
    dr_wr_le32(buf + 20, tb_num);   # scale
    dr_wr_le32(buf + 24, 0);     # frame count — patched at finish
    dr_wr_le32(buf + 28, 0);     # unused
    return w;
}

# Sticky error code.
fn dr_ivf_writer_err(w): i64 { return load64(w + 32); }

# Total bytes written so far (header + frames).
fn dr_ivf_writer_len(w): i64 { return load64(w + 16); }

# Frames appended so far.
fn dr_ivf_writer_frames(w): i64 { return load64(w + 24); }

# Append one frame: 12-byte frame header (size, pts) + payload copy.
# size must be in [0, DR_IVF_MAX_FRAME] (DR_ERR_OVERSIZE otherwise —
# sticky). pts is stored as the full 64-bit LE field. Returns DR_OK /
# sticky error code.
fn dr_ivf_write_frame(w, payload, size, pts): i64 {
    var e = load64(w + 32);
    if (e != DR_OK) { return e; }
    if ((size < 0) || (size > DR_IVF_MAX_FRAME)) {
        store64(w + 32, DR_ERR_OVERSIZE);
        return DR_ERR_OVERSIZE;
    }
    var rc = dr_ivf_writer_ensure(w, 12 + size);
    if (rc != DR_OK) { return rc; }
    var buf = load64(w);
    var len = load64(w + 16);
    dr_wr_le32(buf + len, size);
    dr_wr_le64(buf + len + 4, pts);
    memcpy(buf + len + 12, payload, size);
    store64(w + 16, len + 12 + size);
    store64(w + 24, load64(w + 24) + 1);
    return DR_OK;
}

# Finish the file: patch the frame count into header bytes 24-27 and
# return the buffer pointer (OWNED by the writer; total length stored
# at *out_len). Returns 0 with *out_len = 0 if the writer faulted.
fn dr_ivf_writer_finish(w, out_len): i64 {
    if (load64(w + 32) != DR_OK) {
        store64(out_len, 0);
        return 0;
    }
    var buf = load64(w);
    dr_wr_le32(buf + 24, load64(w + 24));
    store64(out_len, load64(w + 16));
    return buf;
}

# --- frame.cyr ---

# @public — drishti core: the shared YUV planar-frame buffer every codec
# decoder writes pixels into (and the encode lanes read from). One
# `DrFrame` holds 1 (monochrome) or 3 (Y/U/V) planes of 16-bit samples,
# so 8-, 10-, and 12-bit content share one representation; chroma planes
# carry the frame's subsampling. Each plane is allocated with an optional
# padding BORDER so neighbours at negative coordinates (the intra "above"
# / "left" edge, and later inter motion-comp read-past) are addressable
# without per-sample edge branching.
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*) only. This is the "shared planar-frame
# record" the roadmap parks under the AV1 intra-decode milestone (it
# lands with the first decoder to emit pixels); VP8/H.264/H.265 reuse it.
#
# Sample storage: u16 little-endian (store16/load16). A plane's samples
# live in a buffer of (stride * (h + 2*border)) u16 words, stride =
# w + 2*border; the stored plane pointer is the ORIGIN — sample (0,0) —
# so coordinates in [-border, w+border) x [-border, h+border) index
# directly (negative offsets land in the padding).
#
# DrFrame record — heap, DR_FRAME_SIZE bytes; per-plane {ptr,w,h,stride}
# arrays indexed 0..2 (Y,U,V).

# Dimension-bomb guard: reject luma dimensions beyond this (a lying
# header must not drive an unbounded allocation). 16384 is well above any
# AV1/H.26x level's MaxPicSize while keeping width*height*2 in range.
enum DrFrameLimits {
    DR_FRAME_MAX_DIM = 16384;
}

enum DrFrameOff {
    DR_FRAME_NUM_PLANES   = 0;
    DR_FRAME_BIT_DEPTH    = 8;
    DR_FRAME_WIDTH        = 16;   # luma width
    DR_FRAME_HEIGHT       = 24;   # luma height
    DR_FRAME_SUBX         = 32;   # subsampling_x (chroma)
    DR_FRAME_SUBY         = 40;   # subsampling_y
    DR_FRAME_BORDER       = 48;   # padding samples on every side
    DR_FRAME_PLANE_PTR    = 56;   # [3] origin pointers    -> 80
    DR_FRAME_PLANE_W      = 80;   # [3] plane sample widths -> 104
    DR_FRAME_PLANE_H      = 104;  # [3] plane sample heights-> 128
    DR_FRAME_PLANE_STRIDE = 128;  # [3] strides (samples)  -> 152
    DR_FRAME_SIZE         = 152;
}

# Clip1(x) — clamp a reconstructed sample to the valid range for a bit
# depth: Clip3(0, (1<<BitDepth)-1, x). The workhorse of reconstruction.
fn dr_clip1(x, bit_depth): i64 {
    var hi = (1 << bit_depth) - 1;
    if (x < 0) { return 0; }
    if (x > hi) { return hi; }
    return x;
}

# Allocate a planar frame. width/height are luma dimensions (> 0);
# num_planes is 1 (mono) or 3; subx/suby are 0/1 chroma subsampling
# (ignored when mono); bit_depth is 8/10/12; border >= 0 pads every plane
# edge. Returns the DrFrame handle, or 0 with *out_err set:
#   DR_ERR_BOUNDS   — bad argument (dims <= 0, bad num_planes/bit_depth/
#                     subsampling/border)
#   DR_ERR_OVERSIZE — width or height exceeds DR_FRAME_MAX_DIM
#   DR_ERR_OOM      — allocation failure
fn dr_frame_new(width, height, num_planes, subx, suby, bit_depth, border, out_err): i64 {
    store64(out_err, DR_OK);
    if ((width <= 0) || (height <= 0) || (border < 0)) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    if ((num_planes != 1) && (num_planes != 3)) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    if ((subx != 0) && (subx != 1)) { store64(out_err, DR_ERR_BOUNDS); return 0; }
    if ((suby != 0) && (suby != 1)) { store64(out_err, DR_ERR_BOUNDS); return 0; }
    if ((bit_depth != 8) && (bit_depth != 10) && (bit_depth != 12)) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    if ((width > DR_FRAME_MAX_DIM) || (height > DR_FRAME_MAX_DIM)) {
        store64(out_err, DR_ERR_OVERSIZE);
        return 0;
    }
    var f = alloc(DR_FRAME_SIZE);
    if (f == 0) { store64(out_err, DR_ERR_OOM); return 0; }
    store64(f + DR_FRAME_NUM_PLANES, num_planes);
    store64(f + DR_FRAME_BIT_DEPTH, bit_depth);
    store64(f + DR_FRAME_WIDTH, width);
    store64(f + DR_FRAME_HEIGHT, height);
    store64(f + DR_FRAME_SUBX, subx);
    store64(f + DR_FRAME_SUBY, suby);
    store64(f + DR_FRAME_BORDER, border);
    var p = 0;
    while (p < num_planes) {
        var pw = width;
        var ph = height;
        if (p > 0) {
            pw = (width + subx) >> subx;    # ceil(width / 2^subx)
            ph = (height + suby) >> suby;
        }
        var stride = pw + (2 * border);
        var rows = ph + (2 * border);
        var buf = alloc(stride * rows * 2);   # u16 samples
        if (buf == 0) { store64(out_err, DR_ERR_OOM); return 0; }
        memset(buf, 0, stride * rows * 2);
        # origin = sample (0,0): skip `border` rows and `border` columns.
        var origin = buf + (((border * stride) + border) * 2);
        store64(f + DR_FRAME_PLANE_PTR + (p * 8), origin);
        store64(f + DR_FRAME_PLANE_W + (p * 8), pw);
        store64(f + DR_FRAME_PLANE_H + (p * 8), ph);
        store64(f + DR_FRAME_PLANE_STRIDE + (p * 8), stride);
        p = p + 1;
    }
    return f;
}

# ---- accessors ----
fn dr_frame_num_planes(f): i64 { return load64(f + DR_FRAME_NUM_PLANES); }
fn dr_frame_bit_depth(f): i64 { return load64(f + DR_FRAME_BIT_DEPTH); }
fn dr_frame_width(f): i64 { return load64(f + DR_FRAME_WIDTH); }
fn dr_frame_height(f): i64 { return load64(f + DR_FRAME_HEIGHT); }
fn dr_frame_subx(f): i64 { return load64(f + DR_FRAME_SUBX); }
fn dr_frame_suby(f): i64 { return load64(f + DR_FRAME_SUBY); }
fn dr_frame_border(f): i64 { return load64(f + DR_FRAME_BORDER); }
fn dr_frame_plane_ptr(f, p): i64 { return load64(f + DR_FRAME_PLANE_PTR + (p * 8)); }
fn dr_frame_plane_width(f, p): i64 { return load64(f + DR_FRAME_PLANE_W + (p * 8)); }
fn dr_frame_plane_height(f, p): i64 { return load64(f + DR_FRAME_PLANE_H + (p * 8)); }
fn dr_frame_plane_stride(f, p): i64 { return load64(f + DR_FRAME_PLANE_STRIDE + (p * 8)); }

# Sample get/set. x/y are plane-local coordinates; the valid range is
# [-border, plane_w+border) x [-border, plane_h+border). No per-call
# bounds check (hot path; the decoder guarantees the range via plane
# dims + border) — callers stay inside the allocated plane.
fn dr_frame_get(f, p, x, y): i64 {
    var stride = load64(f + DR_FRAME_PLANE_STRIDE + (p * 8));
    return load16(load64(f + DR_FRAME_PLANE_PTR + (p * 8)) + (((y * stride) + x) * 2));
}
fn dr_frame_set(f, p, x, y, val): i64 {
    var stride = load64(f + DR_FRAME_PLANE_STRIDE + (p * 8));
    store16(load64(f + DR_FRAME_PLANE_PTR + (p * 8)) + (((y * stride) + x) * 2), val);
    return 0;
}

# Fill a plane's active area (0..w, 0..h; not the border) with val.
fn dr_frame_fill(f, p, val): i64 {
    var w = load64(f + DR_FRAME_PLANE_W + (p * 8));
    var h = load64(f + DR_FRAME_PLANE_H + (p * 8));
    var stride = load64(f + DR_FRAME_PLANE_STRIDE + (p * 8));
    var base = load64(f + DR_FRAME_PLANE_PTR + (p * 8));
    var y = 0;
    while (y < h) {
        var row = base + ((y * stride) * 2);
        var x = 0;
        while (x < w) {
            store16(row + (x * 2), val);
            x = x + 1;
        }
        y = y + 1;
    }
    return 0;
}

# --- av1_obu.cyr ---

# @public — drishti AV1: OBU (Open Bitstream Unit) layer — header
# parse, buffer walk (iterator), header write (the encode-lane seed).
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/av1.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*)
# and src/bits.cyr (DrBr/DrBw bit I/O, leb128 read/write).
#
# Derived from the "AV1 Bitstream & Decoding Process Specification"
# v1.0.0 with Errata 1 (AOMedia) — section numbers cited inline:
#   5.3.1 open_bitstream_unit()  — obu_size = sz - 1 - obu_extension_flag
#                                  when obu_has_size_field == 0
#   5.3.2 obu_header()           — forbidden(1) type(4) ext(1) has_size(1)
#                                  reserved(1)
#   5.3.3 obu_extension_header() — temporal_id(3) spatial_id(2) reserved(3)
#   4.10.5 leb128()              — obu_size coding (core dr_leb128_*)
#   6.2.2 OBU header semantics   — obu_type table; obu_forbidden_bit
#                                  "must be set to 0"; obu_reserved_1bit
#                                  "must be set to 0. ... ignored by a
#                                  decoder" (parsed, NOT rejected)
#   6.2.3 OBU extension header semantics — reserved 3 bits likewise
#                                  decoder-ignored
# Cross-checked against dav1d src/obu.c (dav1d_parse_obus) and libaom
# av1/common/obu_util.c (aom_read_obu_header) — both reject the
# forbidden bit and ignore the reserved bits, matching the reading above.
#
# Av1Obu record layout (56 bytes, heap) — one parsed OBU header:
#   +0:  type     — obu_type (AV1_OBU_* below)
#   +8:  ext      — obu_extension_flag (0/1)
#   +16: tid      — temporal_id (0 when ext == 0)
#   +24: sid      — spatial_id  (0 when ext == 0)
#   +32: has_size — obu_has_size_field (0/1)
#   +40: size     — payload size in bytes (from leb128 obu_size, or
#                   derived per 5.3.1 when has_size == 0)
#   +48: hdr_size — header bytes consumed (1..2 fixed + 0..8 leb128);
#                   the payload starts at buf + hdr_size
#
# Av1ObuIter layout (40 bytes, heap):
#   +0:  buf — whole-stream buffer (BORROWED — caller keeps it alive)
#   +8:  len — buffer length in bytes
#   +16: pos — byte cursor (start of the next unparsed OBU)
#   +24: err — sticky error code (DR_OK until first fault)
#   +32: obu — Av1Obu record of the last OBU yielded (0 before first)

# obu_type constants — AV1 spec 6.2.2 obu_type table. Values 0 and
# 9..14 are reserved (a decoder "must ignore" reserved-type OBUs; the
# walk yields them and callers skip what they don't handle).
enum Av1ObuType {
    AV1_OBU_SEQUENCE_HEADER        = 1;
    AV1_OBU_TEMPORAL_DELIMITER     = 2;
    AV1_OBU_FRAME_HEADER           = 3;
    AV1_OBU_TILE_GROUP             = 4;
    AV1_OBU_METADATA               = 5;
    AV1_OBU_FRAME                  = 6;
    AV1_OBU_REDUNDANT_FRAME_HEADER = 7;
    AV1_OBU_TILE_LIST              = 8;
    AV1_OBU_PADDING                = 15;
}

# av1_obu_next result code: no more OBUs (clean end of buffer).
# Distinct from DR_OK (0) and every DR_ERR_* (> 0). Module-global var,
# not an enum member — cyrius enums reject negative literals (same
# pattern as DR_IVF_END in src/ivf.cyr).
var AV1_OBU_END = -1;

# ================================================================
# OBU header parse
# ================================================================

# Parse one OBU header at buf[0..len). Returns an Av1Obu record, or 0
# with the error code stored at *out_err:
#   DR_ERR_BOUNDS        — len < 0
#   DR_ERR_TRUNCATED     — buffer ends inside the header, or the leb128
#                          obu_size claims more payload bytes than the
#                          buffer holds (lying size)
#   DR_ERR_FORBIDDEN_BIT — obu_forbidden_bit set (6.2.2: must be 0)
#   DR_ERR_BAD_LEB128    — malformed obu_size (4.10.5 conformance)
#   DR_ERR_OOM           — allocation failure
# The reserved bits (obu_reserved_1bit, extension_header_reserved_3bits)
# are parsed and IGNORED per 6.2.2/6.2.3 ("ignored by a decoder").
# When has_size == 0 the OBU extends to the end of the supplied buffer:
# size = len - hdr_size, the 5.3.1 rule with the container-provided
# sz taken to be len.
fn av1_obu_parse_header(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    var br = dr_br_init(buf, len);
    if (br == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    # 5.3.2 obu_header() — fixed first byte.
    var forbidden = dr_br_read_bit(br);    # obu_forbidden_bit  f(1)
    var type = dr_br_read_bits(br, 4);     # obu_type           f(4)
    var ext = dr_br_read_bit(br);          # obu_extension_flag f(1)
    var has_size = dr_br_read_bit(br);     # obu_has_size_field f(1)
    dr_br_read_bit(br);                    # obu_reserved_1bit  f(1) — 6.2.2: ignored
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (forbidden != 0) {
        store64(out_err, DR_ERR_FORBIDDEN_BIT);
        return 0;
    }
    var tid = 0;
    var sid = 0;
    if (ext) {
        # 5.3.3 obu_extension_header() — one more byte.
        tid = dr_br_read_bits(br, 3);      # temporal_id f(3)
        sid = dr_br_read_bits(br, 2);      # spatial_id  f(2)
        dr_br_read_bits(br, 3);            # extension_header_reserved_3bits — 6.2.3: ignored
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
    }
    var size = 0;
    if (has_size) {
        # 5.3.1: obu_size leb128() — reader is byte-aligned here
        # (8 or 16 bits consumed).
        var rc = dr_leb128_read(br, &size);
        if (rc != DR_OK) {
            store64(out_err, rc);
            return 0;
        }
    }
    var hdr_size = dr_br_byte_pos(br);
    if (has_size) {
        # Lying size: the payload must lie inside the supplied buffer.
        if (size > (len - hdr_size)) {
            store64(out_err, DR_ERR_TRUNCATED);
            return 0;
        }
    } else {
        # 5.3.1: obu_size = sz - 1 - obu_extension_flag, sz = len.
        size = len - hdr_size;
    }
    var o = alloc(56);
    if (o == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(o, type);
    store64(o + 8, ext);
    store64(o + 16, tid);
    store64(o + 24, sid);
    store64(o + 32, has_size);
    store64(o + 40, size);
    store64(o + 48, hdr_size);
    return o;
}

fn av1_obu_type(o): i64 { return load64(o); }
fn av1_obu_ext(o): i64 { return load64(o + 8); }
fn av1_obu_tid(o): i64 { return load64(o + 16); }
fn av1_obu_sid(o): i64 { return load64(o + 24); }
fn av1_obu_has_size(o): i64 { return load64(o + 32); }
fn av1_obu_size(o): i64 { return load64(o + 40); }
fn av1_obu_hdr_size(o): i64 { return load64(o + 48); }

# obu_type -> printable cstring (never null). Table from spec 6.2.2.
fn av1_obu_type_name(type): i64 {
    if (type == AV1_OBU_SEQUENCE_HEADER)        { return "sequence_header"; }
    if (type == AV1_OBU_TEMPORAL_DELIMITER)     { return "temporal_delimiter"; }
    if (type == AV1_OBU_FRAME_HEADER)           { return "frame_header"; }
    if (type == AV1_OBU_TILE_GROUP)             { return "tile_group"; }
    if (type == AV1_OBU_METADATA)               { return "metadata"; }
    if (type == AV1_OBU_FRAME)                  { return "frame"; }
    if (type == AV1_OBU_REDUNDANT_FRAME_HEADER) { return "redundant_frame_header"; }
    if (type == AV1_OBU_TILE_LIST)              { return "tile_list"; }
    if (type == AV1_OBU_PADDING)                { return "padding"; }
    return "reserved";
}

# ================================================================
# OBU walk — iterate the OBUs of a low-overhead bitstream buffer
# (the layout inside an IVF frame payload, spec Annex A / 5.3.1)
# ================================================================

# Create an iterator over buf[0..len) (buffer BORROWED — caller keeps
# it alive for the iterator's lifetime). Returns the Av1ObuIter handle,
# or 0 on negative len / allocation failure.
fn av1_obu_iter_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var it = alloc(40);
    if (it == 0) { return 0; }
    store64(it, buf);
    store64(it + 8, len);
    store64(it + 16, 0);
    store64(it + 24, DR_OK);
    store64(it + 32, 0);
    return it;
}

# Sticky error code (DR_OK until a fault).
fn av1_obu_iter_err(it): i64 { return load64(it + 24); }

# Byte offset of the next unparsed OBU.
fn av1_obu_iter_pos(it): i64 { return load64(it + 16); }

# Av1Obu record of the last OBU yielded (0 before the first yield) —
# for temporal_id / spatial_id / has_size beyond the three outs of
# av1_obu_next.
fn av1_obu_iter_obu(it): i64 { return load64(it + 32); }

# Advance to the next OBU. On success stores:
#   *out_type — obu_type (compare against AV1_OBU_*)
#   *out_off  — byte offset FROM THE BUFFER BASE of the payload
#   *out_size — payload size in bytes (0 is legal, e.g. a temporal
#               delimiter)
# and returns 0 (DR_OK). Returns AV1_OBU_END (-1) at a clean end of
# buffer (cursor exactly at len; repeatable, not sticky). Otherwise
# returns a sticky error with av1_obu_parse_header's codes. An OBU
# without a size field consumes the rest of the buffer (5.3.1), so it
# is always the last one yielded.
fn av1_obu_next(it, out_type, out_off, out_size): i64 {
    var e = load64(it + 24);
    if (e != DR_OK) { return e; }
    var len = load64(it + 8);
    var pos = load64(it + 16);
    if (pos == len) { return AV1_OBU_END; }
    var buf = load64(it);
    var perr = 0;
    var o = av1_obu_parse_header(buf + pos, len - pos, &perr);
    if (o == 0) {
        store64(it + 24, perr);
        return perr;
    }
    var hdr_size = av1_obu_hdr_size(o);
    var size = av1_obu_size(o);
    store64(it + 32, o);
    store64(out_type, av1_obu_type(o));
    store64(out_off, pos + hdr_size);
    store64(out_size, size);
    # parse_header proved size <= len - pos - hdr_size, so the new
    # cursor lands at most on len.
    store64(it + 16, pos + hdr_size + size);
    return DR_OK;
}

# ================================================================
# OBU header write — the encode-lane seed (inverse of the parser)
# ================================================================

# Append an OBU header to a byte-aligned bitwriter: the 5.3.2 header
# byte, the 5.3.3 extension byte when ext is nonzero, and a minimal
# leb128 obu_size when has_size is nonzero. Forbidden and reserved
# bits are emitted as 0 (6.2.2/6.2.3). Arguments:
#   type in [0, 15], tid in [0, 7], sid in [0, 3] — DR_ERR_BOUNDS
#     (sticky) otherwise; tid/sid are only coded when ext is nonzero
#     but are validated regardless
#   size — payload byte count, only coded when has_size is nonzero;
#     range-checked by dr_leb128_write (DR_ERR_BAD_LEB128 outside
#     [0, 0xFFFFFFFF])
# A misaligned writer faults sticky DR_ERR_BOUNDS (OBUs are byte
# entities). Returns DR_OK / sticky error code.
fn av1_obu_write_header(bw, type, ext, tid, sid, has_size, size): i64 {
    var e = dr_bw_err(bw);
    if (e != DR_OK) { return e; }
    if (dr_bw_bit_pos(bw) & 7) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    if ((type < 0) || (type > 15)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    if ((tid < 0) || (tid > 7)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    if ((sid < 0) || (sid > 3)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    var e1 = 0;
    if (ext != 0) { e1 = 1; }
    var h1 = 0;
    if (has_size != 0) { h1 = 1; }
    # 5.3.2 obu_header()
    dr_bw_put_bit(bw, 0);            # obu_forbidden_bit  = 0 (6.2.2)
    dr_bw_put_bits(bw, type, 4);     # obu_type
    dr_bw_put_bit(bw, e1);           # obu_extension_flag
    dr_bw_put_bit(bw, h1);           # obu_has_size_field
    dr_bw_put_bit(bw, 0);            # obu_reserved_1bit  = 0 (6.2.2)
    if (e1) {
        # 5.3.3 obu_extension_header()
        dr_bw_put_bits(bw, tid, 3);  # temporal_id
        dr_bw_put_bits(bw, sid, 2);  # spatial_id
        dr_bw_put_bits(bw, 0, 3);    # extension_header_reserved_3bits = 0 (6.2.3)
    }
    if (h1) {
        # 5.3.1 obu_size leb128() — writer is byte-aligned here.
        var rc = dr_leb128_write(bw, size);
        if (rc != DR_OK) { return rc; }
    }
    return dr_bw_err(bw);
}

# --- av1_seq.cyr ---

# @public — drishti AV1: sequence_header_obu parse — the stream-level
# summary every decode needs first. As of the 0.7.x frame-header bite
# this is a FULL-FIDELITY record: every field the uncompressed frame
# header (5.9.2) reads is captured, not just the 0.7.0 summary set
# (profile / dims / bit depth / mono / still).
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/av1.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*)
# and src/bits.cyr (DrBr bit I/O, uvlc).
#
# Derived from the "AV1 Bitstream & Decoding Process Specification"
# v1.0.0 with Errata 1 (AOMedia) — section numbers cited inline:
#   5.5.1 sequence_header_obu()      — both the reduced_still_picture
#                                      and the full operating-points path
#   5.5.2 color_config()             — BitDepth / mono / subsampling /
#                                      separate_uv_delta_q / color_range
#   5.5.3 timing_info()              — equal_picture_interval captured;
#                                      rest bit-exactly skipped
#   5.5.4 decoder_model_info()       — buffer_removal_time_length +
#                                      frame_presentation_time_length
#                                      captured (they size frame-header
#                                      fields); rest skipped
#   5.5.5 operating_parameters_info()— bit-exactly skipped
#   6.4.1 general semantics          — seq_profile > 2 reserved;
#                                      reduced_still_picture_header == 1
#                                      requires still_picture == 1
# Cross-checked against dav1d src/obu.c (parse_seq_hdr) and libaom
# av1/decoder/obu.c (read_sequence_header_obu) — field order and the
# conditional branches match both.
#
# Av1Seq record — heap, AV1_SEQ_SIZE bytes, memset-zeroed at parse so
# unread fields default to 0. Field offsets are the Av1SeqOff enum below;
# the first seven (offsets 0..48) are ABI-stable from 0.7.0. Per-op
# arrays operating_point_idc[32] / decoder_model_present_for_this_op[32]
# (indexed 0..operating_points_cnt_minus_1, <= 31) sit after the scalars.

# AV1 family error codes — minted inside the reserved AV1 band 10-29
# (src/drishti.cyr); generic faults reuse the core DR_ERR_* codes.
enum Av1ErrCode {
    AV1_ERR_BAD_PROFILE = 10;   # seq_profile 3..7 — reserved per 6.4.1
    AV1_ERR_BAD_SEQ     = 11;   # sequence-header conformance violation
    AV1_ERR_BAD_FRAME   = 12;   # frame-header conformance violation (5.9)
}

# Av1Seq field byte offsets. Offsets 0..48 are the 0.7.0 layout (kept
# stable); everything from 56 up is the frame-header-bite growth.
enum Av1SeqOff {
    AV1_SEQ_PROFILE              = 0;
    AV1_SEQ_WIDTH                = 8;    # max_frame_width_minus_1 + 1
    AV1_SEQ_HEIGHT               = 16;   # max_frame_height_minus_1 + 1
    AV1_SEQ_BITDEPTH             = 24;   # 8 / 10 / 12
    AV1_SEQ_MONO                 = 32;   # mono_chrome
    AV1_SEQ_STILL                = 40;   # still_picture
    AV1_SEQ_REDUCED              = 48;   # reduced_still_picture_header
    AV1_SEQ_NUM_PLANES           = 56;   # mono ? 1 : 3
    AV1_SEQ_SUBX                 = 64;   # subsampling_x
    AV1_SEQ_SUBY                 = 72;   # subsampling_y
    AV1_SEQ_SEP_UV_DQ            = 80;   # separate_uv_delta_q
    AV1_SEQ_COLOR_RANGE          = 88;
    AV1_SEQ_CHROMA_POS           = 96;   # chroma_sample_position
    AV1_SEQ_FW_BITS              = 104;  # frame_width_bits_minus_1 + 1
    AV1_SEQ_FH_BITS              = 112;  # frame_height_bits_minus_1 + 1
    AV1_SEQ_FRAME_ID_PRESENT     = 120;  # frame_id_numbers_present_flag
    AV1_SEQ_DELTA_FID_LEN        = 128;  # delta_frame_id_length_minus_2 + 2
    AV1_SEQ_ADD_FID_LEN          = 136;  # additional_frame_id_length_minus_1 + 1
    AV1_SEQ_SB128                = 144;  # use_128x128_superblock
    AV1_SEQ_ENABLE_ORDER_HINT    = 152;
    AV1_SEQ_ORDER_HINT_BITS      = 160;  # OrderHintBits (0 if !enable_order_hint)
    AV1_SEQ_ENABLE_SUPERRES      = 168;
    AV1_SEQ_ENABLE_CDEF          = 176;
    AV1_SEQ_ENABLE_RESTORATION   = 184;
    AV1_SEQ_ENABLE_WARPED        = 192;  # enable_warped_motion
    AV1_SEQ_ENABLE_REF_FRAME_MVS = 200;
    AV1_SEQ_FORCE_SCT            = 208;  # seq_force_screen_content_tools
    AV1_SEQ_FORCE_INT_MV         = 216;  # seq_force_integer_mv
    AV1_SEQ_DM_PRESENT           = 224;  # decoder_model_info_present_flag
    AV1_SEQ_EQUAL_PIC_INT        = 232;  # equal_picture_interval
    AV1_SEQ_BRT_LEN              = 240;  # buffer_removal_time_length_minus_1 + 1
    AV1_SEQ_FPT_LEN              = 248;  # frame_presentation_time_length_minus_1 + 1
    AV1_SEQ_OP_CNT_M1            = 256;  # operating_points_cnt_minus_1
    AV1_SEQ_FILM_GRAIN_PRESENT   = 264;  # film_grain_params_present
    AV1_SEQ_TIMING_PRESENT       = 272;  # timing_info_present_flag
    AV1_SEQ_ENABLE_FILTER_INTRA  = 280;
    AV1_SEQ_ENABLE_INTRA_EDGE    = 288;  # enable_intra_edge_filter
    AV1_SEQ_ENABLE_INTERINTRA    = 296;  # enable_interintra_compound
    AV1_SEQ_ENABLE_MASKED        = 304;  # enable_masked_compound
    AV1_SEQ_ENABLE_DUAL_FILTER   = 312;
    AV1_SEQ_ENABLE_JNT_COMP      = 320;
    AV1_SEQ_OP_IDC               = 384;  # operating_point_idc[32]     -> 640
    AV1_SEQ_OP_DM                = 640;  # dm_present_for_this_op[32]   -> 896
    AV1_SEQ_SIZE                 = 896;
}

# ================================================================
# Internal skip/capture helpers — consume spec-exact bits. Values the
# frame header needs are stored into the record `s`; the rest discarded.
# All return DR_OK or the reader's (sticky) error code.
# ================================================================

# timing_info() — 5.5.3. Stores equal_picture_interval (the frame header
# consults it to decide whether temporal_point_info is coded). The tick
# counts are display concerns and are discarded.
fn av1_timing_info_skip(br, s): i64 {
    dr_br_read_bits(br, 32);            # num_units_in_display_tick f(32)
    dr_br_read_bits(br, 32);            # time_scale                f(32)
    var equal = dr_br_read_bit(br);     # equal_picture_interval    f(1)
    store64(s + AV1_SEQ_EQUAL_PIC_INT, equal);
    if (equal) {
        var ticks = 0;
        var rc = dr_uvlc_read(br, &ticks);   # num_ticks_per_picture_minus_1 uvlc()
        if (rc != DR_OK) { return rc; }
    }
    return dr_br_err(br);
}

# decoder_model_info() — 5.5.4. Stores buffer_removal_time_length and
# frame_presentation_time_length (both size later frame-header fields).
# buffer_delay_length_minus_1 sizes 5.5.5's fields and is returned at
# *out_bdl_m1; the decoding-tick count is discarded.
fn av1_decoder_model_info_skip(br, s, out_bdl_m1): i64 {
    store64(out_bdl_m1, dr_br_read_bits(br, 5));   # buffer_delay_length_minus_1 f(5)
    dr_br_read_bits(br, 32);   # num_units_in_decoding_tick             f(32)
    store64(s + AV1_SEQ_BRT_LEN, dr_br_read_bits(br, 5) + 1);   # buffer_removal_time_length_minus_1 f(5)
    store64(s + AV1_SEQ_FPT_LEN, dr_br_read_bits(br, 5) + 1);   # frame_presentation_time_length_minus_1 f(5)
    return dr_br_err(br);
}

# operating_parameters_info(op) — 5.5.5. n = buffer_delay_length_minus_1
# + 1 (at most 32, always legal for dr_br_read_bits). All discarded.
fn av1_operating_parameters_info_skip(br, bdl_m1): i64 {
    dr_br_read_bits(br, bdl_m1 + 1);   # decoder_buffer_delay[op] f(n)
    dr_br_read_bits(br, bdl_m1 + 1);   # encoder_buffer_delay[op] f(n)
    dr_br_read_bit(br);                # low_delay_mode_flag[op]  f(1)
    return dr_br_err(br);
}

# color_config() — 5.5.2. Stores BitDepth, mono_chrome, NumPlanes,
# subsampling_x/y, separate_uv_delta_q, color_range, chroma_sample_position
# into `s`. profile is the already-validated seq_profile (0/1/2).
fn av1_color_config_parse(br, profile, s): i64 {
    var depth = 8;
    var high = dr_br_read_bit(br);          # high_bitdepth f(1)
    if ((profile == 2) && high) {
        var twelve = dr_br_read_bit(br);    # twelve_bit f(1)
        if (twelve) { depth = 12; } else { depth = 10; }
    } else {
        # 5.5.2: profiles 0/1 (and profile 2 without high_bitdepth):
        # BitDepth = high_bitdepth ? 10 : 8.
        if (high) { depth = 10; }
    }
    var mono = 0;
    if (profile == 1) {
        mono = 0;                           # 5.5.2: not coded for profile 1
    } else {
        mono = dr_br_read_bit(br);          # mono_chrome f(1)
    }
    store64(s + AV1_SEQ_BITDEPTH, depth);
    store64(s + AV1_SEQ_MONO, mono);
    if (mono) {
        store64(s + AV1_SEQ_NUM_PLANES, 1);
    } else {
        store64(s + AV1_SEQ_NUM_PLANES, 3);
    }
    var cp = 2;                             # CP_UNSPECIFIED (6.4.2)
    var tc = 2;                             # TC_UNSPECIFIED
    var mc = 2;                             # MC_UNSPECIFIED
    var desc = dr_br_read_bit(br);          # color_description_present_flag f(1)
    if (desc) {
        cp = dr_br_read_bits(br, 8);        # color_primaries          f(8)
        tc = dr_br_read_bits(br, 8);        # transfer_characteristics f(8)
        mc = dr_br_read_bits(br, 8);        # matrix_coefficients      f(8)
    }
    if (mono) {
        # 5.5.2 monochrome path: color_range then RETURN — 4:2:0 implied,
        # no chroma position or separate_uv_delta_q coded.
        store64(s + AV1_SEQ_COLOR_RANGE, dr_br_read_bit(br));   # color_range f(1)
        store64(s + AV1_SEQ_SUBX, 1);
        store64(s + AV1_SEQ_SUBY, 1);
        store64(s + AV1_SEQ_CHROMA_POS, 0);   # CSP_UNKNOWN
        store64(s + AV1_SEQ_SEP_UV_DQ, 0);
        return dr_br_err(br);
    }
    var ssx = 1;
    var ssy = 1;
    if ((cp == 1) && (tc == 13) && (mc == 0)) {
        # 5.5.2 sRGB special case (CP_BT_709 + TC_SRGB + MC_IDENTITY):
        # color_range = 1 and 4:4:4 are IMPLIED — no color_range bit.
        store64(s + AV1_SEQ_COLOR_RANGE, 1);
        ssx = 0;
        ssy = 0;
    } else {
        store64(s + AV1_SEQ_COLOR_RANGE, dr_br_read_bit(br));   # color_range f(1)
        if (profile == 0) {
            ssx = 1;                        # 5.5.2: profile 0 is 4:2:0
            ssy = 1;
        } else {
            if (profile == 1) {
                ssx = 0;                    # profile 1 is 4:4:4
                ssy = 0;
            } else {
                if (depth == 12) {
                    ssx = dr_br_read_bit(br);   # subsampling_x f(1)
                    if (ssx) {
                        ssy = dr_br_read_bit(br);   # subsampling_y f(1)
                    } else {
                        ssy = 0;
                    }
                } else {
                    ssx = 1;                # profile 2 at 8/10-bit is 4:2:2
                    ssy = 0;
                }
            }
        }
        if (ssx && ssy) {
            store64(s + AV1_SEQ_CHROMA_POS, dr_br_read_bits(br, 2));   # chroma_sample_position f(2)
        }
    }
    store64(s + AV1_SEQ_SUBX, ssx);
    store64(s + AV1_SEQ_SUBY, ssy);
    store64(s + AV1_SEQ_SEP_UV_DQ, dr_br_read_bit(br));   # separate_uv_delta_q f(1)
    return dr_br_err(br);
}

# ================================================================
# sequence_header_obu parse
# ================================================================

# Parse a sequence_header_obu PAYLOAD (the bytes AFTER the OBU header —
# feed it av1_obu_next's payload slice) from buf[0..len). Returns an
# Av1Seq record, or 0 with the error code stored at *out_err:
#   DR_ERR_BOUNDS       — len < 0
#   DR_ERR_TRUNCATED    — payload ends mid-field
#   AV1_ERR_BAD_PROFILE — seq_profile 3..7 (reserved, 6.4.1)
#   AV1_ERR_BAD_SEQ     — reduced_still_picture_header without
#                         still_picture (6.4.1)
#   DR_ERR_OOM          — allocation failure
# Trailing bits (5.3.4) after film_grain_params_present are not
# inspected. On any fault the (arena) record is abandoned and 0 returned.
fn av1_seq_parse(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    var br = dr_br_init(buf, len);
    if (br == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    var s = alloc(AV1_SEQ_SIZE);
    if (s == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    memset(s, 0, AV1_SEQ_SIZE);
    # 5.5.1 sequence_header_obu() — leading fixed fields.
    var profile = dr_br_read_bits(br, 3);   # seq_profile                  f(3)
    var still = dr_br_read_bit(br);         # still_picture                f(1)
    var reduced = dr_br_read_bit(br);       # reduced_still_picture_header f(1)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (profile > 2) {
        store64(out_err, AV1_ERR_BAD_PROFILE);
        return 0;
    }
    if (reduced && (still == 0)) {
        store64(out_err, AV1_ERR_BAD_SEQ);
        return 0;
    }
    store64(s + AV1_SEQ_PROFILE, profile);
    store64(s + AV1_SEQ_STILL, still);
    store64(s + AV1_SEQ_REDUCED, reduced);
    var bdl_m1 = 0;
    var dm_present = 0;
    if (reduced) {
        # 5.5.1 reduced path: a single implied operating point; all the
        # timing/model/scalability machinery is absent (defaults 0, set
        # by memset). operating_point_idc[0] = 0, dm_present_op[0] = 0.
        dr_br_read_bits(br, 5);             # seq_level_idx[0] f(5) (discard)
    } else {
        var timing = dr_br_read_bit(br);    # timing_info_present_flag f(1)
        store64(s + AV1_SEQ_TIMING_PRESENT, timing);
        if (timing) {
            var rc = av1_timing_info_skip(br, s);
            if (rc != DR_OK) {
                store64(out_err, rc);
                return 0;
            }
            dm_present = dr_br_read_bit(br);   # decoder_model_info_present_flag f(1)
            store64(s + AV1_SEQ_DM_PRESENT, dm_present);
            if (dm_present) {
                rc = av1_decoder_model_info_skip(br, s, &bdl_m1);
                if (rc != DR_OK) {
                    store64(out_err, rc);
                    return 0;
                }
            }
        }
        var idd_present = dr_br_read_bit(br);   # initial_display_delay_present_flag f(1)
        var ops_m1 = dr_br_read_bits(br, 5);    # operating_points_cnt_minus_1 f(5)
        store64(s + AV1_SEQ_OP_CNT_M1, ops_m1);
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        # Loop bound is spec-fixed at 32 (f(5) + 1) — no bomb risk.
        var i = 0;
        while (i <= ops_m1) {
            var idc = dr_br_read_bits(br, 12);  # operating_point_idc[i] f(12)
            store64(s + AV1_SEQ_OP_IDC + (i * 8), idc);
            var level = dr_br_read_bits(br, 5); # seq_level_idx[i]       f(5)
            if (level > 7) {
                dr_br_read_bit(br);             # seq_tier[i] f(1) (else implied 0)
            }
            if (dm_present) {
                var dm_this = dr_br_read_bit(br);   # decoder_model_present_for_this_op[i] f(1)
                store64(s + AV1_SEQ_OP_DM + (i * 8), dm_this);
                if (dm_this) {
                    var rc2 = av1_operating_parameters_info_skip(br, bdl_m1);
                    if (rc2 != DR_OK) {
                        store64(out_err, rc2);
                        return 0;
                    }
                }
            }
            if (idd_present) {
                var idd_this = dr_br_read_bit(br);  # initial_display_delay_present_for_this_op[i] f(1)
                if (idd_this) {
                    dr_br_read_bits(br, 4);         # initial_display_delay_minus_1[i] f(4)
                }
            }
            if (dr_br_err(br) != DR_OK) {
                store64(out_err, dr_br_err(br));
                return 0;
            }
            i = i + 1;
        }
    }
    # Frame-size bounds — common to both paths.
    var wbits = dr_br_read_bits(br, 4) + 1;      # frame_width_bits_minus_1  f(4)
    var hbits = dr_br_read_bits(br, 4) + 1;      # frame_height_bits_minus_1 f(4)
    var width = dr_br_read_bits(br, wbits) + 1;  # max_frame_width_minus_1   f(wbits)
    var height = dr_br_read_bits(br, hbits) + 1; # max_frame_height_minus_1  f(hbits)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    store64(s + AV1_SEQ_FW_BITS, wbits);
    store64(s + AV1_SEQ_FH_BITS, hbits);
    store64(s + AV1_SEQ_WIDTH, width);
    store64(s + AV1_SEQ_HEIGHT, height);
    var frame_id_present = 0;
    if (reduced == 0) {
        frame_id_present = dr_br_read_bit(br);   # frame_id_numbers_present_flag f(1)
        if (frame_id_present) {
            var dfid = dr_br_read_bits(br, 4);   # delta_frame_id_length_minus_2      f(4)
            var afid = dr_br_read_bits(br, 3);   # additional_frame_id_length_minus_1 f(3)
            store64(s + AV1_SEQ_DELTA_FID_LEN, dfid + 2);
            store64(s + AV1_SEQ_ADD_FID_LEN, afid + 1);
        }
    }
    store64(s + AV1_SEQ_FRAME_ID_PRESENT, frame_id_present);
    store64(s + AV1_SEQ_SB128, dr_br_read_bit(br));            # use_128x128_superblock   f(1)
    store64(s + AV1_SEQ_ENABLE_FILTER_INTRA, dr_br_read_bit(br)); # enable_filter_intra   f(1)
    store64(s + AV1_SEQ_ENABLE_INTRA_EDGE, dr_br_read_bit(br));   # enable_intra_edge_filter f(1)
    if (reduced) {
        # 5.5.1 reduced path: inter tools all 0, force fields SELECT_*,
        # OrderHintBits 0 (defaults already 0 via memset, except SELECT).
        store64(s + AV1_SEQ_FORCE_SCT, 2);     # SELECT_SCREEN_CONTENT_TOOLS
        store64(s + AV1_SEQ_FORCE_INT_MV, 2);  # SELECT_INTEGER_MV
    } else {
        # Inter-tool flags — 5.5.1 full path only.
        store64(s + AV1_SEQ_ENABLE_INTERINTRA, dr_br_read_bit(br)); # enable_interintra_compound f(1)
        store64(s + AV1_SEQ_ENABLE_MASKED, dr_br_read_bit(br));     # enable_masked_compound     f(1)
        store64(s + AV1_SEQ_ENABLE_WARPED, dr_br_read_bit(br));     # enable_warped_motion       f(1)
        store64(s + AV1_SEQ_ENABLE_DUAL_FILTER, dr_br_read_bit(br)); # enable_dual_filter        f(1)
        var order_hint = dr_br_read_bit(br);   # enable_order_hint f(1)
        store64(s + AV1_SEQ_ENABLE_ORDER_HINT, order_hint);
        if (order_hint) {
            store64(s + AV1_SEQ_ENABLE_JNT_COMP, dr_br_read_bit(br));      # enable_jnt_comp      f(1)
            store64(s + AV1_SEQ_ENABLE_REF_FRAME_MVS, dr_br_read_bit(br)); # enable_ref_frame_mvs f(1)
        }
        var choose_sct = dr_br_read_bit(br);   # seq_choose_screen_content_tools f(1)
        var force_sct = 2;                     # SELECT_SCREEN_CONTENT_TOOLS
        if (choose_sct == 0) {
            force_sct = dr_br_read_bit(br);    # seq_force_screen_content_tools f(1)
        }
        store64(s + AV1_SEQ_FORCE_SCT, force_sct);
        var force_imv = 2;                     # SELECT_INTEGER_MV
        if (force_sct > 0) {
            var choose_imv = dr_br_read_bit(br);   # seq_choose_integer_mv f(1)
            if (choose_imv == 0) {
                force_imv = dr_br_read_bit(br);    # seq_force_integer_mv f(1)
            }
        }
        store64(s + AV1_SEQ_FORCE_INT_MV, force_imv);
        if (order_hint) {
            var ohb = dr_br_read_bits(br, 3);  # order_hint_bits_minus_1 f(3)
            store64(s + AV1_SEQ_ORDER_HINT_BITS, ohb + 1);
        }
    }
    store64(s + AV1_SEQ_ENABLE_SUPERRES, dr_br_read_bit(br));    # enable_superres    f(1)
    store64(s + AV1_SEQ_ENABLE_CDEF, dr_br_read_bit(br));        # enable_cdef        f(1)
    store64(s + AV1_SEQ_ENABLE_RESTORATION, dr_br_read_bit(br)); # enable_restoration f(1)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    var rc3 = av1_color_config_parse(br, profile, s);   # color_config() 5.5.2
    if (rc3 != DR_OK) {
        store64(out_err, rc3);
        return 0;
    }
    store64(s + AV1_SEQ_FILM_GRAIN_PRESENT, dr_br_read_bit(br)); # film_grain_params_present f(1)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    return s;
}

# ================================================================
# Accessors — the 0.7.0 seven stay ABI-stable; the rest are the
# frame-header-bite growth.
# ================================================================
fn av1_seq_profile(s): i64 { return load64(s + AV1_SEQ_PROFILE); }
fn av1_seq_width(s): i64 { return load64(s + AV1_SEQ_WIDTH); }
fn av1_seq_height(s): i64 { return load64(s + AV1_SEQ_HEIGHT); }
fn av1_seq_bitdepth(s): i64 { return load64(s + AV1_SEQ_BITDEPTH); }
fn av1_seq_mono(s): i64 { return load64(s + AV1_SEQ_MONO); }
fn av1_seq_still(s): i64 { return load64(s + AV1_SEQ_STILL); }
fn av1_seq_reduced(s): i64 { return load64(s + AV1_SEQ_REDUCED); }

fn av1_seq_num_planes(s): i64 { return load64(s + AV1_SEQ_NUM_PLANES); }
fn av1_seq_subsampling_x(s): i64 { return load64(s + AV1_SEQ_SUBX); }
fn av1_seq_subsampling_y(s): i64 { return load64(s + AV1_SEQ_SUBY); }
fn av1_seq_separate_uv_delta_q(s): i64 { return load64(s + AV1_SEQ_SEP_UV_DQ); }
fn av1_seq_color_range(s): i64 { return load64(s + AV1_SEQ_COLOR_RANGE); }
fn av1_seq_chroma_position(s): i64 { return load64(s + AV1_SEQ_CHROMA_POS); }
fn av1_seq_frame_width_bits(s): i64 { return load64(s + AV1_SEQ_FW_BITS); }
fn av1_seq_frame_height_bits(s): i64 { return load64(s + AV1_SEQ_FH_BITS); }
fn av1_seq_frame_id_present(s): i64 { return load64(s + AV1_SEQ_FRAME_ID_PRESENT); }
fn av1_seq_delta_frame_id_len(s): i64 { return load64(s + AV1_SEQ_DELTA_FID_LEN); }
fn av1_seq_add_frame_id_len(s): i64 { return load64(s + AV1_SEQ_ADD_FID_LEN); }
fn av1_seq_use_128x128(s): i64 { return load64(s + AV1_SEQ_SB128); }
fn av1_seq_enable_order_hint(s): i64 { return load64(s + AV1_SEQ_ENABLE_ORDER_HINT); }
fn av1_seq_order_hint_bits(s): i64 { return load64(s + AV1_SEQ_ORDER_HINT_BITS); }
fn av1_seq_enable_superres(s): i64 { return load64(s + AV1_SEQ_ENABLE_SUPERRES); }
fn av1_seq_enable_cdef(s): i64 { return load64(s + AV1_SEQ_ENABLE_CDEF); }
fn av1_seq_enable_restoration(s): i64 { return load64(s + AV1_SEQ_ENABLE_RESTORATION); }
fn av1_seq_enable_warped_motion(s): i64 { return load64(s + AV1_SEQ_ENABLE_WARPED); }
fn av1_seq_enable_ref_frame_mvs(s): i64 { return load64(s + AV1_SEQ_ENABLE_REF_FRAME_MVS); }
fn av1_seq_force_screen_content_tools(s): i64 { return load64(s + AV1_SEQ_FORCE_SCT); }
fn av1_seq_force_integer_mv(s): i64 { return load64(s + AV1_SEQ_FORCE_INT_MV); }
fn av1_seq_decoder_model_present(s): i64 { return load64(s + AV1_SEQ_DM_PRESENT); }
fn av1_seq_equal_picture_interval(s): i64 { return load64(s + AV1_SEQ_EQUAL_PIC_INT); }
fn av1_seq_buffer_removal_time_len(s): i64 { return load64(s + AV1_SEQ_BRT_LEN); }
fn av1_seq_frame_presentation_time_len(s): i64 { return load64(s + AV1_SEQ_FPT_LEN); }
fn av1_seq_op_cnt_minus_1(s): i64 { return load64(s + AV1_SEQ_OP_CNT_M1); }
fn av1_seq_film_grain_present(s): i64 { return load64(s + AV1_SEQ_FILM_GRAIN_PRESENT); }
fn av1_seq_timing_present(s): i64 { return load64(s + AV1_SEQ_TIMING_PRESENT); }

# operating_point_idc[i] / decoder_model_present_for_this_op[i], i in
# [0, operating_points_cnt_minus_1] (caller's responsibility to stay in
# range; the array holds 32 slots).
fn av1_seq_op_idc(s, i): i64 { return load64(s + AV1_SEQ_OP_IDC + (i * 8)); }
fn av1_seq_op_dm_present(s, i): i64 { return load64(s + AV1_SEQ_OP_DM + (i * 8)); }

# --- av1_frame.cyr ---

# @public — drishti AV1: uncompressed frame header (5.9.2) + the
# reference-frame state machine. Turns a frame_header_obu / frame_obu
# payload into an Av1FrameHeader record (frame type, dimensions,
# superres, quant/segmentation/tile/cdef/lr/loop-filter/global-motion/
# film-grain parameters) and maintains the eight-slot RefValid /
# RefOrderHint / RefFrameId / Ref{Upscaled,Frame,Render}{Width,Height} /
# RefFrameType / SavedGmParams state the header both reads from and
# updates.
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*), src/bits.cyr (DrBr, f/su/ns descriptors),
# and src/av1_seq.cyr (Av1Seq accessors + AV1_ERR_BAD_FRAME).
#
# Derived from the "AV1 Bitstream & Decoding Process Specification"
# v1.0.0 with Errata 1 (AOMedia) — section numbers cited inline. The
# whole uncompressed_header is parsed CURSOR-TRUE for every frame type
# (key / inter / intra-only / switch / show_existing): every
# bit-affecting derivation (OrderHintBits, CodedLossless via get_qindex,
# skipModeAllowed, set_frame_refs, ref-order-hint invalidation) is
# computed so the reader always lands exactly at byte_alignment().
# Sections used: 5.9.2 uncompressed_header, 5.9.4 get_relative_dist,
# 5.9.5 frame_size, 5.9.6 render_size, 5.9.7 frame_size_with_refs,
# 5.9.8 superres_params, 5.9.9 compute_image_size, 5.9.10
# read_interpolation_filter, 5.9.11 loop_filter_params, 5.9.12
# quantization_params, 5.9.13 read_delta_q, 5.9.14 segmentation_params,
# 5.9.15 tile_info, 5.9.3 tile_log2, 5.9.17 delta_q_params, 5.9.18
# delta_lf_params, 5.9.19 cdef_params, 5.9.20 lr_params, 5.9.21
# read_tx_mode, 5.9.22 frame_reference_mode, 5.9.23 skip_mode_params,
# 5.9.24 global_motion_params, 5.9.25 read_global_param, 5.9.26-28
# subexp, 5.9.30 film_grain_params, 5.9.31 temporal_point_info; 7.8
# set_frame_refs; 7.20 reference frame update; 7.21 reference frame
# loading; 7.12.2 get_qindex.
# Cross-checked against dav1d src/obu.c (parse_frame_hdr) and libaom
# av1/decoder/decodeframe.c (read_uncompressed_header) — field order and
# every conditional branch match both.
#
# SCOPE (0.7.x frame-header bite): the header is parsed and every field
# stored or (for film-grain point/AR-coefficient arrays) consumed
# bit-exactly. Cross-frame CDF / loop-filter-delta / segment-id
# inheritance via load_previous (primary_ref_frame != PRIMARY_REF_NONE)
# is a decode-state concern (deferred; docs/development/roadmap.md 0.7.x).
# The ref state machine tracks the dimension/order-hint/gm slots the
# header itself consults, which is what set_frame_refs and
# frame_size_with_refs need.

# ================================================================
# Spec constants (5.9 semantics + section 3 symbols).
# ================================================================
enum Av1FrameConst {
    AV1_KEY_FRAME                   = 0;
    AV1_INTER_FRAME                 = 1;
    AV1_INTRA_ONLY_FRAME            = 2;
    AV1_SWITCH_FRAME                = 3;
    AV1_NUM_REF_FRAMES              = 8;
    AV1_REFS_PER_FRAME              = 7;
    AV1_PRIMARY_REF_NONE            = 7;
    AV1_SELECT_SCREEN_CONTENT_TOOLS = 2;
    AV1_SELECT_INTEGER_MV           = 2;
    AV1_SUPERRES_NUM                = 8;
    AV1_SUPERRES_DENOM_MIN          = 9;
    AV1_SUPERRES_DENOM_BITS         = 3;
    # reference frame indices (INTRA + 7 inter)
    AV1_INTRA_FRAME                 = 0;
    AV1_LAST_FRAME                  = 1;
    AV1_LAST2_FRAME                 = 2;
    AV1_LAST3_FRAME                 = 3;
    AV1_GOLDEN_FRAME                = 4;
    AV1_BWDREF_FRAME                = 5;
    AV1_ALTREF2_FRAME               = 6;
    AV1_ALTREF_FRAME                = 7;
    # restoration types (post Remap_Lr_Type)
    AV1_RESTORE_NONE                = 0;
    AV1_RESTORE_WIENER              = 1;
    AV1_RESTORE_SGRPROJ             = 2;
    AV1_RESTORE_SWITCHABLE          = 3;
    # interpolation filter sentinel
    AV1_INTERP_SWITCHABLE           = 4;
    # tx modes
    AV1_ONLY_4X4                    = 0;
    AV1_TX_MODE_LARGEST             = 1;
    AV1_TX_MODE_SELECT              = 2;
    # warp model types
    AV1_GM_IDENTITY                 = 0;
    AV1_GM_TRANSLATION              = 1;
    AV1_GM_ROTZOOM                  = 2;
    AV1_GM_AFFINE                   = 3;
    AV1_WARPEDMODEL_PREC_BITS       = 16;
    AV1_GM_ABS_TRANS_BITS           = 12;
    AV1_GM_ABS_TRANS_ONLY_BITS      = 9;
    AV1_GM_ABS_ALPHA_BITS           = 12;
    AV1_GM_ALPHA_PREC_BITS          = 15;
    AV1_GM_TRANS_PREC_BITS          = 6;
    AV1_GM_TRANS_ONLY_PREC_BITS     = 3;
    # segmentation
    AV1_MAX_SEGMENTS                = 8;
    AV1_SEG_LVL_MAX                 = 8;
    AV1_SEG_LVL_ALT_Q               = 0;
    AV1_SEG_LVL_REF_FRAME           = 5;
    AV1_MAX_LOOP_FILTER             = 63;
    # tiles
    AV1_MAX_TILE_WIDTH              = 4096;
    AV1_MAX_TILE_AREA               = 9437184;   # MAX_TILE_WIDTH * 2304
    AV1_MAX_TILE_COLS               = 64;
    AV1_MAX_TILE_ROWS               = 64;
    AV1_RESTORATION_TILESIZE_MAX    = 256;
}

# ================================================================
# Av1FrameHeader byte offsets. Scalar block first (0..656), then the
# fixed-size arrays. AV1FH_SIZE bytes, memset-zeroed at parse.
# ================================================================
enum Av1FhOff {
    AV1FH_SHOW_EXISTING          = 0;
    AV1FH_FRAME_TO_SHOW          = 8;
    AV1FH_FRAME_TYPE             = 16;
    AV1FH_FRAME_IS_INTRA         = 24;
    AV1FH_SHOW_FRAME             = 32;
    AV1FH_SHOWABLE_FRAME         = 40;
    AV1FH_ERROR_RESILIENT        = 48;
    AV1FH_DISABLE_CDF_UPDATE     = 56;
    AV1FH_ALLOW_SCT              = 64;    # allow_screen_content_tools
    AV1FH_FORCE_INT_MV           = 72;    # force_integer_mv (frame level)
    AV1FH_CURRENT_FRAME_ID       = 80;
    AV1FH_FRAME_SIZE_OVERRIDE    = 88;
    AV1FH_ORDER_HINT             = 96;
    AV1FH_PRIMARY_REF_FRAME      = 104;
    AV1FH_REFRESH_FRAME_FLAGS    = 112;
    AV1FH_DISABLE_FE_UPDATE_CDF  = 120;   # disable_frame_end_update_cdf
    AV1FH_FRAME_WIDTH            = 128;
    AV1FH_FRAME_HEIGHT           = 136;
    AV1FH_UPSCALED_WIDTH         = 144;
    AV1FH_RENDER_WIDTH           = 152;
    AV1FH_RENDER_HEIGHT          = 160;
    AV1FH_SUPERRES_DENOM         = 168;
    AV1FH_USE_SUPERRES           = 176;
    AV1FH_MI_COLS                = 184;
    AV1FH_MI_ROWS                = 192;
    AV1FH_ALLOW_INTRABC          = 200;
    AV1FH_ALLOW_HIGH_PREC_MV     = 208;
    AV1FH_USE_REF_FRAME_MVS      = 216;
    AV1FH_MOTION_MODE_SWITCHABLE = 224;
    AV1FH_INTERP_FILTER          = 232;
    AV1FH_SHORT_SIGNALING        = 240;   # frame_refs_short_signaling
    AV1FH_BASE_Q_IDX             = 248;
    AV1FH_DELTA_Q_Y_DC           = 256;
    AV1FH_DELTA_Q_U_DC           = 264;
    AV1FH_DELTA_Q_U_AC           = 272;
    AV1FH_DELTA_Q_V_DC           = 280;
    AV1FH_DELTA_Q_V_AC           = 288;
    AV1FH_USING_QMATRIX          = 296;
    AV1FH_QM_Y                   = 304;
    AV1FH_QM_U                   = 312;
    AV1FH_QM_V                   = 320;
    AV1FH_DIFF_UV_DELTA          = 328;
    AV1FH_DELTA_Q_PRESENT        = 336;
    AV1FH_DELTA_Q_RES            = 344;
    AV1FH_DELTA_LF_PRESENT       = 352;
    AV1FH_DELTA_LF_RES           = 360;
    AV1FH_DELTA_LF_MULTI         = 368;
    AV1FH_CODED_LOSSLESS         = 376;
    AV1FH_ALL_LOSSLESS           = 384;
    AV1FH_LF_SHARPNESS           = 392;
    AV1FH_LF_DELTA_ENABLED       = 400;
    AV1FH_LF_DELTA_UPDATE        = 408;
    AV1FH_CDEF_DAMPING           = 416;
    AV1FH_CDEF_BITS              = 424;
    AV1FH_USES_LR                = 432;
    AV1FH_TX_MODE                = 440;
    AV1FH_REFERENCE_SELECT       = 448;
    AV1FH_SKIP_MODE_PRESENT      = 456;
    AV1FH_ALLOW_WARPED           = 464;
    AV1FH_REDUCED_TX_SET         = 472;
    AV1FH_SEG_ENABLED            = 480;
    AV1FH_SEG_UPDATE_MAP         = 488;
    AV1FH_SEG_TEMPORAL_UPDATE    = 496;
    AV1FH_SEG_UPDATE_DATA        = 504;
    AV1FH_TILE_COLS              = 512;
    AV1FH_TILE_ROWS              = 520;
    AV1FH_TILE_COLS_LOG2         = 528;
    AV1FH_TILE_ROWS_LOG2         = 536;
    AV1FH_TILE_SIZE_BYTES        = 544;
    AV1FH_CONTEXT_UPDATE_TILE_ID = 552;
    AV1FH_UNIFORM_TILE           = 560;
    AV1FH_APPLY_GRAIN            = 568;
    AV1FH_GRAIN_SEED             = 576;
    AV1FH_UPDATE_GRAIN           = 584;
    AV1FH_GRAIN_REF_IDX          = 592;
    AV1FH_NUM_Y_POINTS           = 600;
    AV1FH_CHROMA_SCALE_FROM_LUMA = 608;
    AV1FH_NUM_CB_POINTS          = 616;
    AV1FH_NUM_CR_POINTS          = 624;
    AV1FH_SKIP_MODE_FRAME0       = 632;
    AV1FH_SKIP_MODE_FRAME1       = 640;
    AV1FH_BITS_CONSUMED          = 648;   # reader bit position at header end
    # arrays
    AV1FH_LF_LEVEL               = 704;   # [4]           -> 736
    AV1FH_LF_REF_DELTAS          = 736;   # [8] signed    -> 800
    AV1FH_LF_MODE_DELTAS         = 800;   # [2] signed    -> 816
    AV1FH_CDEF_Y_PRI             = 816;   # [8]           -> 880
    AV1FH_CDEF_Y_SEC             = 880;   # [8]           -> 944
    AV1FH_CDEF_UV_PRI            = 944;   # [8]           -> 1008
    AV1FH_CDEF_UV_SEC            = 1008;  # [8]           -> 1072
    AV1FH_FRAME_RESTORATION_TYPE = 1072;  # [3]           -> 1096
    AV1FH_LR_SIZE                = 1096;  # [3]           -> 1120
    AV1FH_REF_FRAME_IDX          = 1120;  # [7]           -> 1176
    AV1FH_ORDER_HINTS            = 1176;  # [8] by refFrame-> 1240
    AV1FH_GM_TYPE                = 1240;  # [7] (ref-1)   -> 1296
    AV1FH_GM_PARAMS              = 1296;  # [7*6=42]      -> 1632
    AV1FH_FEATURE_ENABLED        = 1632;  # [8*8=64]      -> 2144
    AV1FH_FEATURE_DATA           = 2144;  # [8*8=64] sign -> 2656
    AV1FH_MI_COL_STARTS          = 2656;  # [65]          -> 3176
    AV1FH_MI_ROW_STARTS          = 3176;  # [65]          -> 3696
    AV1FH_SIZE                   = 3712;
}

# ================================================================
# Av1RefState byte offsets — eight reference slots. Only the fields the
# frame header consults (7.20 subset) are tracked; frame samples, MVs,
# and CDFs live in the decoder proper.
# ================================================================
enum Av1RefOff {
    AV1REF_VALID              = 0;      # [8]
    AV1REF_FRAME_ID           = 64;     # [8]
    AV1REF_UPSCALED_W         = 128;    # [8]
    AV1REF_FRAME_W            = 192;    # [8]
    AV1REF_FRAME_H            = 256;    # [8]
    AV1REF_RENDER_W           = 320;    # [8]
    AV1REF_RENDER_H           = 384;    # [8]
    AV1REF_MI_COLS            = 448;    # [8]
    AV1REF_MI_ROWS            = 512;    # [8]
    AV1REF_FRAME_TYPE         = 576;    # [8]
    AV1REF_SUBX               = 640;    # [8]
    AV1REF_SUBY               = 704;    # [8]
    AV1REF_BITDEPTH           = 768;    # [8]
    AV1REF_ORDER_HINT         = 832;    # [8]
    AV1REF_SAVED_ORDER_HINTS  = 896;    # [8][8]  -> 1408
    AV1REF_SAVED_GM           = 1408;   # [8][7][6] -> 4096
    AV1REF_SIZE               = 4096;
}

# ================================================================
# Small integer helpers (av1_ prefixed — cyrius has no module scoping).
# ================================================================
fn av1_min(a, b): i64 { if (a < b) { return a; } return b; }
fn av1_max(a, b): i64 { if (a > b) { return a; } return b; }
fn av1_clip3(lo, hi, v): i64 {
    if (v < lo) { return lo; }
    if (v > hi) { return hi; }
    return v;
}

# tile_log2(blkSize, target) — 5.9.3: smallest k with (blkSize << k) >= target.
fn av1_tile_log2(blk_size, target): i64 {
    var k = 0;
    while ((blk_size << k) < target) { k = k + 1; }
    return k;
}

# inverse_recenter(r, v) — 5.9.29 (used by subexp decode).
fn av1_inverse_recenter(r, v): i64 {
    if (v > (2 * r)) { return v; }
    if (v & 1) { return r - ((v + 1) >> 1); }
    return r + (v >> 1);
}
# recenter(r, x) — the exact inverse of av1_inverse_recenter (maps an actual value
# x back to its coded delta v), used by the subexp encode mirrors.
fn av1_recenter(r, x): i64 {
    if (x > (2 * r)) { return x; }
    if (x > r) { return 2 * (x - r); }
    if (x < r) { return (2 * (r - x)) - 1; }
    return 0;
}

# get_relative_dist(a, b) — 5.9.4. Needs the sequence header for
# enable_order_hint / OrderHintBits.
fn av1_get_relative_dist(s, a, b): i64 {
    if (av1_seq_enable_order_hint(s) == 0) { return 0; }
    var diff = a - b;
    var m = 1 << (av1_seq_order_hint_bits(s) - 1);
    diff = (diff & (m - 1)) - (diff & m);
    return diff;
}

# Segmentation feature tables (5.9.14): Segmentation_Feature_Bits /
# _Signed / _Max, indexed by feature j in [0, SEG_LVL_MAX).
fn av1_seg_feature_bits(j): i64 {
    if (j == 0) { return 8; }
    if (j == 5) { return 3; }
    if (j >= 6) { return 0; }
    return 6;                      # j in 1..4
}
fn av1_seg_feature_signed(j): i64 {
    if (j <= 4) { return 1; }
    return 0;
}
fn av1_seg_feature_max(j): i64 {
    if (j == 0) { return 255; }
    if (j == 5) { return 7; }
    if (j >= 6) { return 0; }
    return AV1_MAX_LOOP_FILTER;    # j in 1..4
}

# Remap_Lr_Type[4] — 5.9.20.
fn av1_remap_lr_type(t): i64 {
    if (t == 0) { return AV1_RESTORE_NONE; }
    if (t == 1) { return AV1_RESTORE_SWITCHABLE; }
    if (t == 2) { return AV1_RESTORE_WIENER; }
    return AV1_RESTORE_SGRPROJ;
}

# ================================================================
# Av1RefState — allocate + zero (fresh decoder: all slots invalid, order
# hints 0). Returns the handle or 0 on OOM.
# ================================================================
fn av1_ref_state_new(): i64 {
    var r = alloc(AV1REF_SIZE);
    if (r == 0) { return 0; }
    memset(r, 0, AV1REF_SIZE);
    return r;
}

fn av1_ref_valid(r, i): i64 { return load64(r + AV1REF_VALID + (i * 8)); }
fn av1_ref_frame_id(r, i): i64 { return load64(r + AV1REF_FRAME_ID + (i * 8)); }
fn av1_ref_upscaled_width(r, i): i64 { return load64(r + AV1REF_UPSCALED_W + (i * 8)); }
fn av1_ref_frame_width(r, i): i64 { return load64(r + AV1REF_FRAME_W + (i * 8)); }
fn av1_ref_frame_height(r, i): i64 { return load64(r + AV1REF_FRAME_H + (i * 8)); }
fn av1_ref_render_width(r, i): i64 { return load64(r + AV1REF_RENDER_W + (i * 8)); }
fn av1_ref_render_height(r, i): i64 { return load64(r + AV1REF_RENDER_H + (i * 8)); }
fn av1_ref_mi_cols(r, i): i64 { return load64(r + AV1REF_MI_COLS + (i * 8)); }
fn av1_ref_mi_rows(r, i): i64 { return load64(r + AV1REF_MI_ROWS + (i * 8)); }
fn av1_ref_frame_type(r, i): i64 { return load64(r + AV1REF_FRAME_TYPE + (i * 8)); }
fn av1_ref_order_hint(r, i): i64 { return load64(r + AV1REF_ORDER_HINT + (i * 8)); }
fn av1_ref_saved_order_hint(r, i, refFrame): i64 {
    return load64(r + AV1REF_SAVED_ORDER_HINTS + ((i * 8 + refFrame) * 8));
}
fn av1_ref_saved_gm(r, i, ref, idx): i64 {
    return load64(r + AV1REF_SAVED_GM + (((i * 7 + (ref - 1)) * 6 + idx) * 8));
}

