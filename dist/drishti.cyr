# --- drishti.cyr ---

# @public — drishti core: error codes, DrErr record, version, stream sniffing.
# drishti (दृष्टि — sight/vision) — sovereign video codecs for AGNOS.
#
# This module is FLAT (no includes) — stdlib resolves via cyrius.cyml and
# the include chain is wired in src/main.cyr. Every symbol carries the dr_
# prefix (Cyrius has no module-private scoping; duplicate fn names silently
# shadow).
#
# DrErr struct layout (16 bytes, heap; chitra ChitraErr pattern —
# layout-compatible with mabda's GpuErr):
#   +0: code    — error code constant (one of the DR_* below)
#   +8: detail  — pointer to a detail cstring (or 0)

# ================================================================
# Error code constants
#
# Core codes are 0-9. Codec FAMILIES get reserved bands so their
# module-local enums never collide with core or each other:
#   10-29  AV1     (src/av1_*.cyr)
#   30-49  H.264   (src/h264_*.cyr)
#   50-69  H.265   (src/h265_*.cyr)
#   70-89  VP8/VP9 (src/vp8_*.cyr / src/vp9_*.cyr / src/vpx_*.cyr)
#   90-98  reserved (future families)
# Families REUSE the core codes for the generic conditions (truncation,
# bounds, oversize, ...) and mint band codes only for codec-specific
# failures. DR_ERR_OTHER = 99 is the catch-all.
# ================================================================

enum DrErrCode {
    DR_OK                = 0;   # no error
    DR_ERR_TRUNCATED     = 1;   # input ends before a field/payload completes
    DR_ERR_BOUNDS        = 2;   # out-of-bounds read/seek, bad offset, misalignment
    DR_ERR_FORBIDDEN_BIT = 3;   # forbidden/reserved bit set (e.g. H.264 7.4.1 forbidden_zero_bit)
    DR_ERR_BAD_LEB128    = 4;   # leb128 >8 bytes or value >32 bits (AV1 spec 4.10.5 conformance)
    DR_ERR_BAD_VLC       = 5;   # malformed variable-length code (uvlc / exp-Golomb overflow)
    DR_ERR_BAD_HEADER    = 6;   # malformed container/OBU/NAL header (magic, sizes, ordering)
    DR_ERR_UNSUPPORTED   = 7;   # valid stream, but the feature is out of drishti's scope
    DR_ERR_OVERSIZE      = 8;   # size field exceeds sanity cap (decompression-bomb guard)
    DR_ERR_OOM           = 9;   # allocation failed
    DR_ERR_OTHER         = 99;  # catch-all
}

# ================================================================
# Stream/container sniff kinds (dr_sniff result)
# ================================================================

enum DrSniffKind {
    DR_SNIFF_UNKNOWN = 0;   # neither IVF nor Annex-B
    DR_SNIFF_IVF     = 1;   # IVF container ("DKIF" magic)
    DR_SNIFF_ANNEXB  = 2;   # raw Annex-B byte stream (00 00 01 / 00 00 00 01)
}

# ================================================================
# FourCC constants — the u32 you get from a little-endian 32-bit read
# of the 4 ASCII bytes (byte order in file: 'D','K','I','F' etc.).
# ================================================================

enum DrFourcc {
    DR_FOURCC_DKIF = 0x46494B44;   # "DKIF" — IVF magic
    DR_FOURCC_AV01 = 0x31305641;   # "AV01" — AV1 in IVF
    DR_FOURCC_VP80 = 0x30385056;   # "VP80" — VP8 in IVF
    DR_FOURCC_VP90 = 0x30395056;   # "VP90" — VP9 in IVF
}

# ================================================================
# Version — MAJOR*10000 + MINOR*100 + PATCH (0.1.0 -> 100).
# Keep in sync with the VERSION file at each cut.
# ================================================================

fn drishti_version(): i64 {
    return 100;
}

# ================================================================
# DrErr — 16-byte error record {code, detail-ptr}
# ================================================================

# Create a DrErr with code and an optional detail cstring (0 = none).
fn dr_err_new(code, detail): i64 {
    var e = alloc(16);
    if (e == 0) { return 0; }
    store64(e, code);
    store64(e + 8, detail);
    return e;
}

# Create a DrErr with code only (no detail).
fn dr_err(code): i64 {
    return dr_err_new(code, 0);
}

# Get the error code.
fn dr_err_code(e): i64 {
    return load64(e);
}

# Get the detail string pointer (or 0).
fn dr_err_detail(e): i64 {
    return load64(e + 8);
}

# ================================================================
# Error name lookup — returns a cstring (never null). Family-band
# codes fall through to per-band names so an unmapped family code
# still prints something meaningful.
# ================================================================

fn dr_err_name(code): i64 {
    if (code == DR_OK)                { return "ok"; }
    if (code == DR_ERR_TRUNCATED)     { return "truncated input"; }
    if (code == DR_ERR_BOUNDS)        { return "out-of-bounds read"; }
    if (code == DR_ERR_FORBIDDEN_BIT) { return "forbidden bit set"; }
    if (code == DR_ERR_BAD_LEB128)    { return "bad leb128"; }
    if (code == DR_ERR_BAD_VLC)       { return "bad variable-length code"; }
    if (code == DR_ERR_BAD_HEADER)    { return "bad header"; }
    if (code == DR_ERR_UNSUPPORTED)   { return "unsupported feature"; }
    if (code == DR_ERR_OVERSIZE)      { return "oversize field"; }
    if (code == DR_ERR_OOM)           { return "out of memory"; }
    if (code == DR_ERR_OTHER)         { return "other error"; }
    if ((code >= 10) && (code <= 29)) { return "AV1 error"; }
    if ((code >= 30) && (code <= 49)) { return "H.264 error"; }
    if ((code >= 50) && (code <= 69)) { return "H.265 error"; }
    if ((code >= 70) && (code <= 89)) { return "VP8/VP9 error"; }
    return "unknown error";
}

# Print an error name to stderr (fd 2).
fn dr_err_print_name(code): i64 {
    var name = dr_err_name(code);
    syscall(1, 2, name, strlen(name));
    return 0;
}

# ================================================================
# dr_sniff — classify a byte buffer as IVF / Annex-B / unknown.
#
# IVF:     bytes 0-3 == "DKIF" (needs len >= 4). Full header
#          validation is dr_ivf_reader_init's job — sniff is cheap.
# Annex-B: 4-byte start code 00 00 00 01 checked BEFORE the 3-byte
#          00 00 01 (the 3-byte probe would match the 4-byte prefix
#          bytes 0-2 = 00 00 00 and misreport). H.264 spec Annex B /
#          H.265 Annex B byte-stream NAL unit syntax.
# Every read is bounds-checked against len; never reads past buf+len.
# ================================================================

fn dr_sniff(buf, len): i64 {
    if (len >= 4) {
        # "DKIF" byte-by-byte — no unaligned 32-bit read needed.
        if ((load8(buf) == 0x44) && (load8(buf + 1) == 0x4B)
        && (load8(buf + 2) == 0x49) && (load8(buf + 3) == 0x46)) {
            return DR_SNIFF_IVF;
        }
        if ((load8(buf) == 0) && (load8(buf + 1) == 0)
        && (load8(buf + 2) == 0) && (load8(buf + 3) == 1)) {
            return DR_SNIFF_ANNEXB;
        }
    }
    if (len >= 3) {
        if ((load8(buf) == 0) && (load8(buf + 1) == 0) && (load8(buf + 2) == 1)) {
            return DR_SNIFF_ANNEXB;
        }
    }
    return DR_SNIFF_UNKNOWN;
}

# dr_sniff_fourcc — for an IVF buffer, the codec FourCC at header
# bytes 8-11 as a little-endian u32 (compare against DR_FOURCC_*).
# Returns 0 if the buffer is not IVF or too short to carry the field.
# LE read inlined byte-by-byte: drishti.cyr is the dep-free root module
# and must not reach into bits.cyr (dr_rd_le32).
fn dr_sniff_fourcc(buf, len): i64 {
    if (dr_sniff(buf, len) != DR_SNIFF_IVF) { return 0; }
    if (len < 12) { return 0; }
    var v = load8(buf + 8);
    v = v + (load8(buf + 9) << 8);
    v = v + (load8(buf + 10) << 16);
    v = v + (load8(buf + 11) << 24);
    return v;
}

# --- bits.cyr ---

# @public — drishti bit I/O: MSB-first bitreader/bitwriter + the shared
# variable-length codes every video family parses (leb128, uvlc,
# exp-Golomb ue(v)/se(v)) + little/big-endian byte helpers.
#
# FLAT module (no includes) — stdlib resolves via cyrius.cyml; wiring in
# src/main.cyr. Depends on src/drishti.cyr (DR_ERR_* codes) only.
#
# Spec citations:
#   AV1  spec 4.10.3 uvlc(), 4.10.5 leb128()
#   H.264 spec 9.1 ue(v) / 9.1.1 se(v) exp-Golomb   (H.265 9.2 is the
#   same code family — one implementation, cross-checked against both)
#
# Every read is bounds-checked; errors are STICKY: once a reader/writer
# faults, every later call is a no-op returning 0 and the first error
# code is preserved for inspection via dr_br_err / dr_bw_err.
#
# DrBr bitreader layout (32 bytes, heap):
#   +0:  buf — byte buffer base pointer (borrowed, not owned)
#   +8:  len — buffer length in BYTES
#   +16: pos — bit cursor (bits consumed since buf[0] bit 7)
#   +24: err — sticky error code (DR_OK until first fault)
#
# DrBw bitwriter layout (32 bytes, heap):
#   +0:  buf — owned output buffer (auto-grows by doubling)
#   +8:  cap — current capacity in BYTES
#   +16: pos — bit cursor (bits written)
#   +24: err — sticky error code

# Hard cap on bitwriter growth: 1 GiB. A writer asked to exceed it
# faults with DR_ERR_OVERSIZE instead of eating the machine.
enum DrBwLimits {
    DR_BW_MAX_BYTES = 1073741824;   # 1 << 30
}

# ================================================================
# Endian byte helpers — shared by ivf.cyr and the codec families.
# LE for IVF/RIFF-style containers, BE for MP4/avcC-style boxes.
# Callers own the bounds check (these are raw pointer reads).
# ================================================================

fn dr_rd_le16(p): i64 {
    return load8(p) + (load8(p + 1) << 8);
}

fn dr_rd_le32(p): i64 {
    return load8(p) + (load8(p + 1) << 8) + (load8(p + 2) << 16)
    + (load8(p + 3) << 24);
}

fn dr_rd_le64(p): i64 {
    return dr_rd_le32(p) + (dr_rd_le32(p + 4) << 32);
}

fn dr_wr_le16(p, v): i64 {
    store8(p, v & 255);
    store8(p + 1, (v >> 8) & 255);
    return 0;
}

fn dr_wr_le32(p, v): i64 {
    store8(p, v & 255);
    store8(p + 1, (v >> 8) & 255);
    store8(p + 2, (v >> 16) & 255);
    store8(p + 3, (v >> 24) & 255);
    return 0;
}

fn dr_wr_le64(p, v): i64 {
    dr_wr_le32(p, v & 0xFFFFFFFF);
    dr_wr_le32(p + 4, (v >> 32) & 0xFFFFFFFF);
    return 0;
}

fn dr_rd_be16(p): i64 {
    return (load8(p) << 8) + load8(p + 1);
}

fn dr_rd_be32(p): i64 {
    return (load8(p) << 24) + (load8(p + 1) << 16) + (load8(p + 2) << 8)
    + load8(p + 3);
}

fn dr_wr_be16(p, v): i64 {
    store8(p, (v >> 8) & 255);
    store8(p + 1, v & 255);
    return 0;
}

fn dr_wr_be32(p, v): i64 {
    store8(p, (v >> 24) & 255);
    store8(p + 1, (v >> 16) & 255);
    store8(p + 2, (v >> 8) & 255);
    store8(p + 3, v & 255);
    return 0;
}

# ================================================================
# DrBr — MSB-first bitreader
# ================================================================

# Create a bitreader over buf[0..len). The buffer is BORROWED — the
# caller keeps it alive for the reader's lifetime. Returns the DrBr
# handle, or 0 on allocation failure / negative len.
fn dr_br_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var br = alloc(32);
    if (br == 0) { return 0; }
    store64(br, buf);
    store64(br + 8, len);
    store64(br + 16, 0);
    store64(br + 24, DR_OK);
    return br;
}

# Sticky error code (DR_OK if the reader has never faulted).
fn dr_br_err(br): i64 {
    return load64(br + 24);
}

# Latch a sticky error onto the reader from OUTSIDE this module — the
# public seam family modules use to flag domain faults with core-
# consistent sticky semantics (no DrBr layout coupling). First code
# wins: an already-faulted reader keeps its original code. Returns the
# reader's (resulting) sticky code so callers can `return` it directly.
fn dr_br_set_err(br, code): i64 {
    if (load64(br + 24) == DR_OK) { store64(br + 24, code); }
    return load64(br + 24);
}

# Bits remaining (0 when exhausted or after a fault froze the cursor).
fn dr_br_bits_left(br): i64 {
    return (load64(br + 8) << 3) - load64(br + 16);
}

# Bit cursor: bits consumed so far.
fn dr_br_bit_pos(br): i64 {
    return load64(br + 16);
}

# Byte offset of the byte holding the NEXT unread bit (pos >> 3).
fn dr_br_byte_pos(br): i64 {
    return load64(br + 16) >> 3;
}

# Read one bit, MSB-first (bit 7 of buf[0] comes out first).
# Returns 0/1; on exhaustion sets sticky DR_ERR_TRUNCATED and returns 0.
fn dr_br_read_bit(br): i64 {
    if (load64(br + 24) != DR_OK) { return 0; }
    var pos = load64(br + 16);
    if (pos >= (load64(br + 8) << 3)) {
        store64(br + 24, DR_ERR_TRUNCATED);
        return 0;
    }
    var byte = load8(load64(br) + (pos >> 3));
    store64(br + 16, pos + 1);
    return (byte >> (7 - (pos & 7))) & 1;
}

# Read n bits (0 <= n <= 32), MSB-first, returned right-aligned.
# n == 0 reads nothing and returns 0. n outside [0,32] sets sticky
# DR_ERR_BOUNDS; fewer than n bits left sets sticky DR_ERR_TRUNCATED
# WITHOUT advancing the cursor. Faulted reads return 0.
fn dr_br_read_bits(br, n): i64 {
    if (load64(br + 24) != DR_OK) { return 0; }
    if ((n < 0) || (n > 32)) {
        store64(br + 24, DR_ERR_BOUNDS);
        return 0;
    }
    if (n == 0) { return 0; }
    if (dr_br_bits_left(br) < n) {
        store64(br + 24, DR_ERR_TRUNCATED);
        return 0;
    }
    var v = 0;
    var i = 0;
    while (i < n) {
        v = (v << 1) + dr_br_read_bit(br);
        i = i + 1;
    }
    return v;
}

# Advance the cursor to the next byte boundary (no-op if aligned).
# Discarded bits are not inspected. Cannot overrun: pos lands at most
# on len*8. Returns DR_OK (or the sticky error if already faulted).
fn dr_br_byte_align(br): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    var pos = load64(br + 16);
    store64(br + 16, (pos + 7) & (0 - 8));
    return DR_OK;
}

# True (1) when the cursor sits on a byte boundary.
fn dr_br_is_aligned(br): i64 {
    if ((load64(br + 16) & 7) == 0) { return 1; }
    return 0;
}

# ================================================================
# leb128 — AV1 spec 4.10.5 leb128()
#
#   value = 0
#   for (i = 0; i < 8; i++) {
#     leb128_byte = f(8)
#     value |= (leb128_byte & 0x7f) << (i*7)
#     if (!(leb128_byte & 0x80)) break
#   }
#
# Conformance (4.10.5): at most 8 bytes, value <= (1<<32)-1, and the
# final byte has its continuation bit clear. Non-minimal encodings
# (zero-padded, e.g. 0x80 0x00) ARE legal — encoders pad obu_size.
# ================================================================

# Read a leb128 value from a BYTE-ALIGNED reader into *out (u64 store).
# Returns DR_OK, or: DR_ERR_BOUNDS (reader not byte-aligned),
# DR_ERR_TRUNCATED (buffer ends mid-value), DR_ERR_BAD_LEB128 (8th byte
# still has the continuation bit, or decoded value > 0xFFFFFFFF).
# Fault codes are also latched into the reader's sticky error.
fn dr_leb128_read(br, out): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    if (dr_br_is_aligned(br) == 0) {
        store64(br + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var value = 0;
    var i = 0;
    while (i < 8) {
        var b = dr_br_read_bits(br, 8);
        e = load64(br + 24);
        if (e != DR_OK) { return e; }
        value = value + ((b & 0x7F) << (i * 7));
        if ((b & 0x80) == 0) {
            # 4.10.5 conformance: value must fit in 32 bits.
            if (value > 0xFFFFFFFF) {
                store64(br + 24, DR_ERR_BAD_LEB128);
                return DR_ERR_BAD_LEB128;
            }
            store64(out, value);
            return DR_OK;
        }
        i = i + 1;
    }
    # 8 bytes consumed and the last one still had the continuation bit.
    store64(br + 24, DR_ERR_BAD_LEB128);
    return DR_ERR_BAD_LEB128;
}

# ================================================================
# uvlc — AV1 spec 4.10.3 uvlc()
#
#   leadingZeros = 0
#   while (1) { done = f(1); if (done) break; leadingZeros++ }
#   if (leadingZeros >= 32) return (1<<32) - 1
#   value = f(leadingZeros)
#   return value + (1 << leadingZeros) - 1
# ================================================================

# Read a uvlc value into *out. Returns DR_OK or DR_ERR_TRUNCATED
# (zero-run or suffix hits end of buffer). Per spec, leadingZeros >= 32
# is NOT an error: the value is (1<<32)-1 and only the terminating 1
# bit (no suffix) is consumed after the zero run.
fn dr_uvlc_read(br, out): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    var lz = 0;
    while (1) {
        var done = dr_br_read_bit(br);
        e = load64(br + 24);
        if (e != DR_OK) { return e; }
        if (done) { break; }
        lz = lz + 1;
    }
    if (lz >= 32) {
        store64(out, 0xFFFFFFFF);
        return DR_OK;
    }
    var suffix = dr_br_read_bits(br, lz);
    e = load64(br + 24);
    if (e != DR_OK) { return e; }
    store64(out, suffix + (1 << lz) - 1);
    return DR_OK;
}

# ================================================================
# exp-Golomb — H.264 spec 9.1 (ue(v)) / 9.1.1 (se(v)); H.265 spec 9.2
# is the identical code family.
#
#   leadingZeroBits = -1
#   for (b = 0; !b; leadingZeroBits++) b = read_bit()
#   codeNum = 2^leadingZeroBits - 1 + read_bits(leadingZeroBits)
#
# codeNum is spec-bounded to [0, 2^32 - 2] (H.264 9.1: "the bitstream
# shall not contain data that result in a value of codeNum greater than
# 2^32 - 2"), which bounds leadingZeroBits to <= 31. A longer zero run
# is a malformed stream: DR_ERR_BAD_VLC.
# ================================================================

# Read ue(v) into *out. Returns DR_OK, DR_ERR_TRUNCATED, or
# DR_ERR_BAD_VLC (more than 31 leading zeros).
fn dr_ue_read(br, out): i64 {
    var e = load64(br + 24);
    if (e != DR_OK) { return e; }
    var lz = 0;
    while (1) {
        var b = dr_br_read_bit(br);
        e = load64(br + 24);
        if (e != DR_OK) { return e; }
        if (b) { break; }
        lz = lz + 1;
        if (lz > 31) {
            store64(br + 24, DR_ERR_BAD_VLC);
            return DR_ERR_BAD_VLC;
        }
    }
    var suffix = dr_br_read_bits(br, lz);
    e = load64(br + 24);
    if (e != DR_OK) { return e; }
    store64(out, (1 << lz) - 1 + suffix);
    return DR_OK;
}

# Read se(v) into *out (signed, i64 store). H.264 9.1.1 mapping from
# codeNum k: value = (-1)^(k+1) * Ceil(k / 2), i.e. k odd -> (k+1)/2,
# k even -> -(k/2). Range [-(2^31 - 1), 2^31 - 1]. Same errors as ue.
fn dr_se_read(br, out): i64 {
    var k = 0;
    var rc = dr_ue_read(br, &k);
    if (rc != DR_OK) { return rc; }
    if (k & 1) {
        store64(out, (k + 1) >> 1);
    } else {
        store64(out, 0 - (k >> 1));
    }
    return DR_OK;
}

# ================================================================
# DrBw — MSB-first bitwriter (for the encode lanes)
# ================================================================

# Create a bitwriter with an initial capacity hint in bytes (values
# < 16 are rounded up to 16). The buffer auto-grows by doubling up to
# DR_BW_MAX_BYTES. Returns the DrBw handle, or 0 on allocation failure.
fn dr_bw_init(cap_hint): i64 {
    var cap = cap_hint;
    if (cap < 16) { cap = 16; }
    if (cap > DR_BW_MAX_BYTES) { return 0; }
    var buf = alloc(cap);
    if (buf == 0) { return 0; }
    var bw = alloc(32);
    if (bw == 0) { return 0; }
    store64(bw, buf);
    store64(bw + 8, cap);
    store64(bw + 16, 0);
    store64(bw + 24, DR_OK);
    return bw;
}

# Sticky error code (DR_OK if the writer has never faulted).
fn dr_bw_err(bw): i64 {
    return load64(bw + 24);
}

# Latch a sticky error onto the writer from OUTSIDE this module — see
# dr_br_set_err. First code wins; returns the resulting sticky code.
fn dr_bw_set_err(bw, code): i64 {
    if (load64(bw + 24) == DR_OK) { store64(bw + 24, code); }
    return load64(bw + 24);
}

# Bit cursor: bits written so far.
fn dr_bw_bit_pos(bw): i64 {
    return load64(bw + 16);
}

# Bytes occupied so far, counting a trailing partial byte: (pos+7)/8.
fn dr_bw_bytes(bw): i64 {
    return (load64(bw + 16) + 7) >> 3;
}

# Output buffer pointer. OWNED by the writer; stable only until the
# next put (growth may reallocate). Snapshot after dr_bw_flush.
fn dr_bw_buf(bw): i64 {
    return load64(bw);
}

# Internal: ensure room for extra_bits more bits, doubling the buffer.
# Sets sticky DR_ERR_OVERSIZE past DR_BW_MAX_BYTES, DR_ERR_OOM on a
# failed allocation. Returns DR_OK / error code.
fn dr_bw_ensure(bw, extra_bits): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    var need_bytes = (load64(bw + 16) + extra_bits + 7) >> 3;
    var cap = load64(bw + 8);
    if (need_bytes <= cap) { return DR_OK; }
    var new_cap = cap;
    while (new_cap < need_bytes) {
        new_cap = new_cap << 1;
        if (new_cap > DR_BW_MAX_BYTES) {
            store64(bw + 24, DR_ERR_OVERSIZE);
            return DR_ERR_OVERSIZE;
        }
    }
    var new_buf = alloc(new_cap);
    if (new_buf == 0) {
        store64(bw + 24, DR_ERR_OOM);
        return DR_ERR_OOM;
    }
    memcpy(new_buf, load64(bw), dr_bw_bytes(bw));
    store64(bw, new_buf);
    store64(bw + 8, new_cap);
    return DR_OK;
}

# Append one bit (any nonzero bit value writes a 1). MSB-first: the
# first bit written lands in bit 7 of byte 0. Returns DR_OK / sticky
# error code.
fn dr_bw_put_bit(bw, bit): i64 {
    var rc = dr_bw_ensure(bw, 1);
    if (rc != DR_OK) { return rc; }
    var pos = load64(bw + 16);
    var p = load64(bw) + (pos >> 3);
    var shift = 7 - (pos & 7);
    var byte = load8(p);
    # Clear then set — the grown region is not guaranteed zeroed.
    byte = byte & (255 - (1 << shift));
    if (bit) { byte = byte + (1 << shift); }
    store8(p, byte);
    store64(bw + 16, pos + 1);
    return DR_OK;
}

# Append the low n bits of value (0 <= n <= 32), MSB-first. Bits of
# value above n are ignored (masked). n outside [0,32] sets sticky
# DR_ERR_BOUNDS. Returns DR_OK / error code.
fn dr_bw_put_bits(bw, value, n): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    if ((n < 0) || (n > 32)) {
        store64(bw + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var i = n;
    while (i > 0) {
        i = i - 1;
        var rc = dr_bw_put_bit(bw, (value >> i) & 1);
        if (rc != DR_OK) { return rc; }
    }
    return DR_OK;
}

# Zero-pad to a byte boundary. Returns the total byte length of the
# stream (dr_bw_bytes), or 0-with-sticky-error if the writer faulted.
fn dr_bw_flush(bw): i64 {
    if (load64(bw + 24) != DR_OK) { return 0; }
    while (load64(bw + 16) & 7) {
        var rc = dr_bw_put_bit(bw, 0);
        if (rc != DR_OK) { return 0; }
    }
    return dr_bw_bytes(bw);
}

# ================================================================
# VLC writers — inverses of the readers above, for the encode lanes.
# ================================================================

# Write value as leb128 (minimal-length encoding; value 0 emits one
# 0x00 byte). Requires a BYTE-ALIGNED writer (DR_ERR_BOUNDS otherwise)
# and value in [0, 0xFFFFFFFF] (DR_ERR_BAD_LEB128 otherwise, matching
# the 4.10.5 32-bit conformance bound). Returns DR_OK / error code.
fn dr_leb128_write(bw, value): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    if (load64(bw + 16) & 7) {
        store64(bw + 24, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    if ((value < 0) || (value > 0xFFFFFFFF)) {
        store64(bw + 24, DR_ERR_BAD_LEB128);
        return DR_ERR_BAD_LEB128;
    }
    var v = value;
    while (1) {
        var b = v & 0x7F;
        v = v >> 7;
        if (v != 0) { b = b + 0x80; }
        var rc = dr_bw_put_bits(bw, b, 8);
        if (rc != DR_OK) { return rc; }
        if (v == 0) { return DR_OK; }
    }
    return DR_OK;
}

# Write ue(v). value must be in [0, 2^32 - 2] (H.264 9.1 codeNum bound);
# out of range sets sticky DR_ERR_BAD_VLC. Encoding: v+1 has exactly
# lz+1 significant bits (2^lz <= v+1 < 2^(lz+1)); emit lz zeros then
# v+1 in lz+1 bits. Returns DR_OK / error code.
fn dr_ue_write(bw, value): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }
    if ((value < 0) || (value > 0xFFFFFFFE)) {
        store64(bw + 24, DR_ERR_BAD_VLC);
        return DR_ERR_BAD_VLC;
    }
    var x = value + 1;
    var lz = 0;
    while ((x >> (lz + 1)) != 0) { lz = lz + 1; }
    var rc = dr_bw_put_bits(bw, 0, lz);
    if (rc != DR_OK) { return rc; }
    return dr_bw_put_bits(bw, x, lz + 1);
}

# Write se(v). value must be in [-(2^31 - 1), 2^31 - 1] (H.264 9.1.1);
# out of range sets sticky DR_ERR_BAD_VLC. Mapping: v > 0 -> 2v - 1,
# v <= 0 -> -2v. Returns DR_OK / error code.
fn dr_se_write(bw, value): i64 {
    var e = load64(bw + 24);
    if (e != DR_OK) { return e; }   # sticky first — never clobber the first code
    if ((value < (0 - 2147483647)) || (value > 2147483647)) {
        store64(bw + 24, DR_ERR_BAD_VLC);
        return DR_ERR_BAD_VLC;
    }
    var k = 0;
    if (value > 0) {
        k = (value << 1) - 1;
    } else {
        k = 0 - (value << 1);
    }
    return dr_ue_write(bw, k);
}

# --- ivf.cyr ---

# @public — drishti IVF container read + write. Shared by the AV1 and
# VP8/VP9 families (AV1/VP8/VP9 conformance and test vectors ship as IVF).
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*, DR_FOURCC_*) and src/bits.cyr (dr_rd_le*/
# dr_wr_le* byte helpers).
#
# IVF has no formal spec; the format is fixed by convention. Derived from
# TWO sources, cross-checked: the multimedia.cx wiki "IVF" page and
# libvpx tools/ivfenc.c + ivfdec.c (mem_put_le16/32 field order).
#
# 32-byte file header:
#   bytes  0-3   magic "DKIF" (0x44 0x4B 0x49 0x46)
#   bytes  4-5   version, u16 LE — must be 0
#   bytes  6-7   header size, u16 LE — 32 for version 0 (writers emit 32;
#                the reader accepts >= 32 and skips the extra, the libvpx
#                ivfdec tolerance)
#   bytes  8-11  codec FourCC (e.g. "AV01" / "VP80" / "VP90"), u32 LE
#   bytes 12-13  width in pixels, u16 LE
#   bytes 14-15  height in pixels, u16 LE
#   bytes 16-19  timebase DENOMINATOR (rate), u32 LE   — libvpx writes
#   bytes 20-23  timebase NUMERATOR (scale), u32 LE      cfg.g_timebase
#   bytes 24-27  frame count, u32 LE — ADVISORY: real files lie; the
#                reader iterates to end-of-buffer and never trusts it
#   bytes 28-31  unused
#
# 12-byte frame header (before each frame payload):
#   bytes  0-3   payload size in bytes, u32 LE (excludes these 12 bytes)
#   bytes  4-11  presentation timestamp, u64 LE (units of num/den)
#
# DrIvfHdr layout (64 bytes, heap) — all fields widened to i64:
#   +0:  fourcc        — u32 LE fourcc value
#   +8:  width
#   +16: height
#   +24: timebase num  (scale)
#   +32: timebase den  (rate)
#   +40: frame_count   — header field, advisory only
#   +48: hdr_size      — header field (>= 32)
#   +56: version       — header field (0)
#
# DrIvfReader layout (40 bytes, heap):
#   +0:  buf — whole-file buffer (borrowed)
#   +8:  len — buffer length in bytes
#   +16: pos — byte cursor (starts at hdr_size)
#   +24: hdr — DrIvfHdr pointer
#   +32: err — sticky error code
#
# DrIvfWriter layout (40 bytes, heap):
#   +0:  buf — owned output buffer (auto-grows by doubling)
#   +8:  cap — capacity in bytes
#   +16: len — bytes written
#   +24: frames — frames appended so far
#   +32: err — sticky error code

enum DrIvfLimits {
    # A single frame payload larger than 256 MiB is rejected as a bomb
    # (the largest real AV1/VP9 keyframes are a few MiB).
    DR_IVF_MAX_FRAME  = 268435456;    # 1 << 28
    # Whole-file writer cap, mirroring DR_BW_MAX_BYTES.
    DR_IVF_MAX_TOTAL  = 1073741824;   # 1 << 30
}

# dr_ivf_next_frame result code: no more frames (clean end of file).
# Distinct from every DR_ERR_* (those are > 0) and from DR_OK (0).
# Module-global var, not an enum member — cyrius enums don't accept
# negative literals (see lib/fdlopen.cyr:108).
var DR_IVF_END = -1;

# ================================================================
# Header parse + accessors
# ================================================================

# Parse a 32-byte IVF file header from buf[0..len). Returns a DrIvfHdr
# pointer, or 0 with the error code stored at *out_err:
#   DR_ERR_TRUNCATED   — len < 32 or hdr_size > len
#   DR_ERR_BAD_HEADER  — magic != "DKIF" or hdr_size < 32
#   DR_ERR_UNSUPPORTED — version != 0
#   DR_ERR_OOM         — allocation failure
fn dr_ivf_parse_header(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 32) {
        store64(out_err, DR_ERR_TRUNCATED);
        return 0;
    }
    if ((load8(buf) != 0x44) || (load8(buf + 1) != 0x4B)
    || (load8(buf + 2) != 0x49) || (load8(buf + 3) != 0x46)) {
        store64(out_err, DR_ERR_BAD_HEADER);
        return 0;
    }
    var version = dr_rd_le16(buf + 4);
    if (version != 0) {
        store64(out_err, DR_ERR_UNSUPPORTED);
        return 0;
    }
    var hdr_size = dr_rd_le16(buf + 6);
    if (hdr_size < 32) {
        store64(out_err, DR_ERR_BAD_HEADER);
        return 0;
    }
    if (hdr_size > len) {
        store64(out_err, DR_ERR_TRUNCATED);
        return 0;
    }
    var h = alloc(64);
    if (h == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(h, dr_rd_le32(buf + 8));            # fourcc
    store64(h + 8, dr_rd_le16(buf + 12));       # width
    store64(h + 16, dr_rd_le16(buf + 14));      # height
    store64(h + 24, dr_rd_le32(buf + 20));      # timebase num (scale)
    store64(h + 32, dr_rd_le32(buf + 16));      # timebase den (rate)
    store64(h + 40, dr_rd_le32(buf + 24));      # frame count (advisory)
    store64(h + 48, hdr_size);
    store64(h + 56, version);
    return h;
}

fn dr_ivf_hdr_fourcc(h): i64 { return load64(h); }
fn dr_ivf_hdr_width(h): i64 { return load64(h + 8); }
fn dr_ivf_hdr_height(h): i64 { return load64(h + 16); }
fn dr_ivf_hdr_tb_num(h): i64 { return load64(h + 24); }
fn dr_ivf_hdr_tb_den(h): i64 { return load64(h + 32); }
# Advisory frame count from the header — do NOT size loops with it;
# iterate dr_ivf_next_frame to DR_IVF_END instead.
fn dr_ivf_hdr_frame_count(h): i64 { return load64(h + 40); }
fn dr_ivf_hdr_size(h): i64 { return load64(h + 48); }
fn dr_ivf_hdr_version(h): i64 { return load64(h + 56); }

# ================================================================
# Reader — frame iterator over an in-memory IVF file
# ================================================================

# Create a reader over buf[0..len) (buffer BORROWED — keep it alive).
# Parses + validates the file header and positions the cursor at the
# first frame. Returns the DrIvfReader, or 0 with the error at *out_err
# (codes as dr_ivf_parse_header, plus DR_ERR_OOM).
fn dr_ivf_reader_init(buf, len, out_err): i64 {
    var h = dr_ivf_parse_header(buf, len, out_err);
    if (h == 0) { return 0; }
    var r = alloc(40);
    if (r == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(r, buf);
    store64(r + 8, len);
    store64(r + 16, dr_ivf_hdr_size(h));
    store64(r + 24, h);
    store64(r + 32, DR_OK);
    return r;
}

# The parsed DrIvfHdr (owned by the reader).
fn dr_ivf_reader_hdr(r): i64 { return load64(r + 24); }

# Sticky error code (DR_OK until a fault).
fn dr_ivf_reader_err(r): i64 { return load64(r + 32); }

# Byte offset of the next unread frame header.
fn dr_ivf_reader_pos(r): i64 { return load64(r + 16); }

# Advance to the next frame. On success stores:
#   *out_payload — pointer INTO the reader's buffer (zero-copy, borrowed)
#   *out_size    — payload size in bytes
#   *out_pts     — 64-bit presentation timestamp
# and returns 0 (DR_OK). Returns DR_IVF_END (-1) at a clean end of
# file (cursor exactly at len). Otherwise returns a sticky error:
#   DR_ERR_TRUNCATED — trailing bytes < 12, or payload runs past len
#   DR_ERR_OVERSIZE  — payload size field > DR_IVF_MAX_FRAME
fn dr_ivf_next_frame(r, out_payload, out_size, out_pts): i64 {
    var e = load64(r + 32);
    if (e != DR_OK) { return e; }
    var len = load64(r + 8);
    var pos = load64(r + 16);
    if (pos == len) { return DR_IVF_END; }
    if ((len - pos) < 12) {
        store64(r + 32, DR_ERR_TRUNCATED);
        return DR_ERR_TRUNCATED;
    }
    var buf = load64(r);
    var size = dr_rd_le32(buf + pos);
    if (size > DR_IVF_MAX_FRAME) {
        store64(r + 32, DR_ERR_OVERSIZE);
        return DR_ERR_OVERSIZE;
    }
    if (size > (len - pos - 12)) {
        store64(r + 32, DR_ERR_TRUNCATED);
        return DR_ERR_TRUNCATED;
    }
    store64(out_payload, buf + pos + 12);
    store64(out_size, size);
    store64(out_pts, dr_rd_le64(buf + pos + 4));
    store64(r + 16, pos + 12 + size);
    return DR_OK;
}

# ================================================================
# Writer — build an IVF file in memory, round-trip-able through the
# reader above
# ================================================================

# Internal: ensure the writer has room for extra bytes (doubling
# growth, DR_IVF_MAX_TOTAL cap). Returns DR_OK / sticky error.
fn dr_ivf_writer_ensure(w, extra): i64 {
    var e = load64(w + 32);
    if (e != DR_OK) { return e; }
    var need = load64(w + 16) + extra;
    if (need > DR_IVF_MAX_TOTAL) {
        store64(w + 32, DR_ERR_OVERSIZE);
        return DR_ERR_OVERSIZE;
    }
    var cap = load64(w + 8);
    if (need <= cap) { return DR_OK; }
    var new_cap = cap;
    while (new_cap < need) { new_cap = new_cap << 1; }
    if (new_cap > DR_IVF_MAX_TOTAL) { new_cap = DR_IVF_MAX_TOTAL; }
    var new_buf = alloc(new_cap);
    if (new_buf == 0) {
        store64(w + 32, DR_ERR_OOM);
        return DR_ERR_OOM;
    }
    memcpy(new_buf, load64(w), load64(w + 16));
    store64(w, new_buf);
    store64(w + 8, new_cap);
    return DR_OK;
}

# Create an IVF writer and emit the 32-byte header (version 0,
# hdr_size 32, frame count 0 — patched by dr_ivf_writer_finish).
# Validates: width/height in [0, 65535], tb_num/tb_den in
# [0, 0xFFFFFFFF] (u16/u32 fields — DR_ERR_BAD_HEADER otherwise).
# fourcc is any u32 (use DR_FOURCC_*). Returns the DrIvfWriter, or 0
# on validation/allocation failure.
fn dr_ivf_writer_init(fourcc, width, height, tb_num, tb_den): i64 {
    if ((width < 0) || (width > 65535)) { return 0; }
    if ((height < 0) || (height > 65535)) { return 0; }
    if ((tb_num < 0) || (tb_num > 0xFFFFFFFF)) { return 0; }
    if ((tb_den < 0) || (tb_den > 0xFFFFFFFF)) { return 0; }
    if ((fourcc < 0) || (fourcc > 0xFFFFFFFF)) { return 0; }
    var buf = alloc(1024);
    if (buf == 0) { return 0; }
    var w = alloc(40);
    if (w == 0) { return 0; }
    store64(w, buf);
    store64(w + 8, 1024);
    store64(w + 16, 32);
    store64(w + 24, 0);
    store64(w + 32, DR_OK);
    store8(buf, 0x44);           # 'D'
    store8(buf + 1, 0x4B);       # 'K'
    store8(buf + 2, 0x49);       # 'I'
    store8(buf + 3, 0x46);       # 'F'
    dr_wr_le16(buf + 4, 0);      # version 0
    dr_wr_le16(buf + 6, 32);     # header size
    dr_wr_le32(buf + 8, fourcc);
    dr_wr_le16(buf + 12, width);
    dr_wr_le16(buf + 14, height);
    dr_wr_le32(buf + 16, tb_den);   # rate (libvpx field order)
    dr_wr_le32(buf + 20, tb_num);   # scale
    dr_wr_le32(buf + 24, 0);     # frame count — patched at finish
    dr_wr_le32(buf + 28, 0);     # unused
    return w;
}

# Sticky error code.
fn dr_ivf_writer_err(w): i64 { return load64(w + 32); }

# Total bytes written so far (header + frames).
fn dr_ivf_writer_len(w): i64 { return load64(w + 16); }

# Frames appended so far.
fn dr_ivf_writer_frames(w): i64 { return load64(w + 24); }

# Append one frame: 12-byte frame header (size, pts) + payload copy.
# size must be in [0, DR_IVF_MAX_FRAME] (DR_ERR_OVERSIZE otherwise —
# sticky). pts is stored as the full 64-bit LE field. Returns DR_OK /
# sticky error code.
fn dr_ivf_write_frame(w, payload, size, pts): i64 {
    var e = load64(w + 32);
    if (e != DR_OK) { return e; }
    if ((size < 0) || (size > DR_IVF_MAX_FRAME)) {
        store64(w + 32, DR_ERR_OVERSIZE);
        return DR_ERR_OVERSIZE;
    }
    var rc = dr_ivf_writer_ensure(w, 12 + size);
    if (rc != DR_OK) { return rc; }
    var buf = load64(w);
    var len = load64(w + 16);
    dr_wr_le32(buf + len, size);
    dr_wr_le64(buf + len + 4, pts);
    memcpy(buf + len + 12, payload, size);
    store64(w + 16, len + 12 + size);
    store64(w + 24, load64(w + 24) + 1);
    return DR_OK;
}

# Finish the file: patch the frame count into header bytes 24-27 and
# return the buffer pointer (OWNED by the writer; total length stored
# at *out_len). Returns 0 with *out_len = 0 if the writer faulted.
fn dr_ivf_writer_finish(w, out_len): i64 {
    if (load64(w + 32) != DR_OK) {
        store64(out_len, 0);
        return 0;
    }
    var buf = load64(w);
    dr_wr_le32(buf + 24, load64(w + 24));
    store64(out_len, load64(w + 16));
    return buf;
}

# --- av1_obu.cyr ---

# @public — drishti AV1: OBU (Open Bitstream Unit) layer — header
# parse, buffer walk (iterator), header write (the encode-lane seed).
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/av1.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*)
# and src/bits.cyr (DrBr/DrBw bit I/O, leb128 read/write).
#
# Derived from the "AV1 Bitstream & Decoding Process Specification"
# v1.0.0 with Errata 1 (AOMedia) — section numbers cited inline:
#   5.3.1 open_bitstream_unit()  — obu_size = sz - 1 - obu_extension_flag
#                                  when obu_has_size_field == 0
#   5.3.2 obu_header()           — forbidden(1) type(4) ext(1) has_size(1)
#                                  reserved(1)
#   5.3.3 obu_extension_header() — temporal_id(3) spatial_id(2) reserved(3)
#   4.10.5 leb128()              — obu_size coding (core dr_leb128_*)
#   6.2.2 OBU header semantics   — obu_type table; obu_forbidden_bit
#                                  "must be set to 0"; obu_reserved_1bit
#                                  "must be set to 0. ... ignored by a
#                                  decoder" (parsed, NOT rejected)
#   6.2.3 OBU extension header semantics — reserved 3 bits likewise
#                                  decoder-ignored
# Cross-checked against dav1d src/obu.c (dav1d_parse_obus) and libaom
# av1/common/obu_util.c (aom_read_obu_header) — both reject the
# forbidden bit and ignore the reserved bits, matching the reading above.
#
# Av1Obu record layout (56 bytes, heap) — one parsed OBU header:
#   +0:  type     — obu_type (AV1_OBU_* below)
#   +8:  ext      — obu_extension_flag (0/1)
#   +16: tid      — temporal_id (0 when ext == 0)
#   +24: sid      — spatial_id  (0 when ext == 0)
#   +32: has_size — obu_has_size_field (0/1)
#   +40: size     — payload size in bytes (from leb128 obu_size, or
#                   derived per 5.3.1 when has_size == 0)
#   +48: hdr_size — header bytes consumed (1..2 fixed + 0..8 leb128);
#                   the payload starts at buf + hdr_size
#
# Av1ObuIter layout (40 bytes, heap):
#   +0:  buf — whole-stream buffer (BORROWED — caller keeps it alive)
#   +8:  len — buffer length in bytes
#   +16: pos — byte cursor (start of the next unparsed OBU)
#   +24: err — sticky error code (DR_OK until first fault)
#   +32: obu — Av1Obu record of the last OBU yielded (0 before first)

# obu_type constants — AV1 spec 6.2.2 obu_type table. Values 0 and
# 9..14 are reserved (a decoder "must ignore" reserved-type OBUs; the
# walk yields them and callers skip what they don't handle).
enum Av1ObuType {
    AV1_OBU_SEQUENCE_HEADER        = 1;
    AV1_OBU_TEMPORAL_DELIMITER     = 2;
    AV1_OBU_FRAME_HEADER           = 3;
    AV1_OBU_TILE_GROUP             = 4;
    AV1_OBU_METADATA               = 5;
    AV1_OBU_FRAME                  = 6;
    AV1_OBU_REDUNDANT_FRAME_HEADER = 7;
    AV1_OBU_TILE_LIST              = 8;
    AV1_OBU_PADDING                = 15;
}

# av1_obu_next result code: no more OBUs (clean end of buffer).
# Distinct from DR_OK (0) and every DR_ERR_* (> 0). Module-global var,
# not an enum member — cyrius enums reject negative literals (same
# pattern as DR_IVF_END in src/ivf.cyr).
var AV1_OBU_END = -1;

# ================================================================
# OBU header parse
# ================================================================

# Parse one OBU header at buf[0..len). Returns an Av1Obu record, or 0
# with the error code stored at *out_err:
#   DR_ERR_BOUNDS        — len < 0
#   DR_ERR_TRUNCATED     — buffer ends inside the header, or the leb128
#                          obu_size claims more payload bytes than the
#                          buffer holds (lying size)
#   DR_ERR_FORBIDDEN_BIT — obu_forbidden_bit set (6.2.2: must be 0)
#   DR_ERR_BAD_LEB128    — malformed obu_size (4.10.5 conformance)
#   DR_ERR_OOM           — allocation failure
# The reserved bits (obu_reserved_1bit, extension_header_reserved_3bits)
# are parsed and IGNORED per 6.2.2/6.2.3 ("ignored by a decoder").
# When has_size == 0 the OBU extends to the end of the supplied buffer:
# size = len - hdr_size, the 5.3.1 rule with the container-provided
# sz taken to be len.
fn av1_obu_parse_header(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    var br = dr_br_init(buf, len);
    if (br == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    # 5.3.2 obu_header() — fixed first byte.
    var forbidden = dr_br_read_bit(br);    # obu_forbidden_bit  f(1)
    var type = dr_br_read_bits(br, 4);     # obu_type           f(4)
    var ext = dr_br_read_bit(br);          # obu_extension_flag f(1)
    var has_size = dr_br_read_bit(br);     # obu_has_size_field f(1)
    dr_br_read_bit(br);                    # obu_reserved_1bit  f(1) — 6.2.2: ignored
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (forbidden != 0) {
        store64(out_err, DR_ERR_FORBIDDEN_BIT);
        return 0;
    }
    var tid = 0;
    var sid = 0;
    if (ext) {
        # 5.3.3 obu_extension_header() — one more byte.
        tid = dr_br_read_bits(br, 3);      # temporal_id f(3)
        sid = dr_br_read_bits(br, 2);      # spatial_id  f(2)
        dr_br_read_bits(br, 3);            # extension_header_reserved_3bits — 6.2.3: ignored
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
    }
    var size = 0;
    if (has_size) {
        # 5.3.1: obu_size leb128() — reader is byte-aligned here
        # (8 or 16 bits consumed).
        var rc = dr_leb128_read(br, &size);
        if (rc != DR_OK) {
            store64(out_err, rc);
            return 0;
        }
    }
    var hdr_size = dr_br_byte_pos(br);
    if (has_size) {
        # Lying size: the payload must lie inside the supplied buffer.
        if (size > (len - hdr_size)) {
            store64(out_err, DR_ERR_TRUNCATED);
            return 0;
        }
    } else {
        # 5.3.1: obu_size = sz - 1 - obu_extension_flag, sz = len.
        size = len - hdr_size;
    }
    var o = alloc(56);
    if (o == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(o, type);
    store64(o + 8, ext);
    store64(o + 16, tid);
    store64(o + 24, sid);
    store64(o + 32, has_size);
    store64(o + 40, size);
    store64(o + 48, hdr_size);
    return o;
}

fn av1_obu_type(o): i64 { return load64(o); }
fn av1_obu_ext(o): i64 { return load64(o + 8); }
fn av1_obu_tid(o): i64 { return load64(o + 16); }
fn av1_obu_sid(o): i64 { return load64(o + 24); }
fn av1_obu_has_size(o): i64 { return load64(o + 32); }
fn av1_obu_size(o): i64 { return load64(o + 40); }
fn av1_obu_hdr_size(o): i64 { return load64(o + 48); }

# obu_type -> printable cstring (never null). Table from spec 6.2.2.
fn av1_obu_type_name(type): i64 {
    if (type == AV1_OBU_SEQUENCE_HEADER)        { return "sequence_header"; }
    if (type == AV1_OBU_TEMPORAL_DELIMITER)     { return "temporal_delimiter"; }
    if (type == AV1_OBU_FRAME_HEADER)           { return "frame_header"; }
    if (type == AV1_OBU_TILE_GROUP)             { return "tile_group"; }
    if (type == AV1_OBU_METADATA)               { return "metadata"; }
    if (type == AV1_OBU_FRAME)                  { return "frame"; }
    if (type == AV1_OBU_REDUNDANT_FRAME_HEADER) { return "redundant_frame_header"; }
    if (type == AV1_OBU_TILE_LIST)              { return "tile_list"; }
    if (type == AV1_OBU_PADDING)                { return "padding"; }
    return "reserved";
}

# ================================================================
# OBU walk — iterate the OBUs of a low-overhead bitstream buffer
# (the layout inside an IVF frame payload, spec Annex A / 5.3.1)
# ================================================================

# Create an iterator over buf[0..len) (buffer BORROWED — caller keeps
# it alive for the iterator's lifetime). Returns the Av1ObuIter handle,
# or 0 on negative len / allocation failure.
fn av1_obu_iter_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var it = alloc(40);
    if (it == 0) { return 0; }
    store64(it, buf);
    store64(it + 8, len);
    store64(it + 16, 0);
    store64(it + 24, DR_OK);
    store64(it + 32, 0);
    return it;
}

# Sticky error code (DR_OK until a fault).
fn av1_obu_iter_err(it): i64 { return load64(it + 24); }

# Byte offset of the next unparsed OBU.
fn av1_obu_iter_pos(it): i64 { return load64(it + 16); }

# Av1Obu record of the last OBU yielded (0 before the first yield) —
# for temporal_id / spatial_id / has_size beyond the three outs of
# av1_obu_next.
fn av1_obu_iter_obu(it): i64 { return load64(it + 32); }

# Advance to the next OBU. On success stores:
#   *out_type — obu_type (compare against AV1_OBU_*)
#   *out_off  — byte offset FROM THE BUFFER BASE of the payload
#   *out_size — payload size in bytes (0 is legal, e.g. a temporal
#               delimiter)
# and returns 0 (DR_OK). Returns AV1_OBU_END (-1) at a clean end of
# buffer (cursor exactly at len; repeatable, not sticky). Otherwise
# returns a sticky error with av1_obu_parse_header's codes. An OBU
# without a size field consumes the rest of the buffer (5.3.1), so it
# is always the last one yielded.
fn av1_obu_next(it, out_type, out_off, out_size): i64 {
    var e = load64(it + 24);
    if (e != DR_OK) { return e; }
    var len = load64(it + 8);
    var pos = load64(it + 16);
    if (pos == len) { return AV1_OBU_END; }
    var buf = load64(it);
    var perr = 0;
    var o = av1_obu_parse_header(buf + pos, len - pos, &perr);
    if (o == 0) {
        store64(it + 24, perr);
        return perr;
    }
    var hdr_size = av1_obu_hdr_size(o);
    var size = av1_obu_size(o);
    store64(it + 32, o);
    store64(out_type, av1_obu_type(o));
    store64(out_off, pos + hdr_size);
    store64(out_size, size);
    # parse_header proved size <= len - pos - hdr_size, so the new
    # cursor lands at most on len.
    store64(it + 16, pos + hdr_size + size);
    return DR_OK;
}

# ================================================================
# OBU header write — the encode-lane seed (inverse of the parser)
# ================================================================

# Append an OBU header to a byte-aligned bitwriter: the 5.3.2 header
# byte, the 5.3.3 extension byte when ext is nonzero, and a minimal
# leb128 obu_size when has_size is nonzero. Forbidden and reserved
# bits are emitted as 0 (6.2.2/6.2.3). Arguments:
#   type in [0, 15], tid in [0, 7], sid in [0, 3] — DR_ERR_BOUNDS
#     (sticky) otherwise; tid/sid are only coded when ext is nonzero
#     but are validated regardless
#   size — payload byte count, only coded when has_size is nonzero;
#     range-checked by dr_leb128_write (DR_ERR_BAD_LEB128 outside
#     [0, 0xFFFFFFFF])
# A misaligned writer faults sticky DR_ERR_BOUNDS (OBUs are byte
# entities). Returns DR_OK / sticky error code.
fn av1_obu_write_header(bw, type, ext, tid, sid, has_size, size): i64 {
    var e = dr_bw_err(bw);
    if (e != DR_OK) { return e; }
    if (dr_bw_bit_pos(bw) & 7) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    if ((type < 0) || (type > 15)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    if ((tid < 0) || (tid > 7)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    if ((sid < 0) || (sid > 3)) {
        return dr_bw_set_err(bw, DR_ERR_BOUNDS);
    }
    var e1 = 0;
    if (ext != 0) { e1 = 1; }
    var h1 = 0;
    if (has_size != 0) { h1 = 1; }
    # 5.3.2 obu_header()
    dr_bw_put_bit(bw, 0);            # obu_forbidden_bit  = 0 (6.2.2)
    dr_bw_put_bits(bw, type, 4);     # obu_type
    dr_bw_put_bit(bw, e1);           # obu_extension_flag
    dr_bw_put_bit(bw, h1);           # obu_has_size_field
    dr_bw_put_bit(bw, 0);            # obu_reserved_1bit  = 0 (6.2.2)
    if (e1) {
        # 5.3.3 obu_extension_header()
        dr_bw_put_bits(bw, tid, 3);  # temporal_id
        dr_bw_put_bits(bw, sid, 2);  # spatial_id
        dr_bw_put_bits(bw, 0, 3);    # extension_header_reserved_3bits = 0 (6.2.3)
    }
    if (h1) {
        # 5.3.1 obu_size leb128() — writer is byte-aligned here.
        var rc = dr_leb128_write(bw, size);
        if (rc != DR_OK) { return rc; }
    }
    return dr_bw_err(bw);
}

# --- av1_seq.cyr ---

# @public — drishti AV1: sequence_header_obu parse — the stream-level
# summary every decode needs first (profile, coded dimensions, bit
# depth, monochrome, still-picture flags).
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/av1.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*)
# and src/bits.cyr (DrBr bit I/O, uvlc).
#
# Derived from the "AV1 Bitstream & Decoding Process Specification"
# v1.0.0 with Errata 1 (AOMedia) — section numbers cited inline:
#   5.5.1 sequence_header_obu()      — both the reduced_still_picture
#                                      and the full operating-points path
#   5.5.2 color_config()             — BitDepth / mono_chrome extraction
#   5.5.3 timing_info()              — read + discarded (bit-exact skip)
#   5.5.4 decoder_model_info()       — read + discarded, except
#                                      buffer_delay_length_minus_1 which
#                                      sizes 5.5.5's fields
#   5.5.5 operating_parameters_info()— read + discarded
#   6.4.1 general semantics          — seq_profile > 2 reserved;
#                                      reduced_still_picture_header == 1
#                                      requires still_picture == 1
# Cross-checked against dav1d src/obu.c (parse_seq_hdr) and libaom
# av1/decoder/obu.c (read_sequence_header_obu) — field order and the
# conditional branches match both.
#
# drishti 0.1.x extracts a SUMMARY record: fields that later phases
# (frame-header parse, tile decode) don't yet need are consumed
# bit-exactly and discarded, so the cursor is always spec-true. The
# full-fidelity record grows in the 0.2.x frame-header bite.
#
# Av1Seq record layout (56 bytes, heap):
#   +0:  profile  — seq_profile (0/1/2)
#   +8:  width    — max_frame_width_minus_1 + 1
#   +16: height   — max_frame_height_minus_1 + 1
#   +24: bitdepth — 8 / 10 / 12 (5.5.2 high_bitdepth/twelve_bit)
#   +32: mono     — mono_chrome (0/1; forced 0 for profile 1)
#   +40: still    — still_picture (0/1)
#   +48: reduced  — reduced_still_picture_header (0/1)

# AV1 family error codes — minted inside the reserved AV1 band 10-29
# (src/drishti.cyr); generic faults reuse the core DR_ERR_* codes.
# AV1_ERR_BAD_SEQ covers sequence-header conformance violations, e.g.
# reduced_still_picture_header == 1 with still_picture == 0 (6.4.1).
enum Av1ErrCode {
    AV1_ERR_BAD_PROFILE = 10;   # seq_profile 3..7 — reserved per 6.4.1
    AV1_ERR_BAD_SEQ     = 11;   # sequence-header conformance violation
}

# ================================================================
# Internal skip helpers — consume spec-exact bits, discard values.
# All return DR_OK or the reader's (sticky) error code.
# ================================================================

# timing_info() — 5.5.3. Values discarded (the "must be > 0" conformance
# on num_units_in_display_tick/time_scale is a display concern, not
# needed for the summary record; enforcement lands with decoder-model
# support in a later phase).
fn av1_timing_info_skip(br): i64 {
    dr_br_read_bits(br, 32);            # num_units_in_display_tick f(32)
    dr_br_read_bits(br, 32);            # time_scale                f(32)
    var equal = dr_br_read_bit(br);     # equal_picture_interval    f(1)
    if (equal) {
        var ticks = 0;
        var rc = dr_uvlc_read(br, &ticks);   # num_ticks_per_picture_minus_1 uvlc()
        if (rc != DR_OK) { return rc; }
    }
    return dr_br_err(br);
}

# decoder_model_info() — 5.5.4. Stores buffer_delay_length_minus_1 at
# *out_bdl_m1 (0..31 — it sizes operating_parameters_info's fields);
# the rest is discarded.
fn av1_decoder_model_info_skip(br, out_bdl_m1): i64 {
    store64(out_bdl_m1, dr_br_read_bits(br, 5));   # buffer_delay_length_minus_1 f(5)
    dr_br_read_bits(br, 32);   # num_units_in_decoding_tick             f(32)
    dr_br_read_bits(br, 5);    # buffer_removal_time_length_minus_1     f(5)
    dr_br_read_bits(br, 5);    # frame_presentation_time_length_minus_1 f(5)
    return dr_br_err(br);
}

# operating_parameters_info(op) — 5.5.5. n = buffer_delay_length_minus_1
# + 1 (at most 32, the f(5) bound — always legal for dr_br_read_bits).
fn av1_operating_parameters_info_skip(br, bdl_m1): i64 {
    dr_br_read_bits(br, bdl_m1 + 1);   # decoder_buffer_delay[op] f(n)
    dr_br_read_bits(br, bdl_m1 + 1);   # encoder_buffer_delay[op] f(n)
    dr_br_read_bit(br);                # low_delay_mode_flag[op]  f(1)
    return dr_br_err(br);
}

# color_config() — 5.5.2. Extracts BitDepth (8/10/12) into *out_depth
# and mono_chrome into *out_mono; every other field is consumed
# bit-exactly and discarded. profile is the already-validated
# seq_profile (0/1/2).
fn av1_color_config_parse(br, profile, out_depth, out_mono): i64 {
    var depth = 8;
    var high = dr_br_read_bit(br);          # high_bitdepth f(1)
    if ((profile == 2) && high) {
        var twelve = dr_br_read_bit(br);    # twelve_bit f(1)
        if (twelve) { depth = 12; } else { depth = 10; }
    } else {
        # 5.5.2: profiles 0/1 (and profile 2 without high_bitdepth):
        # BitDepth = high_bitdepth ? 10 : 8.
        if (high) { depth = 10; }
    }
    var mono = 0;
    if (profile == 1) {
        mono = 0;                           # 5.5.2: not coded for profile 1
    } else {
        mono = dr_br_read_bit(br);          # mono_chrome f(1)
    }
    var cp = 2;                             # CP_UNSPECIFIED (6.4.2)
    var tc = 2;                             # TC_UNSPECIFIED
    var mc = 2;                             # MC_UNSPECIFIED
    var desc = dr_br_read_bit(br);          # color_description_present_flag f(1)
    if (desc) {
        cp = dr_br_read_bits(br, 8);        # color_primaries          f(8)
        tc = dr_br_read_bits(br, 8);        # transfer_characteristics f(8)
        mc = dr_br_read_bits(br, 8);        # matrix_coefficients      f(8)
    }
    if (mono) {
        # 5.5.2 monochrome path: color_range then RETURN — no
        # subsampling, chroma position, or separate_uv_delta_q coded.
        dr_br_read_bit(br);                 # color_range f(1)
        store64(out_depth, depth);
        store64(out_mono, 1);
        return dr_br_err(br);
    }
    if ((cp == 1) && (tc == 13) && (mc == 0)) {
        # 5.5.2 sRGB special case (CP_BT_709 + TC_SRGB + MC_IDENTITY):
        # color_range = 1 and 4:4:4 are IMPLIED — no further bits on
        # this branch.
    } else {
        dr_br_read_bit(br);                 # color_range f(1)
        var ssx = 1;
        var ssy = 1;
        if (profile == 0) {
            ssx = 1;                        # 5.5.2: profile 0 is 4:2:0
            ssy = 1;
        } else {
            if (profile == 1) {
                ssx = 0;                    # profile 1 is 4:4:4
                ssy = 0;
            } else {
                if (depth == 12) {
                    ssx = dr_br_read_bit(br);   # subsampling_x f(1)
                    if (ssx) {
                        ssy = dr_br_read_bit(br);   # subsampling_y f(1)
                    } else {
                        ssy = 0;
                    }
                } else {
                    ssx = 1;                # profile 2 at 8/10-bit is 4:2:2
                    ssy = 0;
                }
            }
        }
        if (ssx && ssy) {
            dr_br_read_bits(br, 2);         # chroma_sample_position f(2)
        }
    }
    dr_br_read_bit(br);                     # separate_uv_delta_q f(1)
    store64(out_depth, depth);
    store64(out_mono, 0);
    return dr_br_err(br);
}

# ================================================================
# sequence_header_obu parse
# ================================================================

# Parse a sequence_header_obu PAYLOAD (the bytes AFTER the OBU header —
# feed it av1_obu_next's payload slice) from buf[0..len). Returns an
# Av1Seq record, or 0 with the error code stored at *out_err:
#   DR_ERR_BOUNDS       — len < 0
#   DR_ERR_TRUNCATED    — payload ends mid-field
#   AV1_ERR_BAD_PROFILE — seq_profile 3..7 (reserved, 6.4.1)
#   AV1_ERR_BAD_SEQ     — reduced_still_picture_header without
#                         still_picture (6.4.1)
#   DR_ERR_OOM          — allocation failure
# Trailing bits (5.3.4) after film_grain_params_present are not
# inspected in 0.1.x.
fn av1_seq_parse(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    var br = dr_br_init(buf, len);
    if (br == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    # 5.5.1 sequence_header_obu() — leading fixed fields.
    var profile = dr_br_read_bits(br, 3);   # seq_profile                  f(3)
    var still = dr_br_read_bit(br);         # still_picture                f(1)
    var reduced = dr_br_read_bit(br);       # reduced_still_picture_header f(1)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (profile > 2) {
        store64(out_err, AV1_ERR_BAD_PROFILE);
        return 0;
    }
    if (reduced && (still == 0)) {
        store64(out_err, AV1_ERR_BAD_SEQ);
        return 0;
    }
    if (reduced) {
        # 5.5.1 reduced path: a single implied operating point.
        dr_br_read_bits(br, 5);             # seq_level_idx[0] f(5)
    } else {
        var dm_present = 0;
        var bdl_m1 = 0;
        var timing = dr_br_read_bit(br);    # timing_info_present_flag f(1)
        if (timing) {
            var rc = av1_timing_info_skip(br);
            if (rc != DR_OK) {
                store64(out_err, rc);
                return 0;
            }
            dm_present = dr_br_read_bit(br);   # decoder_model_info_present_flag f(1)
            if (dm_present) {
                rc = av1_decoder_model_info_skip(br, &bdl_m1);
                if (rc != DR_OK) {
                    store64(out_err, rc);
                    return 0;
                }
            }
        }
        var idd_present = dr_br_read_bit(br);   # initial_display_delay_present_flag f(1)
        var ops_m1 = dr_br_read_bits(br, 5);    # operating_points_cnt_minus_1 f(5)
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        # Loop bound is spec-fixed at 32 (f(5) + 1) — no bomb risk.
        var i = 0;
        while (i <= ops_m1) {
            dr_br_read_bits(br, 12);            # operating_point_idc[i] f(12)
            var level = dr_br_read_bits(br, 5); # seq_level_idx[i]       f(5)
            if (level > 7) {
                dr_br_read_bit(br);             # seq_tier[i] f(1) (else implied 0)
            }
            if (dm_present) {
                var dm_this = dr_br_read_bit(br);   # decoder_model_present_for_this_op[i] f(1)
                if (dm_this) {
                    var rc2 = av1_operating_parameters_info_skip(br, bdl_m1);
                    if (rc2 != DR_OK) {
                        store64(out_err, rc2);
                        return 0;
                    }
                }
            }
            if (idd_present) {
                var idd_this = dr_br_read_bit(br);  # initial_display_delay_present_for_this_op[i] f(1)
                if (idd_this) {
                    dr_br_read_bits(br, 4);         # initial_display_delay_minus_1[i] f(4)
                }
            }
            if (dr_br_err(br) != DR_OK) {
                store64(out_err, dr_br_err(br));
                return 0;
            }
            i = i + 1;
        }
    }
    # Frame-size bounds — common to both paths.
    var wbits = dr_br_read_bits(br, 4) + 1;      # frame_width_bits_minus_1  f(4)
    var hbits = dr_br_read_bits(br, 4) + 1;      # frame_height_bits_minus_1 f(4)
    var width = dr_br_read_bits(br, wbits) + 1;  # max_frame_width_minus_1   f(wbits)
    var height = dr_br_read_bits(br, hbits) + 1; # max_frame_height_minus_1  f(hbits)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (reduced == 0) {
        var fid = dr_br_read_bit(br);       # frame_id_numbers_present_flag f(1)
        if (fid) {
            dr_br_read_bits(br, 4);         # delta_frame_id_length_minus_2      f(4)
            dr_br_read_bits(br, 3);         # additional_frame_id_length_minus_1 f(3)
        }
    }
    dr_br_read_bit(br);                     # use_128x128_superblock   f(1)
    dr_br_read_bit(br);                     # enable_filter_intra      f(1)
    dr_br_read_bit(br);                     # enable_intra_edge_filter f(1)
    if (reduced == 0) {
        # Inter-tool flags — 5.5.1 full path only (reduced implies all 0
        # and SELECT_* for the force fields).
        dr_br_read_bit(br);                 # enable_interintra_compound f(1)
        dr_br_read_bit(br);                 # enable_masked_compound     f(1)
        dr_br_read_bit(br);                 # enable_warped_motion       f(1)
        dr_br_read_bit(br);                 # enable_dual_filter         f(1)
        var order_hint = dr_br_read_bit(br);    # enable_order_hint f(1)
        if (order_hint) {
            dr_br_read_bit(br);             # enable_jnt_comp      f(1)
            dr_br_read_bit(br);             # enable_ref_frame_mvs f(1)
        }
        var choose_sct = dr_br_read_bit(br);    # seq_choose_screen_content_tools f(1)
        var force_sct = 2;                      # SELECT_SCREEN_CONTENT_TOOLS
        if (choose_sct == 0) {
            force_sct = dr_br_read_bit(br);     # seq_force_screen_content_tools f(1)
        }
        if (force_sct > 0) {
            var choose_imv = dr_br_read_bit(br);    # seq_choose_integer_mv f(1)
            if (choose_imv == 0) {
                dr_br_read_bit(br);         # seq_force_integer_mv f(1)
            }
        }
        if (order_hint) {
            dr_br_read_bits(br, 3);         # order_hint_bits_minus_1 f(3)
        }
    }
    dr_br_read_bit(br);                     # enable_superres    f(1)
    dr_br_read_bit(br);                     # enable_cdef        f(1)
    dr_br_read_bit(br);                     # enable_restoration f(1)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    var depth = 0;
    var mono = 0;
    var rc3 = av1_color_config_parse(br, profile, &depth, &mono);   # color_config() 5.5.2
    if (rc3 != DR_OK) {
        store64(out_err, rc3);
        return 0;
    }
    dr_br_read_bit(br);                     # film_grain_params_present f(1)
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    var s = alloc(56);
    if (s == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(s, profile);
    store64(s + 8, width);
    store64(s + 16, height);
    store64(s + 24, depth);
    store64(s + 32, mono);
    store64(s + 40, still);
    store64(s + 48, reduced);
    return s;
}

fn av1_seq_profile(s): i64 { return load64(s); }
fn av1_seq_width(s): i64 { return load64(s + 8); }
fn av1_seq_height(s): i64 { return load64(s + 16); }
fn av1_seq_bitdepth(s): i64 { return load64(s + 24); }
fn av1_seq_mono(s): i64 { return load64(s + 32); }
fn av1_seq_still(s): i64 { return load64(s + 40); }
fn av1_seq_reduced(s): i64 { return load64(s + 48); }

# --- h264_nal.cyr ---

# @public — drishti H.264/AVC NAL layer: Annex-B byte-stream scan
# (3- and 4-byte start codes), NAL unit header parse, and RBSP
# emulation-prevention handling in BOTH directions (strip 00 00 03 on
# decode, insert emulation_prevention_three_byte on encode).
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_* codes) only. Every symbol carries the
# h264_ family prefix (Cyrius has no module-private scoping).
#
# Spec: ITU-T Rec. H.264 (authoritative) —
#   7.3.1     nal_unit() syntax (header bits + emulation prevention)
#   7.4.1     NAL unit semantics (forbidden_zero_bit, nal_ref_idc
#             constraints, prohibited three-byte sequences)
#   7.4.1.1   encapsulation / emulation_prevention_three_byte
#   Table 7-1 nal_unit_type codes
#   Annex B   byte-stream format (B.1.1 syntax, B.1.2 decoding:
#             leading_zero_8bits, zero_byte, start_code_prefix_one_3bytes,
#             trailing_zero_8bits)
# Cross-checks: RFC 6184 §1.3 (NAL header field recap), openh264
# (DecodeNalHeaderExtension/InitBsWithTwoLevels EPB handling), ffmpeg
# h2645_parse.c (start-code resync + 4-byte zero_byte attribution).
#
# H264Scan layout (40 bytes, heap):
#   +0:  buf   — whole-stream buffer (BORROWED — caller keeps it alive)
#   +8:  len   — buffer length in bytes
#   +16: pos   — byte cursor (start of the next start code to consume)
#   +24: count — NAL units yielded so far
#   +32: err   — sticky error code (DR_OK until first fault)

# ================================================================
# H.264 family error band: 30-49 (see src/drishti.cyr). Generic
# faults reuse the core DR_ERR_* codes; only codec-specific failures
# are minted here.
# ================================================================
enum H264ErrCode {
    H264_ERR_NO_START_CODE = 30;   # non-empty buffer holds no Annex-B start code at all
    H264_ERR_BAD_SPS       = 31;   # SPS field outside its spec 7.4.2.1.1 range
    H264_ERR_BAD_PPS       = 32;   # PPS field outside its spec 7.4.2.2 range
}

# nal_unit_type codes — spec Table 7-1.
enum H264NalType {
    H264_NAL_UNSPEC     = 0;    # unspecified
    H264_NAL_SLICE      = 1;    # coded slice of a non-IDR picture
    H264_NAL_DPA        = 2;    # coded slice data partition A
    H264_NAL_DPB        = 3;    # coded slice data partition B
    H264_NAL_DPC        = 4;    # coded slice data partition C
    H264_NAL_IDR        = 5;    # coded slice of an IDR picture
    H264_NAL_SEI        = 6;    # supplemental enhancement information
    H264_NAL_SPS        = 7;    # sequence parameter set
    H264_NAL_PPS        = 8;    # picture parameter set
    H264_NAL_AUD        = 9;    # access unit delimiter
    H264_NAL_EOSEQ      = 10;   # end of sequence
    H264_NAL_EOSTREAM   = 11;   # end of stream
    H264_NAL_FILLER     = 12;   # filler data
    H264_NAL_SPS_EXT    = 13;   # sequence parameter set extension
    H264_NAL_PREFIX     = 14;   # prefix NAL unit (Annex G/H)
    H264_NAL_SUBSET_SPS = 15;   # subset sequence parameter set (Annex G/H)
    H264_NAL_DPS        = 16;   # depth parameter set (Annex I/J)
    H264_NAL_AUX_SLICE  = 19;   # coded slice of an auxiliary coded picture
    H264_NAL_SLICE_EXT  = 20;   # coded slice extension (Annex G/H)
    H264_NAL_SLICE_3D   = 21;   # coded slice extension for depth views (Annex I/J)
}

# h264_scan_next / h264_find_start_code "no more" sentinel. Distinct
# from DR_OK (0) and every DR_ERR_* / H264_ERR_* (> 0). Module-global
# var, not an enum member — cyrius enums reject negative literals
# (same pattern as DR_IVF_END in src/ivf.cyr).
var H264_NAL_END = -1;

# ================================================================
# Start-code search — Annex B B.1.1/B.1.2
#
# A start code is the 3-byte prefix 00 00 01; a zero_byte immediately
# before it makes the conventional "4-byte start code" 00 00 00 01
# (mandatory before SPS/PPS and the first NAL of an access unit).
# ================================================================

# Find the next start code in buf[from..len). Returns the byte offset
# of the start code's FIRST byte — including the zero_byte when the
# 00 00 01 is preceded by 0x00 at or after `from` (the ffmpeg
# h2645_parse attribution rule) — and stores 3 or 4 at *out_sc_len.
# Returns H264_NAL_END (-1) when no start code exists in the range.
# Never reads outside buf[0..len).
fn h264_find_start_code(buf, len, from, out_sc_len): i64 {
    var i = from;
    if (i < 0) { i = 0; }
    # Pattern needs bytes i, i+1, i+2.
    while ((i + 2) < len) {
        if ((load8(buf + i) == 0) && (load8(buf + i + 1) == 0)
        && (load8(buf + i + 2) == 1)) {
            # zero_byte attribution: a 0x00 directly before the prefix
            # (still inside [from, len)) belongs to the start code.
            if ((i > from) && (load8(buf + i - 1) == 0)) {
                store64(out_sc_len, 4);
                return i - 1;
            }
            store64(out_sc_len, 3);
            return i;
        }
        i = i + 1;
    }
    return H264_NAL_END;
}

# ================================================================
# H264Scan — Annex-B NAL unit iterator
# ================================================================

# Create a scanner over buf[0..len). The buffer is BORROWED — the
# caller keeps it alive for the scanner's (and every yielded NAL
# pointer's) lifetime. Returns the H264Scan handle, or 0 on
# allocation failure / negative len.
fn h264_scan_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var s = alloc(40);
    if (s == 0) { return 0; }
    store64(s, buf);
    store64(s + 8, len);
    store64(s + 16, 0);
    store64(s + 24, 0);
    store64(s + 32, DR_OK);
    return s;
}

# Sticky error code (DR_OK if the scanner has never faulted).
fn h264_scan_err(s): i64 {
    return load64(s + 32);
}

# Byte cursor (start of the next start code, or len at end).
fn h264_scan_pos(s): i64 {
    return load64(s + 16);
}

# NAL units yielded so far.
fn h264_scan_count(s): i64 {
    return load64(s + 24);
}

# Yield the next NAL unit: *out_nal = ZERO-COPY pointer to its first
# byte (the NAL header byte), *out_size = its length in bytes.
#
# Per B.1.2 the NAL unit runs from the byte after the start code up to
# the next start code (a preceding zero_byte counts as part of that
# next start code) or end of buffer; trailing_zero_8bits are stripped.
# A zero-length span between adjacent start codes IS yielded (size 0)
# — rejecting it is the header parser's job (a NAL needs >= 1 byte).
#
# Returns DR_OK; H264_NAL_END (-1, repeatable, not sticky) when no
# start codes remain; sticky H264_ERR_NO_START_CODE when a NON-EMPTY
# buffer contains no start code at all (not an Annex-B stream).
# Bytes before the first start code are skipped (B.1.2 permits
# leading_zero_8bits; we also resync past non-zero garbage, the
# reference-decoder behavior).
fn h264_scan_next(s, out_nal, out_size): i64 {
    var e = load64(s + 32);
    if (e != DR_OK) { return e; }
    var buf = load64(s);
    var len = load64(s + 8);
    var pos = load64(s + 16);
    var sc_len = 0;
    var sc = h264_find_start_code(buf, len, pos, &sc_len);
    if (sc < 0) {
        if ((load64(s + 24) == 0) && (len > 0)) {
            store64(s + 32, H264_ERR_NO_START_CODE);
            return H264_ERR_NO_START_CODE;
        }
        store64(s + 16, len);
        return H264_NAL_END;
    }
    var nal_start = sc + sc_len;
    # NAL end: at the next start code (including its zero_byte) or len.
    var next_len = 0;
    var next_sc = h264_find_start_code(buf, len, nal_start, &next_len);
    var nal_end = len;
    if (next_sc >= 0) { nal_end = next_sc; }
    # Strip trailing_zero_8bits (B.1.2) — not part of the NAL unit.
    while ((nal_end > nal_start) && (load8(buf + nal_end - 1) == 0)) {
        nal_end = nal_end - 1;
    }
    store64(out_nal, buf + nal_start);
    store64(out_size, nal_end - nal_start);
    if (next_sc >= 0) {
        store64(s + 16, next_sc);
    } else {
        store64(s + 16, len);
    }
    store64(s + 24, load64(s + 24) + 1);
    return DR_OK;
}

# ================================================================
# NAL unit header — spec 7.3.1 / 7.4.1 (one byte):
#   forbidden_zero_bit  f(1)  — shall be 0
#   nal_ref_idc         u(2)
#   nal_unit_type       u(5)
# ================================================================

# Parse the header byte of nal[0..len). Stores nal_ref_idc at
# *out_ref_idc and nal_unit_type at *out_type. Returns DR_OK;
# DR_ERR_TRUNCATED (len < 1); DR_ERR_FORBIDDEN_BIT (7.4.1:
# forbidden_zero_bit shall be 0). Decode side does NOT enforce the
# 7.4.1 nal_ref_idc/type pairing constraints (real streams violate
# them; the encode-side h264_annexb_wrap DOES enforce them).
fn h264_nal_hdr_parse(nal, len, out_ref_idc, out_type): i64 {
    if (len < 1) { return DR_ERR_TRUNCATED; }
    var b = load8(nal);
    if (b & 0x80) { return DR_ERR_FORBIDDEN_BIT; }
    store64(out_ref_idc, (b >> 5) & 3);
    store64(out_type, b & 31);
    return DR_OK;
}

# Human-readable name for a Table 7-1 nal_unit_type (cstring, never null).
fn h264_nal_type_name(t): i64 {
    if (t == H264_NAL_SLICE)      { return "slice (non-IDR)"; }
    if (t == H264_NAL_DPA)        { return "data partition A"; }
    if (t == H264_NAL_DPB)        { return "data partition B"; }
    if (t == H264_NAL_DPC)        { return "data partition C"; }
    if (t == H264_NAL_IDR)        { return "IDR slice"; }
    if (t == H264_NAL_SEI)        { return "SEI"; }
    if (t == H264_NAL_SPS)        { return "SPS"; }
    if (t == H264_NAL_PPS)        { return "PPS"; }
    if (t == H264_NAL_AUD)        { return "access unit delimiter"; }
    if (t == H264_NAL_EOSEQ)      { return "end of sequence"; }
    if (t == H264_NAL_EOSTREAM)   { return "end of stream"; }
    if (t == H264_NAL_FILLER)     { return "filler data"; }
    if (t == H264_NAL_SPS_EXT)    { return "SPS extension"; }
    if (t == H264_NAL_PREFIX)     { return "prefix NAL"; }
    if (t == H264_NAL_SUBSET_SPS) { return "subset SPS"; }
    if (t == H264_NAL_DPS)        { return "depth parameter set"; }
    if (t == H264_NAL_AUX_SLICE)  { return "auxiliary slice"; }
    if (t == H264_NAL_SLICE_EXT)  { return "slice extension"; }
    if (t == H264_NAL_SLICE_3D)   { return "3D slice extension"; }
    return "unspecified/reserved";
}

# ================================================================
# RBSP <-> encapsulated payload — spec 7.3.1 / 7.4.1.1
#
# Inside a NAL unit the three-byte sequences 00 00 00, 00 00 01 and
# 00 00 02 shall not occur; the encoder breaks them by inserting an
# emulation_prevention_three_byte (0x03) after every 00 00 that would
# be followed by a byte <= 0x03. The decoder strips those 0x03 bytes
# to recover the raw byte sequence payload (RBSP).
# ================================================================

# Decode direction: strip emulation prevention from the encapsulated
# payload buf[0..len) (the bytes AFTER the NAL header byte). Allocates
# a fresh buffer, stores it at *out_rbsp and its length at *out_len.
# Returns DR_OK; DR_ERR_BOUNDS (negative len); DR_ERR_OOM.
#
# A 0x03 following two zero bytes is dropped unconditionally — the
# lenient reference-decoder rule (openh264 / ffmpeg both do this
# without checking that the NEXT byte is <= 0x03); malformed interior
# 00 00 0x runs are copied through rather than rejected, matching
# both cross-check sources.
fn h264_rbsp_extract(buf, len, out_rbsp, out_len): i64 {
    if (len < 0) { return DR_ERR_BOUNDS; }
    var dst = alloc(len + 1);
    if (dst == 0) { return DR_ERR_OOM; }
    var zeros = 0;
    var o = 0;
    var i = 0;
    while (i < len) {
        var b = load8(buf + i);
        if ((zeros >= 2) && (b == 3)) {
            # emulation_prevention_three_byte — drop it; the 0x03
            # breaks the zero run (7.4.1.1).
            zeros = 0;
        } else {
            store8(dst + o, b);
            o = o + 1;
            if (b == 0) { zeros = zeros + 1; } else { zeros = 0; }
        }
        i = i + 1;
    }
    store64(out_rbsp, dst);
    store64(out_len, o);
    return DR_OK;
}

# Encode direction: insert emulation_prevention_three_byte. Escapes
# every 00 00 pair followed by a byte <= 0x03 (spec 7.3.1 encode
# process: 00 00 00 -> 00 00 03 00, 00 00 01 -> 00 00 03 01,
# 00 00 02 -> 00 00 03 02, 00 00 03 -> 00 00 03 03). A trailing 00 00
# with nothing after it is left alone — a conforming RBSP never ends
# in 0x00 (rbsp_trailing_bits' stop bit makes the last byte nonzero).
# Worst case growth is len + len/2 (all-zero input). Allocates a
# fresh buffer at *out_buf, length at *out_len. Returns DR_OK;
# DR_ERR_BOUNDS (negative len); DR_ERR_OOM.
# h264_rbsp_extract(h264_epb_insert(x)) == x for every input x.
fn h264_epb_insert(buf, len, out_buf, out_len): i64 {
    if (len < 0) { return DR_ERR_BOUNDS; }
    var dst = alloc(len + (len >> 1) + 4);
    if (dst == 0) { return DR_ERR_OOM; }
    var zeros = 0;
    var o = 0;
    var i = 0;
    while (i < len) {
        var b = load8(buf + i);
        if ((zeros >= 2) && (b <= 3)) {
            store8(dst + o, 3);   # emulation_prevention_three_byte
            o = o + 1;
            zeros = 0;
        }
        store8(dst + o, b);
        o = o + 1;
        if (b == 0) { zeros = zeros + 1; } else { zeros = 0; }
        i = i + 1;
    }
    store64(out_buf, dst);
    store64(out_len, o);
    return DR_OK;
}

# ================================================================
# Annex-B NAL composer — the encode seed
# ================================================================

# Build a complete Annex-B NAL unit: start code + header byte +
# emulation-prevented payload. long_sc nonzero emits the 4-byte
# 00 00 00 01 (required before SPS/PPS and first-NAL-of-AU, B.1.2),
# else the 3-byte 00 00 01. Allocates the result at *out_buf,
# length at *out_len.
#
# Validates (7.4.1 semantics): ref_idc in [0,3]; type in [1,31]
# (type 0 is unspecified — refuse to emit it); nal_ref_idc shall NOT
# be 0 for types 5 (IDR), 7 (SPS), 8 (PPS), 13, 15; nal_ref_idc
# SHALL be 0 for types 6 (SEI), 9 (AUD), 10, 11, 12. Violations
# return DR_ERR_BAD_HEADER. Other returns: DR_ERR_BOUNDS (negative
# rbsp_len), DR_ERR_OOM.
fn h264_annexb_wrap(ref_idc, type, rbsp, rbsp_len, long_sc, out_buf, out_len): i64 {
    if ((ref_idc < 0) || (ref_idc > 3)) { return DR_ERR_BAD_HEADER; }
    if ((type < 1) || (type > 31)) { return DR_ERR_BAD_HEADER; }
    if (ref_idc == 0) {
        if ((type == H264_NAL_IDR) || (type == H264_NAL_SPS)
        || (type == H264_NAL_PPS) || (type == H264_NAL_SPS_EXT)
        || (type == H264_NAL_SUBSET_SPS)) {
            return DR_ERR_BAD_HEADER;
        }
    }
    if (ref_idc != 0) {
        if ((type == H264_NAL_SEI) || (type == H264_NAL_AUD)
        || (type == H264_NAL_EOSEQ) || (type == H264_NAL_EOSTREAM)
        || (type == H264_NAL_FILLER)) {
            return DR_ERR_BAD_HEADER;
        }
    }
    if (rbsp_len < 0) { return DR_ERR_BOUNDS; }
    var ebuf = 0;
    var elen = 0;
    var rc = h264_epb_insert(rbsp, rbsp_len, &ebuf, &elen);
    if (rc != DR_OK) { return rc; }
    var sc_len = 3;
    if (long_sc) { sc_len = 4; }
    var total = sc_len + 1 + elen;
    var dst = alloc(total);
    if (dst == 0) { return DR_ERR_OOM; }
    var o = 0;
    if (long_sc) {
        store8(dst, 0);
        o = 1;
    }
    store8(dst + o, 0);
    store8(dst + o + 1, 0);
    store8(dst + o + 2, 1);
    # Header byte: forbidden_zero_bit 0, nal_ref_idc, nal_unit_type.
    store8(dst + o + 3, (ref_idc << 5) + type);
    memcpy(dst + o + 4, ebuf, elen);
    store64(out_buf, dst);
    store64(out_len, total);
    return DR_OK;
}

# --- h264_ps.cyr ---

# @public — drishti H.264/AVC parameter sets: SPS parse (spec 7.3.2.1.1,
# including the High-profile branch and scaling-matrix skip) and a
# minimal PPS parse (spec 7.3.2.2). Input is the RBSP — callers run
# h264_rbsp_extract on the NAL payload (bytes after the header byte)
# first.
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*), src/bits.cyr (DrBr + ue/se exp-Golomb)
# and src/h264_nal.cyr (H264_ERR_* band codes). Every symbol carries
# the h264_ family prefix.
#
# Spec: ITU-T Rec. H.264 (authoritative) —
#   7.3.2.1.1    seq_parameter_set_data() syntax
#   7.3.2.1.1.1  scaling_list() syntax
#   7.4.2.1.1    SPS semantics (field ranges, CropUnitX/Y, dims)
#   7.4.2.1.1.1  delta_scale range
#   7.3.2.2 / 7.4.2.2  PPS syntax + semantics
#   Table 6-1    SubWidthC / SubHeightC per chroma_format_idc
# Cross-checks: openh264 ParseSps/ParsePps (au_parser.cpp), x264
# x264_sps_init serialization order, JM reference InterpretSPS.
#
# H264Sps record layout (224 bytes, heap) — raw spec field values
# (spec names, spec units) plus the two COMPUTED display dimensions:
#   +0:   profile_idc
#   +8:   constraint_flags — bit i = constraint_set{i}_flag, i in 0..5
#   +16:  level_idc
#   +24:  sps_id (seq_parameter_set_id)
#   +32:  chroma_format_idc          (INFERRED 1 = 4:2:0 when the
#                                     High-profile branch is absent)
#   +40:  separate_colour_plane_flag
#   +48:  bit_depth_luma_minus8
#   +56:  bit_depth_chroma_minus8
#   +64:  qpprime_y_zero_transform_bypass_flag
#   +72:  seq_scaling_matrix_present_flag
#   +80:  log2_max_frame_num_minus4
#   +88:  pic_order_cnt_type          (0 or 2; type 1 is unsupported)
#   +96:  log2_max_pic_order_cnt_lsb_minus4 (0 unless poc type == 0)
#   +104: max_num_ref_frames
#   +112: gaps_in_frame_num_value_allowed_flag
#   +120: pic_width_in_mbs_minus1
#   +128: pic_height_in_map_units_minus1
#   +136: frame_mbs_only_flag
#   +144: mb_adaptive_frame_field_flag (mbaff; 0 when frame_mbs_only)
#   +152: direct_8x8_inference_flag
#   +160: frame_cropping_flag
#   +168: frame_crop_left_offset
#   +176: frame_crop_right_offset
#   +184: frame_crop_top_offset
#   +192: frame_crop_bottom_offset
#   +200: vui_parameters_present_flag (VUI itself is NOT parsed in 0.1.x)
#   +208: width  — computed cropped luma width in samples (7.4.2.1.1)
#   +216: height — computed cropped luma height in samples
#
# H264Pps record layout (120 bytes, heap) — raw spec field values:
#   +0:   pps_id (pic_parameter_set_id)
#   +8:   sps_id (seq_parameter_set_id)
#   +16:  entropy_coding_mode_flag (0 = CAVLC, 1 = CABAC)
#   +24:  bottom_field_pic_order_in_frame_present_flag
#   +32:  num_slice_groups_minus1 (only 0 supported — FMO is out of scope)
#   +40:  num_ref_idx_l0_default_active_minus1
#   +48:  num_ref_idx_l1_default_active_minus1
#   +56:  weighted_pred_flag
#   +64:  weighted_bipred_idc
#   +72:  pic_init_qp_minus26 (signed)
#   +80:  pic_init_qs_minus26 (signed)
#   +88:  chroma_qp_index_offset (signed)
#   +96:  deblocking_filter_control_present_flag
#   +104: constrained_intra_pred_flag
#   +112: redundant_pic_cnt_present_flag

# Bomb guard: pic_width_in_mbs_minus1 / pic_height_in_map_units_minus1
# above this yield DR_ERR_OVERSIZE. 1024 MBs = 16384 luma samples per
# axis — beyond every defined level's MaxFS (levels top out at 6.2 =
# 139264 total MBs, 8K frames), so any real SPS fits with margin.
enum H264PsLimits {
    H264_PS_MAX_MBS_MINUS1 = 1023;
}

# Internal helper: latch an error into *out_err and return 0 (the
# "no record" result) so parse call sites stay one-liners.
fn h264_ps_fail(out_err, code): i64 {
    store64(out_err, code);
    return 0;
}

# True (1) when profile_idc selects the extended 7.3.2.1.1 branch
# (chroma format / bit depth / scaling matrix fields present). The
# thirteen-value list is verbatim from the spec's if-condition:
# 100 High, 110 High 10, 122 High 4:2:2, 244 High 4:4:4 Predictive,
# 44 CAVLC 4:4:4 Intra, 83/86 Scalable (Annex G), 118 Multiview High /
# 128 Stereo High (Annex H), 138/139 Multiview Depth (Annex I),
# 134/135 MFC (Annex H).
fn h264_ps_is_high_profile(profile_idc): i64 {
    if (profile_idc == 100) { return 1; }
    if (profile_idc == 110) { return 1; }
    if (profile_idc == 122) { return 1; }
    if (profile_idc == 244) { return 1; }
    if (profile_idc == 44)  { return 1; }
    if (profile_idc == 83)  { return 1; }
    if (profile_idc == 86)  { return 1; }
    if (profile_idc == 118) { return 1; }
    if (profile_idc == 128) { return 1; }
    if (profile_idc == 138) { return 1; }
    if (profile_idc == 139) { return 1; }
    if (profile_idc == 134) { return 1; }
    if (profile_idc == 135) { return 1; }
    return 0;
}

# Skip one scaling_list() of `size` entries (16 for the 4x4 lists,
# 64 for 8x8) — spec 7.3.2.1.1.1. We only SKIP in 0.1.x (the lists
# feed dequant, which lands with the 0.3.x transform milestone), but
# skipping still has to walk the exact syntax: delta_scale symbols
# stop as soon as nextScale hits 0 ("use default" signal).
# Returns DR_OK; DR_ERR_TRUNCATED / DR_ERR_BAD_VLC from the reader;
# H264_ERR_BAD_SPS when delta_scale leaves [-128, 127] (7.4.2.1.1.1).
fn h264_ps_skip_scaling_list(br, size): i64 {
    var last_scale = 8;
    var next_scale = 8;
    var j = 0;
    while (j < size) {
        if (next_scale != 0) {
            var delta = 0;
            var rc = dr_se_read(br, &delta);
            if (rc != DR_OK) { return rc; }
            if ((delta < (0 - 128)) || (delta > 127)) {
                return H264_ERR_BAD_SPS;
            }
            # nextScale = (lastScale + delta_scale + 256) % 256 —
            # operand range [128, 638] keeps the &255 form exact.
            next_scale = (last_scale + delta + 256) & 255;
        }
        if (next_scale != 0) { last_scale = next_scale; }
        j = j + 1;
    }
    return DR_OK;
}

# ================================================================
# SPS parse — spec 7.3.2.1.1 seq_parameter_set_data()
# ================================================================

# Parse an SPS RBSP (rbsp[0..len)). Returns an H264Sps record, or 0
# with the error at *out_err:
#   DR_ERR_TRUNCATED   — RBSP ends mid-field
#   DR_ERR_BAD_VLC     — exp-Golomb overflow (> 31 leading zeros)
#   DR_ERR_BOUNDS      — negative len
#   H264_ERR_BAD_SPS   — a field outside its 7.4.2.1.1 range, or
#                        cropping that consumes the whole frame
#   DR_ERR_OVERSIZE    — width/height in MBs above the bomb guard
#   DR_ERR_UNSUPPORTED — pic_order_cnt_type == 1 (out of 0.1.x scope)
#   DR_ERR_OOM         — allocation failure
fn h264_sps_parse(rbsp, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) { return h264_ps_fail(out_err, DR_ERR_BOUNDS); }
    var br = dr_br_init(rbsp, len);
    if (br == 0) { return h264_ps_fail(out_err, DR_ERR_OOM); }

    # profile_idc u(8), constraint byte u(8), level_idc u(8).
    var profile_idc = dr_br_read_bits(br, 8);
    var cbyte = dr_br_read_bits(br, 8);
    var level_idc = dr_br_read_bits(br, 8);
    var e = dr_br_err(br);
    if (e != DR_OK) { return h264_ps_fail(out_err, e); }
    # constraint_set0..5_flag are the byte's bits 7..2 (MSB first);
    # reserved_zero_2bits (bits 1-0) are IGNORED per 7.4.2.1.1
    # ("decoders shall ignore the value" — reserved for future use).
    var cflags = 0;
    if (cbyte & 0x80) { cflags = cflags + 1; }    # constraint_set0_flag
    if (cbyte & 0x40) { cflags = cflags + 2; }    # constraint_set1_flag
    if (cbyte & 0x20) { cflags = cflags + 4; }    # constraint_set2_flag
    if (cbyte & 0x10) { cflags = cflags + 8; }    # constraint_set3_flag
    if (cbyte & 0x08) { cflags = cflags + 16; }   # constraint_set4_flag
    if (cbyte & 0x04) { cflags = cflags + 32; }   # constraint_set5_flag

    # seq_parameter_set_id ue(v), range [0, 31] (7.4.2.1.1).
    var sps_id = 0;
    var rc = dr_ue_read(br, &sps_id);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (sps_id > 31) { return h264_ps_fail(out_err, H264_ERR_BAD_SPS); }

    # High-profile branch defaults (7.4.2.1.1 inference rules): when
    # absent, chroma_format_idc = 1 (4:2:0) and both bit depths = 8.
    var chroma_format_idc = 1;
    var separate_colour_plane = 0;
    var bit_depth_luma_m8 = 0;
    var bit_depth_chroma_m8 = 0;
    var qpprime_flag = 0;
    var scaling_matrix_flag = 0;
    if (h264_ps_is_high_profile(profile_idc)) {
        # chroma_format_idc ue(v), range [0, 3].
        rc = dr_ue_read(br, &chroma_format_idc);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        if (chroma_format_idc > 3) {
            return h264_ps_fail(out_err, H264_ERR_BAD_SPS);
        }
        if (chroma_format_idc == 3) {
            separate_colour_plane = dr_br_read_bit(br);
        }
        # bit_depth_luma_minus8 / bit_depth_chroma_minus8 ue(v),
        # range [0, 6] (8..14-bit).
        rc = dr_ue_read(br, &bit_depth_luma_m8);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        if (bit_depth_luma_m8 > 6) {
            return h264_ps_fail(out_err, H264_ERR_BAD_SPS);
        }
        rc = dr_ue_read(br, &bit_depth_chroma_m8);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        if (bit_depth_chroma_m8 > 6) {
            return h264_ps_fail(out_err, H264_ERR_BAD_SPS);
        }
        qpprime_flag = dr_br_read_bit(br);
        scaling_matrix_flag = dr_br_read_bit(br);
        e = dr_br_err(br);
        if (e != DR_OK) { return h264_ps_fail(out_err, e); }
        if (scaling_matrix_flag) {
            # 8 lists for 4:2:0/4:2:2 (six 4x4 + two 8x8), 12 for
            # 4:4:4 (six 4x4 + six 8x8) — 7.3.2.1.1.
            var nlists = 8;
            if (chroma_format_idc == 3) { nlists = 12; }
            var i = 0;
            while (i < nlists) {
                var present = dr_br_read_bit(br);
                e = dr_br_err(br);
                if (e != DR_OK) { return h264_ps_fail(out_err, e); }
                if (present) {
                    var lsize = 16;              # lists 0-5: 4x4
                    if (i >= 6) { lsize = 64; }  # lists 6+:  8x8
                    rc = h264_ps_skip_scaling_list(br, lsize);
                    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
                }
                i = i + 1;
            }
        }
    }

    # log2_max_frame_num_minus4 ue(v), range [0, 12].
    var log2_mfn_m4 = 0;
    rc = dr_ue_read(br, &log2_mfn_m4);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (log2_mfn_m4 > 12) { return h264_ps_fail(out_err, H264_ERR_BAD_SPS); }

    # pic_order_cnt_type ue(v), range [0, 2]. Type 1 (expected-delta
    # POC) is DR_ERR_UNSUPPORTED in 0.1.x — vanishingly rare in real
    # streams; support is a 0.2.x slice-header-lane item.
    var poc_type = 0;
    rc = dr_ue_read(br, &poc_type);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (poc_type > 2) { return h264_ps_fail(out_err, H264_ERR_BAD_SPS); }
    if (poc_type == 1) { return h264_ps_fail(out_err, DR_ERR_UNSUPPORTED); }
    var log2_poc_lsb_m4 = 0;
    if (poc_type == 0) {
        # log2_max_pic_order_cnt_lsb_minus4 ue(v), range [0, 12].
        rc = dr_ue_read(br, &log2_poc_lsb_m4);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        if (log2_poc_lsb_m4 > 12) {
            return h264_ps_fail(out_err, H264_ERR_BAD_SPS);
        }
    }

    # max_num_ref_frames ue(v), range [0, MaxDpbFrames] <= 16.
    var max_ref = 0;
    rc = dr_ue_read(br, &max_ref);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (max_ref > 16) { return h264_ps_fail(out_err, H264_ERR_BAD_SPS); }

    var gaps_flag = dr_br_read_bit(br);

    # Frame geometry in macroblock units.
    var pw_m1 = 0;
    rc = dr_ue_read(br, &pw_m1);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (pw_m1 > H264_PS_MAX_MBS_MINUS1) {
        return h264_ps_fail(out_err, DR_ERR_OVERSIZE);
    }
    var ph_m1 = 0;
    rc = dr_ue_read(br, &ph_m1);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (ph_m1 > H264_PS_MAX_MBS_MINUS1) {
        return h264_ps_fail(out_err, DR_ERR_OVERSIZE);
    }

    var frame_mbs_only = dr_br_read_bit(br);
    var mbaff = 0;
    if (frame_mbs_only == 0) {
        mbaff = dr_br_read_bit(br);
    }
    var direct_8x8 = dr_br_read_bit(br);

    var cropping = dr_br_read_bit(br);
    var crop_left = 0;
    var crop_right = 0;
    var crop_top = 0;
    var crop_bottom = 0;
    if (cropping) {
        rc = dr_ue_read(br, &crop_left);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        rc = dr_ue_read(br, &crop_right);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        rc = dr_ue_read(br, &crop_top);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
        rc = dr_ue_read(br, &crop_bottom);
        if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    }
    var vui_flag = dr_br_read_bit(br);
    e = dr_br_err(br);
    if (e != DR_OK) { return h264_ps_fail(out_err, e); }
    # VUI parameters (Annex E) are not parsed in 0.1.x — the flag is
    # recorded and the remaining RBSP bits are left unread.

    # ---- Computed display dimensions (7.4.2.1.1) -------------------
    # PicWidthInSamplesL = (pic_width_in_mbs_minus1 + 1) * 16
    # FrameHeightInMbs   = (2 - frame_mbs_only_flag) *
    #                      (pic_height_in_map_units_minus1 + 1)
    var w = (pw_m1 + 1) * 16;
    var h = (2 - frame_mbs_only) * (ph_m1 + 1) * 16;
    # ChromaArrayType: 0 when separate_colour_plane_flag, else
    # chroma_format_idc. SubWidthC/SubHeightC from Table 6-1.
    var chroma_array_type = chroma_format_idc;
    if (separate_colour_plane != 0) { chroma_array_type = 0; }
    var sub_w = 1;
    var sub_h = 1;
    if (chroma_format_idc == 1) { sub_w = 2; sub_h = 2; }   # 4:2:0
    if (chroma_format_idc == 2) { sub_w = 2; sub_h = 1; }   # 4:2:2
    # CropUnitX/Y (7.4.2.1.1): ChromaArrayType 0 -> 1 / (2 - fmbs);
    # else SubWidthC / SubHeightC * (2 - fmbs).
    var crop_unit_x = 1;
    var crop_unit_y = 2 - frame_mbs_only;
    if (chroma_array_type != 0) {
        crop_unit_x = sub_w;
        crop_unit_y = sub_h * (2 - frame_mbs_only);
    }
    var cx = crop_unit_x * (crop_left + crop_right);
    var cy = crop_unit_y * (crop_top + crop_bottom);
    # Cropping must leave at least one luma sample per axis.
    if ((cx >= w) || (cy >= h)) {
        return h264_ps_fail(out_err, H264_ERR_BAD_SPS);
    }

    var sps = alloc(224);
    if (sps == 0) { return h264_ps_fail(out_err, DR_ERR_OOM); }
    store64(sps, profile_idc);
    store64(sps + 8, cflags);
    store64(sps + 16, level_idc);
    store64(sps + 24, sps_id);
    store64(sps + 32, chroma_format_idc);
    store64(sps + 40, separate_colour_plane);
    store64(sps + 48, bit_depth_luma_m8);
    store64(sps + 56, bit_depth_chroma_m8);
    store64(sps + 64, qpprime_flag);
    store64(sps + 72, scaling_matrix_flag);
    store64(sps + 80, log2_mfn_m4);
    store64(sps + 88, poc_type);
    store64(sps + 96, log2_poc_lsb_m4);
    store64(sps + 104, max_ref);
    store64(sps + 112, gaps_flag);
    store64(sps + 120, pw_m1);
    store64(sps + 128, ph_m1);
    store64(sps + 136, frame_mbs_only);
    store64(sps + 144, mbaff);
    store64(sps + 152, direct_8x8);
    store64(sps + 160, cropping);
    store64(sps + 168, crop_left);
    store64(sps + 176, crop_right);
    store64(sps + 184, crop_top);
    store64(sps + 192, crop_bottom);
    store64(sps + 200, vui_flag);
    store64(sps + 208, w - cx);
    store64(sps + 216, h - cy);
    return sps;
}

# ---- H264Sps accessors (raw spec fields + computed dims) -----------
fn h264_sps_profile_idc(sps): i64 { return load64(sps); }
fn h264_sps_constraint_flags(sps): i64 { return load64(sps + 8); }
fn h264_sps_level_idc(sps): i64 { return load64(sps + 16); }
fn h264_sps_id(sps): i64 { return load64(sps + 24); }
fn h264_sps_chroma_format_idc(sps): i64 { return load64(sps + 32); }
fn h264_sps_separate_colour_plane(sps): i64 { return load64(sps + 40); }
fn h264_sps_bit_depth_luma_minus8(sps): i64 { return load64(sps + 48); }
fn h264_sps_bit_depth_chroma_minus8(sps): i64 { return load64(sps + 56); }
fn h264_sps_qpprime_flag(sps): i64 { return load64(sps + 64); }
fn h264_sps_scaling_matrix_flag(sps): i64 { return load64(sps + 72); }
fn h264_sps_log2_max_frame_num_minus4(sps): i64 { return load64(sps + 80); }
fn h264_sps_pic_order_cnt_type(sps): i64 { return load64(sps + 88); }
fn h264_sps_log2_max_poc_lsb_minus4(sps): i64 { return load64(sps + 96); }
fn h264_sps_max_num_ref_frames(sps): i64 { return load64(sps + 104); }
fn h264_sps_gaps_flag(sps): i64 { return load64(sps + 112); }
fn h264_sps_pic_width_in_mbs_minus1(sps): i64 { return load64(sps + 120); }
fn h264_sps_pic_height_in_map_units_minus1(sps): i64 { return load64(sps + 128); }
fn h264_sps_frame_mbs_only(sps): i64 { return load64(sps + 136); }
fn h264_sps_mbaff(sps): i64 { return load64(sps + 144); }
fn h264_sps_direct_8x8(sps): i64 { return load64(sps + 152); }
fn h264_sps_cropping_flag(sps): i64 { return load64(sps + 160); }
fn h264_sps_crop_left(sps): i64 { return load64(sps + 168); }
fn h264_sps_crop_right(sps): i64 { return load64(sps + 176); }
fn h264_sps_crop_top(sps): i64 { return load64(sps + 184); }
fn h264_sps_crop_bottom(sps): i64 { return load64(sps + 192); }
fn h264_sps_vui_flag(sps): i64 { return load64(sps + 200); }
fn h264_sps_width(sps): i64 { return load64(sps + 208); }
fn h264_sps_height(sps): i64 { return load64(sps + 216); }

# ================================================================
# PPS parse — spec 7.3.2.2 pic_parameter_set_rbsp(), minimal:
# through redundant_pic_cnt_present_flag. The optional tail
# (transform_8x8_mode_flag / pic_scaling_matrix /
# second_chroma_qp_index_offset, gated on more_rbsp_data()) is a
# 0.5.x High-profile item and is left unread.
# ================================================================

# Parse a PPS RBSP (rbsp[0..len)). Returns an H264Pps record, or 0
# with the error at *out_err:
#   DR_ERR_TRUNCATED   — RBSP ends mid-field
#   DR_ERR_BAD_VLC     — exp-Golomb overflow
#   DR_ERR_BOUNDS      — negative len
#   H264_ERR_BAD_PPS   — a field outside its 7.4.2.2 range
#   DR_ERR_UNSUPPORTED — num_slice_groups_minus1 > 0 (FMO)
#   DR_ERR_OOM         — allocation failure
fn h264_pps_parse(rbsp, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) { return h264_ps_fail(out_err, DR_ERR_BOUNDS); }
    var br = dr_br_init(rbsp, len);
    if (br == 0) { return h264_ps_fail(out_err, DR_ERR_OOM); }

    # pic_parameter_set_id ue(v), range [0, 255] (7.4.2.2).
    var pps_id = 0;
    var rc = dr_ue_read(br, &pps_id);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (pps_id > 255) { return h264_ps_fail(out_err, H264_ERR_BAD_PPS); }

    # seq_parameter_set_id ue(v), range [0, 31].
    var sps_id = 0;
    rc = dr_ue_read(br, &sps_id);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (sps_id > 31) { return h264_ps_fail(out_err, H264_ERR_BAD_PPS); }

    # entropy_coding_mode_flag u(1): 0 = CAVLC, 1 = CABAC.
    var entropy = dr_br_read_bit(br);
    # bottom_field_pic_order_in_frame_present_flag u(1)
    # (pic_order_present_flag in older spec editions).
    var bottom_field = dr_br_read_bit(br);

    # num_slice_groups_minus1 ue(v), range [0, 7]. > 0 selects FMO
    # slice-group maps (Baseline-only, essentially extinct) — out of
    # drishti's scope, DR_ERR_UNSUPPORTED.
    var nsg_m1 = 0;
    rc = dr_ue_read(br, &nsg_m1);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (nsg_m1 > 7) { return h264_ps_fail(out_err, H264_ERR_BAD_PPS); }
    if (nsg_m1 > 0) { return h264_ps_fail(out_err, DR_ERR_UNSUPPORTED); }

    # num_ref_idx_l0/l1_default_active_minus1 ue(v), range [0, 31].
    var l0_m1 = 0;
    rc = dr_ue_read(br, &l0_m1);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (l0_m1 > 31) { return h264_ps_fail(out_err, H264_ERR_BAD_PPS); }
    var l1_m1 = 0;
    rc = dr_ue_read(br, &l1_m1);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if (l1_m1 > 31) { return h264_ps_fail(out_err, H264_ERR_BAD_PPS); }

    # weighted_pred_flag u(1), weighted_bipred_idc u(2) (range [0, 2]).
    var wp = dr_br_read_bit(br);
    var wbi = dr_br_read_bits(br, 2);
    var e = dr_br_err(br);
    if (e != DR_OK) { return h264_ps_fail(out_err, e); }
    if (wbi > 2) { return h264_ps_fail(out_err, H264_ERR_BAD_PPS); }

    # pic_init_qp_minus26 se(v), range [-(26 + QpBdOffsetY), +25].
    # QpBdOffsetY = 6 * bit_depth_luma_minus8 <= 36; the PPS doesn't
    # know its SPS here, so the permissive bound [-62, 25] is used.
    var init_qp = 0;
    rc = dr_se_read(br, &init_qp);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if ((init_qp < (0 - 62)) || (init_qp > 25)) {
        return h264_ps_fail(out_err, H264_ERR_BAD_PPS);
    }
    # pic_init_qs_minus26 se(v), range [-26, +25] (SP/SI, no BD offset).
    var init_qs = 0;
    rc = dr_se_read(br, &init_qs);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if ((init_qs < (0 - 26)) || (init_qs > 25)) {
        return h264_ps_fail(out_err, H264_ERR_BAD_PPS);
    }
    # chroma_qp_index_offset se(v), range [-12, +12].
    var cqp = 0;
    rc = dr_se_read(br, &cqp);
    if (rc != DR_OK) { return h264_ps_fail(out_err, rc); }
    if ((cqp < (0 - 12)) || (cqp > 12)) {
        return h264_ps_fail(out_err, H264_ERR_BAD_PPS);
    }

    var deblock = dr_br_read_bit(br);
    var constrained = dr_br_read_bit(br);
    var redundant = dr_br_read_bit(br);
    e = dr_br_err(br);
    if (e != DR_OK) { return h264_ps_fail(out_err, e); }

    var pps = alloc(120);
    if (pps == 0) { return h264_ps_fail(out_err, DR_ERR_OOM); }
    store64(pps, pps_id);
    store64(pps + 8, sps_id);
    store64(pps + 16, entropy);
    store64(pps + 24, bottom_field);
    store64(pps + 32, nsg_m1);
    store64(pps + 40, l0_m1);
    store64(pps + 48, l1_m1);
    store64(pps + 56, wp);
    store64(pps + 64, wbi);
    store64(pps + 72, init_qp);
    store64(pps + 80, init_qs);
    store64(pps + 88, cqp);
    store64(pps + 96, deblock);
    store64(pps + 104, constrained);
    store64(pps + 112, redundant);
    return pps;
}

# ---- H264Pps accessors ---------------------------------------------
fn h264_pps_id(pps): i64 { return load64(pps); }
fn h264_pps_sps_id(pps): i64 { return load64(pps + 8); }
fn h264_pps_entropy_coding_mode(pps): i64 { return load64(pps + 16); }
fn h264_pps_bottom_field_poc_flag(pps): i64 { return load64(pps + 24); }
fn h264_pps_num_slice_groups_minus1(pps): i64 { return load64(pps + 32); }
fn h264_pps_ref_idx_l0_default_minus1(pps): i64 { return load64(pps + 40); }
fn h264_pps_ref_idx_l1_default_minus1(pps): i64 { return load64(pps + 48); }
fn h264_pps_weighted_pred_flag(pps): i64 { return load64(pps + 56); }
fn h264_pps_weighted_bipred_idc(pps): i64 { return load64(pps + 64); }
fn h264_pps_init_qp_minus26(pps): i64 { return load64(pps + 72); }
fn h264_pps_init_qs_minus26(pps): i64 { return load64(pps + 80); }
fn h264_pps_chroma_qp_index_offset(pps): i64 { return load64(pps + 88); }
fn h264_pps_deblocking_flag(pps): i64 { return load64(pps + 96); }
fn h264_pps_constrained_intra_pred(pps): i64 { return load64(pps + 104); }
fn h264_pps_redundant_pic_cnt_flag(pps): i64 { return load64(pps + 112); }

# --- h265_nal.cyr ---

# @public — drishti H.265/HEVC NAL layer: Annex-B byte-stream scan,
# two-byte NAL unit header parse, emulation-prevention (EPB) strip.
# DECODE-ONLY charter (replaces libde265) — no writers in this family.
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_* codes) only. Every symbol carries the h265_
# prefix (Cyrius has no module-private scoping).
#
# Derived from ITU-T Rec. H.265 (section numbers cited inline);
# cross-checked against libde265 (nal.cc / nal-parser.cc) and ffmpeg
# (libavcodec/hevc_parse.c, h2645_parse.c).
#
# Spec map:
#   7.3.1.2 nal_unit_header()      — two-byte header layout
#   7.4.2.2 header semantics       — forbidden_zero_bit == 0,
#                                    nuh_temporal_id_plus1 != 0
#   Table 7-1                      — nal_unit_type codes
#   7.3.1.1 / 7.4.2                — emulation_prevention_three_byte
#   Annex B (B.2.2)                — byte-stream NAL unit decoding

# ================================================================
# H.265 family error band: 50-69 (see src/drishti.cyr). Generic
# faults (truncation, bounds, OOM, forbidden bit, bad VLC) reuse the
# core DR_ERR_* codes; only codec-specific failures are minted here.
# ================================================================
enum H265Err {
    # nuh_temporal_id_plus1 == 0 — spec 7.4.2.2: "nuh_temporal_id_plus1
    # shall not be equal to 0" (TemporalId = nuh_temporal_id_plus1 - 1
    # would underflow).
    H265_ERR_TEMPORAL_ID0 = 50;
    # A syntax element decoded outside its spec-mandated range
    # (7.4.3.x "shall be in the range of ..." constraints).
    H265_ERR_RANGE        = 51;
}

# ================================================================
# nal_unit_type — spec Table 7-1. Types 0..31 are VCL, 32..63 non-VCL.
# ================================================================
enum H265NalType {
    H265_NAL_TRAIL_N        = 0;    # non-TSA, non-STSA trailing, non-ref
    H265_NAL_TRAIL_R        = 1;    # non-TSA, non-STSA trailing, ref
    H265_NAL_TSA_N          = 2;    # temporal sub-layer access, non-ref
    H265_NAL_TSA_R          = 3;    # temporal sub-layer access, ref
    H265_NAL_STSA_N         = 4;    # step-wise TSA, non-ref
    H265_NAL_STSA_R         = 5;    # step-wise TSA, ref
    H265_NAL_RADL_N         = 6;    # random access decodable leading, non-ref
    H265_NAL_RADL_R         = 7;    # random access decodable leading, ref
    H265_NAL_RASL_N         = 8;    # random access skipped leading, non-ref
    H265_NAL_RASL_R         = 9;    # random access skipped leading, ref
    H265_NAL_BLA_W_LP       = 16;   # broken link access, with leading pics
    H265_NAL_BLA_W_RADL     = 17;   # broken link access, with RADL
    H265_NAL_BLA_N_LP       = 18;   # broken link access, no leading pics
    H265_NAL_IDR_W_RADL     = 19;   # IDR, may have RADL pictures
    H265_NAL_IDR_N_LP       = 20;   # IDR, no leading pictures
    H265_NAL_CRA_NUT        = 21;   # clean random access
    H265_NAL_RSV_IRAP_VCL22 = 22;   # reserved IRAP
    H265_NAL_RSV_IRAP_VCL23 = 23;   # reserved IRAP
    H265_NAL_VPS_NUT        = 32;   # video parameter set
    H265_NAL_SPS_NUT        = 33;   # sequence parameter set
    H265_NAL_PPS_NUT        = 34;   # picture parameter set
    H265_NAL_AUD_NUT        = 35;   # access unit delimiter
    H265_NAL_EOS_NUT        = 36;   # end of sequence
    H265_NAL_EOB_NUT        = 37;   # end of bitstream
    H265_NAL_FD_NUT         = 38;   # filler data
    H265_NAL_PREFIX_SEI_NUT = 39;   # SEI, prefix
    H265_NAL_SUFFIX_SEI_NUT = 40;   # SEI, suffix
}

# h265_ab_next result code: no more NAL units (clean end of stream).
# Distinct from every DR_ERR_* (> 0) and from DR_OK (0). Module-global
# var, not an enum member — cyrius enums reject negative literals
# (same pattern as DR_IVF_END in src/ivf.cyr).
var H265_AB_END = -1;

# ================================================================
# Family error names — the two minted band codes, falling through to
# dr_err_name for everything else (core codes + band fallback).
# ================================================================
fn h265_err_name(code): i64 {
    if (code == H265_ERR_TEMPORAL_ID0) { return "H.265: nuh_temporal_id_plus1 is zero"; }
    if (code == H265_ERR_RANGE)        { return "H.265: syntax element out of range"; }
    return dr_err_name(code);
}

# ================================================================
# NAL unit type predicates — spec Table 7-1 classification.
# ================================================================

# VCL NAL unit: nal_unit_type in [0, 31] (Table 7-1).
fn h265_nal_is_vcl(t): i64 {
    if ((t >= 0) && (t <= 31)) { return 1; }
    return 0;
}

# IRAP picture: nal_unit_type in [BLA_W_LP, RSV_IRAP_VCL23] = [16, 23]
# (spec 3.73 / Table 7-1 note).
fn h265_nal_is_irap(t): i64 {
    if ((t >= H265_NAL_BLA_W_LP) && (t <= H265_NAL_RSV_IRAP_VCL23)) { return 1; }
    return 0;
}

# IDR picture: IDR_W_RADL (19) or IDR_N_LP (20).
fn h265_nal_is_idr(t): i64 {
    if ((t == H265_NAL_IDR_W_RADL) || (t == H265_NAL_IDR_N_LP)) { return 1; }
    return 0;
}

# ================================================================
# nal_unit_header() — spec 7.3.1.2, TWO bytes:
#
#   forbidden_zero_bit        f(1)   — shall be 0 (7.4.2.2)
#   nal_unit_type             u(6)
#   nuh_layer_id              u(6)
#   nuh_temporal_id_plus1     u(3)   — shall NOT be 0 (7.4.2.2)
#
# Bit layout across the two bytes (MSB-first):
#   byte0: F TTTTTT L      (F = forbidden, T = type, L = layer_id bit 5)
#   byte1: LLLLL III       (L = layer_id bits 4..0, I = tid_plus1)
# ================================================================

# Parse the two-byte NAL unit header at buf[0..len). On DR_OK stores
# nal_unit_type at *out_type, nuh_layer_id at *out_layer, and the
# DERIVED TemporalId (nuh_temporal_id_plus1 - 1, spec 7.4.2.2) at
# *out_tid. Errors (outputs untouched):
#   DR_ERR_TRUNCATED      — len < 2
#   DR_ERR_FORBIDDEN_BIT  — forbidden_zero_bit set
#   H265_ERR_TEMPORAL_ID0 — nuh_temporal_id_plus1 == 0
fn h265_nal_hdr_parse(buf, len, out_type, out_layer, out_tid): i64 {
    if (len < 2) { return DR_ERR_TRUNCATED; }
    var b0 = load8(buf);
    var b1 = load8(buf + 1);
    # forbidden_zero_bit — byte0 bit 7 (7.4.2.2: shall be 0).
    if (b0 & 0x80) { return DR_ERR_FORBIDDEN_BIT; }
    # nuh_temporal_id_plus1 — byte1 bits 2..0 (7.4.2.2: shall not be 0).
    var tid_plus1 = b1 & 7;
    if (tid_plus1 == 0) { return H265_ERR_TEMPORAL_ID0; }
    # nal_unit_type — byte0 bits 6..1.
    store64(out_type, (b0 >> 1) & 0x3F);
    # nuh_layer_id — byte0 bit 0 (MSB) then byte1 bits 7..3.
    store64(out_layer, ((b0 & 1) << 5) + (b1 >> 3));
    store64(out_tid, tid_plus1 - 1);
    return DR_OK;
}

# ================================================================
# Annex-B byte-stream scanner — spec B.2.2 decoding process.
#
# A byte-stream NAL unit is: leading_zero_8bits* (0x00 only),
# [zero_byte] start_code_prefix_one_3bytes (00 00 01), nal_unit(),
# trailing_zero_8bits* (0x00 only). Per B.2.2 step 3 the NAL unit
# extends up to (not including) the next byte-aligned three-byte
# sequence equal to 00 00 00 or 00 00 01, or the end of the stream —
# this single rule handles 3-byte codes, 4-byte codes (zero_byte +
# prefix) and trailing zeros uniformly, and is why the scanner never
# needs to trim trailing bytes.
#
# Strictness: only 0x00 bytes may precede a start code (B.2.2 step 1 +
# leading_zero_8bits semantics "equal to 0x00"). A non-zero byte where
# a start code prefix is required is DR_ERR_BAD_HEADER (sticky).
# libde265/ffmpeg resync instead; drishti rejects — adversarial input
# gets a clean error, not a guess.
#
# H265AbScan layout (32 bytes, heap):
#   +0:  buf — byte-stream buffer (BORROWED, caller keeps it alive)
#   +8:  len — buffer length in bytes
#   +16: pos — byte cursor (start of the not-yet-consumed region)
#   +24: err — sticky error code (DR_OK until first fault)
# ================================================================

# Create an Annex-B scanner over buf[0..len). Returns the handle, or
# 0 on negative len / allocation failure.
fn h265_ab_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var sc = alloc(32);
    if (sc == 0) { return 0; }
    store64(sc, buf);
    store64(sc + 8, len);
    store64(sc + 16, 0);
    store64(sc + 24, DR_OK);
    return sc;
}

# Sticky error code (DR_OK if the scanner has never faulted).
fn h265_ab_err(sc): i64 {
    return load64(sc + 24);
}

# Byte cursor position (start of the unconsumed region).
fn h265_ab_pos(sc): i64 {
    return load64(sc + 16);
}

# Advance to the next NAL unit. On DR_OK stores a ZERO-COPY pointer to
# the NAL's first byte (its header byte, PAST the start code) at
# *out_nal and the NAL length in bytes at *out_size. Returns:
#   DR_OK             — NAL found (size may be 0 for a degenerate
#                       start-code-then-boundary stream; the header
#                       parse rejects it as DR_ERR_TRUNCATED)
#   H265_AB_END (-1)  — clean end of stream (only zeros / nothing
#                       left); repeatable, not sticky
#   DR_ERR_BAD_HEADER — sticky: non-zero byte where a start code
#                       prefix is required, or a lone 01 with fewer
#                       than two zero bytes before it (B.2.2)
fn h265_ab_next(sc, out_nal, out_size): i64 {
    var e = load64(sc + 24);
    if (e != DR_OK) { return e; }
    var buf = load64(sc);
    var len = load64(sc + 8);
    var pos = load64(sc + 16);
    # --- B.2.2 step 1: consume leading/trailing zero bytes up to the
    # start code. Find the first non-zero byte at or after pos.
    var i = pos;
    while ((i < len) && (load8(buf + i) == 0)) {
        i = i + 1;
    }
    if (i >= len) {
        # Nothing but zeros (or nothing at all) left: clean end.
        return H265_AB_END;
    }
    # The non-zero byte must be the 0x01 of a start code prefix with at
    # least two zero bytes in front of it (00 00 01; a third zero is
    # the optional zero_byte / trailing zeros of the previous unit).
    if (load8(buf + i) != 1) {
        store64(sc + 24, DR_ERR_BAD_HEADER);
        return DR_ERR_BAD_HEADER;
    }
    if ((i - pos) < 2) {
        store64(sc + 24, DR_ERR_BAD_HEADER);
        return DR_ERR_BAD_HEADER;
    }
    var start = i + 1;   # first byte of nal_unit()
    # --- B.2.2 step 3: NumBytesInNalUnit = bytes up to the next
    # byte-aligned 00 00 00 or 00 00 01, or end of stream.
    var j = start;
    var end = len;
    while ((j + 2) < len) {
        if ((load8(buf + j) == 0) && (load8(buf + j + 1) == 0)) {
            var b2 = load8(buf + j + 2);
            if ((b2 == 0) || (b2 == 1)) {
                end = j;
                break;
            }
        }
        j = j + 1;
    }
    store64(out_nal, buf + start);
    store64(out_size, end - start);
    store64(sc + 16, end);
    return DR_OK;
}

# ================================================================
# EPB strip — RBSP extraction, spec 7.3.1.1 nal_unit():
#
#   for (i = 0; i < NumBytes; i++)
#     if (i + 2 < NumBytes && next_bits(24) == 0x000003) {
#       rbsp_byte; rbsp_byte;            // the two 0x00s
#       i += 2;
#       emulation_prevention_three_byte  // the 0x03, discarded
#     } else
#       rbsp_byte
#
# 7.4.2 constrains the encoder (00 00 03 must be followed by
# 00/01/02/03; bare 00 00 00 / 00 00 01 / 00 00 02 never occur inside
# a NAL). The DECODER algorithm above needs no such check — drishti
# strips exactly per 7.3.1.1 and stays lenient on encoder-side
# violations (matching libde265 and ffmpeg h2645_parse behavior).
# ================================================================

# Extract the RBSP from ebsp[0..size) — the NAL payload AFTER the
# two-byte header (pass nal + 2, size - 2). Allocates a fresh buffer
# (never larger than size + 1 bytes), stores its pointer at *out_rbsp
# and the RBSP byte count at *out_size. Returns:
#   DR_OK          — extracted (size 0 in -> empty RBSP out, valid ptr)
#   DR_ERR_BOUNDS  — negative size
#   DR_ERR_OOM     — allocation failure
fn h265_rbsp_extract(ebsp, size, out_rbsp, out_size): i64 {
    if (size < 0) { return DR_ERR_BOUNDS; }
    # RBSP is never longer than the EBSP; +1 keeps alloc(0) out of play.
    var rbsp = alloc(size + 1);
    if (rbsp == 0) { return DR_ERR_OOM; }
    var i = 0;
    var n = 0;
    while (i < size) {
        # 7.3.1.1 window: bytes i, i+1, i+2 all inside the payload.
        if ((i + 2) < size) {
            if ((load8(ebsp + i) == 0) && (load8(ebsp + i + 1) == 0)
            && (load8(ebsp + i + 2) == 3)) {
                # Copy the two zeros, discard the 0x03 EPB.
                store8(rbsp + n, 0);
                store8(rbsp + n + 1, 0);
                n = n + 2;
                i = i + 3;
                continue;
            }
        }
        store8(rbsp + n, load8(ebsp + i));
        n = n + 1;
        i = i + 1;
    }
    store64(out_rbsp, rbsp);
    store64(out_size, n);
    return DR_OK;
}

# --- h265_ps.cyr ---

# @public — drishti H.265/HEVC parameter sets: profile_tier_level,
# minimal VPS, SPS through the sizing block (with computed display
# dimensions), minimal PPS. DECODE-ONLY charter (replaces libde265).
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*), src/bits.cyr (DrBr + dr_ue/dr_se), and
# src/h265_nal.cyr (H265_ERR_* band codes). Every symbol carries the
# h265_ prefix (Cyrius has no module-private scoping).
#
# All parse entry points take an RBSP buffer — the NAL payload AFTER
# the two-byte header, with emulation-prevention bytes already
# stripped (h265_nal_hdr_parse + h265_rbsp_extract feed this module).
#
# Derived from ITU-T Rec. H.265 (section numbers cited inline);
# cross-checked against libde265 (vps.cc / sps.cc / pps.cc) and ffmpeg
# (libavcodec/hevc_ps.c).
#
# Spec map:
#   7.3.3    profile_tier_level()      7.4.4    its semantics
#   7.3.2.1  video_parameter_set_rbsp  7.4.3.1  its semantics
#   7.3.2.2  seq_parameter_set_rbsp    7.4.3.2.1 its semantics
#   7.3.2.3  pic_parameter_set_rbsp    7.4.3.3.1 its semantics
#   Table 6-1  SubWidthC / SubHeightC per chroma_format_idc
#   A.4.1/A.4.2  level limits (dimension bomb guard)
#
# Reserved-vs-forbidden policy: RESERVED fields (the PTL 43+1 tail —
# constraint flags for Annex-A extension profiles — vps_reserved_
# 0xffff_16bits, reserved_zero_2bits) are CAPTURED, never rejected:
# the spec directs decoders to ignore their values for forward
# compatibility. Range constraints ("shall be in the range of ...")
# ARE enforced: violations return H265_ERR_RANGE.

enum H265Limits {
    # Dimension bomb guard. A.4.2: pic_width/height_in_luma_samples
    # <= Sqrt(MaxLumaPs * 8); Table A.8 level 6.2 MaxLumaPs =
    # 35,651,584 -> Sqrt(35651584 * 8) = 16888. Nothing conforming to
    # any Annex-A level exceeds it; larger values are rejected with
    # DR_ERR_OVERSIZE before any dimension math happens.
    H265_MAX_DIM = 16888;
}

# ================================================================
# profile_tier_level — spec 7.3.3 (general block, profilePresentFlag):
#
#   general_profile_space                    u(2)
#   general_tier_flag                        u(1)
#   general_profile_idc                      u(5)
#   general_profile_compatibility_flag[32]   u(1) each
#   general_progressive_source_flag          u(1)
#   general_interlaced_source_flag           u(1)
#   general_non_packed_constraint_flag       u(1)
#   general_frame_only_constraint_flag       u(1)
#   43 bits — extension-profile constraint flags (max_12bit ... ) or
#             general_reserved_zero_43bits, profile-dependent (7.4.4);
#             captured raw, never validated
#   1 bit  — general_inbld_flag or general_reserved_zero_bit (7.4.4)
#   general_level_idc                        u(8)
#   sub_layer_profile_present_flag[i]        u(1)   i in [0, mslm1)
#   sub_layer_level_present_flag[i]          u(1)   i in [0, mslm1)
#   if (mslm1 > 0) reserved_zero_2bits[i]    u(2)   i in [mslm1, 8)
#   per sub-layer: profile block (88 bits) if profile-present,
#                  sub_layer_level_idc u(8) if level-present
#
# Sub-layer PTL values are parsed for ALIGNMENT (the bit cursor must
# land exactly at the end of the structure) and discarded at 0.1.x.
#
# H265Ptl layout (96 bytes, heap) — all fields widened to i64:
#   +0:  profile_space           +8:  tier_flag
#   +16: profile_idc             +24: compat_flags (32-bit raw;
#                                     flag[j] = bit (31 - j))
#   +32: progressive_source_flag +40: interlaced_source_flag
#   +48: non_packed_flag         +56: frame_only_flag
#   +64: constraint_43 (raw 43-bit tail, MSB-first)
#   +72: inbld_flag              +80: level_idc
#   +88: max_sub_layers_minus1 (as parsed against)
# ================================================================

# Parse profile_tier_level from a DrBr positioned at its first bit.
# profile_present is profilePresentFlag; max_sub_layers_minus1 must be
# in [0, 6] (7.4.3.1 / 7.4.3.2.1 bound both callers). Returns the
# H265Ptl handle, or 0 with the fault latched in the reader's sticky
# error: DR_ERR_TRUNCATED (bits run out), H265_ERR_RANGE (bad
# max_sub_layers_minus1), DR_ERR_OOM.
fn h265_ptl_parse(br, profile_present, max_sub_layers_minus1): i64 {
    if (dr_br_err(br) != DR_OK) { return 0; }
    if ((max_sub_layers_minus1 < 0) || (max_sub_layers_minus1 > 6)) {
        store64(br + 24, H265_ERR_RANGE);
        return 0;
    }
    var ptl = alloc(96);
    if (ptl == 0) {
        store64(br + 24, DR_ERR_OOM);
        return 0;
    }
    store64(ptl, 0);
    store64(ptl + 8, 0);
    store64(ptl + 16, 0);
    store64(ptl + 24, 0);
    store64(ptl + 32, 0);
    store64(ptl + 40, 0);
    store64(ptl + 48, 0);
    store64(ptl + 56, 0);
    store64(ptl + 64, 0);
    store64(ptl + 72, 0);
    store64(ptl + 80, 0);
    store64(ptl + 88, max_sub_layers_minus1);
    if (profile_present) {
        store64(ptl, dr_br_read_bits(br, 2));        # general_profile_space
        store64(ptl + 8, dr_br_read_bits(br, 1));    # general_tier_flag
        store64(ptl + 16, dr_br_read_bits(br, 5));   # general_profile_idc
        # 32 compatibility flags as one MSB-first word: flag[0] lands
        # in bit 31, flag[j] in bit (31 - j).
        store64(ptl + 24, dr_br_read_bits(br, 32));
        store64(ptl + 32, dr_br_read_bits(br, 1));   # progressive_source
        store64(ptl + 40, dr_br_read_bits(br, 1));   # interlaced_source
        store64(ptl + 48, dr_br_read_bits(br, 1));   # non_packed_constraint
        store64(ptl + 56, dr_br_read_bits(br, 1));   # frame_only_constraint
        # 43-bit tail — dr_br_read_bits caps at 32, so 32 + 11.
        var hi = dr_br_read_bits(br, 32);
        var lo = dr_br_read_bits(br, 11);
        store64(ptl + 64, (hi << 11) + lo);
        store64(ptl + 72, dr_br_read_bits(br, 1));   # inbld / reserved bit
    }
    store64(ptl + 80, dr_br_read_bits(br, 8));       # general_level_idc
    # Sub-layer presence flags + alignment + (discarded) payloads.
    # sub_layer_*_present_flag[i] pairs pack into one word: profile-
    # present in bit (2i + 1), level-present in bit (2i) of the read.
    var present = 0;
    if (max_sub_layers_minus1 > 0) {
        present = dr_br_read_bits(br, max_sub_layers_minus1 * 2);
        # reserved_zero_2bits[i] for i in [mslm1, 8) — captured to
        # keep alignment, value ignored (reserved; 7.3.3).
        dr_br_read_bits(br, (8 - max_sub_layers_minus1) * 2);
    }
    var i = 0;
    while (i < max_sub_layers_minus1) {
        var shift = (max_sub_layers_minus1 - 1 - i) * 2;
        if ((present >> (shift + 1)) & 1) {
            # sub_layer profile block: 2+1+5+32+4+43+1 = 88 bits,
            # same shape as the general block (7.3.3). Discarded.
            dr_br_read_bits(br, 32);
            dr_br_read_bits(br, 32);
            dr_br_read_bits(br, 24);
        }
        if ((present >> shift) & 1) {
            dr_br_read_bits(br, 8);   # sub_layer_level_idc[i]
        }
        i = i + 1;
    }
    if (dr_br_err(br) != DR_OK) { return 0; }
    return ptl;
}

fn h265_ptl_profile_space(ptl): i64 { return load64(ptl); }
fn h265_ptl_tier_flag(ptl): i64 { return load64(ptl + 8); }
fn h265_ptl_profile_idc(ptl): i64 { return load64(ptl + 16); }
fn h265_ptl_compat_flags(ptl): i64 { return load64(ptl + 24); }

# general_profile_compatibility_flag[j] (7.3.3), j in [0, 31];
# out-of-range j returns 0.
fn h265_ptl_compat_flag(ptl, j): i64 {
    if ((j < 0) || (j > 31)) { return 0; }
    return (load64(ptl + 24) >> (31 - j)) & 1;
}

fn h265_ptl_progressive_source(ptl): i64 { return load64(ptl + 32); }
fn h265_ptl_interlaced_source(ptl): i64 { return load64(ptl + 40); }
fn h265_ptl_non_packed(ptl): i64 { return load64(ptl + 48); }
fn h265_ptl_frame_only(ptl): i64 { return load64(ptl + 56); }
fn h265_ptl_constraint_bits(ptl): i64 { return load64(ptl + 64); }
fn h265_ptl_inbld(ptl): i64 { return load64(ptl + 72); }
fn h265_ptl_level_idc(ptl): i64 { return load64(ptl + 80); }
fn h265_ptl_max_sub_layers_minus1(ptl): i64 { return load64(ptl + 88); }

# ================================================================
# VPS (minimal) — spec 7.3.2.1 video_parameter_set_rbsp() prefix:
#
#   vps_video_parameter_set_id     u(4)
#   vps_base_layer_internal_flag   u(1)
#   vps_base_layer_available_flag  u(1)
#   vps_max_layers_minus1          u(6)
#   vps_max_sub_layers_minus1      u(3)   — [0, 6] (7.4.3.1)
#   vps_temporal_id_nesting_flag   u(1)
#   vps_reserved_0xffff_16bits     u(16)  — captured, never rejected
#                                    (7.4.3.1: decoders ignore value)
#   profile_tier_level(1, vps_max_sub_layers_minus1)
#   ... (sub-layer ordering info et seq. — out of the 0.1.x cut)
#
# H265Vps layout (64 bytes, heap):
#   +0:  vps_id                   +8:  base_layer_internal_flag
#   +16: base_layer_available_flag +24: max_layers_minus1
#   +32: max_sub_layers_minus1    +40: temporal_id_nesting_flag
#   +48: reserved_0xffff_16bits   +56: H265Ptl handle
# ================================================================

# Parse the minimal VPS prefix from rbsp[0..len) (EPB-stripped, header
# excluded). Returns the H265Vps handle, or 0 with the code at
# *out_err: DR_ERR_TRUNCATED, H265_ERR_RANGE (vps_max_sub_layers_
# minus1 > 6), DR_ERR_OOM, DR_ERR_BOUNDS (negative len).
fn h265_vps_parse(rbsp, len, out_err): i64 {
    store64(out_err, DR_OK);
    var br = dr_br_init(rbsp, len);
    if (br == 0) {
        if (len < 0) { store64(out_err, DR_ERR_BOUNDS); } else { store64(out_err, DR_ERR_OOM); }
        return 0;
    }
    var vps_id = dr_br_read_bits(br, 4);       # vps_video_parameter_set_id
    var bl_int = dr_br_read_bits(br, 1);       # vps_base_layer_internal_flag
    var bl_avail = dr_br_read_bits(br, 1);     # vps_base_layer_available_flag
    var max_layers_m1 = dr_br_read_bits(br, 6);   # vps_max_layers_minus1
    var max_sub_m1 = dr_br_read_bits(br, 3);   # vps_max_sub_layers_minus1
    var nesting = dr_br_read_bits(br, 1);      # vps_temporal_id_nesting_flag
    var reserved = dr_br_read_bits(br, 16);    # vps_reserved_0xffff_16bits
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    # 7.4.3.1: vps_max_sub_layers_minus1 shall be in [0, 6].
    if (max_sub_m1 > 6) {
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var ptl = h265_ptl_parse(br, 1, max_sub_m1);
    if (ptl == 0) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    var vps = alloc(64);
    if (vps == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(vps, vps_id);
    store64(vps + 8, bl_int);
    store64(vps + 16, bl_avail);
    store64(vps + 24, max_layers_m1);
    store64(vps + 32, max_sub_m1);
    store64(vps + 40, nesting);
    store64(vps + 48, reserved);
    store64(vps + 56, ptl);
    return vps;
}

fn h265_vps_id(v): i64 { return load64(v); }
fn h265_vps_base_layer_internal(v): i64 { return load64(v + 8); }
fn h265_vps_base_layer_available(v): i64 { return load64(v + 16); }
fn h265_vps_max_layers_minus1(v): i64 { return load64(v + 24); }
fn h265_vps_max_sub_layers_minus1(v): i64 { return load64(v + 32); }
fn h265_vps_temporal_id_nesting(v): i64 { return load64(v + 40); }
fn h265_vps_reserved_0xffff(v): i64 { return load64(v + 48); }
fn h265_vps_ptl(v): i64 { return load64(v + 56); }

# ================================================================
# SPS through the sizing block — spec 7.3.2.2 seq_parameter_set_rbsp()
# prefix:
#
#   sps_video_parameter_set_id           u(4)
#   sps_max_sub_layers_minus1            u(3)   — [0, 6]
#   sps_temporal_id_nesting_flag         u(1)
#   profile_tier_level(1, sps_max_sub_layers_minus1)
#   sps_seq_parameter_set_id             ue(v)  — [0, 15]
#   chroma_format_idc                    ue(v)  — [0, 3]
#   if (chroma_format_idc == 3)
#     separate_colour_plane_flag         u(1)
#   pic_width_in_luma_samples            ue(v)  — != 0
#   pic_height_in_luma_samples           ue(v)  — != 0
#   conformance_window_flag              u(1)
#   if (conformance_window_flag)
#     conf_win_{left,right,top,bottom}_offset  ue(v) x4
#   bit_depth_luma_minus8                ue(v)  — [0, 8]
#   bit_depth_chroma_minus8              ue(v)  — [0, 8]
#   log2_max_pic_order_cnt_lsb_minus4    ue(v)  — [0, 12]
#   --- 0.1.x stops cleanly here (sizing block complete) ---
#
# Computed output dimensions (7.4.3.2.1, Table 6-1): the conformance
# cropping window is expressed in chroma units —
#   width  = pic_width  - SubWidthC  * (conf_win_left + conf_win_right)
#   height = pic_height - SubHeightC * (conf_win_top  + conf_win_bottom)
# SubWidthC/SubHeightC: idc 0 (mono) -> 1,1; 1 (4:2:0) -> 2,2;
# 2 (4:2:2) -> 2,1; 3 (4:4:4) -> 1,1 (also 1,1 when separate_colour_
# plane_flag == 1: ChromaArrayType == 0, Table 6-1).
#
# H265Sps layout (144 bytes, heap):
#   +0:   vps_id                    +8:   max_sub_layers_minus1
#   +16:  temporal_id_nesting_flag  +24:  H265Ptl handle
#   +32:  sps_id                    +40:  chroma_format_idc
#   +48:  separate_colour_plane_flag
#   +56:  pic_width_in_luma_samples +64:  pic_height_in_luma_samples
#   +72:  conf_win_left_offset      +80:  conf_win_right_offset
#   +88:  conf_win_top_offset       +96:  conf_win_bottom_offset
#   +104: bit_depth_luma  (BitDepthY  = minus8 + 8, 7.4.3.2.1)
#   +112: bit_depth_chroma (BitDepthC = minus8 + 8)
#   +120: log2_max_pic_order_cnt_lsb (minus4 + 4, range [4, 16])
#   +128: width  (computed cropped display width)
#   +136: height (computed cropped display height)
# ================================================================

# Parse the SPS sizing prefix from rbsp[0..len) (EPB-stripped, header
# excluded). Returns the H265Sps handle, or 0 with the code at
# *out_err:
#   DR_ERR_TRUNCATED — bits run out mid-field
#   DR_ERR_BAD_VLC   — malformed exp-Golomb (> 31 leading zeros)
#   H265_ERR_RANGE   — a "shall be in the range" constraint violated
#                      (7.4.3.2.1), incl. zero dimensions and a
#                      cropping window that consumes the whole picture
#   DR_ERR_OVERSIZE  — width/height > H265_MAX_DIM (A.4.2 bomb guard)
#   DR_ERR_OOM / DR_ERR_BOUNDS (negative len)
fn h265_sps_parse(rbsp, len, out_err): i64 {
    store64(out_err, DR_OK);
    var br = dr_br_init(rbsp, len);
    if (br == 0) {
        if (len < 0) { store64(out_err, DR_ERR_BOUNDS); } else { store64(out_err, DR_ERR_OOM); }
        return 0;
    }
    var vps_id = dr_br_read_bits(br, 4);      # sps_video_parameter_set_id
    var max_sub_m1 = dr_br_read_bits(br, 3);  # sps_max_sub_layers_minus1
    var nesting = dr_br_read_bits(br, 1);     # sps_temporal_id_nesting_flag
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    # 7.4.3.2.1: sps_max_sub_layers_minus1 shall be in [0, 6].
    if (max_sub_m1 > 6) {
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var ptl = h265_ptl_parse(br, 1, max_sub_m1);
    if (ptl == 0) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    var sps_id = 0;
    var rc = dr_ue_read(br, &sps_id);         # sps_seq_parameter_set_id
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    if (sps_id > 15) {                        # 7.4.3.2.1: [0, 15]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var chroma = 0;
    rc = dr_ue_read(br, &chroma);             # chroma_format_idc
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    if (chroma > 3) {                         # 7.4.3.2.1: [0, 3]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var sep_plane = 0;
    if (chroma == 3) {
        sep_plane = dr_br_read_bits(br, 1);   # separate_colour_plane_flag
    }
    var pic_w = 0;
    rc = dr_ue_read(br, &pic_w);              # pic_width_in_luma_samples
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    var pic_h = 0;
    rc = dr_ue_read(br, &pic_h);              # pic_height_in_luma_samples
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    # 7.4.3.2.1: shall not be equal to 0.
    if ((pic_w == 0) || (pic_h == 0)) {
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    # A.4.2 bomb guard: no Annex-A level admits a dimension beyond
    # Sqrt(MaxLumaPs * 8) = 16888 (level 6.2, Table A.8).
    if ((pic_w > H265_MAX_DIM) || (pic_h > H265_MAX_DIM)) {
        store64(out_err, DR_ERR_OVERSIZE);
        return 0;
    }
    var win_l = 0;
    var win_r = 0;
    var win_t = 0;
    var win_b = 0;
    var conf_win = dr_br_read_bits(br, 1);    # conformance_window_flag
    if (conf_win) {
        rc = dr_ue_read(br, &win_l);          # conf_win_left_offset
        if (rc != DR_OK) { store64(out_err, rc); return 0; }
        rc = dr_ue_read(br, &win_r);          # conf_win_right_offset
        if (rc != DR_OK) { store64(out_err, rc); return 0; }
        rc = dr_ue_read(br, &win_t);          # conf_win_top_offset
        if (rc != DR_OK) { store64(out_err, rc); return 0; }
        rc = dr_ue_read(br, &win_b);          # conf_win_bottom_offset
        if (rc != DR_OK) { store64(out_err, rc); return 0; }
    }
    var bd_luma_m8 = 0;
    rc = dr_ue_read(br, &bd_luma_m8);         # bit_depth_luma_minus8
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    var bd_chroma_m8 = 0;
    rc = dr_ue_read(br, &bd_chroma_m8);       # bit_depth_chroma_minus8
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    var log2_poc_m4 = 0;
    rc = dr_ue_read(br, &log2_poc_m4);        # log2_max_pic_order_cnt_lsb_minus4
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    if (dr_br_err(br) != DR_OK) {
        # Catches the unchecked separate_colour_plane_flag /
        # conformance_window_flag single-bit reads.
        store64(out_err, dr_br_err(br));
        return 0;
    }
    # 7.4.3.2.1 ranges.
    if ((bd_luma_m8 > 8) || (bd_chroma_m8 > 8)) {    # [0, 8]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    if (log2_poc_m4 > 12) {                          # [0, 12]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    # Table 6-1: SubWidthC / SubHeightC. separate_colour_plane == 1
    # means ChromaArrayType == 0 -> treated as monochrome (1, 1).
    var sub_w = 1;
    var sub_h = 1;
    if (sep_plane == 0) {
        if (chroma == 1) { sub_w = 2; sub_h = 2; }   # 4:2:0
        if (chroma == 2) { sub_w = 2; sub_h = 1; }   # 4:2:2
    }
    # 7.4.3.2.1: the cropping window shall not consume the picture —
    # SubWidthC*(left+right) < pic_width, SubHeightC*(top+bottom) <
    # pic_height.
    var crop_w = sub_w * (win_l + win_r);
    var crop_h = sub_h * (win_t + win_b);
    if ((crop_w >= pic_w) || (crop_h >= pic_h)) {
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var sps = alloc(144);
    if (sps == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(sps, vps_id);
    store64(sps + 8, max_sub_m1);
    store64(sps + 16, nesting);
    store64(sps + 24, ptl);
    store64(sps + 32, sps_id);
    store64(sps + 40, chroma);
    store64(sps + 48, sep_plane);
    store64(sps + 56, pic_w);
    store64(sps + 64, pic_h);
    store64(sps + 72, win_l);
    store64(sps + 80, win_r);
    store64(sps + 88, win_t);
    store64(sps + 96, win_b);
    store64(sps + 104, bd_luma_m8 + 8);      # BitDepthY (7.4.3.2.1)
    store64(sps + 112, bd_chroma_m8 + 8);    # BitDepthC
    store64(sps + 120, log2_poc_m4 + 4);     # MaxPicOrderCntLsb = 2^this
    store64(sps + 128, pic_w - crop_w);      # cropped display width
    store64(sps + 136, pic_h - crop_h);      # cropped display height
    return sps;
}

fn h265_sps_vps_id(s): i64 { return load64(s); }
fn h265_sps_max_sub_layers_minus1(s): i64 { return load64(s + 8); }
fn h265_sps_temporal_id_nesting(s): i64 { return load64(s + 16); }
fn h265_sps_ptl(s): i64 { return load64(s + 24); }
fn h265_sps_id(s): i64 { return load64(s + 32); }
fn h265_sps_chroma_format_idc(s): i64 { return load64(s + 40); }
fn h265_sps_separate_colour_plane(s): i64 { return load64(s + 48); }
fn h265_sps_pic_width(s): i64 { return load64(s + 56); }
fn h265_sps_pic_height(s): i64 { return load64(s + 64); }
fn h265_sps_conf_win_left(s): i64 { return load64(s + 72); }
fn h265_sps_conf_win_right(s): i64 { return load64(s + 80); }
fn h265_sps_conf_win_top(s): i64 { return load64(s + 88); }
fn h265_sps_conf_win_bottom(s): i64 { return load64(s + 96); }
fn h265_sps_bit_depth_luma(s): i64 { return load64(s + 104); }
fn h265_sps_bit_depth_chroma(s): i64 { return load64(s + 112); }
fn h265_sps_log2_max_poc_lsb(s): i64 { return load64(s + 120); }
fn h265_sps_width(s): i64 { return load64(s + 128); }
fn h265_sps_height(s): i64 { return load64(s + 136); }

# ================================================================
# PPS (minimal) — spec 7.3.2.3 pic_parameter_set_rbsp() prefix:
#
#   pps_pic_parameter_set_id               ue(v) — [0, 63]
#   pps_seq_parameter_set_id               ue(v) — [0, 15]
#   dependent_slice_segments_enabled_flag  u(1)
#   output_flag_present_flag               u(1)
#   num_extra_slice_header_bits            u(3)  — reserved > 2;
#                                            captured, not rejected
#   sign_data_hiding_enabled_flag          u(1)
#   cabac_init_present_flag                u(1)
#   num_ref_idx_l0_default_active_minus1   ue(v) — [0, 14]
#   num_ref_idx_l1_default_active_minus1   ue(v) — [0, 14]
#   init_qp_minus26                        se(v) — [-(26+QpBdOffsetY), 25];
#                                            QpBdOffsetY unknown at PPS
#                                            time, checked at loosest
#                                            bound [-74, 25] (bd 16)
#   constrained_intra_pred_flag            u(1)
#   transform_skip_enabled_flag            u(1)
#   cu_qp_delta_enabled_flag               u(1)
#   if (cu_qp_delta_enabled_flag)
#     diff_cu_qp_delta_depth               ue(v) — inferred 0 if absent
#   --- 0.1.x stops cleanly here ---
#
# H265Pps layout (112 bytes, heap):
#   +0:   pps_id                    +8:   sps_id
#   +16:  dependent_slice_segments_enabled
#   +24:  output_flag_present       +32:  num_extra_slice_header_bits
#   +40:  sign_data_hiding_enabled  +48:  cabac_init_present
#   +56:  num_ref_idx_l0_default_active_minus1
#   +64:  num_ref_idx_l1_default_active_minus1
#   +72:  init_qp_minus26 (SIGNED)  +80:  constrained_intra_pred
#   +88:  transform_skip_enabled    +96:  cu_qp_delta_enabled
#   +104: diff_cu_qp_delta_depth (0 when flag off, 7.4.3.3.1)
# ================================================================

# Parse the minimal PPS prefix from rbsp[0..len) (EPB-stripped, header
# excluded). Returns the H265Pps handle, or 0 with the code at
# *out_err: DR_ERR_TRUNCATED, DR_ERR_BAD_VLC, H265_ERR_RANGE,
# DR_ERR_OOM, DR_ERR_BOUNDS (negative len).
fn h265_pps_parse(rbsp, len, out_err): i64 {
    store64(out_err, DR_OK);
    var br = dr_br_init(rbsp, len);
    if (br == 0) {
        if (len < 0) { store64(out_err, DR_ERR_BOUNDS); } else { store64(out_err, DR_ERR_OOM); }
        return 0;
    }
    var pps_id = 0;
    var rc = dr_ue_read(br, &pps_id);         # pps_pic_parameter_set_id
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    if (pps_id > 63) {                        # 7.4.3.3.1: [0, 63]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var sps_id = 0;
    rc = dr_ue_read(br, &sps_id);             # pps_seq_parameter_set_id
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    if (sps_id > 15) {                        # 7.4.3.3.1: [0, 15]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var dep_slices = dr_br_read_bits(br, 1);  # dependent_slice_segments_enabled_flag
    var out_flag = dr_br_read_bits(br, 1);    # output_flag_present_flag
    var extra_bits = dr_br_read_bits(br, 3);  # num_extra_slice_header_bits
    var sdh = dr_br_read_bits(br, 1);         # sign_data_hiding_enabled_flag
    var cabac_init = dr_br_read_bits(br, 1);  # cabac_init_present_flag
    var l0 = 0;
    rc = dr_ue_read(br, &l0);                 # num_ref_idx_l0_default_active_minus1
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    var l1 = 0;
    rc = dr_ue_read(br, &l1);                 # num_ref_idx_l1_default_active_minus1
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    if ((l0 > 14) || (l1 > 14)) {             # 7.4.3.3.1: [0, 14]
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var init_qp = 0;
    rc = dr_se_read(br, &init_qp);            # init_qp_minus26
    if (rc != DR_OK) { store64(out_err, rc); return 0; }
    # 7.4.3.3.1: [-(26 + QpBdOffsetY), 25]; QpBdOffsetY = 6 *
    # bit_depth_luma_minus8 <= 48, so the loosest legal bound is -74.
    if ((init_qp < (0 - 74)) || (init_qp > 25)) {
        store64(out_err, H265_ERR_RANGE);
        return 0;
    }
    var cip = dr_br_read_bits(br, 1);         # constrained_intra_pred_flag
    var tskip = dr_br_read_bits(br, 1);       # transform_skip_enabled_flag
    var cu_qp = dr_br_read_bits(br, 1);       # cu_qp_delta_enabled_flag
    var diff_depth = 0;
    if (dr_br_err(br) != DR_OK) {
        # Catches truncation in the seven unchecked flag reads above.
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (cu_qp) {
        rc = dr_ue_read(br, &diff_depth);     # diff_cu_qp_delta_depth
        if (rc != DR_OK) { store64(out_err, rc); return 0; }
    }
    var pps = alloc(112);
    if (pps == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(pps, pps_id);
    store64(pps + 8, sps_id);
    store64(pps + 16, dep_slices);
    store64(pps + 24, out_flag);
    store64(pps + 32, extra_bits);
    store64(pps + 40, sdh);
    store64(pps + 48, cabac_init);
    store64(pps + 56, l0);
    store64(pps + 64, l1);
    store64(pps + 72, init_qp);
    store64(pps + 80, cip);
    store64(pps + 88, tskip);
    store64(pps + 96, cu_qp);
    store64(pps + 104, diff_depth);
    return pps;
}

fn h265_pps_id(p): i64 { return load64(p); }
fn h265_pps_sps_id(p): i64 { return load64(p + 8); }
fn h265_pps_dependent_slice_segments(p): i64 { return load64(p + 16); }
fn h265_pps_output_flag_present(p): i64 { return load64(p + 24); }
fn h265_pps_num_extra_slice_header_bits(p): i64 { return load64(p + 32); }
fn h265_pps_sign_data_hiding(p): i64 { return load64(p + 40); }
fn h265_pps_cabac_init_present(p): i64 { return load64(p + 48); }
fn h265_pps_num_ref_idx_l0_minus1(p): i64 { return load64(p + 56); }
fn h265_pps_num_ref_idx_l1_minus1(p): i64 { return load64(p + 64); }
fn h265_pps_init_qp_minus26(p): i64 { return load64(p + 72); }
fn h265_pps_constrained_intra_pred(p): i64 { return load64(p + 80); }
fn h265_pps_transform_skip(p): i64 { return load64(p + 88); }
fn h265_pps_cu_qp_delta_enabled(p): i64 { return load64(p + 96); }
fn h265_pps_diff_cu_qp_delta_depth(p): i64 { return load64(p + 104); }

# --- vpx_bool.cyr ---

# @public — drishti VP8/VP9: the boolean arithmetic coder (bounds-checked
# DECODER + ENCODER), the foundation every VP8/VP9 layer sits on.
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/vpx.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*
# codes) only — it does NOT use the core DrBr/DrBw bit I/O: the bool
# coder is an arithmetic coder with its own range/value state machine,
# not a plain bit packer.
#
# Derived from RFC 6386 "VP8 Data Format and Decoding Guide" — the RFC
# is code-as-spec; section numbers cited inline:
#   7.1  underlying theory (range subdivision by 8-bit probability)
#   7.3  bool_decoder: init_bool_decoder() / bool_decode() reference code
#   7.3  bool_encoder: init_bool_encoder() / write_bool() /
#        flush_bool_encoder() / add_one_to_output() reference code
#   7.3  read_literal(): n bools at probability 128, MSB-first
#   9.x  signed values are coded magnitude-then-sign (e.g. 9.6 delta_q:
#        L(4) magnitude followed by a sign bit, sign 1 = negative)
# VP9 uses the IDENTICAL coder ("VP9 Bitstream & Decoding Process
# Specification" 9.2 bool decoding) — one implementation serves both.
# Cross-checked against libvpx vp8/decoder/dboolhuff.h (vp8dx_decode_bool)
# and vp8/encoder/boolhuff.c (vp8_encode_bool): same split arithmetic,
# same carry-at-renormalization propagation.
#
# BOUNDS / ERROR POLICY (this implementation; the RFC reference reads
# unchecked past the buffer):
#   * Errors are STICKY (core DrBr/DrBw pattern): after the first fault
#     every later op is a no-op returning 0 / the sticky code.
#   * Decoder: a renormalization that needs a byte past buf+len shifts
#     in a zero AND latches DR_ERR_TRUNCATED. The bool being decoded by
#     the CURRENT call was already resolved before renormalization, so
#     the current call still returns it; every LATER call returns 0.
#     A properly flushed stream never overreads while decoding exactly
#     the symbols that were encoded: the decoder consumes at most
#     2 + floor(shifts/8) bytes while the encoder emitted at least that
#     many (flush pads 32 bits, RFC 7.3), so round-trips stay clean.
#   * Encoder: the output buffer is OWNED and auto-grows by doubling up
#     to VBOOL_ENC_MAX_BYTES (DR_ERR_OVERSIZE past it, DR_ERR_OOM on a
#     failed allocation).
#
# VboolDec decoder layout (56 bytes, heap):
#   +0:  buf       — input byte buffer (BORROWED, caller keeps it alive)
#   +8:  len       — buffer length in BYTES
#   +16: pos       — index of the next byte to shift in
#   +24: value     — decoder window, at most 16 significant bits (RFC 7.3
#                    primes it with two bytes: "raise to power of 16")
#   +32: range     — current range, 128 <= range <= 255 after renorm
#   +40: bit_count — renorm shifts since the last byte fill (0..7)
#   +48: err       — sticky error code (DR_OK until first fault)
#
# VboolEnc encoder layout (56 bytes, heap):
#   +0:  buf       — output buffer (OWNED, may move on growth — snapshot
#                    via vbool_enc_buf AFTER vbool_enc_flush)
#   +8:  cap       — current capacity in BYTES
#   +16: len       — bytes emitted so far
#   +24: range     — current range, 128 <= range <= 255 after renorm
#   +32: bottom    — pending low end of the interval (32-bit window;
#                    carries propagate into already-emitted bytes)
#   +40: bit_count — bits until the next byte is emitted (starts 24,
#                    RFC 7.3 init_bool_encoder)
#   +48: err       — sticky error code

# Hard cap on encoder output growth: 1 GiB (mirrors core DR_BW_MAX_BYTES).
enum VboolLimits {
    VBOOL_ENC_MAX_BYTES = 1073741824;   # 1 << 30
}

# ================================================================
# Decoder — RFC 6386 7.3 bool_decoder
# ================================================================

# Create a bool decoder over buf[0..len) (buffer BORROWED). Returns the
# VboolDec handle, or 0 on negative len / allocation failure.
# RFC 7.3 init_bool_decoder(): value is primed with TWO bytes. A buffer
# shorter than 2 bytes is already truncated (a flushed stream is always
# >= 4 bytes: flush writes 32 bits, RFC 7.3): the decoder is still
# constructed (missing bytes prime as zero) but starts with sticky
# DR_ERR_TRUNCATED so the caller sees a clean error, not garbage bools.
fn vbool_dec_init(buf, len): i64 {
    if (len < 0) { return 0; }
    var d = alloc(56);
    if (d == 0) { return 0; }
    var value = 0;
    var pos = 0;
    var err = DR_OK;
    # "for (v = 0; v < 2; v++) value = (value << 8) | *input++"  (7.3)
    var i = 0;
    while (i < 2) {
        value = value << 8;
        if (pos < len) {
            value = value + load8(buf + pos);
            pos = pos + 1;
        } else {
            err = DR_ERR_TRUNCATED;
        }
        i = i + 1;
    }
    store64(d, buf);
    store64(d + 8, len);
    store64(d + 16, pos);
    store64(d + 24, value);
    store64(d + 32, 255);   # "initial range is full"  (7.3)
    store64(d + 40, 0);     # "have not yet shifted out any bits"
    store64(d + 48, err);
    return d;
}

# Sticky error code (DR_OK if the decoder has never faulted).
fn vbool_dec_err(d): i64 {
    return load64(d + 48);
}

# Bytes consumed so far (includes the two init-priming bytes).
fn vbool_dec_pos(d): i64 {
    return load64(d + 16);
}

# Decode one bool with the given 8-bit probability-of-zero (0..255).
# RFC 6386 7.3 bool_decode(), verbatim arithmetic:
#   split = 1 + (((range - 1) * prob) >> 8)
#   value >= (split << 8)  ->  1: value -= split<<8; range -= split
#   else                   ->  0: range = split
#   then renormalize while range < 128: shift value/range left one bit,
#   refilling one input byte into value's low bits every 8 shifts.
# prob outside [0,255] latches sticky DR_ERR_BOUNDS and returns 0. A
# renorm refill past buf+len shifts in zero bits and latches sticky
# DR_ERR_TRUNCATED; the CURRENT call's bool was resolved before renorm
# and is still returned (module-header policy); later calls return 0.
fn vbool_dec_bool(d, prob): i64 {
    if (load64(d + 48) != DR_OK) { return 0; }
    if ((prob < 0) || (prob > 255)) {
        store64(d + 48, DR_ERR_BOUNDS);
        return 0;
    }
    var range = load64(d + 32);
    var value = load64(d + 24);
    var split = 1 + (((range - 1) * prob) >> 8);
    var big_split = split << 8;   # "SPLIT = split << 8" — 16-bit scale
    var ret = 0;
    if (value >= big_split) {
        ret = 1;                       # "encoded a one"
        value = value - big_split;
        range = range - split;
    } else {
        range = split;                 # "encoded a zero"
    }
    # Renormalization (7.3). value stays < 2^16: before each shift
    # range < 128 bounds value < range << 8 < 2^15.
    var buf = load64(d);
    var len = load64(d + 8);
    var pos = load64(d + 16);
    var bit_count = load64(d + 40);
    while (range < 128) {
        value = value << 1;
        range = range << 1;
        bit_count = bit_count + 1;
        if (bit_count == 8) {          # "shift in new byte"
            bit_count = 0;
            if (pos < len) {
                value = value + load8(buf + pos);
                pos = pos + 1;
            } else {
                # Past the end: zero-fill (value's low 8 bits are
                # already zero after the shifts) + sticky truncation.
                store64(d + 48, DR_ERR_TRUNCATED);
            }
        }
    }
    store64(d + 16, pos);
    store64(d + 24, value);
    store64(d + 32, range);
    store64(d + 40, bit_count);
    return ret;
}

# Decode an n-bit unsigned literal (0 <= n <= 32), MSB-first, each bit
# a bool at probability 128 — RFC 6386 7.3 read_literal():
#   "uint32 read_literal(d, i) { v = 0; while (i--) v = (v << 1) +
#    bool_decode(d, 128); return v; }"
# n outside [0,32] latches sticky DR_ERR_BOUNDS. n == 0 is a legal
# no-op returning 0. Faulted decoders return 0.
fn vbool_dec_literal(d, n): i64 {
    if (load64(d + 48) != DR_OK) { return 0; }
    if ((n < 0) || (n > 32)) {
        store64(d + 48, DR_ERR_BOUNDS);
        return 0;
    }
    var v = 0;
    var i = 0;
    while (i < n) {
        v = (v << 1) + vbool_dec_bool(d, 128);
        i = i + 1;
    }
    return v;
}

# Decode a sign-magnitude signed value: an n-bit magnitude literal
# followed by one sign bool (sign 1 = negative) — the RFC 6386 9.x
# coding of signed header fields (e.g. 9.6 delta_q: L(4) then sign).
# Errors as vbool_dec_literal; a faulted decoder returns 0.
fn vbool_dec_signed(d, n): i64 {
    var mag = vbool_dec_literal(d, n);
    var sign = vbool_dec_bool(d, 128);
    if (load64(d + 48) != DR_OK) { return 0; }
    if (sign) { return 0 - mag; }
    return mag;
}

# ================================================================
# Encoder — RFC 6386 7.3 bool_encoder
# ================================================================

# Create a bool encoder with an initial output-capacity hint in bytes
# (values < 16 round up to 16; the buffer auto-grows by doubling up to
# VBOOL_ENC_MAX_BYTES). Returns the VboolEnc handle, or 0 on allocation
# failure / hint above the cap.
# RFC 7.3 init_bool_encoder(): range = 255, bottom = 0, bit_count = 24.
fn vbool_enc_init(cap_hint): i64 {
    var cap = cap_hint;
    if (cap < 16) { cap = 16; }
    if (cap > VBOOL_ENC_MAX_BYTES) { return 0; }
    var buf = alloc(cap);
    if (buf == 0) { return 0; }
    var e = alloc(56);
    if (e == 0) { return 0; }
    store64(e, buf);
    store64(e + 8, cap);
    store64(e + 16, 0);
    store64(e + 24, 255);   # range
    store64(e + 32, 0);     # bottom
    store64(e + 40, 24);    # bit_count — 24 shifts before the 1st byte
    store64(e + 48, DR_OK);
    return e;
}

# Sticky error code (DR_OK if the encoder has never faulted).
fn vbool_enc_err(e): i64 {
    return load64(e + 48);
}

# Bytes emitted so far (call after vbool_enc_flush for the final size).
fn vbool_enc_bytes(e): i64 {
    return load64(e + 16);
}

# Output buffer pointer. OWNED by the encoder; stable only until the
# next write (growth may reallocate). Snapshot after vbool_enc_flush.
fn vbool_enc_buf(e): i64 {
    return load64(e);
}

# Internal: ensure room for extra more output bytes, doubling the
# buffer. Sticky DR_ERR_OVERSIZE past VBOOL_ENC_MAX_BYTES, DR_ERR_OOM
# on failed allocation. Returns DR_OK / error code.
fn vbool_enc_ensure(e, extra): i64 {
    var err = load64(e + 48);
    if (err != DR_OK) { return err; }
    var need = load64(e + 16) + extra;
    var cap = load64(e + 8);
    if (need <= cap) { return DR_OK; }
    var new_cap = cap;
    while (new_cap < need) {
        new_cap = new_cap << 1;
        if (new_cap > VBOOL_ENC_MAX_BYTES) {
            store64(e + 48, DR_ERR_OVERSIZE);
            return DR_ERR_OVERSIZE;
        }
    }
    var new_buf = alloc(new_cap);
    if (new_buf == 0) {
        store64(e + 48, DR_ERR_OOM);
        return DR_ERR_OOM;
    }
    memcpy(new_buf, load64(e), load64(e + 16));
    store64(e, new_buf);
    store64(e + 8, new_cap);
    return DR_OK;
}

# Internal: append one output byte. Returns DR_OK / error code.
fn vbool_enc_put_byte(e, b): i64 {
    var rc = vbool_enc_ensure(e, 1);
    if (rc != DR_OK) { return rc; }
    var len = load64(e + 16);
    store8(load64(e) + len, b & 255);
    store64(e + 16, len + 1);
    return DR_OK;
}

# Internal: RFC 6386 7.3 add_one_to_output() — propagate an arithmetic
# carry into the already-emitted bytes: walk back over 0xFF bytes
# (zeroing them) and increment the first non-0xFF byte.
#   "void add_one_to_output(uint8_t *q) { while (*--q == 255) *q = 0;
#    ++*q; }"
# The reference walks unchecked before the buffer start; a carry can
# only reach position -1 if EVERY emitted byte is 0xFF, which the coder
# never produces (a carry into a 0xFF byte would have rippled at emit
# time) — but this port bounds-checks anyway and latches DR_ERR_OTHER
# instead of corrupting memory. Returns DR_OK / error code.
fn vbool_enc_carry(e): i64 {
    var err = load64(e + 48);
    if (err != DR_OK) { return err; }
    var buf = load64(e);
    var x = load64(e + 16) - 1;
    while ((x >= 0) && (load8(buf + x) == 255)) {
        store8(buf + x, 0);
        x = x - 1;
    }
    if (x < 0) {
        store64(e + 48, DR_ERR_OTHER);   # can't-happen guard (see above)
        return DR_ERR_OTHER;
    }
    store8(buf + x, load8(buf + x) + 1);
    return DR_OK;
}

# Encode one bool with the given 8-bit probability-of-zero (0..255).
# RFC 6386 7.3 write_bool(), verbatim arithmetic:
#   split = 1 + (((range - 1) * prob) >> 8)
#   bool 1: bottom += split; range -= split      bool 0: range = split
#   then renormalize while range < 128: detect a carry out of bottom's
#   32-bit window (reference: "if (e->bottom & (1 << 31)) detect carry"
#   before the shift), shift bottom left, and emit bottom's top byte
#   every 8 shifts, keeping the low 3 bytes.
# The reference keeps bottom in a uint32; this port keeps it in an i64
# and additionally propagates a carry OUT of bit 31 produced by the
# `bottom += split` add itself (in uint32 arithmetic that add wraps; the
# wrapped-away bit is exactly one carry into the emitted bytes), then
# masks back to 32 bits — same stream, no lost carry.
# prob outside [0,255] latches sticky DR_ERR_BOUNDS; any nonzero
# bool_value writes a 1. Returns DR_OK / error code.
fn vbool_enc_bool(e, prob, bool_value): i64 {
    var err = load64(e + 48);
    if (err != DR_OK) { return err; }
    if ((prob < 0) || (prob > 255)) {
        store64(e + 48, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var range = load64(e + 24);
    var bottom = load64(e + 32);
    var split = 1 + (((range - 1) * prob) >> 8);
    if (bool_value) {
        bottom = bottom + split;       # "move up bottom of interval"
        range = range - split;
        if (bottom > 0xFFFFFFFF) {     # carry out of the 32-bit window
            var rc = vbool_enc_carry(e);
            if (rc != DR_OK) { return rc; }
            bottom = bottom & 0xFFFFFFFF;
        }
    } else {
        range = split;                 # "decrease range, leaving bottom alone"
    }
    var bit_count = load64(e + 40);
    while (range < 128) {
        range = range << 1;
        if (bottom & 0x80000000) {     # "detect carry" (bit 31 set)
            var rc2 = vbool_enc_carry(e);
            if (rc2 != DR_OK) { return rc2; }
        }
        bottom = (bottom << 1) & 0xFFFFFFFF;   # "before shifting bottom"
        bit_count = bit_count - 1;
        if (bit_count == 0) {          # "write out high byte of bottom"
            var rc3 = vbool_enc_put_byte(e, (bottom >> 24) & 255);
            if (rc3 != DR_OK) { return rc3; }
            bottom = bottom & 0xFFFFFF;   # "keeping low 3 bytes"
            bit_count = 8;                # "8 shifts until next output"
        }
    }
    store64(e + 24, range);
    store64(e + 32, bottom);
    store64(e + 40, bit_count);
    return DR_OK;
}

# Encode the low n bits of value (0 <= n <= 32) as an MSB-first literal,
# each bit a bool at probability 128 — the exact inverse of
# vbool_dec_literal / RFC 7.3 read_literal(). Bits of value above n are
# ignored (masked by iteration). n outside [0,32] latches sticky
# DR_ERR_BOUNDS. Returns DR_OK / error code.
fn vbool_enc_literal(e, value, n): i64 {
    var err = load64(e + 48);
    if (err != DR_OK) { return err; }
    if ((n < 0) || (n > 32)) {
        store64(e + 48, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var i = n;
    while (i > 0) {
        i = i - 1;
        var rc = vbool_enc_bool(e, 128, (value >> i) & 1);
        if (rc != DR_OK) { return rc; }
    }
    return DR_OK;
}

# Encode a sign-magnitude signed value: n-bit magnitude then one sign
# bool (sign 1 = negative) — inverse of vbool_dec_signed. The magnitude
# |value| must fit in n bits (|value| < 2^n) or sticky DR_ERR_BOUNDS.
# Returns DR_OK / error code.
fn vbool_enc_signed(e, value, n): i64 {
    var err = load64(e + 48);
    if (err != DR_OK) { return err; }
    if ((n < 0) || (n > 32)) {
        store64(e + 48, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var mag = value;
    var sign = 0;
    if (value < 0) {
        mag = 0 - value;
        sign = 1;
    }
    if (mag >= (1 << n)) {
        store64(e + 48, DR_ERR_BOUNDS);
        return DR_ERR_BOUNDS;
    }
    var rc = vbool_enc_literal(e, mag, n);
    if (rc != DR_OK) { return rc; }
    return vbool_enc_bool(e, 128, sign);
}

# Terminate the stream — RFC 6386 7.3 flush_bool_encoder(), verbatim:
# propagate a final carry if bit (32 - bit_count) of bottom is set,
# left-align the remaining payload bits, and emit 4 more bytes (the
# stream is zero-padded; a flushed stream is therefore always >= 4
# bytes). Returns the total output length in BYTES, or 0 if the encoder
# faulted. Call ONCE; the encoder must not be written to afterwards.
fn vbool_enc_flush(e): i64 {
    if (load64(e + 48) != DR_OK) { return 0; }
    var c = load64(e + 40);
    var v = load64(e + 32);
    if (v & (1 << (32 - c))) {        # "propagate (unlikely) carry"
        var rc = vbool_enc_carry(e);
        if (rc != DR_OK) { return 0; }
    }
    v = (v << (c & 7)) & 0xFFFFFFFF;  # "before shifting remaining output"
    c = c >> 3;                       # "to top of internal buffer"
    while (c > 0) {
        c = c - 1;
        v = (v << 8) & 0xFFFFFFFF;
    }
    var i = 0;
    while (i < 4) {                   # "write remaining data, possibly padded"
        var rc2 = vbool_enc_put_byte(e, (v >> 24) & 255);
        if (rc2 != DR_OK) { return 0; }
        v = (v << 8) & 0xFFFFFFFF;
        i = i + 1;
    }
    return load64(e + 16);
}

# --- vp8.cyr ---

# @public — drishti VP8: frame framing — the 3-byte frame tag, the
# 7-byte keyframe start-code/dimension block, and the matching writer
# (the encode-lane seed).
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/vpx.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*
# codes) only.
#
# Derived from RFC 6386 "VP8 Data Format and Decoding Guide" (code-as-
# spec) — section numbers cited inline:
#   9.1  uncompressed data chunk: 3-byte frame tag; keyframes append the
#        start code 0x9d 0x01 0x2a and two 16-bit LE width/height words
#        (14-bit dimension + 2-bit upscale each). Reference code:
#          tmp = (c[2] << 16) | (c[1] << 8) | c[0];
#          key_frame  = !(tmp & 0x1);           <- INVERTED sense:
#                                                  tag bit 0 == 0 KEY
#          version    = (tmp >> 1) & 0x7;
#          show_frame = (tmp >> 4) & 0x1;
#          first_part_size = (tmp >> 5) & 0x7FFFF;   (19 bits)
#          if (c[3] != 0x9d || c[4] != 0x01 || c[5] != 0x2a) error;
#          width  = (c[6] | (c[7] << 8)) & 0x3fff;  hscale = c[7] >> 6;
#          height = (c[8] | (c[9] << 8)) & 0x3fff;  vscale = c[9] >> 6;
#   9.1  "The first data partition begins at the first byte following
#        the uncompressed data chunk" — used for the lying-size check.
#   9.2  version numbers 0-3 select reconstruction/loop filters; values
#        above 3 are undefined -> DR_ERR_UNSUPPORTED (libvpx
#        vp8/decoder/decodeframe.c rejects them the same way).
# NOTE the frame tag is LITTLE-ENDIAN bit-packed (fields fill from bit
# 0 of byte 0 upward) — the core DrBr reader is MSB-first and would
# assemble the fields backwards, so the tag bytes are hand-extracted
# here instead of going through dr_br_*.
#
# Vp8FrameHdr record layout (72 bytes, heap):
#   +0:  key_frame  — 1 = key frame (NORMALIZED: tag bit 0 inverted)
#   +8:  version    — 0..3
#   +16: show_frame — 0/1
#   +24: part_size  — first_part_size (19 bits): bytes in the first
#                     compressed partition, which starts at buf+hdr_size
#   +32: width      — 14-bit luma width in pixels (key frames; else 0)
#   +40: height     — 14-bit luma height in pixels (key frames; else 0)
#   +48: hscale     — 2-bit horizontal upscale code (key frames; else 0)
#   +56: vscale     — 2-bit vertical upscale code (key frames; else 0)
#   +64: hdr_size   — uncompressed-chunk bytes: 10 key / 3 interframe

# Family error band (VP8/VP9 = 70-89, see src/drishti.cyr). Generic
# faults reuse core codes; this module mints only the codec-specific one.
enum Vp8Err {
    VP8_ERR_BAD_START_CODE = 70;   # keyframe start code != 9d 01 2a (9.1)
}

# Keyframe start-code bytes — RFC 6386 9.1.
enum Vp8StartCode {
    VP8_START_0 = 0x9d;
    VP8_START_1 = 0x01;
    VP8_START_2 = 0x2a;
}

# ================================================================
# Parse
# ================================================================

# Parse the uncompressed data chunk at buf[0..len). Returns a
# Vp8FrameHdr record, or 0 with the error code stored at *out_err:
#   DR_ERR_BOUNDS          — len < 0
#   DR_ERR_TRUNCATED       — len < 3; keyframe with len < 10; or the
#                            first partition (first_part_size) extends
#                            past buf+len (lying size)
#   DR_ERR_UNSUPPORTED     — version > 3 (RFC 6386 9.2 defines 0-3)
#   VP8_ERR_BAD_START_CODE — keyframe start code != 9d 01 2a
#   DR_ERR_OOM             — allocation failure
fn vp8_parse_frame_hdr(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    if (len < 3) {
        store64(out_err, DR_ERR_TRUNCATED);
        return 0;
    }
    # 9.1 frame tag — little-endian 24-bit assembly, hand-extracted
    # (LE-packed fields; the MSB-first core reader would misassemble).
    var tmp = load8(buf) + (load8(buf + 1) << 8) + (load8(buf + 2) << 16);
    var key_frame = 0;                    # tag bit 0: 0 = KEY (inverted)
    if ((tmp & 1) == 0) { key_frame = 1; }
    var version = (tmp >> 1) & 7;         # 3 bits
    var show_frame = (tmp >> 4) & 1;      # 1 bit
    var part_size = (tmp >> 5) & 0x7FFFF; # 19 bits
    if (version > 3) {
        # 9.2: versions 0-3 defined; libvpx rejects > 3 as unsupported.
        store64(out_err, DR_ERR_UNSUPPORTED);
        return 0;
    }
    var width = 0;
    var height = 0;
    var hscale = 0;
    var vscale = 0;
    var hdr_size = 3;
    if (key_frame) {
        hdr_size = 10;                     # 3 tag + 3 start code + 2+2 dims
        if (len < 10) {
            store64(out_err, DR_ERR_TRUNCATED);
            return 0;
        }
        # 9.1: "vet via sync code" — bytes 3..5 must be 9d 01 2a.
        if ((load8(buf + 3) != VP8_START_0) || (load8(buf + 4) != VP8_START_1)
        || (load8(buf + 5) != VP8_START_2)) {
            store64(out_err, VP8_ERR_BAD_START_CODE);
            return 0;
        }
        # 9.1: 16-bit LE words — 14-bit dimension, top 2 bits upscale.
        width = (load8(buf + 6) + (load8(buf + 7) << 8)) & 0x3FFF;
        hscale = load8(buf + 7) >> 6;
        height = (load8(buf + 8) + (load8(buf + 9) << 8)) & 0x3FFF;
        vscale = load8(buf + 9) >> 6;
    }
    # 9.1: the first partition starts right after the uncompressed
    # chunk — a first_part_size that runs past the buffer is lying.
    if (part_size > (len - hdr_size)) {
        store64(out_err, DR_ERR_TRUNCATED);
        return 0;
    }
    var h = alloc(72);
    if (h == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(h, key_frame);
    store64(h + 8, version);
    store64(h + 16, show_frame);
    store64(h + 24, part_size);
    store64(h + 32, width);
    store64(h + 40, height);
    store64(h + 48, hscale);
    store64(h + 56, vscale);
    store64(h + 64, hdr_size);
    return h;
}

# ================================================================
# Accessors
# ================================================================

fn vp8_hdr_key_frame(h): i64 { return load64(h); }
fn vp8_hdr_version(h): i64 { return load64(h + 8); }
fn vp8_hdr_show_frame(h): i64 { return load64(h + 16); }
fn vp8_hdr_part_size(h): i64 { return load64(h + 24); }
fn vp8_hdr_width(h): i64 { return load64(h + 32); }
fn vp8_hdr_height(h): i64 { return load64(h + 40); }
fn vp8_hdr_hscale(h): i64 { return load64(h + 48); }
fn vp8_hdr_vscale(h): i64 { return load64(h + 56); }
fn vp8_hdr_size(h): i64 { return load64(h + 64); }

# ================================================================
# Build + write (encode lane)
# ================================================================

# Build a VALIDATED Vp8FrameHdr record from field values (key_frame in
# the normalized sense: 1 = key frame). Returns the record, or 0 with
# the error code stored at *out_err:
#   DR_ERR_UNSUPPORTED — version outside [0,3] (RFC 6386 9.2)
#   DR_ERR_BOUNDS      — show_frame outside [0,1]; part_size outside
#                        [0, 2^19-1]; width/height outside [0, 0x3FFF];
#                        hscale/vscale outside [0,3] (9.1 field widths)
#   DR_ERR_OOM         — allocation failure
# Dimensions/scales are only meaningful when key_frame == 1 (they are
# stored regardless; the writer emits them only for key frames).
fn vp8_hdr_new(key_frame, version, show_frame, part_size, width, height, hscale, vscale, out_err): i64 {
    store64(out_err, DR_OK);
    if ((version < 0) || (version > 3)) {
        store64(out_err, DR_ERR_UNSUPPORTED);
        return 0;
    }
    if ((show_frame < 0) || (show_frame > 1)
    || (part_size < 0) || (part_size > 0x7FFFF)
    || (width < 0) || (width > 0x3FFF)
    || (height < 0) || (height > 0x3FFF)
    || (hscale < 0) || (hscale > 3)
    || (vscale < 0) || (vscale > 3)) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    var norm_key = 0;
    if (key_frame) { norm_key = 1; }
    var hdr_size = 3;
    if (norm_key) { hdr_size = 10; }
    var h = alloc(72);
    if (h == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(h, norm_key);
    store64(h + 8, version);
    store64(h + 16, show_frame);
    store64(h + 24, part_size);
    store64(h + 32, width);
    store64(h + 40, height);
    store64(h + 48, hscale);
    store64(h + 56, vscale);
    store64(h + 64, hdr_size);
    return h;
}

# Serialize a Vp8FrameHdr to a freshly-allocated buffer — the exact
# inverse of vp8_parse_frame_hdr (RFC 6386 9.1 layout). Returns the
# OWNED buffer pointer and stores its length (10 key / 3 interframe) at
# *out_len; returns 0 with *out_len = 0 on allocation failure. Assumes
# a record built by vp8_hdr_new / vp8_parse_frame_hdr (fields already
# validated).
fn vp8_write_frame_hdr(h, out_len): i64 {
    store64(out_len, 0);
    var hdr_size = load64(h + 64);
    var buf = alloc(hdr_size);
    if (buf == 0) { return 0; }
    # 9.1 frame tag: bit 0 = !key_frame (inverted sense), bits 1-3
    # version, bit 4 show_frame, bits 5-23 first_part_size; packed LE.
    var not_key = 1;
    if (load64(h)) { not_key = 0; }
    var tmp = not_key + (load64(h + 8) << 1) + (load64(h + 16) << 4)
    + (load64(h + 24) << 5);
    store8(buf, tmp & 255);
    store8(buf + 1, (tmp >> 8) & 255);
    store8(buf + 2, (tmp >> 16) & 255);
    if (load64(h)) {
        store8(buf + 3, VP8_START_0);      # 9.1 start code
        store8(buf + 4, VP8_START_1);
        store8(buf + 5, VP8_START_2);
        var w = load64(h + 32) + (load64(h + 48) << 14);   # dim | scale<<14
        store8(buf + 6, w & 255);
        store8(buf + 7, (w >> 8) & 255);
        var v = load64(h + 40) + (load64(h + 56) << 14);
        store8(buf + 8, v & 255);
        store8(buf + 9, (v >> 8) & 255);
    }
    store64(out_len, hdr_size);
    return buf;
}

# --- vp9.cyr ---

# @public — drishti VP9: the uncompressed frame header — frame marker,
# profile, show_existing_frame short-circuit, frame type/flags, and the
# keyframe path (frame sync code, color config, frame size, render
# size) -> Vp9FrameHdr record.
#
# FLAT module (no includes) — wiring in src/main.cyr; until this family
# is wired into [lib], the standalone suite tests/vpx.tcyr includes it
# explicitly after the lib root. Depends on src/drishti.cyr (DR_ERR_*
# codes) and src/bits.cyr (DrBr MSB-first bitreader — VP9's f(n) fields
# are big-endian MSB-first bit packs, unlike VP8's little-endian tag).
#
# Derived from the "VP9 Bitstream & Decoding Process Specification"
# v0.7 (Grange / de Rivaz / Hunt, Google) — section numbers cited:
#   6.2    uncompressed_header(): frame_marker f(2) == 2, profile low/
#          high bits, profile-3 reserved_zero bit, show_existing_frame
#          (+ frame_to_show_map_idx f(3) short-circuit), frame_type,
#          show_frame, error_resilient_mode
#   6.2.1  frame_sync_code(): 0x49 0x83 0x42 (one f(8) each)
#   6.2.2  color_config(): ten_or_twelve_bit for profile >= 2 (BitDepth
#          10/12; profiles 0/1 are 8-bit), color_space f(3), and per
#          color-space/profile: color_range, subsampling_x/y +
#          reserved_zero for profiles 1/3; profiles 0/2 imply 4:2:0.
#          CS_RGB implies full range and 4:4:4 (profiles 1/3 only —
#          RGB in profile 0/2 has no defined subsampling: rejected,
#          matching libvpx vp9_decodeframe.c "4:4:4 color not supported
#          in profile 0 or 2").
#   6.2.3  frame_size(): frame_width_minus_1 f(16), frame_height_minus_1
#          f(16)
#   6.2.4  render_size(): render_and_frame_size_different f(1), then
#          render_width/height_minus_1 f(16) each; otherwise the render
#          size defaults to the frame size
#   7.2    frame type semantics: KEY_FRAME = 0, NON_KEY_FRAME = 1
#   7.2.2  color_space enumeration (CS_UNKNOWN .. CS_RGB)
# Cross-checked against libvpx vp9/decoder/vp9_decodeframe.c
# (read_uncompressed_header / read_bitdepth_colorspace_sampling) and
# ffmpeg libavcodec/vp9.c (decode_frame_header) — field order, the
# profile bit split (low bit first), and the rejection set all agree.
#
# Parsing STOPS after render_size() on the keyframe path — the rest of
# uncompressed_header() (refresh flags, loop-filter/quant/segmentation/
# tile syntax, header_size_in_bytes) is the 0.4.x VP9-keyframe-decode
# milestone. bits_consumed tells the caller exactly where this parse
# stopped. Inter-frame headers (frame_type == 1) stop right after
# error_resilient_mode for the same reason.
#
# Vp9FrameHdr record layout (128 bytes, heap):
#   +0:   profile        — 0..3 ((high << 1) + low, 6.2)
#   +8:   show_existing  — show_existing_frame flag (0/1)
#   +16:  show_map_idx   — frame_to_show_map_idx (only when
#                          show_existing == 1; else 0)
#   +24:  frame_type     — VP9_KEY_FRAME / VP9_NON_KEY_FRAME
#                          (meaningless when show_existing == 1)
#   +32:  show_frame     — 0/1
#   +40:  error_resilient— 0/1
#   +48:  bit_depth      — 8 / 10 / 12 (keyframe path; else 0)
#   +56:  color_space    — VP9_CS_* (keyframe path; else 0)
#   +64:  color_range    — 0 studio / 1 full (keyframe path; else 0)
#   +72:  subsampling_x  — 0/1 (keyframe path; else 0)
#   +80:  subsampling_y  — 0/1 (keyframe path; else 0)
#   +88:  width          — FrameWidth in pixels (keyframe path; else 0)
#   +96:  height         — FrameHeight in pixels (keyframe path; else 0)
#   +104: render_width   — RenderWidth (defaults to width, 6.2.4)
#   +112: render_height  — RenderHeight (defaults to height, 6.2.4)
#   +120: bits_consumed  — header bits parsed (where this parse stopped)

# Family error band (VP8/VP9 = 70-89, see src/drishti.cyr) — VP8 uses
# 70..74 (src/vp8.cyr), VP9 mints from 75. Generic faults reuse core
# codes (truncation, reserved bits, OOM, ...).
enum Vp9Err {
    VP9_ERR_BAD_MARKER = 75;   # frame_marker != 2 (6.2)
    VP9_ERR_BAD_SYNC   = 76;   # frame_sync_code != 49 83 42 (6.2.1)
}

# Frame types — spec 7.2.
enum Vp9FrameType {
    VP9_KEY_FRAME     = 0;
    VP9_NON_KEY_FRAME = 1;
}

# color_space — spec 7.2.2.
enum Vp9ColorSpace {
    VP9_CS_UNKNOWN   = 0;
    VP9_CS_BT_601    = 1;
    VP9_CS_BT_709    = 2;
    VP9_CS_SMPTE_170 = 3;
    VP9_CS_SMPTE_240 = 4;
    VP9_CS_BT_2020   = 5;
    VP9_CS_RESERVED  = 6;
    VP9_CS_RGB       = 7;
}

# frame_sync_code bytes — spec 6.2.1.
enum Vp9SyncCode {
    VP9_SYNC_0 = 0x49;
    VP9_SYNC_1 = 0x83;
    VP9_SYNC_2 = 0x42;
}

# ================================================================
# Parse
# ================================================================

# Internal: allocate a zeroed Vp9FrameHdr. Returns record or 0 on OOM.
fn vp9_hdr_alloc(): i64 {
    var h = alloc(128);
    if (h == 0) { return 0; }
    var i = 0;
    while (i < 128) {
        store64(h + i, 0);
        i = i + 8;
    }
    return h;
}

# Parse the uncompressed header at buf[0..len) (spec 6.2). Returns a
# Vp9FrameHdr record, or 0 with the error code stored at *out_err:
#   DR_ERR_BOUNDS        — len < 0
#   DR_ERR_TRUNCATED     — buffer ends inside the header
#   VP9_ERR_BAD_MARKER   — frame_marker != 2 (6.2)
#   DR_ERR_FORBIDDEN_BIT — a reserved_zero bit is set (profile-3 bit,
#                          6.2; color_config reserved bits, 6.2.2)
#   VP9_ERR_BAD_SYNC     — frame_sync_code != 49 83 42 (6.2.1)
#   DR_ERR_BAD_HEADER    — CS_RGB in profile 0/2 (6.2.2 conformance;
#                          libvpx: "4:4:4 color not supported in
#                          profile 0 or 2")
#   DR_ERR_OOM           — allocation failure
# On the show_existing_frame == 1 short-circuit only profile,
# show_existing, show_map_idx and bits_consumed are meaningful.
fn vp9_parse_uncompressed_header(buf, len, out_err): i64 {
    store64(out_err, DR_OK);
    if (len < 0) {
        store64(out_err, DR_ERR_BOUNDS);
        return 0;
    }
    var br = dr_br_init(buf, len);
    if (br == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    # 6.2: frame_marker f(2) — "shall be equal to 2".
    var marker = dr_br_read_bits(br, 2);
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (marker != 2) {
        store64(out_err, VP9_ERR_BAD_MARKER);
        return 0;
    }
    # 6.2: profile_low_bit f(1), profile_high_bit f(1);
    # Profile = (high << 1) + low. Profile 3 carries reserved_zero f(1).
    var low = dr_br_read_bit(br);
    var high = dr_br_read_bit(br);
    var profile = (high << 1) + low;
    if (profile == 3) {
        var rz = dr_br_read_bit(br);
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        if (rz != 0) {
            store64(out_err, DR_ERR_FORBIDDEN_BIT);
            return 0;
        }
    }
    # 6.2: show_existing_frame f(1) — a 1 short-circuits the header to
    # frame_to_show_map_idx f(3) and nothing else.
    var show_existing = dr_br_read_bit(br);
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    if (show_existing) {
        var idx = dr_br_read_bits(br, 3);
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        var hs = vp9_hdr_alloc();
        if (hs == 0) {
            store64(out_err, DR_ERR_OOM);
            return 0;
        }
        store64(hs, profile);
        store64(hs + 8, 1);
        store64(hs + 16, idx);
        store64(hs + 120, dr_br_bit_pos(br));
        return hs;
    }
    # 6.2: frame_type f(1), show_frame f(1), error_resilient_mode f(1).
    var frame_type = dr_br_read_bit(br);
    var show_frame = dr_br_read_bit(br);
    var error_resilient = dr_br_read_bit(br);
    if (dr_br_err(br) != DR_OK) {
        store64(out_err, dr_br_err(br));
        return 0;
    }
    var bit_depth = 0;
    var color_space = 0;
    var color_range = 0;
    var ssx = 0;
    var ssy = 0;
    var width = 0;
    var height = 0;
    var render_width = 0;
    var render_height = 0;
    if (frame_type == VP9_KEY_FRAME) {
        # 6.2.1 frame_sync_code(): three fixed bytes 49 83 42.
        var s0 = dr_br_read_bits(br, 8);
        var s1 = dr_br_read_bits(br, 8);
        var s2 = dr_br_read_bits(br, 8);
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        if ((s0 != VP9_SYNC_0) || (s1 != VP9_SYNC_1) || (s2 != VP9_SYNC_2)) {
            store64(out_err, VP9_ERR_BAD_SYNC);
            return 0;
        }
        # 6.2.2 color_config().
        bit_depth = 8;                     # profiles 0/1 are 8-bit
        if (profile >= 2) {
            var ten_or_twelve = dr_br_read_bit(br);
            if (ten_or_twelve) {
                bit_depth = 12;
            } else {
                bit_depth = 10;
            }
        }
        color_space = dr_br_read_bits(br, 3);
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        if (color_space != VP9_CS_RGB) {
            color_range = dr_br_read_bit(br);
            if ((profile == 1) || (profile == 3)) {
                ssx = dr_br_read_bit(br);
                ssy = dr_br_read_bit(br);
                var rz1 = dr_br_read_bit(br);
                if (dr_br_err(br) != DR_OK) {
                    store64(out_err, dr_br_err(br));
                    return 0;
                }
                if (rz1 != 0) {            # 6.2.2 reserved_zero
                    store64(out_err, DR_ERR_FORBIDDEN_BIT);
                    return 0;
                }
            } else {
                ssx = 1;                   # profiles 0/2: implied 4:2:0
                ssy = 1;
            }
        } else {
            color_range = 1;               # 6.2.2: CS_RGB implies full range
            if ((profile == 1) || (profile == 3)) {
                ssx = 0;                   # implied 4:4:4
                ssy = 0;
                var rz2 = dr_br_read_bit(br);
                if (dr_br_err(br) != DR_OK) {
                    store64(out_err, dr_br_err(br));
                    return 0;
                }
                if (rz2 != 0) {            # 6.2.2 reserved_zero
                    store64(out_err, DR_ERR_FORBIDDEN_BIT);
                    return 0;
                }
            } else {
                # 6.2.2 has no RGB path for profiles 0/2 (4:2:0-only
                # profiles) — conformance violation.
                store64(out_err, DR_ERR_BAD_HEADER);
                return 0;
            }
        }
        # 6.2.3 frame_size(): 16-bit minus_1 fields.
        width = dr_br_read_bits(br, 16) + 1;
        height = dr_br_read_bits(br, 16) + 1;
        # 6.2.4 render_size(): defaults to the frame size.
        render_width = width;
        render_height = height;
        var rdiff = dr_br_read_bit(br);
        if (dr_br_err(br) != DR_OK) {
            store64(out_err, dr_br_err(br));
            return 0;
        }
        if (rdiff) {
            render_width = dr_br_read_bits(br, 16) + 1;
            render_height = dr_br_read_bits(br, 16) + 1;
            if (dr_br_err(br) != DR_OK) {
                store64(out_err, dr_br_err(br));
                return 0;
            }
        }
    }
    var h = vp9_hdr_alloc();
    if (h == 0) {
        store64(out_err, DR_ERR_OOM);
        return 0;
    }
    store64(h, profile);
    store64(h + 8, 0);
    store64(h + 16, 0);
    store64(h + 24, frame_type);
    store64(h + 32, show_frame);
    store64(h + 40, error_resilient);
    store64(h + 48, bit_depth);
    store64(h + 56, color_space);
    store64(h + 64, color_range);
    store64(h + 72, ssx);
    store64(h + 80, ssy);
    store64(h + 88, width);
    store64(h + 96, height);
    store64(h + 104, render_width);
    store64(h + 112, render_height);
    store64(h + 120, dr_br_bit_pos(br));
    return h;
}

# ================================================================
# Accessors
# ================================================================

fn vp9_hdr_profile(h): i64 { return load64(h); }
fn vp9_hdr_show_existing(h): i64 { return load64(h + 8); }
fn vp9_hdr_show_map_idx(h): i64 { return load64(h + 16); }
fn vp9_hdr_frame_type(h): i64 { return load64(h + 24); }
fn vp9_hdr_show_frame(h): i64 { return load64(h + 32); }
fn vp9_hdr_error_resilient(h): i64 { return load64(h + 40); }
fn vp9_hdr_bit_depth(h): i64 { return load64(h + 48); }
fn vp9_hdr_color_space(h): i64 { return load64(h + 56); }
fn vp9_hdr_color_range(h): i64 { return load64(h + 64); }
fn vp9_hdr_subsampling_x(h): i64 { return load64(h + 72); }
fn vp9_hdr_subsampling_y(h): i64 { return load64(h + 80); }
fn vp9_hdr_width(h): i64 { return load64(h + 88); }
fn vp9_hdr_height(h): i64 { return load64(h + 96); }
fn vp9_hdr_render_width(h): i64 { return load64(h + 104); }
fn vp9_hdr_render_height(h): i64 { return load64(h + 112); }
fn vp9_hdr_bits_consumed(h): i64 { return load64(h + 120); }
