# dc_q(b) = Dc_Qlookup[(BitDepth-8)>>1][Clip3(0,255,b)]. depth is clamped
# to 0..2 as an OOB backstop (BitDepth is 8/10/12 for any conformant frame).
fn av1_dc_q(bit_depth, b): i64 {
    var depth = av1_clip3(0, 2, (bit_depth - 8) >> 1);
    return load64(av1_dc_qlookup() + (((depth * 256) + av1_clip3(0, 255, b)) * 8));
}
# ac_q(b) = Ac_Qlookup[(BitDepth-8)>>1][Clip3(0,255,b)].
fn av1_ac_q(bit_depth, b): i64 {
    var depth = av1_clip3(0, 2, (bit_depth - 8) >> 1);
    return load64(av1_ac_qlookup() + (((depth * 256) + av1_clip3(0, 255, b)) * 8));
}

# get_qindex(ignoreDeltaQ, segmentId) — 7.12.2. seg_active is
# seg_feature_active_idx(segmentId, SEG_LVL_ALT_Q); seg_data is
# FeatureData[segmentId][SEG_LVL_ALT_Q]; current_qindex is CurrentQIndex.
# These per-block/frame inputs are caller-provided until block decode lands.
fn av1_get_qindex(ignore_delta_q, base_q_idx, current_qindex, delta_q_present,
seg_active, seg_data): i64 {
    if (seg_active) {
        var qindex = base_q_idx + seg_data;
        if ((ignore_delta_q == 0) && delta_q_present) {
            qindex = current_qindex + seg_data;
        }
        return av1_clip3(0, 255, qindex);
    }
    if ((ignore_delta_q == 0) && delta_q_present) {
        return current_qindex;
    }
    return base_q_idx;
}

# get_dc_quant(plane) / get_ac_quant(plane) — 7.12.2. The caller supplies
# the resolved qindex (get_qindex(0, segment_id)) and the plane delta:
# DeltaQYDc/UDc/VDc for DC; 0 (luma) / DeltaQUAc / DeltaQVAc for AC.
fn av1_get_dc_quant(bit_depth, qindex, delta_dc): i64 {
    return av1_dc_q(bit_depth, qindex + delta_dc);
}
fn av1_get_ac_quant(bit_depth, qindex, delta_ac): i64 {
    return av1_ac_q(bit_depth, qindex + delta_ac);
}

# --- av1_recon.cyr ---

# src/av1_recon.cyr — AV1 reconstruct process (spec 7.12.3).
#
# The reconstruct glue turns a block of quantized coefficients into
# reconstructed pixels: dequantize (7.12.3 step 1) -> 2D inverse transform
# (7.13.3, in src/av1_itx.cyr) -> add the residual onto the prediction
# already in CurrFrame, with the FLIPADST up/down + left/right flips
# (7.12.3 step 3). This is the bite that emits first pixels; the coeffs()
# entropy decode that fills Quant[] from the bitstream lands later.
#
# FLAT module (no includes) — wiring in src/main.cyr, after av1_itx.cyr and
# av1_quant.cyr. Reuses av1_inverse_transform_2d + av1_itx_abs (av1_itx),
# av1_clip3 (av1_frame), and dr_frame_* / dr_clip1 (frame). Family av1_.
#
# NOT YET (caller inputs / deferred, see docs/development/roadmap.md):
#   - the quantizer matrix path (using_qmatrix / Quantizer_Matrix, 7.12.3
#     step 1b): q2 == q here; qmatrix scaling is a later sub-bite.
#   - q_dc / q_ac are resolved by the caller (av1_get_dc_quant /
#     av1_get_ac_quant); the Quant[] array is a caller input until coeffs().

# dqDenom (7.12.3): 4 for the 64x{64,32} + 32x64 transforms, 2 for the
# 32-class (32x32 / 16x32 / 32x16 / 16x64 / 64x16), else 1 — keyed off the
# transform log2 dimensions.
fn av1_dq_denom(log2w, log2h): i64 {
    if (((log2w == 6) && (log2h == 6)) || ((log2w == 5) && (log2h == 6)) || ((log2w == 6) && (log2h == 5))) {
        return 4;
    }
    if (((log2w == 5) && (log2h == 5)) || ((log2w == 4) && (log2h == 5)) || ((log2w == 5) && (log2h == 4))
    || ((log2w == 4) && (log2h == 6)) || ((log2w == 6) && (log2h == 4))) {
        return 2;
    }
    return 1;
}

# flipUD (7.12.3): PlaneTxType in {FLIPADST_DCT, FLIPADST_ADST, V_FLIPADST,
# FLIPADST_FLIPADST}.
fn av1_recon_flip_ud(tx_type): i64 {
    if ((tx_type == AV1_FLIPADST_DCT) || (tx_type == AV1_FLIPADST_ADST)
    || (tx_type == AV1_V_FLIPADST) || (tx_type == AV1_FLIPADST_FLIPADST)) {
        return 1;
    }
    return 0;
}

# flipLR (7.12.3): PlaneTxType in {DCT_FLIPADST, ADST_FLIPADST, H_FLIPADST,
# FLIPADST_FLIPADST}.
fn av1_recon_flip_lr(tx_type): i64 {
    if ((tx_type == AV1_DCT_FLIPADST) || (tx_type == AV1_ADST_FLIPADST)
    || (tx_type == AV1_H_FLIPADST) || (tx_type == AV1_FLIPADST_FLIPADST)) {
        return 1;
    }
    return 0;
}

# Dequantize one coefficient (7.12.3 steps 1c-1f, no qmatrix): dq = coeff*q;
# dq2 = sign(dq) * ((|dq| & 0xFFFFFF) / dqDenom); clamp to the +-2^(7+BitDepth)
# range. The division is on the non-negative magnitude, so it matches the
# spec's truncate-toward-zero regardless of cyrius's signed-/ convention.
fn av1_dequant_coeff(coeff, q, dq_denom, bit_depth): i64 {
    var dq = coeff * q;
    var sign = 1;
    if (dq < 0) { sign = 0 - 1; }
    var mag = (av1_itx_abs(dq) & 16777215) / dq_denom;   # 0xFFFFFF
    var lo = 0 - (1 << (7 + bit_depth));
    var hi = (1 << (7 + bit_depth)) - 1;
    return av1_clip3(lo, hi, sign * mag);
}

# Reconstruct process (7.12.3). plane / x / y locate the transform block's
# top-left in CurrFrame[plane]; tx_size (0..18) + tx_type (PlaneTxType,
# 0..15) describe the transform; lossless selects the WHT path; quant is the
# tw*th (row-major, stride tw) quantized-coefficient array; q_dc / q_ac are
# get_dc_quant(plane) / get_ac_quant(plane). Adds the residual onto the
# prediction already in CurrFrame. Returns DR_OK, AV1_ERR_BAD_TX, DR_ERR_OOM.
fn av1_reconstruct(frame, plane, x, y, tx_size, tx_type, lossless, quant, q_dc, q_ac): i64 {
    if ((tx_size < 0) || (tx_size > 18)) { return AV1_ERR_BAD_TX; }
    var log2w = av1_tx_width_log2(tx_size);
    var log2h = av1_tx_height_log2(tx_size);
    var w = 1 << log2w;
    var h = 1 << log2h;
    var tw = av1_min(32, w);
    var th = av1_min(32, h);
    var bit_depth = dr_frame_bit_depth(frame);
    var dq_denom = av1_dq_denom(log2w, log2h);

    var dequant = alloc(w * h * 8);
    var residual = alloc(w * h * 8);
    if ((dequant == 0) || (residual == 0)) { return DR_ERR_OOM; }
    memset(dequant, 0, w * h * 8);

    # Step 1: dequantize the tw x th coefficients into dequant[i*w + j].
    var i = 0;
    while (i < th) {
        var j = 0;
        while (j < tw) {
            var q = q_ac;
            if ((i == 0) && (j == 0)) { q = q_dc; }
            var coeff = load64(quant + (((i * tw) + j) * 8));
            store64(dequant + (((i * w) + j) * 8), av1_dequant_coeff(coeff, q, dq_denom, bit_depth));
            j = j + 1;
        }
        i = i + 1;
    }

    # Step 2: 2D inverse transform (un-flipped residual) — 7.13.3.
    var rc = av1_inverse_transform_2d(dequant, residual, tx_size, tx_type, lossless, bit_depth);
    if (rc != DR_OK) { return rc; }

    # Step 3: flip + add residual onto the prediction, clamp to the range.
    var flip_ud = av1_recon_flip_ud(tx_type);
    var flip_lr = av1_recon_flip_lr(tx_type);
    i = 0;
    while (i < h) {
        var j2 = 0;
        while (j2 < w) {
            var xx = j2;
            if (flip_lr) { xx = w - j2 - 1; }
            var yy = i;
            if (flip_ud) { yy = h - i - 1; }
            var cur = dr_frame_get(frame, plane, x + xx, y + yy);
            var res = load64(residual + (((i * w) + j2) * 8));
            dr_frame_set(frame, plane, x + xx, y + yy, dr_clip1(cur + res, bit_depth));
            j2 = j2 + 1;
        }
        i = i + 1;
    }
    return DR_OK;
}

# --- av1_scan.cyr ---

# src/av1_scan.cyr — AV1 coefficient scan orders (spec 5.11.41 get_scan +
# the Default/Mrow/Mcol scan tables from the additional-tables annex).
#
# A scan order maps a linear coefficient index to a raster position within
# the transform block; the coeffs() decode reads levels in scan order. This
# module holds the 32 scan tables (14 default + 9 mrow + 9 mcol, 4912 entries
# total) in one lazily-built blob, plus get_scan(txSz, txType) (5.11.41)
# which selects a scan from the transform size and type, and av1_scan_size
# (the scan length = Min(32,w)*Min(32,h)). Each table is a permutation of
# 0..len-1. The coeffs() reading loop that consumes these lands later.
#
# FLAT module (no includes) — wiring in src/main.cyr, after av1_itx.cyr
# (reuses av1_tx_width_log2 / av1_tx_height_log2 / av1_max and the
# AV1_IDTX / AV1_V_* / AV1_H_* tx-type enum). Family av1_. Tables extracted
# from the AV1 spec and cross-checked (each validated as a permutation).
#
# TxSize indices (spec TX_SIZES_ALL order, matching av1_itx.cyr): 0 TX_4X4,
# 1 TX_8X8, 2 TX_16X16, 3 TX_32X32, 4 TX_64X64, 5 TX_4X8, 6 TX_8X4,
# 7 TX_8X16, 8 TX_16X8, 9 TX_16X32, 10 TX_32X16, 11 TX_32X64, 12 TX_64X32,
# 13 TX_4X16, 14 TX_16X4, 15 TX_8X32, 16 TX_32X8, 17 TX_16X64, 18 TX_64X16.

var Av1_ScanBlob = 0;
var Av1_ScanSel = 0;   # 3*19 i64: default_off[19], mcol_off[19], mrow_off[19]

fn av1_scanfill8(t, off, v0, v1, v2, v3, v4, v5, v6, v7) {
    store64(t + ((off + 0) * 8), v0);   store64(t + ((off + 1) * 8), v1);
    store64(t + ((off + 2) * 8), v2);   store64(t + ((off + 3) * 8), v3);
    store64(t + ((off + 4) * 8), v4);   store64(t + ((off + 5) * 8), v5);
    store64(t + ((off + 6) * 8), v6);   store64(t + ((off + 7) * 8), v7);
    return 0;
}
fn av1_scanfill19(t, a0, a1, a2, a3, a4, a5, a6, a7, a8, a9, a10, a11, a12, a13, a14, a15, a16, a17, a18) {
    store64(t + 0, a0);    store64(t + 8, a1);    store64(t + 16, a2);   store64(t + 24, a3);
    store64(t + 32, a4);   store64(t + 40, a5);   store64(t + 48, a6);   store64(t + 56, a7);
    store64(t + 64, a8);   store64(t + 72, a9);   store64(t + 80, a10);  store64(t + 88, a11);
    store64(t + 96, a12);  store64(t + 104, a13); store64(t + 112, a14); store64(t + 120, a15);
    store64(t + 128, a16); store64(t + 136, a17); store64(t + 144, a18);
    return 0;
}

fn av1_scan_blob(): i64 {
    if (Av1_ScanBlob != 0) { return Av1_ScanBlob; }
    var t = alloc(4912 * 8);
    if (t == 0) { return 0; }
    av1_scanfill8(t, 0, 0, 1, 4, 8, 5, 2, 3, 6);
    av1_scanfill8(t, 8, 9, 12, 13, 10, 7, 11, 14, 15);
    av1_scanfill8(t, 16, 0, 1, 4, 2, 5, 8, 3, 6);
