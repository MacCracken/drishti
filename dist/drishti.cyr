# Coeff_Br[4][5][2][21][5]: q, txSzCtx (caller passes Min(.,3)), ptype, ctx (0..20).
fn av1_coeff_br_cdf(q, txsz_ctx, ptype, ctx): i64 {
    return av1_coeff_br_blob() + (((((q * 5) + txsz_ctx) * 2) + ptype) * 21 + ctx) * 5 * 8;
}

# --- av1_noncoeffcdf.cyr ---

# src/av1_noncoeffcdf.cyr — AV1 default NON-coefficient CDF tables for the
# intra keyframe path (spec additional-tables annex). These are the initial
# adaptive-CDF values the block/partition decode loads for partition, skip,
# intra y/uv modes, CfL sign/alpha, angle delta, filter-intra, tx-size, and
# intra tx-type reads. Unlike the coeff CDFs there is NO quantizer bucket, so
# init_non_coeff_cdfs copies the whole default blob into one mutable per-tile
# context. Format matches the symbol coder: an N-symbol cdf is N+1 i64 (N
# cumulative freqs ending 32768, then a 0 adaptation count). 1634 entries
# (1622 intra keyframe CDFs + the 3 loop-restoration type CDFs at 1624..1633).
#
# Extracted from the spec and validated (every cdf non-decreasing, ends
# 32768, count 0). The mode-info / tx-size / tx-type / partition reads that
# consume these land in later 0.7.x bites (roadmap.md). FLAT module — wiring
# in src/main.cyr after av1_coeffs.cyr. Family av1_. Deferred (feature-gated,
# later): partition W128, segment_id, delta_q/lf, intrabc, palette CDFs.

var Av1_NCdf = 0;
fn av1_ncdffill8(t, off, v0, v1, v2, v3, v4, v5, v6, v7) {
    store64(t + ((off + 0) * 8), v0);   store64(t + ((off + 1) * 8), v1);
    store64(t + ((off + 2) * 8), v2);   store64(t + ((off + 3) * 8), v3);
    store64(t + ((off + 4) * 8), v4);   store64(t + ((off + 5) * 8), v5);
    store64(t + ((off + 6) * 8), v6);   store64(t + ((off + 7) * 8), v7);
    return 0;
}

fn av1_noncoeff_cdf_blob(): i64 {
    if (Av1_NCdf != 0) { return Av1_NCdf; }
    var t = alloc(1636 * 8);   # 1634 entries (+ LR restoration CDFs at 1624..1633) + pad
    if (t == 0) { return 0; }
    av1_ncdffill8(t, 0, 19132, 25510, 30392, 32768, 0, 13928, 19855, 28540);
