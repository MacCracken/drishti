# tests/av1_mc_driver.tcyr — the MC driver av1_mc_pred_block (spec 7.11.3.1 steps 10+13,
# unscaled single-ref translation-only case). Known answers generated by a SPEC-LITERAL
# Python reference (scratchpad/mc_driver_ref.py): full 7.11.3.3 motion-vector scaling +
# verbatim 7.11.3.4 block inter prediction, with Subpel_Filters parsed straight out of
# the spec markdown — the reference shares no table or kernel code with src/av1_mc.cyr,
# so it independently checks the geometry reduction, the emu_edge gather composition,
# the filter-set mapping (incl. the w<=4 / h<=4 remap), and the rounding equivalence of
# the dav1d-convention kernel at 8/10/12-bit. Both sides fill the reference plane with
# the same deterministic formula.
include "src/main.cyr"

# the shared deterministic plane fill: value(p, r, c) — matches mc_driver_ref.py fill_val.
fn mcd_val(p, r, c, bd): i64 {
    return ((r * 31) + (c * 17) + (((r * c) % 11) * 5) + (p * 29)) % (1 << bd);
}

# fill every plane of frame f with mcd_val (over plane dims), plane index in the formula.
fn mcd_fill(f): i64 {
    var bd = dr_frame_bit_depth(f);
    var p = 0;
    while (p < dr_frame_num_planes(f)) {
        var pw = dr_frame_plane_width(f, p);
        var ph = dr_frame_plane_height(f, p);
        var r = 0;
        while (r < ph) {
            var c = 0;
            while (c < pw) {
                dr_frame_set(f, p, c, r, mcd_val(p, r, c, bd));
                c = c + 1;
            }
            r = r + 1;
        }
        p = p + 1;
    }
    return 0;
}

# position-weighted checksum of the w x h block at (x, y) in dst plane, row-major:
# sum v*(i+1) — matches the reference's checksum(pred).
fn mcd_cs(f, plane, x, y, w, h): i64 {
    var cs = 0;
    var i = 0;
    var r = 0;
    while (r < h) {
        var c = 0;
        while (c < w) {
            cs = cs + (dr_frame_get(f, plane, x + c, y + r) * (i + 1));
            i = i + 1;
            c = c + 1;
        }
        r = r + 1;
    }
    return cs;
}

var Mcd_Err = 0;   # out_err scratch for dr_frame_new (module-global: 8 bytes via alloc)

# build a (ref, dst) frame pair: ref filled with mcd_val, dst prefilled with sentinel 7.
# returns ref; the dst handle is left in Mcd_Dst.
var Mcd_Dst = 0;
fn mcd_pair(w, h, planes, subx, suby, bd, border): i64 {
    var ref = dr_frame_new(w, h, planes, subx, suby, bd, border, Mcd_Err);
    assert_eq(load64(Mcd_Err), DR_OK, "mcd_pair ref frame alloc");
    mcd_fill(ref);
    Mcd_Dst = dr_frame_new(w, h, planes, subx, suby, bd, border, Mcd_Err);
    assert_eq(load64(Mcd_Err), DR_OK, "mcd_pair dst frame alloc");
    var p = 0;
    while (p < planes) {
        dr_frame_fill(Mcd_Dst, p, 7);
        p = p + 1;
    }
    return ref;
}

# run one known-answer case against frame pair geometry (w x h, planes, subx/suby, bd):
# predict, then assert checksum + first/last pixel of the block.
fn mcd_case(name, fw, fh, planes, subx, suby, bd, plane, x, y, w, h, mvr, mvc, fx, fy, cs, first, last) {
    var ref = mcd_pair(fw, fh, planes, subx, suby, bd, 0);
    var d = Mcd_Dst;
    assert_eq(av1_mc_pred_block(d, ref, plane, x, y, w, h, mvr, mvc, fx, fy), DR_OK, name);
    assert_eq(mcd_cs(d, plane, x, y, w, h), cs, name);
    assert_eq(dr_frame_get(d, plane, x, y), first, name);
    assert_eq(dr_frame_get(d, plane, (x + w) - 1, (y + h) - 1), last, name);
    return 0;
}

fn test_mc_pos16() {
    # the 7.11.3.3 unscaled split needs floor semantics on negative positions:
    # x=0, mv=-1, sub=0 -> pos16 = -2 -> integer -1, phase 14 (NOT truncation's 0/-2).
    assert_eq(av1_mc_pos16(0, 0 - 1, 0), 0 - 2, "pos16(0,-1,0) = -2");
    assert_eq(av1_mc_pos16(0, 0 - 1, 0) >>> 4, 0 - 1, "pos16 -2 integer part floors to -1");
    assert_eq(av1_mc_pos16(0, 0 - 1, 0) & 15, 14, "pos16 -2 phase is 14");
    # chroma halving is an ARITHMETIC shift of 2*mv: mv=-5, sub=1 -> (2*-5)>>1 = -5.
    assert_eq(av1_mc_pos16(3, 0 - 5, 1), 43, "pos16 chroma (3,-5,1) = 48-5");
    # luma: 1/8-pel mv doubles into even 1/16-pel phases only.
    assert_eq(av1_mc_pos16(8, 3, 0) & 15, 6, "pos16 luma phase even (2*3)");
    return 0;
}

fn test_mc_pred_known_answers() {
    #                        fw  fh  pl sx sy  bd  p   x   y   w   h    mvr     mvc     fx fy  checksum first last
    mcd_case("c01 copy", 24, 18, 3, 1, 1, 8, 0, 4, 3, 8, 8, 0, 0, 0, 0, 300779, 166, 241);
    mcd_case("c02 int-mv", 24, 18, 3, 1, 1, 8, 0, 4, 3, 8, 8, 40, 0 - 16, 0, 0, 260369, 51, 121);
    mcd_case("c03 h-only", 24, 18, 3, 1, 1, 8, 0, 8, 5, 8, 8, 0, 3, 0, 0, 260523, 66, 144);
    mcd_case("c04 v-only", 24, 18, 3, 1, 1, 8, 0, 6, 4, 8, 8, 5, 0, 0, 0, 297019, 114, 70);
    mcd_case("c05 hv", 24, 18, 3, 1, 1, 8, 0, 10, 8, 8, 8, 0 - 13, 21, 0, 0, 283279, 164, 94);
    mcd_case("c06 tl-overhang", 24, 18, 3, 1, 1, 8, 0, 0, 0, 8, 8, 0 - 9, 0 - 7, 0, 0, 288945, 0, 38);
    mcd_case("c07 br-overhang", 24, 18, 3, 1, 1, 8, 0, 16, 10, 8, 8, 60, 50, 0, 0, 366794, 146, 180);
    mcd_case("c08 wholly-out", 24, 18, 3, 1, 1, 8, 0, 8, 8, 8, 8, 0, 512, 0, 0, 210996, 167, 108);
    mcd_case("c09 chroma", 24, 18, 3, 1, 1, 8, 1, 3, 2, 4, 4, 7, 0 - 5, 0, 1, 15534, 182, 64);
    mcd_case("c10 w4-sharp", 24, 18, 3, 1, 1, 8, 0, 5, 5, 4, 8, 0, 9, 2, 2, 81628, 25, 63);
    mcd_case("c11 mixed-filt", 24, 18, 3, 1, 1, 8, 0, 6, 6, 8, 8, 11, 19, 1, 2, 262426, 139, 194);
    mcd_case("c12 10-bit", 16, 12, 1, 0, 0, 10, 0, 4, 4, 8, 8, 0 - 3, 5, 0, 0, 873423, 219, 540);
    mcd_case("c13 12-bit", 16, 12, 1, 0, 0, 12, 0, 4, 4, 8, 8, 0 - 3, 5, 0, 0, 873351, 219, 540);
    mcd_case("c14 extreme-neg", 24, 18, 3, 1, 1, 8, 0, 8, 8, 8, 8, 0 - 30000, 0 - 30000, 0, 0, 0, 0, 0);
    mcd_case("c14b extreme-pos", 24, 18, 3, 1, 1, 8, 0, 8, 8, 8, 8, 30000, 30000, 0, 0, 374400, 180, 180);
    mcd_case("c15 h4-remap", 24, 18, 3, 1, 1, 8, 0, 6, 6, 8, 4, 9, 0, 0, 0, 86793, 111, 64);
    mcd_case("c16 big-16x16", 48, 32, 3, 1, 1, 8, 0, 12, 9, 16, 16, 0 - 27, 43, 0, 1, 4154216, 173, 164);
    return 0;
}

fn test_mc_pred_chroma_full() {
    # c09 full 4x4 block, every pixel (chroma plane, subsampled MV, w<=4 remap, SMOOTH v).
    var ref = mcd_pair(24, 18, 3, 1, 1, 8, 0);
    var d = Mcd_Dst;
    assert_eq(av1_mc_pred_block(d, ref, 1, 3, 2, 4, 4, 7, 0 - 5, 0, 1), DR_OK, "c09 full decode");
    var exp = alloc(16 * 8);
    store64(exp + 0, 182);   store64(exp + 8, 195);   store64(exp + 16, 210);  store64(exp + 24, 132);
    store64(exp + 32, 205);  store64(exp + 40, 213);  store64(exp + 48, 161);  store64(exp + 56, 55);
    store64(exp + 64, 195);  store64(exp + 72, 178);  store64(exp + 80, 77);   store64(exp + 88, 34);
    store64(exp + 96, 157);  store64(exp + 104, 96);  store64(exp + 112, 49);  store64(exp + 120, 64);
    var i = 0;
    while (i < 16) {
        assert_eq(dr_frame_get(d, 1, 3 + (i % 4), 2 + (i / 4)), load64(exp + (i * 8)), "c09 pixel");
        i = i + 1;
    }
    return 0;
}

fn test_mc_pred_confinement() {
    # the write-back touches ONLY the block: sentinel 7 must survive on all four sides.
    var ref = mcd_pair(24, 18, 3, 1, 1, 8, 0);
    var d = Mcd_Dst;
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 3, 8, 8, 0 - 13, 21, 0, 0), DR_OK, "confinement decode");
    assert_eq(dr_frame_get(d, 0, 3, 3), 7, "left column untouched");
    assert_eq(dr_frame_get(d, 0, 12, 3), 7, "right column untouched");
    assert_eq(dr_frame_get(d, 0, 4, 2), 7, "row above untouched");
    assert_eq(dr_frame_get(d, 0, 4, 11), 7, "row below untouched");
    assert_eq(dr_frame_get(d, 1, 2, 2), 7, "other plane untouched");
    return 0;
}

fn test_mc_pred_border_independent() {
    # frame borders (zeroed padding) must not leak into the clamped gather: c05 on a
    # border=8 frame pair decodes to the border=0 checksum.
    var ref = mcd_pair(24, 18, 3, 1, 1, 8, 8);
    var d = Mcd_Dst;
    assert_eq(av1_mc_pred_block(d, ref, 0, 10, 8, 8, 8, 0 - 13, 21, 0, 0), DR_OK, "border decode");
    assert_eq(mcd_cs(d, 0, 10, 8, 8, 8), 283279, "c05 checksum with border=8");
    return 0;
}

fn test_mc_pred_rejects() {
    var ref = mcd_pair(24, 18, 3, 1, 1, 8, 0);
    var d = Mcd_Dst;
    # BILINEAR interpolation filter — clean reject until its bite lands.
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 3, 8, 8, 0, 0, 3, 0), DR_ERR_UNSUPPORTED, "bilinear fx");
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 3, 8, 8, 0, 0, 0, 3), DR_ERR_UNSUPPORTED, "bilinear fy");
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 3, 8, 8, 0, 0, 4, 0), DR_ERR_BOUNDS, "filter out of range");
    # scaled / mismatched reference — clean reject until the scaled-MC bite lands.
    var small = dr_frame_new(20, 18, 3, 1, 1, 8, 0, Mcd_Err);
    mcd_fill(small);
    assert_eq(av1_mc_pred_block(d, small, 0, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_UNSUPPORTED, "scaled ref");
    var deep = dr_frame_new(24, 18, 3, 1, 1, 10, 0, Mcd_Err);
    assert_eq(av1_mc_pred_block(d, deep, 0, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_UNSUPPORTED, "bit-depth mismatch");
    # scaled-CHROMA blind spot: luma 24x18 vs 23x17 collide to 12x9 chroma at 4:2:0. The gate
    # must reject on BOTH the luma plane AND the chroma plane (a per-plane-only check would
    # accept the chroma plane and emit wrong pixels — spec 7.11.3.3 scaledness is luma-derived).
    var odd = dr_frame_new(23, 17, 3, 1, 1, 8, 0, Mcd_Err);
    mcd_fill(odd);
    assert_eq(av1_mc_pred_block(d, odd, 0, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_UNSUPPORTED, "scaled ref luma plane");
    assert_eq(av1_mc_pred_block(d, odd, 1, 2, 2, 4, 4, 0, 0, 0, 0), DR_ERR_UNSUPPORTED, "scaled ref chroma collision");
    # hostile geometry.
    assert_eq(av1_mc_pred_block(0, ref, 0, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "null dst");
    assert_eq(av1_mc_pred_block(d, 0, 0, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "null ref");
    assert_eq(av1_mc_pred_block(d, ref, 3, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "plane out of range");
    assert_eq(av1_mc_pred_block(d, ref, 0 - 1, 4, 3, 8, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "negative plane");
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 3, 0, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "zero width");
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 3, 8, 129, 0, 0, 0, 0), DR_ERR_BOUNDS, "oversize block");
    assert_eq(av1_mc_pred_block(d, ref, 0, 20, 3, 8, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "block past right edge");
    assert_eq(av1_mc_pred_block(d, ref, 0, 4, 0 - 1, 8, 8, 0, 0, 0, 0), DR_ERR_BOUNDS, "negative y");
    # i64-overflow guard bypass: a hostile x near i64-max would wrap (x + w) negative and slip
    # the block-inside-plane check, reaching dr_frame_set with an unclamped coord (OOB write).
    # The subtraction-form guard (x > pw - w) must reject it cleanly.
    assert_eq(av1_mc_pred_block(d, ref, 0, 9223372036854775807, 0, 8, 8, 0, 0, 0, 0),
    DR_ERR_BOUNDS, "x overflow guard bypass");
    assert_eq(av1_mc_pred_block(d, ref, 0, 0, 9223372036854775807, 8, 8, 0, 0, 0, 0),
    DR_ERR_BOUNDS, "y overflow guard bypass");
    return 0;
}

# COMPOUND_AVERAGE MC (7.11.3.1 isCompound): with INTEGER MVs the intermediate math
# collapses to (ref0[s0] + ref1[s1] + 1) >> 1 (prep = pixel<<ib; combine strips it +
# halves). Two DISTINCT gradient refs, exhaustive 1024-px oracle with edge clamp.
fn test_mc_compound_avg() {
    var r0 = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    var r1 = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            dr_frame_set(r0, 0, x, y, (x + (2 * y)) & 255);
            dr_frame_set(r1, 0, x, y, ((3 * x) + y) & 255);
            x = x + 1;
        }
        y = y + 1;
    }
    var d = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    # ref0 MV (row 16=+2px, col 8=+1px); ref1 MV (row -8=-1px, col 24=+3px). Filter 0.
    assert_eq(av1_mc_pred_compound(d, r0, r1, 0, 0, 0, 32, 32, 16, 8, 0 - 8, 24, 0, 0, 8, 8),
    DR_OK, "compound-average decodes");
    var diff = 0;
    y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            var x0 = x + 1;
            if (x0 > 31) { x0 = 31; }
            var y0 = y + 2;
            if (y0 > 31) { y0 = 31; }
            var x1 = x + 3;
            if (x1 > 31) { x1 = 31; }
            var y1 = y - 1;
            if (y1 < 0) { y1 = 0; }
            var exp = (dr_frame_get(r0, 0, x0, y0) + dr_frame_get(r1, 0, x1, y1) + 1) >> 1;
            if (dr_frame_get(d, 0, x, y) != exp) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "compound AVERAGE == (ref0 + ref1 + 1) >> 1 (integer MVs, 1024 px)");
    # SUBPEL: averaging a ref with ITSELF (same MV) must stay within 1 of the single-ref
    # prediction — the ONLY difference is the split-round timing. A WRONG prep shift
    # (e.g. 6 vs 6+ib) misscales the intermediate by ~2^ib, so the diff blows far past 1.
    # Covers all three subpel prep paths: 2D (both), H-only, V-only.
    mcd_compound_self(r0, 13, 10, "2D subpel");     # both axes fractional
    mcd_compound_self(r0, 0, 10, "H-only subpel");  # x fractional, y integer
    mcd_compound_self(r0, 13, 0, "V-only subpel");  # x integer, y fractional
    return 0;
}
fn mcd_compound_self(ref, mvr, mvc, tag): i64 {
    var s = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    av1_mc_pred_block(s, ref, 0, 0, 0, 32, 32, mvr, mvc, 0, 0);
    var d = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    av1_mc_pred_compound(d, ref, ref, 0, 0, 0, 32, 32, mvr, mvc, mvr, mvc, 0, 0, 8, 8);
    var big = 0;
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            var dd = dr_frame_get(d, 0, x, y) - dr_frame_get(s, 0, x, y);
            if (dd < 0) { dd = 0 - dd; }
            if (dd > 1) { big = big + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(big, 0, tag);
    return 0;
}

# COMPOUND DISTANCE (jnt, 0.7.88): with INTEGER MVs + explicit weights the combine collapses
# to (ref0[s0]*Fwd + ref1[s1]*Bck + 8) >> 4 (prep = pixel<<ib; combine >>(ib+4), the 2^ib
# cancels). Fwd->ref0, Bck->ref1. SAME two gradient refs + MVs + edge clamp as the AVERAGE
# oracle above — the ONLY change is the weighting. Independent (scripts/refs/dist_wtd_ref.py).
fn mcd_dist_oracle(r0, r1, fwd, bck, tag): i64 {
    var d = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    assert_eq(av1_mc_pred_compound(d, r0, r1, 0, 0, 0, 32, 32, 16, 8, 0 - 8, 24, 0, 0, fwd, bck),
    DR_OK, tag);
    var diff = 0;
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            var x0 = x + 1;
            if (x0 > 31) { x0 = 31; }
            var y0 = y + 2;
            if (y0 > 31) { y0 = 31; }
            var x1 = x + 3;
            if (x1 > 31) { x1 = 31; }
            var y1 = y - 1;
            if (y1 < 0) { y1 = 0; }
            var exp = ((dr_frame_get(r0, 0, x0, y0) * fwd) + (dr_frame_get(r1, 0, x1, y1) * bck) + 8) >>> 4;
            if (dr_frame_get(d, 0, x, y) != exp) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, tag);
    return 0;
}
fn test_mc_compound_dist() {
    var r0 = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    var r1 = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            dr_frame_set(r0, 0, x, y, (x + (2 * y)) & 255);
            dr_frame_set(r1, 0, x, y, ((3 * x) + y) & 255);
            x = x + 1;
        }
        y = y + 1;
    }
    mcd_dist_oracle(r0, r1, 13, 3, "DISTANCE Fwd=13 == (r0*13+r1*3+8)>>4 (1024 px)");
    mcd_dist_oracle(r0, r1, 3, 13, "DISTANCE Fwd=3 == (r0*3+r1*13+8)>>4 (1024 px)");
    mcd_dist_oracle(r0, r1, 7, 9, "DISTANCE Fwd=7 == (r0*7+r1*9+8)>>4 (1024 px)");
    # Fwd=Bck=8 must be BIT-IDENTICAL to the plain average (Option A regression witness).
    mcd_dist_oracle(r0, r1, 8, 8, "DISTANCE Fwd=8 == AVERAGE oracle (bit-exact)");
    # DISTANCE (13/3) must actually DIFFER from AVERAGE (8/8) — else the mode is untested.
    var da = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    var dd = dr_frame_new(32, 32, 1, 0, 0, 8, 8, Mcd_Err);
    av1_mc_pred_compound(da, r0, r1, 0, 0, 0, 32, 32, 16, 8, 0 - 8, 24, 0, 0, 8, 8);
    av1_mc_pred_compound(dd, r0, r1, 0, 0, 0, 32, 32, 16, 8, 0 - 8, 24, 0, 0, 13, 3);
    var ndiff = 0;
    y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            if (dr_frame_get(da, 0, x, y) != dr_frame_get(dd, 0, x, y)) { ndiff = ndiff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(ndiff > 0, 1, "DISTANCE (13/3) DIFFERS from AVERAGE (8/8) — mode observable");
    return 0;
}

fn main() {
    alloc_init();
    Mcd_Err = alloc(8);
    test_group("MC driver geometry (7.11.3.3 unscaled split)");
    test_mc_pos16();
    test_group("MC driver known answers (7.11.3.4 spec-literal reference)");
    test_mc_pred_known_answers();
    test_mc_pred_chroma_full();
    test_group("MC driver write confinement + border independence");
    test_mc_pred_confinement();
    test_mc_pred_border_independent();
    test_group("MC driver hostile-input rejects");
    test_mc_pred_rejects();
    test_group("compound-average MC (7.11.3.1 isCompound)");
    test_mc_compound_avg();
    test_group("compound-distance MC (7.11.3.15 jnt weights)");
    test_mc_compound_dist();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
