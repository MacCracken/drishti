# tests/av1_decode.tcyr — AV1 in-loop filter pipeline (av1_apply_loop_filters):
# deblock -> CDEF -> LR chaining + the CurrFrame/CdefFrame/LrFrame management.
# The individual filters are tested in their own suites; here we verify the
# orchestration (which filters run, which frame is returned) against known-answer
# single-filter cases.
include "src/main.cyr"
include "src/av1_decode.cyr"

fn dec_fill(f, w, h, v): i64 {
    var y = 0;
    while (y < h) {
        var x = 0;
        while (x < w) { dr_frame_set(f, 0, x, y, v); x = x + 1; }
        y = y + 1;
    }
    return 0;
}
# a frame header carrying the loop-filter level, CDEF params, and UsesLr.
fn mk_dec_fh(lf_level, damping, y_pri, y_sec, uses_lr): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_LF_LEVEL + 0, lf_level);
    store64(fh + AV1FH_LF_LEVEL + 8, lf_level);
    store64(fh + AV1FH_LF_LEVEL + 16, lf_level);
    store64(fh + AV1FH_LF_LEVEL + 24, lf_level);
    store64(fh + AV1FH_CDEF_DAMPING, damping);
    store64(fh + AV1FH_CDEF_Y_PRI, y_pri);
    store64(fh + AV1FH_CDEF_Y_SEC, y_sec);
    store64(fh + AV1FH_USES_LR, uses_lr);
    return fh;
}
fn mk_dec_seq(enable_cdef): i64 {
    var s = alloc(256);
    store64(s + AV1_SEQ_ENABLE_CDEF, enable_cdef);
    return s;
}
# 32x32 border-8 tile (mi 8x8): flat 128 + a spike 140 at (11,11); CdefIdx 0, no skip.
fn mk_dec_tile(): i64 {
    var oe = alloc(8);
    var frame = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    dec_fill(frame, 32, 32, 128);
    dr_frame_set(frame, 0, 11, 11, 140);
    var tile = av1_tile_new(frame, 8, 8, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    av1_cdefidx_set(tile, 0, 0, 0);
    var r = 0;
    while (r < 8) {
        var c = 0;
        while (c < 8) { av1_grid_set(tile, AV1TILE_SKIPS, r, c, 0); c = c + 1; }
        r = r + 1;
    }
    return tile;
}

# No filters enabled: deblock is a no-op (level 0), CDEF off, no LR -> the pipeline
# returns the input frame unchanged.
fn test_pipeline_none() {
    var tile = mk_dec_tile();
    var frame = load64(tile + AV1TILE_FRAME);
    var oe = alloc(8);
    var result = av1_apply_loop_filters(tile, mk_dec_fh(0, 4, 8, 4, 0), mk_dec_seq(0), 0, oe);
    assert_eq(result, frame, "no filters -> result is the input frame");
    assert_eq(dr_frame_get(result, 0, 11, 11), 140, "no filters -> spike unchanged (140)");
    assert_eq(load64(oe), DR_OK, "no filters -> DR_OK");
    return 0;
}
# CDEF enabled -> the pipeline returns a NEW CdefFrame with the spike deringed
# (matching the standalone CDEF driver: 140 -> 138), input frame untouched.
fn test_pipeline_cdef() {
    var tile = mk_dec_tile();
    var frame = load64(tile + AV1TILE_FRAME);
    var oe = alloc(8);
    var result = av1_apply_loop_filters(tile, mk_dec_fh(0, 4, 8, 4, 0), mk_dec_seq(1), 0, oe);
    assert_eq(load64(oe), DR_OK, "cdef -> DR_OK");
    assert_eq(result != frame, 1, "cdef -> result is a new CdefFrame");
    assert_eq(dr_frame_get(result, 0, 11, 11), 138, "cdef -> spike deringed to 138");
    assert_eq(dr_frame_get(frame, 0, 11, 11), 140, "input frame untouched by CDEF");
    return 0;
}
# CDEF + LR (UsesLr, all-NONE units) -> LR chains after CDEF, returning a fresh
# LrFrame that copies the CDEF result through (138 carries).
fn test_pipeline_cdef_lr() {
    var tile = mk_dec_tile();
    var frame = load64(tile + AV1TILE_FRAME);
    var lrp = av1_lr_params_new(32, 32, 1, 0, 0, 1);
    var oe = alloc(8);
    var result = av1_apply_loop_filters(tile, mk_dec_fh(0, 4, 8, 4, 1), mk_dec_seq(1), lrp, oe);
    assert_eq(load64(oe), DR_OK, "cdef+lr -> DR_OK");
    assert_eq(result != frame, 1, "cdef+lr -> result is the LrFrame");
    assert_eq(dr_frame_get(result, 0, 11, 11), 138, "cdef+lr -> LR carries the CDEF result (138)");
    return 0;
}
# Deblocking only (level 40, a vertical block edge) -> in place on the input frame.
fn test_pipeline_deblock() {
    var oe = alloc(8);
    var frame = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var tile = av1_tile_new(frame, 4, 4, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    var r = 0;
    while (r < 4) {
        var c = 0;
        while (c < 4) {
            av1_grid_set(tile, AV1TILE_MISIZES, r, c, 3);   # BLOCK_8X8
            av1_grid_set(tile, AV1TILE_SKIPS, r, c, 0);
            av1_lftx_set(tile, 0, r, c, 1);                 # TX_8X8
            c = c + 1;
        }
        r = r + 1;
    }
    var y = 0;
    while (y < 16) {
        var x = 0;
        while (x < 16) {
            var v = 100;
            if (x >= 8) { v = 140; }
            dr_frame_set(frame, 0, x, y, v);
            x = x + 1;
        }
        y = y + 1;
    }
    var result = av1_apply_loop_filters(tile, mk_dec_fh(40, 4, 0, 0, 0), mk_dec_seq(0), 0, oe);
    assert_eq(result, frame, "deblock-only -> result is the in-place deblocked input frame");
    assert_eq(dr_frame_get(result, 0, 8, 4), 125, "deblock smoothed the x=8 edge (125)");
    return 0;
}

# ================================================================
# Frame-header filter activation: av1_lr_params_from_fh builds the LR params from
# the parsed header, av1_activate_intra_filters attaches CDEF ctx + LR params to a
# tile — the step that turns the wired-but-inert CDEF/LR reads live.
# ================================================================
# fh carrying the LR + CDEF header fields the activation helpers read.
fn mk_act_fh(uses_lr, rtype0, usize0, cdef_bits, allow_intrabc): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_USES_LR, uses_lr);
    store64(fh + AV1FH_FRAME_RESTORATION_TYPE + 0, rtype0);
    store64(fh + AV1FH_LR_SIZE + 0, usize0);
    store64(fh + AV1FH_CDEF_BITS, cdef_bits);
    store64(fh + AV1FH_ALLOW_INTRABC, allow_intrabc);
    store64(fh + AV1FH_CODED_LOSSLESS, 0);
    store64(fh + AV1FH_USE_SUPERRES, 0);
    store64(fh + AV1FH_SUPERRES_DENOM, 8);
    return fh;
}
# seq carrying subsampling + enable_cdef.
fn mk_act_seq(enable_cdef): i64 {
    var s = alloc(256);
    store64(s + AV1_SEQ_ENABLE_CDEF, enable_cdef);
    store64(s + AV1_SEQ_SUBX, 0);
    store64(s + AV1_SEQ_SUBY, 0);
    return s;
}
# from_fh maps the header's per-plane restoration type/size + frame flags into a
# fresh Av1LrParams (UsesLr) or 0 (no LR), never an error on the no-LR path.
fn test_lr_params_from_fh() {
    var oe = alloc(8);
    var fh = mk_act_fh(1, AV1_RESTORE_WIENER, 64, 3, 0);
    var seq = mk_act_seq(1);
    var p = av1_lr_params_from_fh(fh, seq, 128, 64, 1, oe);
    assert_eq(load64(oe), DR_OK, "from_fh -> DR_OK");
    assert_eq(p != 0, 1, "UsesLr -> non-null params");
    assert_eq(load64(p + AV1LRP_USES), 1, "UsesLr propagated");
    assert_eq(load64(p + AV1LRP_RTYPE), AV1_RESTORE_WIENER, "plane0 rtype WIENER (from header)");
    assert_eq(load64(p + AV1LRP_USIZE), 64, "plane0 unit size 64 (from header)");
    assert_eq(av1_lr_ucols_of(p, 0), 2, "128/64 -> 2 unit cols");
    assert_eq(av1_lr_srdenom(p), 8, "SuperresDenom 8 (from header flags)");
    assert_eq(av1_lr_intrabc(p), 0, "allow_intrabc 0 (from header flags)");
    # UsesLr == 0 -> null params, and NOT an error (frame simply uses no LR).
    var p0 = av1_lr_params_from_fh(mk_act_fh(0, AV1_RESTORE_NONE, 0, 3, 0), seq, 128, 64, 1, oe);
    assert_eq(p0, 0, "no UsesLr -> null params");
    assert_eq(load64(oe), DR_OK, "no UsesLr -> not an error");
    return 0;
}
# activate attaches the CDEF ctx (only when the sequence enables CDEF) + LR params
# (always) to a decode tile from the header.
fn test_activate_intra_filters() {
    var tile = mk_dec_tile();
    var fh = mk_act_fh(1, AV1_RESTORE_WIENER, 64, 2, 0);
    var lrp = av1_lr_params_new(32, 32, 1, 0, 0, 1);
    var rc = av1_activate_intra_filters(tile, mk_act_seq(1), fh, lrp);
    assert_eq(rc, DR_OK, "activate -> DR_OK");
    assert_eq(load64(tile + AV1TILE_LRPARAMS), lrp, "LR params attached");
    var ctx = load64(tile + AV1TILE_CDEF_CTX);
    assert_eq(ctx != 0, 1, "CDEF enabled -> ctx attached");
    assert_eq(load64(ctx + 8), 2, "ctx carries cdef_bits=2 (from header)");
    # CDEF disabled -> ctx stays null (read_cdef inert), LR still attached.
    var tile2 = mk_dec_tile();
    var lrp2 = av1_lr_params_new(32, 32, 1, 0, 0, 1);
    assert_eq(av1_activate_intra_filters(tile2, mk_act_seq(0), fh, lrp2), DR_OK, "activate (no CDEF) -> DR_OK");
    assert_eq(load64(tile2 + AV1TILE_CDEF_CTX), 0, "CDEF off -> ctx stays null");
    assert_eq(load64(tile2 + AV1TILE_LRPARAMS), lrp2, "LR still attached with CDEF off");
    return 0;
}

# ================================================================
# Tile-group OBU parsing (spec 5.11.1): the group header (tg_start/tg_end +
# present flag) + per-tile byte-range extraction. Hand-packed payloads comment
# every field's bit packing.
# ================================================================
# a frame header carrying only the tile-info fields the tile-group parser reads.
fn mk_tg_fh(tile_cols, tile_rows, cols_log2, rows_log2, tsbytes): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_TILE_COLS, tile_cols);
    store64(fh + AV1FH_TILE_ROWS, tile_rows);
    store64(fh + AV1FH_TILE_COLS_LOG2, cols_log2);
    store64(fh + AV1FH_TILE_ROWS_LOG2, rows_log2);
    store64(fh + AV1FH_TILE_SIZE_BYTES, tsbytes);
    return fh;
}
# le(n) little-endian byte read (spec 4.10.4).
fn test_tg_read_le() {
    var b = alloc(4);
    store8(b + 0, 0x78); store8(b + 1, 0x56); store8(b + 2, 0x34); store8(b + 3, 0x12);
    assert_eq(av1_read_le(b, 1), 0x78, "le(1)");
    assert_eq(av1_read_le(b, 2), 0x5678, "le(2) little-endian");
    assert_eq(av1_read_le(b, 3), 0x345678, "le(3)");
    assert_eq(av1_read_le(b, 4), 0x12345678, "le(4)");
    return 0;
}
# Single tile (NumTiles == 1): no group header bits, the whole payload is tile 0.
fn test_tg_single() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(1);
    var buf = alloc(6);
    var i = 0;
    while (i < 6) { store8(buf + i, 0x40 + i); i = i + 1; }
    var n = av1_tile_group_parse(tg, buf, 6, mk_tg_fh(1, 1, 0, 0, 1), oe);
    assert_eq(load64(oe), DR_OK, "single-tile parse ok");
    assert_eq(n, 1, "one tile in group");
    assert_eq(av1_tg_start(tg), 0, "tg_start 0");
    assert_eq(av1_tg_end(tg), 0, "tg_end 0");
    assert_eq(av1_tg_tile_offset(tg, 0), 0, "tile0 offset 0 (no header)");
    assert_eq(av1_tg_tile_size(tg, 0), 6, "tile0 size = whole payload");
    return 0;
}
# 2x2 = 4 tiles, tile_start_and_end_present_flag = 0 -> whole frame is one group.
# Non-last tiles carry a le(1) size prefix; the last takes the remainder.
fn test_tg_multi_no_present() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(4);
    var buf = alloc(18);
    store8(buf + 0, 0x00);                              # [0] header: present(bit7)=0
    store8(buf + 1, 0x02);                              # tile0 size_minus_1=2 -> size 3
    store8(buf + 2, 0xA0); store8(buf + 3, 0xA1); store8(buf + 4, 0xA2);   # tile0 data
    store8(buf + 5, 0x01);                              # tile1 size_minus_1=1 -> size 2
    store8(buf + 6, 0xB0); store8(buf + 7, 0xB1);       # tile1 data
    store8(buf + 8, 0x03);                              # tile2 size_minus_1=3 -> size 4
    store8(buf + 9, 0xC0); store8(buf + 10, 0xC1); store8(buf + 11, 0xC2); store8(buf + 12, 0xC3);
    store8(buf + 13, 0xD0); store8(buf + 14, 0xD1);     # tile3 (last) data, 5 bytes
    store8(buf + 15, 0xD2); store8(buf + 16, 0xD3); store8(buf + 17, 0xD4);
    var n = av1_tile_group_parse(tg, buf, 18, mk_tg_fh(2, 2, 1, 1, 1), oe);
    assert_eq(load64(oe), DR_OK, "multi parse ok");
    assert_eq(n, 4, "4 tiles in group");
    assert_eq(av1_tg_start(tg), 0, "tg_start 0");
    assert_eq(av1_tg_end(tg), 3, "tg_end 3 (all tiles)");
    assert_eq(av1_tg_num_tiles(tg), 4, "NumTiles 4");
    assert_eq(av1_tg_tile_offset(tg, 0), 2, "tile0 data offset 2");
    assert_eq(av1_tg_tile_size(tg, 0), 3, "tile0 size 3");
    assert_eq(av1_tg_tile_offset(tg, 1), 6, "tile1 data offset 6");
    assert_eq(av1_tg_tile_size(tg, 1), 2, "tile1 size 2");
    assert_eq(av1_tg_tile_offset(tg, 2), 9, "tile2 data offset 9");
    assert_eq(av1_tg_tile_size(tg, 2), 4, "tile2 size 4");
    assert_eq(av1_tg_tile_offset(tg, 3), 13, "tile3 (last) data offset 13");
    assert_eq(av1_tg_tile_size(tg, 3), 5, "tile3 size 5 (remaining)");
    assert_eq(load8(buf + av1_tg_tile_offset(tg, 2)), 0xC0, "tile2 offset points at its data");
    assert_eq(av1_tg_tile_row(3, 2), 1, "tile3 row 1");
    assert_eq(av1_tg_tile_col(3, 2), 1, "tile3 col 1");
    assert_eq(av1_tg_tile_col(2, 2), 0, "tile2 col 0");
    return 0;
}
# present flag set with a sub-range: only tiles [1,2] are in this group; tiles 0,3
# stay absent (offset -1). Header byte = present(1) tg_start(01=1) tg_end(10=2).
fn test_tg_present_subrange() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(4);
    var buf = alloc(7);
    store8(buf + 0, 0xB0);                              # 1 01 10 000: present=1, tg_start=1, tg_end=2
    store8(buf + 1, 0x01);                              # tile1 size_minus_1=1 -> size 2
    store8(buf + 2, 0xE0); store8(buf + 3, 0xE1);       # tile1 data
    store8(buf + 4, 0xF0); store8(buf + 5, 0xF1); store8(buf + 6, 0xF2);   # tile2 (last) data
    var n = av1_tile_group_parse(tg, buf, 7, mk_tg_fh(2, 2, 1, 1, 1), oe);
    assert_eq(load64(oe), DR_OK, "subrange parse ok");
    assert_eq(n, 2, "2 tiles in group");
    assert_eq(av1_tg_start(tg), 1, "tg_start 1");
    assert_eq(av1_tg_end(tg), 2, "tg_end 2");
    assert_eq(av1_tg_tile_offset(tg, 0), 0 - 1, "tile0 absent (-1)");
    assert_eq(av1_tg_tile_offset(tg, 1), 2, "tile1 data offset 2");
    assert_eq(av1_tg_tile_size(tg, 1), 2, "tile1 size 2");
    assert_eq(av1_tg_tile_offset(tg, 2), 4, "tile2 data offset 4");
    assert_eq(av1_tg_tile_size(tg, 2), 3, "tile2 size 3 (remaining)");
    assert_eq(av1_tg_tile_offset(tg, 3), 0 - 1, "tile3 absent (-1)");
    return 0;
}
# TileSizeBytes = 2: the non-last size field is a 2-byte le() read — exercise the
# full multi-byte size path through the parser (not just av1_read_le in isolation).
fn test_tg_tsbytes2() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(2);
    var buf = alloc(9);
    store8(buf + 0, 0x00);                              # header: present=0
    store8(buf + 1, 0x03); store8(buf + 2, 0x00);       # tile0 size_minus_1 = le2(0x0003)=3 -> size 4
    store8(buf + 3, 0x50); store8(buf + 4, 0x51); store8(buf + 5, 0x52); store8(buf + 6, 0x53);  # tile0 data
    store8(buf + 7, 0x60); store8(buf + 8, 0x61);       # tile1 (last) data
    var n = av1_tile_group_parse(tg, buf, 9, mk_tg_fh(2, 1, 1, 0, 2), oe);
    assert_eq(load64(oe), DR_OK, "tsbytes=2 parse ok");
    assert_eq(n, 2, "2 tiles");
    assert_eq(av1_tg_tile_offset(tg, 0), 3, "tile0 data offset 3 (past 2-byte size field)");
    assert_eq(av1_tg_tile_size(tg, 0), 4, "tile0 size 4 (le2 size field)");
    assert_eq(av1_tg_tile_offset(tg, 1), 7, "tile1 data offset 7");
    assert_eq(av1_tg_tile_size(tg, 1), 2, "tile1 size 2 (remaining)");
    return 0;
}
# Single-tile group at a nonzero index (tg_start == tg_end != 0): the one in-group
# tile is also the last, so no size prefix — it takes the whole remaining payload.
fn test_tg_single_nonzero_index() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(4);
    var buf = alloc(5);
    store8(buf + 0, 0xD0);                              # 1 10 10 000: present=1, tg_start=2, tg_end=2
    store8(buf + 1, 0x70); store8(buf + 2, 0x71); store8(buf + 3, 0x72); store8(buf + 4, 0x73);  # tile2 data
    var n = av1_tile_group_parse(tg, buf, 5, mk_tg_fh(2, 2, 1, 1, 1), oe);
    assert_eq(load64(oe), DR_OK, "single-nonzero-index parse ok");
    assert_eq(n, 1, "1 tile in group");
    assert_eq(av1_tg_start(tg), 2, "tg_start 2");
    assert_eq(av1_tg_end(tg), 2, "tg_end 2");
    assert_eq(av1_tg_tile_offset(tg, 2), 1, "tile2 data offset 1 (post-header, last tile)");
    assert_eq(av1_tg_tile_size(tg, 2), 4, "tile2 size 4 (whole remainder)");
    assert_eq(av1_tg_tile_offset(tg, 0), 0 - 1, "tile0 absent");
    assert_eq(av1_tg_tile_offset(tg, 1), 0 - 1, "tile1 absent");
    assert_eq(av1_tg_tile_offset(tg, 3), 0 - 1, "tile3 absent");
    return 0;
}
# Trust no input byte: lying sizes, truncation, inverted ranges, undersized cap.
fn test_tg_adversarial() {
    var oe = alloc(8);
    # (a) lying tile size: tile0 claims 201 bytes in a 5-byte payload.
    var tg = av1_tile_group_new(2);
    var buf = alloc(5);
    store8(buf + 0, 0x00);                              # present=0
    store8(buf + 1, 0xC8);                              # size_minus_1=200 -> size 201
    store8(buf + 2, 0x11); store8(buf + 3, 0x22); store8(buf + 4, 0x33);
    assert_eq(av1_tile_group_parse(tg, buf, 5, mk_tg_fh(2, 1, 1, 0, 1), oe), 0, "lying size -> 0 tiles");
    assert_eq(load64(oe), DR_ERR_TRUNCATED, "lying tile size -> truncated");
    # (b) truncated size field: payload is just the header byte.
    var tg2 = av1_tile_group_new(2);
    var buf2 = alloc(1);
    store8(buf2 + 0, 0x00);
    assert_eq(av1_tile_group_parse(tg2, buf2, 1, mk_tg_fh(2, 1, 1, 0, 1), oe), 0, "no size field -> 0");
    assert_eq(load64(oe), DR_ERR_TRUNCATED, "missing size field -> truncated");
    # (c) inverted range: present=1, tg_start=2(10), tg_end=1(01) -> 1 10 01 000 = 0xC8.
    var tg3 = av1_tile_group_new(4);
    var buf3 = alloc(4);
    store8(buf3 + 0, 0xC8); store8(buf3 + 1, 0x00); store8(buf3 + 2, 0x00); store8(buf3 + 3, 0x00);
    assert_eq(av1_tile_group_parse(tg3, buf3, 4, mk_tg_fh(2, 2, 1, 1, 1), oe), 0, "tg_end<tg_start -> 0");
    assert_eq(load64(oe), DR_ERR_BAD_HEADER, "inverted range -> bad header");
    # (d) cap too small: tg sized for 2, but the frame has 4 tiles.
    var tgsmall = av1_tile_group_new(2);
    assert_eq(av1_tile_group_parse(tgsmall, buf3, 4, mk_tg_fh(2, 2, 1, 1, 1), oe), 0, "cap<NumTiles -> 0");
    assert_eq(load64(oe), DR_ERR_BOUNDS, "cap too small -> bounds");
    return 0;
}

# ================================================================
# Frame-level driver (av1_decode_frame): decode a single-tile keyframe from
# parsed headers + the tile-group payload, end-to-end (encode a tile -> wrap as a
# 1-tile group -> av1_decode_frame -> pixels + grids).
# ================================================================
# Encode a 128x64 keyframe tile (mi 32x16, base_q 40, all-skip DC): SB0 32x32,
# SB1 64x64 — the same plan as av1_tile.tcyr's keyframe round-trip. Returns the
# tile byte buffer, length at *out_len. For NumTiles==1 this buffer IS the
# tile-group payload (no group header bits).
fn frame_enc_keyframe(out_len): i64 {
    var mi = av1_modeinfo_new();
    store64(mi + AV1MI_SKIP, 1);
    store64(mi + AV1MI_YMODE, AV1_DC_PRED);
    store64(mi + AV1MI_UVMODE, AV1_DC_PRED);
    var pp = alloc(6 * 8);
    store64(pp + 0, AV1_PARTITION_SPLIT);
    store64(pp + 8, AV1_PARTITION_NONE);   store64(pp + 16, AV1_PARTITION_NONE);
    store64(pp + 24, AV1_PARTITION_NONE);  store64(pp + 32, AV1_PARTITION_NONE);
    store64(pp + 40, AV1_PARTITION_NONE);
    var pm = alloc(5 * 8);
    var pt = alloc(5 * 8);
    var k = 0;
    while (k < 4) { store64(pm + (k * 8), mi); store64(pt + (k * 8), 3); k = k + 1; }
    store64(pm + (4 * 8), mi);
    store64(pt + (4 * 8), 4);
    var eoe = alloc(8);
    var eframe = dr_frame_new(128, 64, 1, 0, 0, 8, 8, eoe);
    var etile = av1_tile_new(eframe, 32, 16, 40, 1, 0, 1);   # enable_ef=1, reduced_tx=0, 1 plane
    av1_tile_grids_new(etile);
    return av1_encode_intra_tile(etile, pp, pm, pt, 1, out_len);   # disable_cdf=1
}
# a sequence header carrying the fields av1_decode_frame reads (zeroed first —
# alloc is not zero-init).
fn frame_mk_seq(enable_cdef): i64 {
    var s = alloc(AV1_SEQ_SIZE);
    memset(s, 0, AV1_SEQ_SIZE);
    store64(s + AV1_SEQ_BITDEPTH, 8);
    store64(s + AV1_SEQ_NUM_PLANES, 1);
    store64(s + AV1_SEQ_SUBX, 0);
    store64(s + AV1_SEQ_SUBY, 0);
    store64(s + AV1_SEQ_ENABLE_CDEF, enable_cdef);
    store64(s + AV1_SEQ_ENABLE_RESTORATION, 0);
    store64(s + AV1_SEQ_ENABLE_FILTER_INTRA, 0);     # matches the encode tile (ENABLE_FI=0)
    store64(s + AV1_SEQ_ENABLE_INTRA_EDGE, 1);       # matches the encode tile (enable_ef=1)
    return s;
}
# a frame header for the 128x64 keyframe (tile_cols/rows configurable for the
# multi-tile-rejection test). base_q 40, TX_MODE_SELECT, disable_cdf_update=1 —
# all matching the encode tile; loop_filter_level/uses_lr/superres stay 0 (zeroed).
fn frame_mk_fh(tile_cols, tile_rows, tile_cols_log2, tile_rows_log2): i64 {
    var fh = alloc(AV1FH_SIZE);
    memset(fh, 0, AV1FH_SIZE);
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_FRAME_HEIGHT, 64);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_ROWS, 16);
    store64(fh + AV1FH_BASE_Q_IDX, 40);
    store64(fh + AV1FH_TX_MODE, AV1_TX_MODE_SELECT);
    store64(fh + AV1FH_REDUCED_TX_SET, 0);
    store64(fh + AV1FH_TILE_COLS, tile_cols);
    store64(fh + AV1FH_TILE_ROWS, tile_rows);
    store64(fh + AV1FH_TILE_COLS_LOG2, tile_cols_log2);
    store64(fh + AV1FH_TILE_ROWS_LOG2, tile_rows_log2);
    store64(fh + AV1FH_TILE_SIZE_BYTES, 1);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 1);        # matches encode disable_cdf=1
    return fh;
}
# no filters (enable_cdef=0, uses_lr=0, lf_level=0): decode the keyframe end-to-end
# to a flat DC (128) frame; the pipeline returns the reconstruction unchanged.
fn test_frame_decode_plain() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    assert_eq(olen > 0, 1, "encoded a keyframe tile");
    var oe = alloc(8);
    var frame = av1_decode_frame(frame_mk_seq(0), frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "decode_frame ok");
    assert_eq(frame != 0, 1, "decode_frame returns a frame");
    assert_eq(dr_frame_width(frame), 128, "frame width 128");
    assert_eq(dr_frame_height(frame), 64, "frame height 64");
    # flat DC prediction, skip -> no residual: every luma sample is 128.
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 128) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "keyframe pixels all 128 (headers -> pixels)");
    return 0;
}
# CDEF enabled: the pipeline runs the CDEF stage (into a fresh CdefFrame) and
# returns it. All-skip blocks -> cdef_idx never read -> CDEF is a no-op, so the
# pixels stay 128 — but the decode drove the full seq/fh -> activate -> filter path.
fn test_frame_decode_cdef() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var frame = av1_decode_frame(frame_mk_seq(1), frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "decode_frame (CDEF) ok");
    assert_eq(frame != 0, 1, "decode_frame (CDEF) returns a frame");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 128, "CDEF-path pixels still 128 (skip -> no dering)");
    return 0;
}
# Multi-tile frames are unsupported here -> rejected cleanly (never a wrong
# decode). Uses a valid 2-tile group payload so the parse succeeds first.
fn test_frame_decode_multitile_rejected() {
    var oe = alloc(8);
    var buf = alloc(8);
    store8(buf + 0, 0x00);                 # present=0 -> tg covers both tiles
    store8(buf + 1, 0x01);                 # tile0 size_minus_1=1 -> size 2
    store8(buf + 2, 0xAA); store8(buf + 3, 0xBB);   # tile0 data
    store8(buf + 4, 0xCC); store8(buf + 5, 0xDD);   # tile1 (last) data
    var frame = av1_decode_frame(frame_mk_seq(0), frame_mk_fh(2, 1, 1, 0), buf, 6, oe);
    assert_eq(frame, 0, "multi-tile -> no frame");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, "multi-tile -> DR_ERR_UNSUPPORTED (not a wrong decode)");
    return 0;
}
# use_superres reconstructs downscaled then upscales (7.16); upscaling is not
# implemented, so it is rejected rather than emitting a wrong-size frame.
fn test_frame_decode_superres_rejected() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);
    store64(fh + AV1FH_USE_SUPERRES, 1);
    var frame = av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe);
    assert_eq(frame, 0, "superres -> no frame");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, "use_superres -> DR_ERR_UNSUPPORTED");
    return 0;
}
# The 8-bit-only decode path rejects a 10-bit sequence rather than reconstructing
# at the wrong depth.
fn test_frame_decode_highbd_rejected() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var seq = frame_mk_seq(0);
    store64(seq + AV1_SEQ_BITDEPTH, 10);
    var frame = av1_decode_frame(seq, frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(frame, 0, "10-bit -> no frame");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, "10-bit seq -> DR_ERR_UNSUPPORTED");
    return 0;
}
# The driver genuinely runs the symbol decode over the payload: a truncated tile
# surfaces the decoder's sticky error (not a silently-returned default frame).
fn test_frame_decode_truncated() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    # 1 byte cannot carry the tile's symbols -> the symbol decoder faults.
    var frame = av1_decode_frame(frame_mk_seq(0), frame_mk_fh(1, 1, 0, 0), out, 1, oe);
    assert_eq(frame, 0, "truncated tile -> no frame");
    assert_eq(load64(oe) != DR_OK, 1, "truncated tile -> decode error surfaced");
    return 0;
}

fn main() {
    alloc_init();
    test_group("in-loop filter pipeline (deblock -> CDEF -> LR)");
    test_pipeline_none();
    test_pipeline_cdef();
    test_pipeline_cdef_lr();
    test_pipeline_deblock();
    test_group("frame-header filter activation");
    test_lr_params_from_fh();
    test_activate_intra_filters();
    test_group("tile-group OBU parse (5.11.1)");
    test_tg_read_le();
    test_tg_single();
    test_tg_multi_no_present();
    test_tg_present_subrange();
    test_tg_tsbytes2();
    test_tg_single_nonzero_index();
    test_tg_adversarial();
    test_group("frame-level driver (av1_decode_frame)");
    test_frame_decode_plain();
    test_frame_decode_cdef();
    test_frame_decode_multitile_rejected();
    test_frame_decode_superres_rejected();
    test_frame_decode_highbd_rejected();
    test_frame_decode_truncated();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
