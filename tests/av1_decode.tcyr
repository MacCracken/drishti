# tests/av1_decode.tcyr — AV1 in-loop filter pipeline (av1_apply_loop_filters):
# deblock -> CDEF -> LR chaining + the CurrFrame/CdefFrame/LrFrame management.
# The individual filters are tested in their own suites; here we verify the
# orchestration (which filters run, which frame is returned) against known-answer
# single-filter cases.
include "src/main.cyr"
include "src/av1_decode.cyr"

fn dec_fill(f, w, h, v): i64 {
    var y = 0;
    while (y < h) {
        var x = 0;
        while (x < w) { dr_frame_set(f, 0, x, y, v); x = x + 1; }
        y = y + 1;
    }
    return 0;
}
# a frame header carrying the loop-filter level, CDEF params, and UsesLr.
fn mk_dec_fh(lf_level, damping, y_pri, y_sec, uses_lr): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_LF_LEVEL + 0, lf_level);
    store64(fh + AV1FH_LF_LEVEL + 8, lf_level);
    store64(fh + AV1FH_LF_LEVEL + 16, lf_level);
    store64(fh + AV1FH_LF_LEVEL + 24, lf_level);
    store64(fh + AV1FH_CDEF_DAMPING, damping);
    store64(fh + AV1FH_CDEF_Y_PRI, y_pri);
    store64(fh + AV1FH_CDEF_Y_SEC, y_sec);
    store64(fh + AV1FH_USES_LR, uses_lr);
    return fh;
}
fn mk_dec_seq(enable_cdef): i64 {
    var s = alloc(256);
    store64(s + AV1_SEQ_ENABLE_CDEF, enable_cdef);
    return s;
}
# 32x32 border-8 tile (mi 8x8): flat 128 + a spike 140 at (11,11); CdefIdx 0, no skip.
fn mk_dec_tile(): i64 {
    var oe = alloc(8);
    var frame = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    dec_fill(frame, 32, 32, 128);
    dr_frame_set(frame, 0, 11, 11, 140);
    var tile = av1_tile_new(frame, 8, 8, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    av1_cdefidx_set(tile, 0, 0, 0);
    var r = 0;
    while (r < 8) {
        var c = 0;
        while (c < 8) { av1_grid_set(tile, AV1TILE_SKIPS, r, c, 0); c = c + 1; }
        r = r + 1;
    }
    return tile;
}

# No filters enabled: deblock is a no-op (level 0), CDEF off, no LR -> the pipeline
# returns the input frame unchanged.
fn test_pipeline_none() {
    var tile = mk_dec_tile();
    var frame = load64(tile + AV1TILE_FRAME);
    var oe = alloc(8);
    var result = av1_apply_loop_filters(tile, mk_dec_fh(0, 4, 8, 4, 0), mk_dec_seq(0), 0, oe);
    assert_eq(result, frame, "no filters -> result is the input frame");
    assert_eq(dr_frame_get(result, 0, 11, 11), 140, "no filters -> spike unchanged (140)");
    assert_eq(load64(oe), DR_OK, "no filters -> DR_OK");
    return 0;
}
# CDEF enabled -> the pipeline returns a NEW CdefFrame with the spike deringed
# (matching the standalone CDEF driver: 140 -> 138), input frame untouched.
fn test_pipeline_cdef() {
    var tile = mk_dec_tile();
    var frame = load64(tile + AV1TILE_FRAME);
    var oe = alloc(8);
    var result = av1_apply_loop_filters(tile, mk_dec_fh(0, 4, 8, 4, 0), mk_dec_seq(1), 0, oe);
    assert_eq(load64(oe), DR_OK, "cdef -> DR_OK");
    assert_eq(result != frame, 1, "cdef -> result is a new CdefFrame");
    assert_eq(dr_frame_get(result, 0, 11, 11), 138, "cdef -> spike deringed to 138");
    assert_eq(dr_frame_get(frame, 0, 11, 11), 140, "input frame untouched by CDEF");
    return 0;
}
# CDEF + LR (UsesLr, all-NONE units) -> LR chains after CDEF, returning a fresh
# LrFrame that copies the CDEF result through (138 carries).
fn test_pipeline_cdef_lr() {
    var tile = mk_dec_tile();
    var frame = load64(tile + AV1TILE_FRAME);
    var lrp = av1_lr_params_new(32, 32, 1, 0, 0, 1);
    var oe = alloc(8);
    var result = av1_apply_loop_filters(tile, mk_dec_fh(0, 4, 8, 4, 1), mk_dec_seq(1), lrp, oe);
    assert_eq(load64(oe), DR_OK, "cdef+lr -> DR_OK");
    assert_eq(result != frame, 1, "cdef+lr -> result is the LrFrame");
    assert_eq(dr_frame_get(result, 0, 11, 11), 138, "cdef+lr -> LR carries the CDEF result (138)");
    return 0;
}
# Deblocking only (level 40, a vertical block edge) -> in place on the input frame.
fn test_pipeline_deblock() {
    var oe = alloc(8);
    var frame = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var tile = av1_tile_new(frame, 4, 4, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    var r = 0;
    while (r < 4) {
        var c = 0;
        while (c < 4) {
            av1_grid_set(tile, AV1TILE_MISIZES, r, c, 3);   # BLOCK_8X8
            av1_grid_set(tile, AV1TILE_SKIPS, r, c, 0);
            av1_lftx_set(tile, 0, r, c, 1);                 # TX_8X8
            c = c + 1;
        }
        r = r + 1;
    }
    var y = 0;
    while (y < 16) {
        var x = 0;
        while (x < 16) {
            var v = 100;
            if (x >= 8) { v = 140; }
            dr_frame_set(frame, 0, x, y, v);
            x = x + 1;
        }
        y = y + 1;
    }
    var result = av1_apply_loop_filters(tile, mk_dec_fh(40, 4, 0, 0, 0), mk_dec_seq(0), 0, oe);
    assert_eq(result, frame, "deblock-only -> result is the in-place deblocked input frame");
    assert_eq(dr_frame_get(result, 0, 8, 4), 125, "deblock smoothed the x=8 edge (125)");
    return 0;
}

# ================================================================
# Frame-header filter activation: av1_lr_params_from_fh builds the LR params from
# the parsed header, av1_activate_intra_filters attaches CDEF ctx + LR params to a
# tile — the step that turns the wired-but-inert CDEF/LR reads live.
# ================================================================
# fh carrying the LR + CDEF header fields the activation helpers read.
fn mk_act_fh(uses_lr, rtype0, usize0, cdef_bits, allow_intrabc): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_USES_LR, uses_lr);
    store64(fh + AV1FH_FRAME_RESTORATION_TYPE + 0, rtype0);
    store64(fh + AV1FH_LR_SIZE + 0, usize0);
    store64(fh + AV1FH_CDEF_BITS, cdef_bits);
    store64(fh + AV1FH_ALLOW_INTRABC, allow_intrabc);
    store64(fh + AV1FH_CODED_LOSSLESS, 0);
    store64(fh + AV1FH_USE_SUPERRES, 0);
    store64(fh + AV1FH_SUPERRES_DENOM, 8);
    return fh;
}
# seq carrying subsampling + enable_cdef.
fn mk_act_seq(enable_cdef): i64 {
    var s = alloc(256);
    store64(s + AV1_SEQ_ENABLE_CDEF, enable_cdef);
    store64(s + AV1_SEQ_SUBX, 0);
    store64(s + AV1_SEQ_SUBY, 0);
    return s;
}
# from_fh maps the header's per-plane restoration type/size + frame flags into a
# fresh Av1LrParams (UsesLr) or 0 (no LR), never an error on the no-LR path.
fn test_lr_params_from_fh() {
    var oe = alloc(8);
    var fh = mk_act_fh(1, AV1_RESTORE_WIENER, 64, 3, 0);
    var seq = mk_act_seq(1);
    var p = av1_lr_params_from_fh(fh, seq, 128, 64, 1, oe);
    assert_eq(load64(oe), DR_OK, "from_fh -> DR_OK");
    assert_eq(p != 0, 1, "UsesLr -> non-null params");
    assert_eq(load64(p + AV1LRP_USES), 1, "UsesLr propagated");
    assert_eq(load64(p + AV1LRP_RTYPE), AV1_RESTORE_WIENER, "plane0 rtype WIENER (from header)");
    assert_eq(load64(p + AV1LRP_USIZE), 64, "plane0 unit size 64 (from header)");
    assert_eq(av1_lr_ucols_of(p, 0), 2, "128/64 -> 2 unit cols");
    assert_eq(av1_lr_srdenom(p), 8, "SuperresDenom 8 (from header flags)");
    assert_eq(av1_lr_intrabc(p), 0, "allow_intrabc 0 (from header flags)");
    # UsesLr == 0 -> null params, and NOT an error (frame simply uses no LR).
    var p0 = av1_lr_params_from_fh(mk_act_fh(0, AV1_RESTORE_NONE, 0, 3, 0), seq, 128, 64, 1, oe);
    assert_eq(p0, 0, "no UsesLr -> null params");
    assert_eq(load64(oe), DR_OK, "no UsesLr -> not an error");
    return 0;
}
# activate attaches the CDEF ctx (only when the sequence enables CDEF) + LR params
# (always) to a decode tile from the header.
fn test_activate_intra_filters() {
    var tile = mk_dec_tile();
    var fh = mk_act_fh(1, AV1_RESTORE_WIENER, 64, 2, 0);
    var lrp = av1_lr_params_new(32, 32, 1, 0, 0, 1);
    var rc = av1_activate_intra_filters(tile, mk_act_seq(1), fh, lrp);
    assert_eq(rc, DR_OK, "activate -> DR_OK");
    assert_eq(load64(tile + AV1TILE_LRPARAMS), lrp, "LR params attached");
    var ctx = load64(tile + AV1TILE_CDEF_CTX);
    assert_eq(ctx != 0, 1, "CDEF enabled -> ctx attached");
    assert_eq(load64(ctx + 8), 2, "ctx carries cdef_bits=2 (from header)");
    # CDEF disabled -> ctx stays null (read_cdef inert), LR still attached.
    var tile2 = mk_dec_tile();
    var lrp2 = av1_lr_params_new(32, 32, 1, 0, 0, 1);
    assert_eq(av1_activate_intra_filters(tile2, mk_act_seq(0), fh, lrp2), DR_OK, "activate (no CDEF) -> DR_OK");
    assert_eq(load64(tile2 + AV1TILE_CDEF_CTX), 0, "CDEF off -> ctx stays null");
    assert_eq(load64(tile2 + AV1TILE_LRPARAMS), lrp2, "LR still attached with CDEF off");
    return 0;
}

# ================================================================
# Tile-group OBU parsing (spec 5.11.1): the group header (tg_start/tg_end +
# present flag) + per-tile byte-range extraction. Hand-packed payloads comment
# every field's bit packing.
# ================================================================
# a frame header carrying only the tile-info fields the tile-group parser reads.
fn mk_tg_fh(tile_cols, tile_rows, cols_log2, rows_log2, tsbytes): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_TILE_COLS, tile_cols);
    store64(fh + AV1FH_TILE_ROWS, tile_rows);
    store64(fh + AV1FH_TILE_COLS_LOG2, cols_log2);
    store64(fh + AV1FH_TILE_ROWS_LOG2, rows_log2);
    store64(fh + AV1FH_TILE_SIZE_BYTES, tsbytes);
    return fh;
}
# le(n) little-endian byte read (spec 4.10.4).
fn test_tg_read_le() {
    var b = alloc(4);
    store8(b + 0, 0x78); store8(b + 1, 0x56); store8(b + 2, 0x34); store8(b + 3, 0x12);
    assert_eq(av1_read_le(b, 1), 0x78, "le(1)");
    assert_eq(av1_read_le(b, 2), 0x5678, "le(2) little-endian");
    assert_eq(av1_read_le(b, 3), 0x345678, "le(3)");
    assert_eq(av1_read_le(b, 4), 0x12345678, "le(4)");
    return 0;
}
# Single tile (NumTiles == 1): no group header bits, the whole payload is tile 0.
fn test_tg_single() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(1);
    var buf = alloc(6);
    var i = 0;
    while (i < 6) { store8(buf + i, 0x40 + i); i = i + 1; }
    var n = av1_tile_group_parse(tg, buf, 6, mk_tg_fh(1, 1, 0, 0, 1), oe);
    assert_eq(load64(oe), DR_OK, "single-tile parse ok");
    assert_eq(n, 1, "one tile in group");
    assert_eq(av1_tg_start(tg), 0, "tg_start 0");
    assert_eq(av1_tg_end(tg), 0, "tg_end 0");
    assert_eq(av1_tg_tile_offset(tg, 0), 0, "tile0 offset 0 (no header)");
    assert_eq(av1_tg_tile_size(tg, 0), 6, "tile0 size = whole payload");
    return 0;
}
# 2x2 = 4 tiles, tile_start_and_end_present_flag = 0 -> whole frame is one group.
# Non-last tiles carry a le(1) size prefix; the last takes the remainder.
fn test_tg_multi_no_present() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(4);
    var buf = alloc(18);
    store8(buf + 0, 0x00);                              # [0] header: present(bit7)=0
    store8(buf + 1, 0x02);                              # tile0 size_minus_1=2 -> size 3
    store8(buf + 2, 0xA0); store8(buf + 3, 0xA1); store8(buf + 4, 0xA2);   # tile0 data
    store8(buf + 5, 0x01);                              # tile1 size_minus_1=1 -> size 2
    store8(buf + 6, 0xB0); store8(buf + 7, 0xB1);       # tile1 data
    store8(buf + 8, 0x03);                              # tile2 size_minus_1=3 -> size 4
    store8(buf + 9, 0xC0); store8(buf + 10, 0xC1); store8(buf + 11, 0xC2); store8(buf + 12, 0xC3);
    store8(buf + 13, 0xD0); store8(buf + 14, 0xD1);     # tile3 (last) data, 5 bytes
    store8(buf + 15, 0xD2); store8(buf + 16, 0xD3); store8(buf + 17, 0xD4);
    var n = av1_tile_group_parse(tg, buf, 18, mk_tg_fh(2, 2, 1, 1, 1), oe);
    assert_eq(load64(oe), DR_OK, "multi parse ok");
    assert_eq(n, 4, "4 tiles in group");
    assert_eq(av1_tg_start(tg), 0, "tg_start 0");
    assert_eq(av1_tg_end(tg), 3, "tg_end 3 (all tiles)");
    assert_eq(av1_tg_num_tiles(tg), 4, "NumTiles 4");
    assert_eq(av1_tg_tile_offset(tg, 0), 2, "tile0 data offset 2");
    assert_eq(av1_tg_tile_size(tg, 0), 3, "tile0 size 3");
    assert_eq(av1_tg_tile_offset(tg, 1), 6, "tile1 data offset 6");
    assert_eq(av1_tg_tile_size(tg, 1), 2, "tile1 size 2");
    assert_eq(av1_tg_tile_offset(tg, 2), 9, "tile2 data offset 9");
    assert_eq(av1_tg_tile_size(tg, 2), 4, "tile2 size 4");
    assert_eq(av1_tg_tile_offset(tg, 3), 13, "tile3 (last) data offset 13");
    assert_eq(av1_tg_tile_size(tg, 3), 5, "tile3 size 5 (remaining)");
    assert_eq(load8(buf + av1_tg_tile_offset(tg, 2)), 0xC0, "tile2 offset points at its data");
    assert_eq(av1_tg_tile_row(3, 2), 1, "tile3 row 1");
    assert_eq(av1_tg_tile_col(3, 2), 1, "tile3 col 1");
    assert_eq(av1_tg_tile_col(2, 2), 0, "tile2 col 0");
    return 0;
}
# present flag set with a sub-range: only tiles [1,2] are in this group; tiles 0,3
# stay absent (offset -1). Header byte = present(1) tg_start(01=1) tg_end(10=2).
fn test_tg_present_subrange() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(4);
    var buf = alloc(7);
    store8(buf + 0, 0xB0);                              # 1 01 10 000: present=1, tg_start=1, tg_end=2
    store8(buf + 1, 0x01);                              # tile1 size_minus_1=1 -> size 2
    store8(buf + 2, 0xE0); store8(buf + 3, 0xE1);       # tile1 data
    store8(buf + 4, 0xF0); store8(buf + 5, 0xF1); store8(buf + 6, 0xF2);   # tile2 (last) data
    var n = av1_tile_group_parse(tg, buf, 7, mk_tg_fh(2, 2, 1, 1, 1), oe);
    assert_eq(load64(oe), DR_OK, "subrange parse ok");
    assert_eq(n, 2, "2 tiles in group");
    assert_eq(av1_tg_start(tg), 1, "tg_start 1");
    assert_eq(av1_tg_end(tg), 2, "tg_end 2");
    assert_eq(av1_tg_tile_offset(tg, 0), 0 - 1, "tile0 absent (-1)");
    assert_eq(av1_tg_tile_offset(tg, 1), 2, "tile1 data offset 2");
    assert_eq(av1_tg_tile_size(tg, 1), 2, "tile1 size 2");
    assert_eq(av1_tg_tile_offset(tg, 2), 4, "tile2 data offset 4");
    assert_eq(av1_tg_tile_size(tg, 2), 3, "tile2 size 3 (remaining)");
    assert_eq(av1_tg_tile_offset(tg, 3), 0 - 1, "tile3 absent (-1)");
    return 0;
}
# TileSizeBytes = 2: the non-last size field is a 2-byte le() read — exercise the
# full multi-byte size path through the parser (not just av1_read_le in isolation).
fn test_tg_tsbytes2() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(2);
    var buf = alloc(9);
    store8(buf + 0, 0x00);                              # header: present=0
    store8(buf + 1, 0x03); store8(buf + 2, 0x00);       # tile0 size_minus_1 = le2(0x0003)=3 -> size 4
    store8(buf + 3, 0x50); store8(buf + 4, 0x51); store8(buf + 5, 0x52); store8(buf + 6, 0x53);  # tile0 data
    store8(buf + 7, 0x60); store8(buf + 8, 0x61);       # tile1 (last) data
    var n = av1_tile_group_parse(tg, buf, 9, mk_tg_fh(2, 1, 1, 0, 2), oe);
    assert_eq(load64(oe), DR_OK, "tsbytes=2 parse ok");
    assert_eq(n, 2, "2 tiles");
    assert_eq(av1_tg_tile_offset(tg, 0), 3, "tile0 data offset 3 (past 2-byte size field)");
    assert_eq(av1_tg_tile_size(tg, 0), 4, "tile0 size 4 (le2 size field)");
    assert_eq(av1_tg_tile_offset(tg, 1), 7, "tile1 data offset 7");
    assert_eq(av1_tg_tile_size(tg, 1), 2, "tile1 size 2 (remaining)");
    return 0;
}
# Single-tile group at a nonzero index (tg_start == tg_end != 0): the one in-group
# tile is also the last, so no size prefix — it takes the whole remaining payload.
fn test_tg_single_nonzero_index() {
    var oe = alloc(8);
    var tg = av1_tile_group_new(4);
    var buf = alloc(5);
    store8(buf + 0, 0xD0);                              # 1 10 10 000: present=1, tg_start=2, tg_end=2
    store8(buf + 1, 0x70); store8(buf + 2, 0x71); store8(buf + 3, 0x72); store8(buf + 4, 0x73);  # tile2 data
    var n = av1_tile_group_parse(tg, buf, 5, mk_tg_fh(2, 2, 1, 1, 1), oe);
    assert_eq(load64(oe), DR_OK, "single-nonzero-index parse ok");
    assert_eq(n, 1, "1 tile in group");
    assert_eq(av1_tg_start(tg), 2, "tg_start 2");
    assert_eq(av1_tg_end(tg), 2, "tg_end 2");
    assert_eq(av1_tg_tile_offset(tg, 2), 1, "tile2 data offset 1 (post-header, last tile)");
    assert_eq(av1_tg_tile_size(tg, 2), 4, "tile2 size 4 (whole remainder)");
    assert_eq(av1_tg_tile_offset(tg, 0), 0 - 1, "tile0 absent");
    assert_eq(av1_tg_tile_offset(tg, 1), 0 - 1, "tile1 absent");
    assert_eq(av1_tg_tile_offset(tg, 3), 0 - 1, "tile3 absent");
    return 0;
}
# Trust no input byte: lying sizes, truncation, inverted ranges, undersized cap.
fn test_tg_adversarial() {
    var oe = alloc(8);
    # (a) lying tile size: tile0 claims 201 bytes in a 5-byte payload.
    var tg = av1_tile_group_new(2);
    var buf = alloc(5);
    store8(buf + 0, 0x00);                              # present=0
    store8(buf + 1, 0xC8);                              # size_minus_1=200 -> size 201
    store8(buf + 2, 0x11); store8(buf + 3, 0x22); store8(buf + 4, 0x33);
    assert_eq(av1_tile_group_parse(tg, buf, 5, mk_tg_fh(2, 1, 1, 0, 1), oe), 0, "lying size -> 0 tiles");
    assert_eq(load64(oe), DR_ERR_TRUNCATED, "lying tile size -> truncated");
    # (b) truncated size field: payload is just the header byte.
    var tg2 = av1_tile_group_new(2);
    var buf2 = alloc(1);
    store8(buf2 + 0, 0x00);
    assert_eq(av1_tile_group_parse(tg2, buf2, 1, mk_tg_fh(2, 1, 1, 0, 1), oe), 0, "no size field -> 0");
    assert_eq(load64(oe), DR_ERR_TRUNCATED, "missing size field -> truncated");
    # (c) inverted range: present=1, tg_start=2(10), tg_end=1(01) -> 1 10 01 000 = 0xC8.
    var tg3 = av1_tile_group_new(4);
    var buf3 = alloc(4);
    store8(buf3 + 0, 0xC8); store8(buf3 + 1, 0x00); store8(buf3 + 2, 0x00); store8(buf3 + 3, 0x00);
    assert_eq(av1_tile_group_parse(tg3, buf3, 4, mk_tg_fh(2, 2, 1, 1, 1), oe), 0, "tg_end<tg_start -> 0");
    assert_eq(load64(oe), DR_ERR_BAD_HEADER, "inverted range -> bad header");
    # (d) cap too small: tg sized for 2, but the frame has 4 tiles.
    var tgsmall = av1_tile_group_new(2);
    assert_eq(av1_tile_group_parse(tgsmall, buf3, 4, mk_tg_fh(2, 2, 1, 1, 1), oe), 0, "cap<NumTiles -> 0");
    assert_eq(load64(oe), DR_ERR_BOUNDS, "cap too small -> bounds");
    return 0;
}

# ================================================================
# Frame-level driver (av1_decode_frame): decode a single-tile keyframe from
# parsed headers + the tile-group payload, end-to-end (encode a tile -> wrap as a
# 1-tile group -> av1_decode_frame -> pixels + grids).
# ================================================================
# Encode a 128x64 keyframe tile (mi 32x16, base_q 40, all-skip DC): SB0 32x32,
# SB1 64x64 — the same plan as av1_tile.tcyr's keyframe round-trip. Returns the
# tile byte buffer, length at *out_len. For NumTiles==1 this buffer IS the
# tile-group payload (no group header bits).
fn frame_enc_keyframe(out_len): i64 {
    var mi = av1_modeinfo_new();
    store64(mi + AV1MI_SKIP, 1);
    store64(mi + AV1MI_YMODE, AV1_DC_PRED);
    store64(mi + AV1MI_UVMODE, AV1_DC_PRED);
    var pp = alloc(6 * 8);
    store64(pp + 0, AV1_PARTITION_SPLIT);
    store64(pp + 8, AV1_PARTITION_NONE);   store64(pp + 16, AV1_PARTITION_NONE);
    store64(pp + 24, AV1_PARTITION_NONE);  store64(pp + 32, AV1_PARTITION_NONE);
    store64(pp + 40, AV1_PARTITION_NONE);
    var pm = alloc(5 * 8);
    var pt = alloc(5 * 8);
    var k = 0;
    while (k < 4) { store64(pm + (k * 8), mi); store64(pt + (k * 8), 3); k = k + 1; }
    store64(pm + (4 * 8), mi);
    store64(pt + (4 * 8), 4);
    var eoe = alloc(8);
    var eframe = dr_frame_new(128, 64, 1, 0, 0, 8, 8, eoe);
    var etile = av1_tile_new(eframe, 32, 16, 40, 1, 0, 1);   # enable_ef=1, reduced_tx=0, 1 plane
    av1_tile_grids_new(etile);
    return av1_encode_intra_tile(etile, pp, pm, pt, 1, out_len);   # disable_cdf=1
}
# a sequence header carrying the fields av1_decode_frame reads (zeroed first —
# alloc is not zero-init).
fn frame_mk_seq(enable_cdef): i64 {
    var s = alloc(AV1_SEQ_SIZE);
    memset(s, 0, AV1_SEQ_SIZE);
    store64(s + AV1_SEQ_BITDEPTH, 8);
    store64(s + AV1_SEQ_NUM_PLANES, 1);
    store64(s + AV1_SEQ_SUBX, 0);
    store64(s + AV1_SEQ_SUBY, 0);
    store64(s + AV1_SEQ_ENABLE_CDEF, enable_cdef);
    store64(s + AV1_SEQ_ENABLE_RESTORATION, 0);
    store64(s + AV1_SEQ_ENABLE_FILTER_INTRA, 0);     # matches the encode tile (ENABLE_FI=0)
    store64(s + AV1_SEQ_ENABLE_INTRA_EDGE, 1);       # matches the encode tile (enable_ef=1)
    return s;
}
# a frame header for the 128x64 keyframe (tile_cols/rows configurable for the
# multi-tile-rejection test). base_q 40, TX_MODE_SELECT, disable_cdf_update=1 —
# all matching the encode tile; loop_filter_level/uses_lr/superres stay 0 (zeroed).
fn frame_mk_fh(tile_cols, tile_rows, tile_cols_log2, tile_rows_log2): i64 {
    var fh = alloc(AV1FH_SIZE);
    memset(fh, 0, AV1FH_SIZE);
    store64(fh + AV1FH_FRAME_IS_INTRA, 1);   # hand-built KEYFRAME (the 0.7.84 gate reads it)
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_FRAME_HEIGHT, 64);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_ROWS, 16);
    store64(fh + AV1FH_BASE_Q_IDX, 40);
    store64(fh + AV1FH_TX_MODE, AV1_TX_MODE_SELECT);
    store64(fh + AV1FH_REDUCED_TX_SET, 0);
    store64(fh + AV1FH_TILE_COLS, tile_cols);
    store64(fh + AV1FH_TILE_ROWS, tile_rows);
    store64(fh + AV1FH_TILE_COLS_LOG2, tile_cols_log2);
    store64(fh + AV1FH_TILE_ROWS_LOG2, tile_rows_log2);
    store64(fh + AV1FH_TILE_SIZE_BYTES, 1);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 1);        # matches encode disable_cdf=1
    # single tile spanning the frame: MiColStarts = [0, MiCols], MiRowStarts = [0, MiRows].
    store64(fh + AV1FH_MI_COL_STARTS + 0, 0);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_ROW_STARTS + 0, 0);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 16);
    return fh;
}
# a 256x64 frame header with 2 tile columns [0,32)/[32,64) MI, 1 tile row (each tile
# 32x16 MI = the frame_enc_keyframe tile) — for the multi-tile / multi-tile-group
# tests. Same encode-matched params as frame_mk_fh (base_q 40, TX_MODE_SELECT,
# disable_cdf_update=1); MiColStarts = [0, 32, 64], MiRowStarts = [0, 16].
fn frame_mk_fh_2tile(): i64 {
    var fh = alloc(AV1FH_SIZE);
    memset(fh, 0, AV1FH_SIZE);
    store64(fh + AV1FH_FRAME_IS_INTRA, 1);   # hand-built KEYFRAME (the 0.7.84 gate reads it)
    store64(fh + AV1FH_FRAME_WIDTH, 256);
    store64(fh + AV1FH_FRAME_HEIGHT, 64);
    store64(fh + AV1FH_UPSCALED_WIDTH, 256);
    store64(fh + AV1FH_MI_COLS, 64);
    store64(fh + AV1FH_MI_ROWS, 16);
    store64(fh + AV1FH_BASE_Q_IDX, 40);
    store64(fh + AV1FH_TX_MODE, AV1_TX_MODE_SELECT);
    store64(fh + AV1FH_TILE_COLS, 2);
    store64(fh + AV1FH_TILE_ROWS, 1);
    store64(fh + AV1FH_TILE_COLS_LOG2, 1);
    store64(fh + AV1FH_TILE_SIZE_BYTES, 1);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 1);
    store64(fh + AV1FH_MI_COL_STARTS + 0, 0);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 16, 64);
    store64(fh + AV1FH_MI_ROW_STARTS + 0, 0);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 16);
    return fh;
}
# no filters (enable_cdef=0, uses_lr=0, lf_level=0): decode the keyframe end-to-end
# to a flat DC (128) frame; the pipeline returns the reconstruction unchanged.
fn test_frame_decode_plain() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    assert_eq(olen > 0, 1, "encoded a keyframe tile");
    var oe = alloc(8);
    var frame = av1_decode_frame(frame_mk_seq(0), frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "decode_frame ok");
    assert_eq(frame != 0, 1, "decode_frame returns a frame");
    assert_eq(dr_frame_width(frame), 128, "frame width 128");
    assert_eq(dr_frame_height(frame), 64, "frame height 64");
    # flat DC prediction, skip -> no residual: every luma sample is 128.
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 128) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "keyframe pixels all 128 (headers -> pixels)");
    return 0;
}
# CDEF enabled: the pipeline runs the CDEF stage (into a fresh CdefFrame) and
# returns it. All-skip blocks -> cdef_idx never read -> CDEF is a no-op, so the
# pixels stay 128 — but the decode drove the full seq/fh -> activate -> filter path.
fn test_frame_decode_cdef() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var frame = av1_decode_frame(frame_mk_seq(1), frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "decode_frame (CDEF) ok");
    assert_eq(frame != 0, 1, "decode_frame (CDEF) returns a frame");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 128, "CDEF-path pixels still 128 (skip -> no dering)");
    return 0;
}
# Multi-tile frames are unsupported here -> rejected cleanly (never a wrong
# decode). Uses a valid 2-tile group payload so the parse succeeds first.
# THE multi-tile milestone: a 256x64 frame split into two 128px tiles, each decoding
# the SAME single-tile keyframe bytes into its own MI window of the shared frame
# grids. Both halves reconstruct flat-DC (128) — proving per-tile placement + tile
# independence (tile 1's left neighbor is across the tile edge -> unavailable, so it
# reads the same bits as tile 0). (All-skip, so the coeff-context split isn't needed.)
fn test_frame_decode_2tile() {
    var tlen = 0;
    var tb = frame_enc_keyframe(&tlen);            # the 32x16-MI single-tile bytes
    # 2-tile group payload: header(present=0) + tile0(le1 size + data) + tile1(data).
    var plen = 2 + (2 * tlen);
    var buf = alloc(plen);
    store8(buf + 0, 0x00);                          # tile_start_and_end_present_flag = 0
    store8(buf + 1, tlen - 1);                      # tile0 size_minus_1 (le1) -> size tlen
    var i = 0;
    while (i < tlen) { store8(buf + 2 + i, load8(tb + i)); i = i + 1; }
    i = 0;
    while (i < tlen) { store8(buf + 2 + tlen + i, load8(tb + i)); i = i + 1; }
    # frame header: 256x64 (MiCols 64), 2 tile columns [0,32) and [32,64).
    var fh = alloc(AV1FH_SIZE);
    memset(fh, 0, AV1FH_SIZE);
    store64(fh + AV1FH_FRAME_IS_INTRA, 1);   # hand-built KEYFRAME (the 0.7.84 gate reads it)
    store64(fh + AV1FH_FRAME_WIDTH, 256);
    store64(fh + AV1FH_FRAME_HEIGHT, 64);
    store64(fh + AV1FH_UPSCALED_WIDTH, 256);
    store64(fh + AV1FH_MI_COLS, 64);
    store64(fh + AV1FH_MI_ROWS, 16);
    store64(fh + AV1FH_BASE_Q_IDX, 40);
    store64(fh + AV1FH_TX_MODE, AV1_TX_MODE_SELECT);
    store64(fh + AV1FH_TILE_COLS, 2);
    store64(fh + AV1FH_TILE_ROWS, 1);
    store64(fh + AV1FH_TILE_COLS_LOG2, 1);
    store64(fh + AV1FH_TILE_SIZE_BYTES, 1);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 1);
    store64(fh + AV1FH_MI_COL_STARTS + 0, 0);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 16, 64);
    store64(fh + AV1FH_MI_ROW_STARTS + 0, 0);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 16);
    var oe = alloc(8);
    var frame = av1_decode_frame(frame_mk_seq(0), fh, buf, plen, oe);
    assert_eq(load64(oe), DR_OK, "2-tile decode ok");
    assert_eq(frame != 0, 1, "2-tile -> a frame");
    assert_eq(dr_frame_width(frame), 256, "frame width 256");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 128, "tile 0 (left half) flat 128");
    assert_eq(dr_frame_get(frame, 0, 180, 30), 128, "tile 1 (right half) flat 128");
    # whole frame flat-128: both windows placed with no gap / overlap.
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 256) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "2-tile frame all flat-128 (both tile windows correct)");
    # decode again with CDEF enabled: the filter pipeline runs over the WHOLE 2-tile
    # frame (tile0's window reset to [0,64)); a wrong reset would OOB / mis-size the
    # CdefFrame. All-skip -> CDEF is a no-op, so the 256x64 result stays flat-128.
    var oe2 = alloc(8);
    var cf = av1_decode_frame(frame_mk_seq(1), fh, buf, plen, oe2);
    assert_eq(load64(oe2), DR_OK, "2-tile + CDEF decode ok (filter over the whole frame)");
    assert_eq(dr_frame_width(cf), 256, "2-tile CdefFrame width 256");
    assert_eq(dr_frame_get(cf, 0, 180, 30), 128, "2-tile CDEF path -> right tile still 128");
    return 0;
}
# multi-tile-GROUP: a frame whose 2 tiles arrive in 2 SEPARATE tile groups (partial
# groups). Drives the frame-decode context directly: new -> group0 (not done) ->
# group1 (done) -> finish, decoding into ONE shared frame. Same all-skip bytes into
# each window -> whole 256x64 frame flat-128. Also checks the in-order/contiguous guard.
fn test_frame_decode_multigroup() {
    var tlen = 0;
    var tb = frame_enc_keyframe(&tlen);
    # two partial tile-group payloads, one tile each. Header is MSB-first:
    # present=1 then tg_start then tg_end (1 bit each, tilebits = tile_cols_log2=1).
    # group 0 -> present=1,tg_start=0,tg_end=0 = 0b100.... = 0x80; then tile 0 bytes.
    var g0 = alloc(1 + tlen);
    store8(g0 + 0, 0x80);
    var i = 0;
    while (i < tlen) { store8(g0 + 1 + i, load8(tb + i)); i = i + 1; }
    # group 1 -> present=1,tg_start=1,tg_end=1 = 0b111.... = 0xE0; then tile 1 bytes.
    var g1 = alloc(1 + tlen);
    store8(g1 + 0, 0xE0);
    i = 0;
    while (i < tlen) { store8(g1 + 1 + i, load8(tb + i)); i = i + 1; }
    var seq = frame_mk_seq(0);
    var oe = alloc(8);
    var fdc = av1_frame_dec_new(seq, frame_mk_fh_2tile(), oe);
    assert_eq(load64(oe), DR_OK, "frame-dec context created");
    assert_eq(fdc != 0, 1, "fdc non-null");
    var d0 = av1_frame_dec_group(fdc, g0, 1 + tlen, oe);
    assert_eq(load64(oe), DR_OK, "group 0 decodes");
    assert_eq(d0, 0, "group 0 -> frame incomplete (more groups expected)");
    var d1 = av1_frame_dec_group(fdc, g1, 1 + tlen, oe);
    assert_eq(load64(oe), DR_OK, "group 1 decodes");
    assert_eq(d1, 1, "group 1 -> frame complete");
    var frame = av1_frame_dec_finish(fdc, oe);
    assert_eq(load64(oe), DR_OK, "finish ok");
    assert_eq(frame != 0, 1, "finish -> a frame");
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 256) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "multi-tile-group frame all flat-128 (2 groups, one shared frame)");
    # grid probe: identical flat-128 pixels can't distinguish a wrong-window grid write,
    # so probe the SHARED frame-addressed grids directly. All-skip -> the Skips grid is 1
    # at every decoded MI; group 1's tile must have written its skip flags into its OWN
    # absolute window [32,64) (a frame-addressed share of tile0's grids), NOT tile 0's
    # [0,32). grids_new zero-inits, so a tile-relative / wrong-window write would leave
    # [32,64) at 0. This directly exercises the multi-tile grid addressing (0.7.47-0.7.51).
    var tile0 = load64(fdc + AV1FDEC_TILE0);
    assert_eq(av1_grid_get(tile0, AV1TILE_SKIPS, 4, 8), 1, "group 0 tile: skip=1 in [0,32)");
    assert_eq(av1_grid_get(tile0, AV1TILE_SKIPS, 4, 40), 1, "group 1 tile: skip=1 at abs col 40 (own window [32,64))");
    assert_eq(av1_grid_get(tile0, AV1TILE_SKIPS, 12, 60), 1, "group 1 tile: skip=1 at abs col 60 (deep in [32,64))");
    # trust no input: a first group that does NOT start at TileNum 0 is rejected.
    var fdc2 = av1_frame_dec_new(seq, frame_mk_fh_2tile(), oe);
    var dbad = av1_frame_dec_group(fdc2, g1, 1 + tlen, oe);   # g1 starts at tile 1
    assert_eq(dbad, 0 - 1, "out-of-order first group -> -1");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, "out-of-order group -> UNSUPPORTED");
    return 0;
}
# use_superres reconstructs at FrameWidth (downscaled) then upscales to UpscaledWidth
# (7.16) between CDEF and LR. An all-skip keyframe -> flat-128; upscaling a flat frame
# stays flat-128, now at the upscaled width (256, a 2x upscale of the 128 recon).
fn test_frame_decode_superres() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);                 # FrameWidth 128 (MiCols 32)
    store64(fh + AV1FH_USE_SUPERRES, 1);
    store64(fh + AV1FH_UPSCALED_WIDTH, 256);          # 2x upscale
    var frame = av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe);
    assert_eq(load64(oe), DR_OK, "superres decode ok");
    assert_eq(frame != 0, 1, "superres -> a frame");
    assert_eq(dr_frame_width(frame), 256, "output at UpscaledWidth 256");
    assert_eq(dr_frame_height(frame), 64, "height unchanged (horizontal-only upscale)");
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 256) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "superres frame all flat-128 at 256 wide");
    # again with CDEF on -> exercises the SEPARATE up-cdef upscale path (all-skip -> CDEF
    # is a no-op, still flat-128 at 256).
    var oe2 = alloc(8);
    var cf = av1_decode_frame(frame_mk_seq(1), fh, out, olen, oe2);
    assert_eq(load64(oe2), DR_OK, "superres + CDEF decode ok");
    assert_eq(dr_frame_width(cf), 256, "superres+CDEF output at 256");
    assert_eq(dr_frame_get(cf, 0, 200, 30), 128, "superres+CDEF still flat-128");
    return 0;
}
# 10-bit decode: the same skip-DC keyframe tile bytes (mode-info/partition are
# bit-depth independent) reconstruct at 10-bit — the no-neighbor DC prediction is
# 1 << (BitDepth-1) = 512, and every pixel-pipeline stage threads bit_depth.
fn test_frame_decode_10bit() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var seq = frame_mk_seq(0);
    store64(seq + AV1_SEQ_BITDEPTH, 10);
    var frame = av1_decode_frame(seq, frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "10-bit decode ok");
    assert_eq(frame != 0, 1, "10-bit -> a frame");
    assert_eq(dr_frame_bit_depth(frame), 10, "reconstruction frame is 10-bit");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 512, "10-bit keyframe -> flat DC 512 (1<<9)");
    assert_eq(dr_frame_get(frame, 0, 0, 0), 512, "10-bit corner pixel 512");
    return 0;
}
# 12-bit decode: DC pred = 1 << 11 = 2048 (the dequant Qlookup has a 12-bit table).
fn test_frame_decode_12bit() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var seq = frame_mk_seq(0);
    store64(seq + AV1_SEQ_BITDEPTH, 12);
    var frame = av1_decode_frame(seq, frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "12-bit decode ok");
    assert_eq(dr_frame_bit_depth(frame), 12, "reconstruction frame is 12-bit");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 2048, "12-bit keyframe -> flat DC 2048 (1<<11)");
    return 0;
}
# CDEF at 10-bit: enable_cdef drives the CDEF stage (direction search + strengths
# scaled by coeff_shift = bit_depth-8 = 2) over a fresh 10-bit CdefFrame. All-skip
# blocks -> CDEF is a no-op, so the mid-value (512) carries through — but this
# exercises the CDEF path end-to-end at 10-bit (allocation + driver, depth-safe).
fn test_frame_decode_10bit_cdef() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var seq = frame_mk_seq(1);                 # enable_cdef = 1
    store64(seq + AV1_SEQ_BITDEPTH, 10);
    var frame = av1_decode_frame(seq, frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(load64(oe), DR_OK, "10-bit + CDEF decode ok");
    assert_eq(dr_frame_bit_depth(frame), 10, "10-bit CdefFrame");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 512, "10-bit CDEF path -> mid-value 512 carries (skip)");
    return 0;
}
# A dimension-bomb FrameWidth is rejected with dr_frame_new's precise code
# (DR_ERR_OVERSIZE), NOT masked as a generic OOM — the caller can tell a hostile
# oversize from a transient resource failure.
fn test_frame_decode_dimbomb() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);
    store64(fh + AV1FH_FRAME_WIDTH, 20000);   # > DR_FRAME_MAX_DIM (16384)
    var frame = av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe);
    assert_eq(frame, 0, "dimension bomb -> no frame");
    assert_eq(load64(oe), DR_ERR_OVERSIZE, "oversize dims -> DR_ERR_OVERSIZE (not masked as OOM)");
    return 0;
}
# The driver genuinely runs the symbol decode over the payload: a truncated tile
# surfaces the decoder's sticky error (not a silently-returned default frame).
fn test_frame_decode_truncated() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    # 1 byte cannot carry the tile's symbols -> the symbol decoder faults.
    var frame = av1_decode_frame(frame_mk_seq(0), frame_mk_fh(1, 1, 0, 0), out, 1, oe);
    assert_eq(frame, 0, "truncated tile -> no frame");
    assert_eq(load64(oe) != DR_OK, 1, "truncated tile -> decode error surfaced");
    return 0;
}
# use_128x128_superblock=1 must be REJECTED, not silently mis-parsed. The tile SB loop
# (av1_decode_tile) hardcodes 64x64 SBs — it steps by AV1_SB4 and calls
# av1_decode_partition with BLOCK_64X64 — so a 128-SB stream would decode only the
# top-left 64x64 of each superblock (garbage partition/positions). The gate in
# av1_frame_dec_new latches DR_ERR_UNSUPPORTED before any tile runs, at the one chokepoint
# every decode path shares. SB128 is the SOLE difference from test_frame_decode_plain:
# same valid keyframe payload, same fh. Mutation-verify: delete that gate and this test
# flips UNSUPPORTED -> DR_OK (the 64x64 payload decodes, the flag ignored) — i.e. the
# mis-parse ships green.
fn test_frame_decode_sb128_rejected() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    assert_eq(olen > 0, 1, "encoded a keyframe tile");
    var oe = alloc(8);
    var seq128 = frame_mk_seq(0);
    store64(seq128 + AV1_SEQ_SB128, 1);        # signal 128x128 superblocks
    var frame = av1_decode_frame(seq128, frame_mk_fh(1, 1, 0, 0), out, olen, oe);
    assert_eq(frame, 0, "use_128x128_superblock -> no frame (clean reject, no crash/garbage)");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, "use_128x128_superblock -> DR_ERR_UNSUPPORTED");
    # direction: the identical payload with SB128=0 decodes cleanly, so the reject is
    # driven by the flag, not the bytes (av1_seq_use_128x128 is the sole gate input).
    var oe2 = alloc(8);
    var frame0 = av1_decode_frame(frame_mk_seq(0), frame_mk_fh(1, 1, 0, 0), out, olen, oe2);
    assert_eq(load64(oe2), DR_OK, "same payload, SB128=0 -> decodes (flag is the gate)");
    assert_eq(frame0 != 0, 1, "SB128=0 -> a frame");
    return 0;
}

# ================================================================
# OBU-stream walk (av1_decode_obus): dispatch + error paths. (The full
# raw-bytes -> pixels end-to-end test is test_obus_end_to_end below.)
# ================================================================
# Append n raw bytes from src into a byte-aligned bit writer.
fn obus_append(bw, src, n): i64 {
    var i = 0;
    while (i < n) { dr_bw_put_bits(bw, load8(src + i), 8); i = i + 1; }
    return 0;
}
# Frame one OBU (header + optional payload) into bw.
fn obus_wrap(bw, type, payload, plen): i64 {
    av1_obu_write_header(bw, type, 0, 0, 0, 1, plen);
    if (plen > 0) { obus_append(bw, payload, plen); }
    return 0;
}
# null buffer / negative size -> DR_ERR_BOUNDS.
fn test_obus_bad_args() {
    var oe = alloc(8);
    assert_eq(av1_decode_obus(0, 8, oe), 0, "null buf -> 0");
    assert_eq(load64(oe), DR_ERR_BOUNDS, "null buf -> BOUNDS");
    assert_eq(av1_decode_obus(alloc(8), 0 - 1, oe), 0, "negative sz -> 0");
    assert_eq(load64(oe), DR_ERR_BOUNDS, "negative sz -> BOUNDS");
    return 0;
}
# A temporal-delimiter-only stream is walked (TD skipped) but carries no tile
# group -> DR_ERR_BAD_HEADER (proves TD is skipped, not errored on).
fn test_obus_td_only() {
    var oe = alloc(8);
    var bw = dr_bw_init(16);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    var n = dr_bw_flush(bw);
    assert_eq(av1_decode_obus(dr_bw_buf(bw), n, oe), 0, "TD-only -> no frame");
    assert_eq(load64(oe), DR_ERR_BAD_HEADER, "TD skipped, no tile group -> BAD_HEADER");
    return 0;
}
# A FRAME OBU (type 6) before any SEQUENCE_HEADER -> DR_ERR_BAD_HEADER (no context
# to parse the embedded frame header against).
fn test_obus_frame_obu_no_seq() {
    var oe = alloc(8);
    var pay = alloc(2);
    store8(pay + 0, 0x00); store8(pay + 1, 0x00);
    var bw = dr_bw_init(16);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_FRAME, pay, 2);
    var n = dr_bw_flush(bw);
    assert_eq(av1_decode_obus(dr_bw_buf(bw), n, oe), 0, "FRAME OBU w/o seq -> no frame");
    assert_eq(load64(oe), DR_ERR_BAD_HEADER, "FRAME OBU before seq -> BAD_HEADER");
    return 0;
}
# A FRAME OBU with a garbage frame-header payload surfaces the parser's error
# (not a wrong decode).
fn test_obus_frame_obu_malformed() {
    var slen = 0;
    var seq = frame_build_seq(&slen);
    var oe = alloc(8);
    var pay = alloc(4);
    store8(pay + 0, 0xFF); store8(pay + 1, 0xFF); store8(pay + 2, 0xFF); store8(pay + 3, 0xFF);
    var bw = dr_bw_init(64);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, seq, slen);
    obus_wrap(bw, AV1_OBU_FRAME, pay, 4);
    var n = dr_bw_flush(bw);
    assert_eq(av1_decode_obus(dr_bw_buf(bw), n, oe), 0, "malformed FRAME OBU -> no frame");
    assert_eq(load64(oe) != DR_OK, 1, "malformed FRAME OBU -> parse error surfaced");
    return 0;
}
# A FRAME OBU whose payload is EXACTLY the frame header (no tile-group bytes):
# hbytes == osize, so the split leaves a 0-byte tile group -> a clean error
# downstream (not a crash / garbage frame). Exercises the hbytes == osize boundary.
fn test_obus_frame_obu_empty_tg() {
    var slen = 0;
    var seq = frame_build_seq(&slen);
    var flen = 0;
    var fh = frame_build_fh(&flen);
    var oe = alloc(8);
    var bw = dr_bw_init(64);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, seq, slen);
    obus_wrap(bw, AV1_OBU_FRAME, fh, flen);       # payload = frame header only
    var n = dr_bw_flush(bw);
    var frame = av1_decode_obus(dr_bw_buf(bw), n, oe);
    assert_eq(frame, 0, "FRAME OBU with 0-byte tile group -> no frame");
    assert_eq(load64(oe) != DR_OK, 1, "empty tile group -> clean error (no crash/garbage)");
    return 0;
}
# Custom mono reduced-still-picture seq matching frame_enc_keyframe: profile 0,
# 8-bit, mono (1 plane), 128x64, enable_intra_edge_filter=1, enable_filter_intra=0,
# no cdef/lr/superres. (fx_seq_reduced can't be reused — it hardcodes 3 planes +
# enable_intra_edge=0.) Bit layout traced against av1_seq_parse / color_config.
fn frame_build_seq(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bits(bw, 0, 3);        # seq_profile = 0
    dr_bw_put_bit(bw, 1);            # still_picture = 1
    dr_bw_put_bit(bw, 1);            # reduced_still_picture_header = 1
    dr_bw_put_bits(bw, 0, 5);        # seq_level_idx[0] = 0
    dr_bw_put_bits(bw, 15, 4);       # frame_width_bits_minus_1 = 15 (16-bit dims)
    dr_bw_put_bits(bw, 15, 4);       # frame_height_bits_minus_1 = 15
    dr_bw_put_bits(bw, 127, 16);     # max_frame_width_minus_1 = 127 -> width 128
    dr_bw_put_bits(bw, 63, 16);      # max_frame_height_minus_1 = 63 -> height 64
    dr_bw_put_bit(bw, 0);            # use_128x128_superblock = 0 (64x64 SB)
    dr_bw_put_bit(bw, 0);            # enable_filter_intra = 0
    dr_bw_put_bit(bw, 1);            # enable_intra_edge_filter = 1
    dr_bw_put_bit(bw, 0);            # enable_superres = 0
    dr_bw_put_bit(bw, 0);            # enable_cdef = 0
    dr_bw_put_bit(bw, 0);            # enable_restoration = 0
    dr_bw_put_bit(bw, 0);            # high_bitdepth = 0 -> 8-bit
    dr_bw_put_bit(bw, 1);            # mono_chrome = 1 -> num_planes = 1
    dr_bw_put_bit(bw, 0);            # color_description_present_flag = 0
    dr_bw_put_bit(bw, 0);            # color_range = 0 (mono path returns here)
    dr_bw_put_bit(bw, 0);            # film_grain_params_present = 0
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# Reduced-still-picture KEY frame header matching frame_enc_keyframe: dims from the
# seq (128x64 -> MiCols 32, MiRows 16), base_q_idx 40, single tile, TX_MODE_SELECT,
# reduced_tx=0, disable_cdf_update=1. The increment_tile_cols_log2 bit is required
# at 128-wide (sb_cols=2 -> max_log2_tile_cols=1); mono omits the DeltaQU* bits.
fn frame_build_fh(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bit(bw, 1);            # disable_cdf_update = 1
    dr_bw_put_bit(bw, 0);            # allow_screen_content_tools = 0
    dr_bw_put_bit(bw, 0);            # render_and_frame_size_different = 0
    dr_bw_put_bit(bw, 1);            # uniform_tile_spacing_flag = 1
    dr_bw_put_bit(bw, 0);            # increment_tile_cols_log2 = 0 (single tile col)
    dr_bw_put_bits(bw, 40, 8);       # base_q_idx = 40
    dr_bw_put_bit(bw, 0);            # DeltaQYDc delta_coded = 0 (mono: no DeltaQU*)
    dr_bw_put_bit(bw, 0);            # using_qmatrix = 0
    dr_bw_put_bit(bw, 0);            # segmentation_enabled = 0
    dr_bw_put_bit(bw, 0);            # delta_q_present = 0
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[0] = 0
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[1] = 0
    dr_bw_put_bits(bw, 0, 3);        # loop_filter_sharpness = 0
    dr_bw_put_bit(bw, 0);            # loop_filter_delta_enabled = 0
    dr_bw_put_bit(bw, 1);            # tx_mode_select = 1 -> TX_MODE_SELECT
    dr_bw_put_bit(bw, 0);            # reduced_tx_set = 0
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# frame_build_seq for a 256x64 mono frame (max_frame_width_minus_1 = 255 -> width 256,
# MiCols 64), otherwise identical to frame_build_seq. sb_cols = 4 -> max_log2_tile_cols
# = 2, so 2 tile columns are legal (tile_info increment bit).
fn frame_build_seq_2tile(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bits(bw, 0, 3);        # seq_profile = 0
    dr_bw_put_bit(bw, 1);            # still_picture = 1
    dr_bw_put_bit(bw, 1);            # reduced_still_picture_header = 1
    dr_bw_put_bits(bw, 0, 5);        # seq_level_idx[0] = 0
    dr_bw_put_bits(bw, 15, 4);       # frame_width_bits_minus_1 = 15 (16-bit dims)
    dr_bw_put_bits(bw, 15, 4);       # frame_height_bits_minus_1 = 15
    dr_bw_put_bits(bw, 255, 16);     # max_frame_width_minus_1 = 255 -> width 256
    dr_bw_put_bits(bw, 63, 16);      # max_frame_height_minus_1 = 63 -> height 64
    dr_bw_put_bit(bw, 0);            # use_128x128_superblock = 0 (64x64 SB)
    dr_bw_put_bit(bw, 0);            # enable_filter_intra = 0
    dr_bw_put_bit(bw, 1);            # enable_intra_edge_filter = 1
    dr_bw_put_bit(bw, 0);            # enable_superres = 0
    dr_bw_put_bit(bw, 0);            # enable_cdef = 0
    dr_bw_put_bit(bw, 0);            # enable_restoration = 0
    dr_bw_put_bit(bw, 0);            # high_bitdepth = 0 -> 8-bit
    dr_bw_put_bit(bw, 1);            # mono_chrome = 1 -> num_planes = 1
    dr_bw_put_bit(bw, 0);            # color_description_present_flag = 0
    dr_bw_put_bit(bw, 0);            # color_range = 0 (mono path returns here)
    dr_bw_put_bit(bw, 0);            # film_grain_params_present = 0
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# frame_build_fh for the 256x64 frame with 2 tile columns (tile_cols_log2 = 1). The
# tile_info section differs from frame_build_fh: uniform spacing, increment_tile_cols
# = [1,0] (stop at log2 1; max_log2_tile_cols = 2 here), no tile-rows bit (sb_rows = 1),
# then context_update_tile_id (tile_rows_log2+tile_cols_log2 = 1 bit) + tile_size_bytes.
fn frame_build_fh_2tile(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bit(bw, 1);            # disable_cdf_update = 1
    dr_bw_put_bit(bw, 0);            # allow_screen_content_tools = 0
    dr_bw_put_bit(bw, 0);            # render_and_frame_size_different = 0
    dr_bw_put_bit(bw, 1);            # uniform_tile_spacing_flag = 1
    dr_bw_put_bit(bw, 1);            # increment_tile_cols_log2 = 1 -> 2 tile columns
    dr_bw_put_bit(bw, 0);            # increment_tile_cols_log2 = 0 (stop at log2 = 1)
    dr_bw_put_bit(bw, 0);            # context_update_tile_id = 0 (1 bit)
    dr_bw_put_bits(bw, 0, 2);        # tile_size_bytes_minus_1 = 0 -> 1 byte
    dr_bw_put_bits(bw, 40, 8);       # base_q_idx = 40
    dr_bw_put_bit(bw, 0);            # DeltaQYDc delta_coded = 0 (mono: no DeltaQU*)
    dr_bw_put_bit(bw, 0);            # using_qmatrix = 0
    dr_bw_put_bit(bw, 0);            # segmentation_enabled = 0
    dr_bw_put_bit(bw, 0);            # delta_q_present = 0
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[0] = 0
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[1] = 0
    dr_bw_put_bits(bw, 0, 3);        # loop_filter_sharpness = 0
    dr_bw_put_bit(bw, 0);            # loop_filter_delta_enabled = 0
    dr_bw_put_bit(bw, 1);            # tx_mode_select = 1 -> TX_MODE_SELECT
    dr_bw_put_bit(bw, 0);            # reduced_tx_set = 0
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# multi-tile-group over the OBU walk: TD + seq + FRAME_HEADER + two TILE_GROUP OBUs
# (one tile each). av1_decode_obus creates the frame-decode context at the first group
# and accumulates the second, returning the filtered 256x64 frame (all flat-128).
fn test_obus_multigroup() {
    var slen = 0;
    var seq = frame_build_seq_2tile(&slen);
    var flen = 0;
    var fh = frame_build_fh_2tile(&flen);
    var tlen = 0;
    var tb = frame_enc_keyframe(&tlen);
    var g0 = alloc(1 + tlen);
    store8(g0 + 0, 0x80);            # present=1, tg_start=0, tg_end=0
    var i = 0;
    while (i < tlen) { store8(g0 + 1 + i, load8(tb + i)); i = i + 1; }
    var g1 = alloc(1 + tlen);
    store8(g1 + 0, 0xE0);            # present=1, tg_start=1, tg_end=1
    i = 0;
    while (i < tlen) { store8(g1 + 1 + i, load8(tb + i)); i = i + 1; }
    var bw = dr_bw_init(256);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, seq, slen);
    obus_wrap(bw, AV1_OBU_FRAME_HEADER, fh, flen);
    obus_wrap(bw, AV1_OBU_TILE_GROUP, g0, 1 + tlen);
    obus_wrap(bw, AV1_OBU_TILE_GROUP, g1, 1 + tlen);
    var n = dr_bw_flush(bw);
    var oe = alloc(8);
    var frame = av1_decode_obus(dr_bw_buf(bw), n, oe);
    assert_eq(load64(oe), DR_OK, "multi-group OBU stream decodes to a frame");
    assert_eq(frame != 0, 1, "-> a frame");
    assert_eq(dr_frame_width(frame), 256, "frame width 256");
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 256) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "2-tile-group OBU frame all flat-128 (av1_decode_obus accumulates)");
    return 0;
}
# Header-construction sanity: the custom seq + fh parse to exactly the fields the
# encode assumed (isolates header-layout bugs from the full decode).
fn test_obus_header_sanity() {
    var slen = 0;
    var seq = frame_build_seq(&slen);
    var se = 0;
    var s = av1_seq_parse(seq, slen, &se);
    assert_eq(se, DR_OK, "custom seq parses");
    assert_eq(av1_seq_num_planes(s), 1, "seq -> 1 plane (mono)");
    assert_eq(av1_seq_bitdepth(s), 8, "seq -> 8-bit");
    var flen = 0;
    var fh_b = frame_build_fh(&flen);
    var refs = av1_ref_state_new();
    var fe = 0;
    var fh = av1_frame_parse_uncompressed_header(s, refs, 0, 0, fh_b, flen, &fe);
    assert_eq(fe, DR_OK, "custom fh parses");
    assert_eq(av1_fh_frame_width(fh), 128, "fh FrameWidth 128 (from seq)");
    assert_eq(av1_fh_frame_height(fh), 64, "fh FrameHeight 64 (from seq)");
    assert_eq(av1_fh_mi_cols(fh), 32, "fh MiCols 32");
    assert_eq(av1_fh_mi_rows(fh), 16, "fh MiRows 16");
    assert_eq(av1_fh_base_q_idx(fh), 40, "fh base_q_idx 40");
    assert_eq(av1_fh_tx_mode(fh), AV1_TX_MODE_SELECT, "fh tx_mode SELECT");
    assert_eq(av1_fh_tile_cols(fh), 1, "fh TileCols 1");
    assert_eq(av1_fh_disable_cdf_update(fh), 1, "fh disable_cdf_update 1");
    return 0;
}
# THE milestone: a raw OBU byte stream (TD + SEQ + FRAME_HEADER + TILE_GROUP)
# decodes end-to-end to pixels through av1_decode_obus -> av1_decode_frame.
fn test_obus_end_to_end() {
    var tlen = 0;
    var tile = frame_enc_keyframe(&tlen);   # the single-tile group payload
    var slen = 0;
    var seq = frame_build_seq(&slen);
    var flen = 0;
    var fh = frame_build_fh(&flen);
    var bw = dr_bw_init(256);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, seq, slen);
    obus_wrap(bw, AV1_OBU_FRAME_HEADER, fh, flen);
    obus_wrap(bw, AV1_OBU_TILE_GROUP, tile, tlen);
    var stream_len = dr_bw_flush(bw);
    var stream = dr_bw_buf(bw);
    var oe = alloc(8);
    var frame = av1_decode_obus(stream, stream_len, oe);
    assert_eq(load64(oe), DR_OK, "decode_obus ok (raw bytes -> frame)");
    assert_eq(frame != 0, 1, "decode_obus returns a frame");
    assert_eq(dr_frame_width(frame), 128, "decoded frame width 128");
    assert_eq(dr_frame_height(frame), 64, "decoded frame height 64");
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 128) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "raw OBU bytes -> flat-DC keyframe pixels (all 128)");
    return 0;
}
# THE common real-stream form: a combined FRAME OBU (type 6) carrying the frame
# header + tile group in one OBU. The walk parses the fh, byte-splits off the tile
# group (5.10), and decodes it — end-to-end to pixels.
fn test_obus_frame_obu() {
    var tlen = 0;
    var tile = frame_enc_keyframe(&tlen);
    var slen = 0;
    var seq = frame_build_seq(&slen);
    var flen = 0;
    var fh = frame_build_fh(&flen);
    # FRAME OBU payload = frame-header bytes (byte-aligned) ++ tile-group bytes.
    var fpay_bw = dr_bw_init(256);
    obus_append(fpay_bw, fh, flen);
    obus_append(fpay_bw, tile, tlen);
    var fpay_len = dr_bw_flush(fpay_bw);
    var fpay = dr_bw_buf(fpay_bw);
    var bw = dr_bw_init(256);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, seq, slen);
    obus_wrap(bw, AV1_OBU_FRAME, fpay, fpay_len);
    var stream_len = dr_bw_flush(bw);
    var stream = dr_bw_buf(bw);
    var oe = alloc(8);
    var frame = av1_decode_obus(stream, stream_len, oe);
    assert_eq(load64(oe), DR_OK, "FRAME OBU decode ok (raw bytes -> frame)");
    assert_eq(frame != 0, 1, "FRAME OBU -> a frame");
    assert_eq(dr_frame_width(frame), 128, "FRAME OBU -> width 128");
    var bad = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 128) { if (dr_frame_get(frame, 0, x, y) != 128) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "FRAME OBU -> flat-DC keyframe pixels (fh/tile split correct)");
    return 0;
}
# A tile group before any sequence/frame header -> DR_ERR_BAD_HEADER (no context).
fn test_obus_tilegroup_no_headers() {
    var oe = alloc(8);
    var pay = alloc(2);
    store8(pay + 0, 0xAA); store8(pay + 1, 0xBB);
    var bw = dr_bw_init(16);
    obus_wrap(bw, AV1_OBU_TILE_GROUP, pay, 2);
    var n = dr_bw_flush(bw);
    assert_eq(av1_decode_obus(dr_bw_buf(bw), n, oe), 0, "tile group w/o headers -> no frame");
    assert_eq(load64(oe), DR_ERR_BAD_HEADER, "tile group before seq/fh -> BAD_HEADER");
    return 0;
}

# A malformed OBU (forbidden bit set) makes av1_obu_next fault; the walk propagates
# the parser's PRECISE sticky code, not a generic BAD_HEADER.
fn test_obus_forbidden_bit() {
    var oe = alloc(8);
    var buf = alloc(4);
    store8(buf + 0, 0x80);                 # obu_forbidden_bit = 1 (6.2.2 violation)
    store8(buf + 1, 0x00); store8(buf + 2, 0x00); store8(buf + 3, 0x00);
    var frame = av1_decode_obus(buf, 4, oe);
    assert_eq(frame, 0, "forbidden-bit OBU -> no frame");
    assert_eq(load64(oe), DR_ERR_FORBIDDEN_BIT, "sticky parse fault propagated (not masked as BAD_HEADER)");
    return 0;
}
# A malformed SEQUENCE_HEADER payload surfaces a parse error (the walk does not
# silently continue past a failed seq_parse).
fn test_obus_bad_seq_payload() {
    var oe = alloc(8);
    var pay = alloc(2);
    store8(pay + 0, 0xFF); store8(pay + 1, 0xFF);   # seq_profile = 7 (invalid) etc.
    var bw = dr_bw_init(16);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, pay, 2);
    var n = dr_bw_flush(bw);
    var frame = av1_decode_obus(dr_bw_buf(bw), n, oe);
    assert_eq(frame, 0, "bad seq payload -> no frame");
    assert_eq(load64(oe) != DR_OK, 1, "bad seq payload -> error surfaced");
    return 0;
}
# metadata + padding OBUs interspersed are skipped without disturbing the decode.
# This also stresses the per-OBU byte-offset slicing (buf+off): interspersed OBUs
# shift every payload offset, so a mis-sliced tile group would desync -> wrong
# pixels. A correct flat-128 decode here is a much stronger witness than the plain
# end-to-end stream.
fn test_obus_metadata_padding_skipped() {
    var tlen = 0;
    var tile = frame_enc_keyframe(&tlen);
    var slen = 0;
    var seq = frame_build_seq(&slen);
    var flen = 0;
    var fh = frame_build_fh(&flen);
    var meta = alloc(3);
    store8(meta + 0, 0x01); store8(meta + 1, 0x02); store8(meta + 2, 0x03);
    var pad = alloc(4);
    var i = 0;
    while (i < 4) { store8(pad + i, 0); i = i + 1; }
    var bw = dr_bw_init(256);
    obus_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    obus_wrap(bw, AV1_OBU_METADATA, meta, 3);           # skipped (shifts offsets)
    obus_wrap(bw, AV1_OBU_SEQUENCE_HEADER, seq, slen);
    obus_wrap(bw, AV1_OBU_PADDING, pad, 4);             # skipped (shifts offsets)
    obus_wrap(bw, AV1_OBU_FRAME_HEADER, fh, flen);
    obus_wrap(bw, AV1_OBU_TILE_GROUP, tile, tlen);
    var n = dr_bw_flush(bw);
    var oe = alloc(8);
    var frame = av1_decode_obus(dr_bw_buf(bw), n, oe);
    assert_eq(load64(oe), DR_OK, "metadata/padding interspersed -> still decodes");
    assert_eq(frame != 0, 1, "-> returns a frame");
    assert_eq(dr_frame_get(frame, 0, 40, 30), 128, "-> correct pixels (slicing robust to offset shifts)");
    return 0;
}

# ================================================================
# REGRESSION (0.7.114): the decode frame allocation must cover a block's NOMINAL write extent.
# The overflow this pins is proven in tests/frame.tcyr (test_alloc_covers_nominal_overhang);
# these two assertions pin the DECODE SITE — that av1_decode_frame actually asks for it.
# ================================================================
fn test_decode_alloc_extent() {
    var fh = frame_mk_fh(1, 1, 0, 0);          # 128x64, MI 32x16 -> MI extent == visible
    assert_eq(av1_decode_alloc_w(fh), 128, "alloc extent: MI grid covers a 128-wide frame exactly");
    assert_eq(av1_decode_alloc_h(fh), 64, "alloc extent: ...and a 64-tall one");
    # a width that is NOT a multiple of 8 is where MI-alignment actually does work:
    # MiCols = 2*((65+7)>>3) = 18 -> 72 samples, seven past the visible 65.
    store64(fh + AV1FH_FRAME_WIDTH, 65);
    store64(fh + AV1FH_MI_COLS, 18);
    assert_eq(av1_decode_alloc_w(fh), 72, "alloc extent: MI grid exceeds a 65-wide frame by 7");
    store64(fh + AV1FH_FRAME_HEIGHT, 33);
    store64(fh + AV1FH_MI_ROWS, 10);
    assert_eq(av1_decode_alloc_h(fh), 40, "alloc extent: MI grid exceeds a 33-tall frame by 7");
    # ...and the max() guard: MI counts inconsistent with the dims must not shrink the alloc.
    store64(fh + AV1FH_MI_COLS, 2);
    assert_eq(av1_decode_alloc_w(fh), 65, "alloc extent: never smaller than the visible frame");
    return 0;
}

# the BORDER half of the invariant, on a genuinely decoded frame. frame_mk_seq(0) disables
# CDEF and restoration, so av1_decode_frame returns the PREDICTION frame — the one whose
# allocation prediction writes into.
fn test_decode_frame_alloc_invariant() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);
    var frame = av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe);
    assert_eq(load64(oe), DR_OK, "alloc invariant: frame decoded");
    # the addressable extent right of the origin must reach the MI grid plus the worst-case
    # 28-sample block overhang. With the old 8-sample border this is 136 against a required
    # 156 and goes red.
    var addressable = dr_frame_plane_stride(frame, 0) - dr_frame_border(frame);
    assert_eq(addressable >= (av1_decode_alloc_w(fh) + 28), 1,
    "alloc invariant: decoded frame covers MiCols*4 + the 28-sample block overhang");
    assert_eq(dr_frame_border(frame) >= 28, 1,
    "alloc invariant: the border alone covers the worst-case overhang past the MI grid");
    # reported dims stay VISIBLE — CDEF / LR / superres / output crop must not see the pad.
    assert_eq(dr_frame_width(frame), 128, "alloc invariant: reported width is still visible");
    assert_eq(dr_frame_plane_width(frame, 0), 128, "alloc invariant: plane width is still visible");
    return 0;
}

# ================================================================
# SILENT-MIS-DECODE REJECTS (0.7.116). Each of these frame-header features is PARSED but not
# IMPLEMENTED; before this they were accepted and decoded wrong with no error. Parsing without
# implementing is the failure "trust no input byte" exists to prevent, so each must now fail
# CLEANLY at the shared chokepoint.
# ================================================================
fn dec_reject(mutate_field, value, tag): i64 {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);
    store64(fh + mutate_field, value);
    var frame = av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe);
    assert_eq(frame, 0, tag);
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, tag);
    return 0;
}

# C1 (7.20): decoding a frame through the frame path SAVES its CDFs into every DPB slot its
# refresh_frame_flags marks (and leaves the others null), so a future frame can inherit them.
# Witnesses the av1_frame_dec_finish save loop + its refresh_frame_flags gating + the one-bundle
# aliasing. (The save/load COPY correctness + load-bearingness are pinned by test_cdf_inheritance.)
fn test_cdf_save_populates_slots() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 5);   # refresh slots 0 and 2 (bits 0b101)
    var refs = av1_ref_state_new();
    var dpb = av1_dpb_new();
    var frame = av1_decode_frame_ref(frame_mk_seq(0), fh, dpb, refs, out, olen, oe);
    assert_eq(frame != 0, 1, "CDF save: keyframe decodes");
    assert_eq(load64(oe), DR_OK, "CDF save: DR_OK");
    assert_eq(av1_ref_saved_cdf(refs, 0) != 0, 1, "CDF save: refreshed slot 0 has a saved bundle");
    assert_eq(av1_ref_saved_cdf(refs, 2) != 0, 1, "CDF save: refreshed slot 2 has a saved bundle");
    assert_eq(av1_ref_saved_cdf(refs, 1), 0, "CDF save: un-refreshed slot 1 stays null");
    var si = 3;
    while (si < 8) {
        assert_eq(av1_ref_saved_cdf(refs, si), 0, "CDF save: every un-refreshed high slot stays null");
        si = si + 1;
    }
    assert_eq(av1_ref_saved_cdf(refs, 0), av1_ref_saved_cdf(refs, 2),
    "CDF save: ONE bundle is aliased into every refreshed slot");
    # this keyframe has disable_frame_end_update_cdf=1 (forced by disable_cdf_update=1), so 7.20 saves the
    # frame's INITIAL context — the bundle's coeff region equals a fresh q-bucket default, not adapted CDFs.
    var b = av1_ref_saved_cdf(refs, 0);
    var defcc = av1_ccdf_new(av1_coeff_cdf_qbucket(40));
    var cceq = 1;
    var wj = 0;
    while (wj < 3999) {
        if (load64(b + ((1756 + wj) * 8)) != load64(defcc + (wj * 8))) { cceq = 0; }
        wj = wj + 1;
    }
    assert_eq(cceq, 1, "CDF save: disable_frame_end_update_cdf=1 saves the INITIAL (default) coeff CDFs");
    return 0;
}
# C1 gate: an ADAPTING frame (disable_frame_end_update_cdf=0) whose context_update_tile_id names a tile
# other than tile0 cannot have the right tile's CDFs saved (only tile0 is retained) -> reject cleanly
# rather than silently save tile0's context for a future inheritor.
fn test_cdf_multitile_ctx_rejected() {
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    var fh = frame_mk_fh(1, 1, 0, 0);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 0);          # adapting
    store64(fh + AV1FH_DISABLE_FE_UPDATE_CDF, 0);       # ...and saving the adapted context
    store64(fh + AV1FH_CONTEXT_UPDATE_TILE_ID, 1);      # ...from a NON-tile0 context tile
    assert_eq(av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe), 0,
    "adapting frame with context_update_tile_id != 0 rejected (context tile not retained)");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED, "...with DR_ERR_UNSUPPORTED");
    return 0;
}

fn test_silent_misdecode_rejects() {
    # the control: the same stream decodes when none of the flags are set.
    var olen = 0;
    var out = frame_enc_keyframe(&olen);
    var oe = alloc(8);
    assert_eq(av1_decode_frame(frame_mk_seq(0), frame_mk_fh(1, 1, 0, 0), out, olen, oe) != 0, 1,
    "reject control: the unflagged stream still decodes");
    dec_reject(AV1FH_SEG_ENABLED, 1, "segmentation_enabled rejected (no segment-id read)");
    dec_reject(AV1FH_DELTA_Q_PRESENT, 1, "delta_q_present rejected (per-SB delta-q unread)");
    dec_reject(AV1FH_DELTA_LF_PRESENT, 1, "delta_lf_present rejected (per-SB delta-lf unread)");
    dec_reject(AV1FH_ALLOW_INTRABC, 1, "allow_intrabc rejected (5.11.6 unimplemented)");
    dec_reject(AV1FH_ALLOW_SCT, 1, "allow_screen_content_tools rejected (palette unimplemented)");
    # primary_ref_frame only binds on a NON-intra frame; the spec forces PRIMARY_REF_NONE on
    # key frames, so a keyframe fixture must NOT be rejected for it.
    var fh = frame_mk_fh(1, 1, 0, 0);
    store64(fh + AV1FH_PRIMARY_REF_FRAME, 0);
    assert_eq(av1_decode_frame(frame_mk_seq(0), fh, out, olen, oe) != 0, 1,
    "primary_ref_frame is ignored on a KEY frame (spec forces PRIMARY_REF_NONE)");
    # CDF inheritance (C1) is now IMPLEMENTED, but an inter frame whose primary_ref_frame selects a
    # DPB slot that was NEVER a decoded frame (no saved CDFs) is malformed — the tile inherit rejects
    # it rather than silently start from defaults. Here nothing was decoded into any slot, so the
    # inheriting inter frame still rejects DR_ERR_UNSUPPORTED (the load-bearing WITH a valid bundle is
    # test_cdf_inheritance / test_cdf_save_populates_slots).
    var fh2 = frame_mk_fh(1, 1, 0, 0);
    store64(fh2 + AV1FH_FRAME_IS_INTRA, 0);
    store64(fh2 + AV1FH_PRIMARY_REF_FRAME, 0);
    assert_eq(av1_decode_frame(frame_mk_seq(0), fh2, out, olen, oe), 0,
    "an INTER frame inheriting from a slot with NO saved CDFs is rejected, not mis-decoded");
    assert_eq(load64(oe), DR_ERR_UNSUPPORTED,
    "...with DR_ERR_UNSUPPORTED, not a mis-decode returning DR_OK");
    return 0;
}

fn main() {
    alloc_init();
    test_group("silent-mis-decode rejects (0.7.116)");
    test_cdf_save_populates_slots();
    test_cdf_multitile_ctx_rejected();
    test_silent_misdecode_rejects();
    test_group("decode frame allocation extent (0.7.114 regression)");
    test_decode_alloc_extent();
    test_decode_frame_alloc_invariant();
    test_group("in-loop filter pipeline (deblock -> CDEF -> LR)");
    test_pipeline_none();
    test_pipeline_cdef();
    test_pipeline_cdef_lr();
    test_pipeline_deblock();
    test_group("frame-header filter activation");
    test_lr_params_from_fh();
    test_activate_intra_filters();
    test_group("tile-group OBU parse (5.11.1)");
    test_tg_read_le();
    test_tg_single();
    test_tg_multi_no_present();
    test_tg_present_subrange();
    test_tg_tsbytes2();
    test_tg_single_nonzero_index();
    test_tg_adversarial();
    test_group("frame-level driver (av1_decode_frame)");
    test_frame_decode_plain();
    test_frame_decode_cdef();
    test_frame_decode_2tile();
    test_frame_decode_multigroup();
    test_frame_decode_superres();
    test_frame_decode_10bit();
    test_frame_decode_12bit();
    test_frame_decode_10bit_cdef();
    test_frame_decode_dimbomb();
    test_frame_decode_truncated();
    test_frame_decode_sb128_rejected();
    test_group("OBU-stream walk (av1_decode_obus)");
    test_obus_bad_args();
    test_obus_td_only();
    test_obus_frame_obu_no_seq();
    test_obus_frame_obu_malformed();
    test_obus_frame_obu_empty_tg();
    test_obus_tilegroup_no_headers();
    test_obus_header_sanity();
    test_obus_end_to_end();
    test_obus_frame_obu();
    test_obus_multigroup();
    test_obus_forbidden_bit();
    test_obus_bad_seq_payload();
    test_obus_metadata_padding_skipped();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
