    test_group("MI-grid addressing (absolute — accessor-independent)");
    test_mi_grid_addressing();
    test_group("MI-grid population (5.11.4 storage loops)");
    test_mi_store_footprint();
    test_mi_store_mode_footprint();
    test_mi_store_fields();
    test_mi_store_inter_fields();
    test_mi_store_clip();
