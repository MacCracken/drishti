    test_div_lut();
    test_resolve_divisor();
    test_warp_estimation();
    test_warp_est_badargs();
    test_group("setup_shear (7.11.3.6) — shear params + warpValid");
    test_setup_shear();
    test_setup_shear_badargs();
    return assert_summary();
}

# ---- warp estimation (7.11.3.8) — KATs from scripts/refs/warp_estimation_ref.py ----
# Div_Lut generated lazily; pin the 9 anchored spot values + a full 257-entry digest
# (sum + position-weighted checksum) vs the ref port. The digest defeats a per-entry
# accessor-circular test: fill and check share nothing.
fn test_div_lut() {
    var t = av1_div_lut_tbl();
    if (t == 0) { assert_eq(0, 1, "div_lut alloc failed"); return 0; }
    assert_eq(load64(t + (0 * 8)), 16384, "Div_Lut[0]=16384=2^14 (anchor)");
    assert_eq(load64(t + (1 * 8)), 16320, "Div_Lut[1]=16320");
    assert_eq(load64(t + (2 * 8)), 16257, "Div_Lut[2]=16257");
    assert_eq(load64(t + (3 * 8)), 16194, "Div_Lut[3]=16194");
    assert_eq(load64(t + (64 * 8)), 13107, "Div_Lut[64]=13107");
    assert_eq(load64(t + (128 * 8)), 10923, "Div_Lut[128]=10923");
    assert_eq(load64(t + (192 * 8)), 9362, "Div_Lut[192]=9362");
    assert_eq(load64(t + (255 * 8)), 8208, "Div_Lut[255]=8208");
    assert_eq(load64(t + (256 * 8)), 8192, "Div_Lut[256]=8192=2^13 (anchor)");
    var sum = 0;
    var ck = 0;
    var i = 0;
    while (i <= 256) {
        var v = load64(t + (i * 8));
        sum = sum + v;
        ck = ck + ((i + 1) * v);
        i = i + 1;
    }
    assert_eq(sum, 2919562, "Div_Lut full sum");
    assert_eq(ck, 333447688, "Div_Lut position-weighted checksum (257 entries)");
    return 0;
}
fn we_rd(d, es, ef, tag): i64 {
    var o = alloc(16);
    assert_eq(av1_resolve_divisor(d, o), DR_OK, tag);
    assert_eq(load64(o + 0), es, tag);
    assert_eq(load64(o + 8), ef, tag);
    return 0;
}
fn test_resolve_divisor() {
    we_rd(1, 14, 16384, "resolve_divisor(1): n=0 f=0");
    we_rd(7, 16, 9362, "resolve_divisor(7): n=2 f=192");
    we_rd(255, 21, 8224, "resolve_divisor(255): n=7 f=254");
    we_rd(256, 22, 16384, "resolve_divisor(256): n=8 e=0 f=0");
    we_rd(511, 22, 8208, "resolve_divisor(511): n=8 f=255");
    we_rd(512, 23, 16384, "resolve_divisor(512): n=9 e=0 f=0");
    we_rd(1023, 23, 8192, "resolve_divisor(1023): f=256 (upper index)");
    we_rd(0 - 1023, 23, 0 - 8192, "resolve_divisor(-1023): negative factor");
    we_rd(4194304, 36, 16384, "resolve_divisor(2^22): large n");
    return 0;
}
# hand-set one CandList entry {srcY, srcX, dstY, dstX} in 1/8-pel (matches add_sample).
fn we_add(ws, i, cy, cx, smvr, smvc): i64 {
    var base = ws + AV1WS_CAND + ((i * 4) * 8);
    store64(base + 0, cy * 8);
    store64(base + 8, cx * 8);
    store64(base + 16, (cy * 8) + smvr);
    store64(base + 24, (cx * 8) + smvc);
    return 0;
}
fn we_check(out, valid, w0, w1, w2, w3, w4, w5, tag): i64 {
    assert_eq(av1_warp_model_valid(out), valid, tag);
    if (valid != 0) {
        assert_eq(av1_warp_model_param(out, 0), w0, tag);
        assert_eq(av1_warp_model_param(out, 1), w1, tag);
        assert_eq(av1_warp_model_param(out, 2), w2, tag);
        assert_eq(av1_warp_model_param(out, 3), w3, tag);
        assert_eq(av1_warp_model_param(out, 4), w4, tag);
        assert_eq(av1_warp_model_param(out, 5), w5, tag);
    }
    return 0;
}
# all cases: block at MiRow=8, MiCol=8, MiSize=6 (BLOCK_16X16 -> w4=h4=4, center px 39).
fn test_warp_estimation() {
    var out = av1_warp_model_new();
    # A: every sample carries the block MV -> identity 2x2, translation = MV.
    var wa = av1_warp_new();
    we_add(wa, 0, 23, 31, 16, 24);
    we_add(wa, 1, 23, 39, 16, 24);
    we_add(wa, 2, 39, 23, 16, 24);
    store64(wa + AV1WS_NUM, 3);
    assert_eq(av1_warp_estimation(wa, 8, 8, 6, 16, 24, out), DR_OK, "warp A ok");
    we_check(out, 1, 200079, 134543, 65447, 0, 0, 65447, "warp A translation (identity 2x2)");
    # F: a clean affine — four DISTINCT un-clamped params (transposition witness).
    var wf = av1_warp_new();
    we_add(wf, 0, 20, 20, 0 - 8, 0 - 12);
    we_add(wf, 1, 20, 58, 0 - 12, 8);
    we_add(wf, 2, 58, 20, 8, 0 - 12);
    we_add(wf, 3, 58, 58, 4, 10);
    store64(wf + AV1WS_NUM, 4);
    assert_eq(av1_warp_estimation(wf, 8, 8, 6, 0, 0, out), DR_OK, "warp F ok");
    we_check(out, 1, 0 - 185328, 0 - 101166, 70077, 211, 0 - 868, 68998, "warp F clean affine");
    # C: sample 2 has a delta-MV >= LS_MV_MAX -> dropped by the guard; equals the 2-prefix.
    var wc = av1_warp_new();
    we_add(wc, 0, 23, 31, 16, 24);
    we_add(wc, 1, 23, 55, 40, 24);
    we_add(wc, 2, 55, 31, 16, 324);
    store64(wc + AV1WS_NUM, 3);
    assert_eq(av1_warp_estimation(wc, 8, 8, 6, 16, 24, out), DR_OK, "warp C ok");
    we_check(out, 1, 200430, 0 - 25825, 65438, 0, 8179, 61380, "warp C LS_MV_MAX guard");
    # E: strong expansion -> diag UPPER clamp (73727) + nondiag UPPER clamp (8191).
    var we = av1_warp_new();
    we_add(we, 0, 20, 20, 0, 0 - 96);
    we_add(we, 1, 20, 60, 0, 96);
    we_add(we, 2, 60, 20, 0 - 96, 0);
    we_add(we, 3, 60, 60, 96, 0);
    store64(we + AV1WS_NUM, 4);
    assert_eq(av1_warp_estimation(we, 8, 8, 6, 0, 0, out), DR_OK, "warp E ok");
    we_check(out, 1, 0 - 317031, 0 - 312936, 73727, 0 - 62, 8191, 65369, "warp E diag+nondiag UPPER clamp");
    # G: strong contraction -> diag LOWER clamp (57345) + nondiag LOWER clamp (-8191).
    var wg = av1_warp_new();
    we_add(wg, 0, 20, 20, 0, 96);
    we_add(wg, 1, 20, 60, 0, 0 - 96);
    we_add(wg, 2, 60, 20, 96, 0);
    we_add(wg, 3, 60, 60, 0 - 96, 0);
    store64(wg + AV1WS_NUM, 4);
    assert_eq(av1_warp_estimation(wg, 8, 8, 6, 0, 0, out), DR_OK, "warp G ok");
    we_check(out, 1, 317031, 321126, 57345, 62, 0 - 8191, 65493, "warp G diag+nondiag LOWER clamp");
    # H: reversed shear -> clean NEGATIVE un-clamped nondiag (transposition witness).
    var wh = av1_warp_new();
    we_add(wh, 0, 20, 20, 12, 8);
    we_add(wh, 1, 20, 60, 0 - 12, 8);
    we_add(wh, 2, 60, 20, 12, 0 - 8);
    we_add(wh, 3, 60, 60, 0 - 12, 0 - 8);
    store64(wh + AV1WS_NUM, 4);
    assert_eq(av1_warp_estimation(wh, 8, 8, 6, 0, 0, out), DR_OK, "warp H ok");
    we_check(out, 1, 130884, 194259, 65441, 0 - 3261, 0 - 4892, 65447, "warp H reversed shear");
    # J1: a SINGLE sample (NumSamples==1, a real find_warp_samples outcome) — the KEY
    # witness that the LS shift is ARITHMETIC (by0 = ls_product1(8,-45) < 0, so a logical
    # >> corrupts it) AND that mult uses SIGNED rounding (wm[3]=-6317, floor would give -6316).
    var wj = av1_warp_new();
    we_add(wj, 0, 39, 40, 0 - 38, 0 - 7);
    store64(wj + AV1WS_NUM, 1);
    assert_eq(av1_warp_estimation(wj, 8, 8, 6, 7, 1, out), DR_OK, "warp J1 ok");
    we_check(out, 1, 574004, 696242, 57345, 0 - 6317, 0 - 8191, 57345, "warp J1 single (arith-shift + signed-round)");
    # J2: a clean 2-sample case with a small negative product1 term (no overflow) — a
    # second, independent witness that the LS product1 shift is arithmetic, not logical.
    var wj2 = av1_warp_new();
    we_add(wj2, 0, 30, 50, 2, 0 - 4);
    we_add(wj2, 1, 48, 44, 6, 3);
    store64(wj2 + AV1WS_NUM, 2);
    assert_eq(av1_warp_estimation(wj2, 8, 8, 6, 0, 0, out), DR_OK, "warp J2 ok");
    we_check(out, 1, 0 - 93951, 0 - 276354, 64945, 3000, 3981, 68641, "warp J2 negative product1 term");
    # K: a single sample with sx=sy=dx=dy=-1 -> det=1 -> resolve divShift=14, minus 16 = -2
    # < 0, witnessing the divFactor<<(-divShift) rescale branch. Raw cand (311 not /8).
    var wk = av1_warp_new();
    store64(wk + AV1WS_CAND + 0, 311);
    store64(wk + AV1WS_CAND + 8, 311);
    store64(wk + AV1WS_CAND + 16, 311);
    store64(wk + AV1WS_CAND + 24, 311);
    store64(wk + AV1WS_NUM, 1);
    assert_eq(av1_warp_estimation(wk, 8, 8, 6, 0, 0, out), DR_OK, "warp K ok");
    we_check(out, 1, 0, 0, 65536, 0, 0, 65536, "warp K det=1 -> divShift<0 rescale branch");
    # CV: like C but sample 2 is dropped by the VERTICAL guard conjunct (|sy-dy|>=256,
    # |sx-dx|<256) -> equals the 2-prefix; witnesses the sy-dy half of the LS_MV_MAX guard.
    var wcv = av1_warp_new();
    we_add(wcv, 0, 23, 31, 16, 24);
    we_add(wcv, 1, 23, 55, 40, 24);
    we_add(wcv, 2, 55, 31, 316, 24);
    store64(wcv + AV1WS_NUM, 3);
    assert_eq(av1_warp_estimation(wcv, 8, 8, 6, 16, 24, out), DR_OK, "warp CV ok");
    we_check(out, 1, 200430, 0 - 25825, 65438, 0, 8179, 61380, "warp CV vertical LS_MV_MAX guard");
    # TC: a large MV (col +1100, row -1100) drives the translation past +-2^23 -> witnesses
    # BOTH translation clamp bounds: wm[0]=2^23-1=8388607 (hi), wm[1]=-2^23=-8388608 (lo).
    var wtc = av1_warp_new();
    we_add(wtc, 0, 23, 31, 0 - 1100, 1100);
    we_add(wtc, 1, 23, 39, 0 - 1100, 1100);
    we_add(wtc, 2, 39, 23, 0 - 1100, 1100);
    store64(wtc + AV1WS_NUM, 3);
    assert_eq(av1_warp_estimation(wtc, 8, 8, 6, 0 - 1100, 1100, out), DR_OK, "warp TC ok");
    we_check(out, 1, 8388607, 0 - 8388608, 65447, 0, 0, 65447, "warp TC translation clamp both bounds");
    # D: no samples -> det == 0 -> invalid, identity default left in place.
    var wd = av1_warp_new();
    store64(wd + AV1WS_NUM, 0);
    assert_eq(av1_warp_estimation(wd, 8, 8, 6, 16, 24, out), DR_OK, "warp D ok");
    assert_eq(av1_warp_model_valid(out), 0, "warp D empty -> LocalValid 0");
    assert_eq(av1_warp_model_param(out, 2), 65536, "warp D invalid -> identity default wm[2]");
    return 0;
}
fn test_warp_est_badargs() {
    var out = av1_warp_model_new();
    var ws = av1_warp_new();
    assert_eq(av1_warp_estimation(0, 8, 8, 6, 0, 0, out), DR_ERR_BOUNDS, "warp ws==0 rejects");
    assert_eq(av1_warp_estimation(ws, 8, 8, 6, 0, 0, 0), DR_ERR_BOUNDS, "warp out==0 rejects");
    assert_eq(av1_warp_estimation(ws, 8, 8, 0 - 1, 0, 0, out), DR_ERR_BOUNDS, "warp mi_size<0 rejects");
    assert_eq(av1_warp_estimation(ws, 8, 8, 22, 0, 0, out), DR_ERR_BOUNDS, "warp mi_size>=22 rejects");
    return 0;
}

# ---- setup_shear (7.11.3.6) — KATs from scripts/refs/setup_shear_ref.py ----
fn ss_model(w0, w1, w2, w3, w4, w5): i64 {
    var m = av1_warp_model_new();
    store64(m + AV1WM_MAT + (0 * 8), w0);
    store64(m + AV1WM_MAT + (1 * 8), w1);
    store64(m + AV1WM_MAT + (2 * 8), w2);
    store64(m + AV1WM_MAT + (3 * 8), w3);
    store64(m + AV1WM_MAT + (4 * 8), w4);
    store64(m + AV1WM_MAT + (5 * 8), w5);
    return m;
}
fn ss_check(m, valid, a, b, g, d, tag): i64 {
    assert_eq(av1_setup_shear(m), DR_OK, tag);
    assert_eq(av1_warp_model_shear_valid(m), valid, tag);
    assert_eq(av1_warp_model_alpha(m), a, tag);
    assert_eq(av1_warp_model_beta(m), b, tag);
    assert_eq(av1_warp_model_gamma(m), g, tag);
    assert_eq(av1_warp_model_delta(m), d, tag);
    return 0;
}
fn test_setup_shear() {
    # identity model -> all-zero shear, valid.
    ss_check(ss_model(0, 0, 65536, 0, 0, 65536), 1, 0, 0, 0, 0, "shear identity");
    # real warp_estimation outputs (0.7.93 F/E/G) -> genuine 4-distinct shear params, valid.
    ss_check(ss_model(0 - 185328, 0 - 101166, 70077, 211, 0 - 868, 68998),
    1, 4544, 192, 0 - 832, 3456, "shear est_F (4 distinct params)");
    ss_check(ss_model(0 - 317031, 0 - 312936, 73727, 0 - 62, 8191, 65369),
    1, 8192, 0 - 64, 7296, 0 - 192, "shear est_E");
    ss_check(ss_model(317031, 321126, 57345, 62, 0 - 8191, 65493),
    1, 0 - 8192, 64, 0 - 9344, 0 - 64, "shear est_G");
    # fail the 4|alpha|+7|beta| realizability check -> warpValid 0 (params still computed).
    ss_check(ss_model(0, 0, 73727, 8191, 0, 65536), 0, 8192, 8192, 0, 0, "shear bad_ab reject");
    # alpha EXACTLY at the boundary (4*16384==65536) -> pins the alpha coeff + the >= compare.
    ss_check(ss_model(0, 0, 81920, 0, 0, 65536), 0, 16384, 0, 0, 0, "shear alpha boundary (>=)");
    # beta-dominant boundary (7*9408 over, 6*9408 under) -> pins the beta coefficient (7).
    ss_check(ss_model(0, 0, 65536, 9408, 0, 65536), 0, 0, 9408, 0, 0, "shear beta coeff (7)");
    # fail ONLY the 4|gamma|+4|delta| check -> warpValid 0.
    ss_check(ss_model(0, 0, 65536, 0, 8191, 73727), 0, 0, 0, 8192, 8192, "shear bad_gd reject");
    # second-check coefficient pins BOTH directions (bad_gd is symmetric -> can't pin either):
    # gamma at the exact boundary (4*16384==65536) rejects -> pins gamma coeff decrease + >=;
    # a gamma pass at 13120 (5*13120 would reject) -> pins gamma coeff increase. Same for delta.
    ss_check(ss_model(0, 0, 65536, 0, 16384, 65536), 0, 0, 0, 16384, 0, "shear gamma boundary (>=)");
    ss_check(ss_model(0, 0, 65536, 0, 13120, 65536), 1, 0, 0, 13120, 0, "shear gamma coeff (4)");
    ss_check(ss_model(0, 0, 65536, 0, 0, 81920), 0, 0, 0, 0, 16384, "shear delta boundary (>=)");
    ss_check(ss_model(0, 0, 65536, 0, 0, 78656), 1, 0, 0, 0, 13120, "shear delta coeff (4)");
    # first-check coefficient INCREASE pins (the boundary cases above only catch decreases):
    ss_check(ss_model(0, 0, 78656, 0, 0, 65536), 1, 13120, 0, 0, 0, "shear alpha coeff incr (4)");
    ss_check(ss_model(0, 0, 65536, 8192, 0, 65536), 1, 0, 8192, 0, 0, "shear beta coeff incr (7)");
    # precondition guard: wmmat[2] <= 0 -> warpValid 0, params 0, before resolve_divisor.
    ss_check(ss_model(0, 0, 0, 0, 0, 65536), 0, 0, 0, 0, 0, "shear guard m2==0");
    ss_check(ss_model(0, 0, 0 - 100, 5, 5, 65536), 0, 0, 0, 0, 0, "shear guard m2<0");
    # reduce witness: alpha0=100 -> reduced to a multiple of 64 (128), not 100.
    ss_check(ss_model(0, 0, 65636, 0, 0, 65536), 1, 128, 0, 0, 0, "shear reduce 100->128");
    # INT16 clamp witnesses (lower -32768 via m2=100; upper 32767 via m2=100000).
    ss_check(ss_model(0, 0, 100, 0, 0, 65536), 0, 0 - 32768, 0, 0, 0, "shear clamp_lo -32768");
    ss_check(ss_model(0, 0, 100000, 40000, 0, 65536), 0, 32768, 32768, 0, 0, "shear clamp_hi 32767");
    return 0;
}
fn test_setup_shear_badargs() {
    assert_eq(av1_setup_shear(0), DR_ERR_BOUNDS, "setup_shear model==0 rejects");
    return 0;
}

var exit_code = main();
syscall(60, exit_code);
