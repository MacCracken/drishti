# tests/av1_deblock.tcyr — AV1 deblocking loop-filter kernels (spec 7.14.3-7.14.6).
# The filter-size / strength / limit derivations by arithmetic known-answers, and
# the sample filters (mask, narrow 4-tap, wide low-pass) by hand-computed edges.
include "src/main.cyr"
include "src/av1_deblock.cyr"

# ---- filter size (7.14.3) ----
fn test_filter_size() {
    # TX_8X8=1, TX_16X16=2, TX_4X4=0, TX_32X32=3.
    assert_eq(av1_lf_filter_size(1, 1, 0, 0), 8, "8x8 luma -> 8");
    assert_eq(av1_lf_filter_size(2, 2, 0, 0), 16, "16x16 luma -> 16");
    assert_eq(av1_lf_filter_size(0, 0, 0, 0), 4, "4x4 luma -> 4");
    assert_eq(av1_lf_filter_size(3, 3, 0, 0), 16, "32x32 luma -> clamp 16");
    assert_eq(av1_lf_filter_size(2, 2, 0, 1), 8, "16x16 chroma -> clamp 8");
    # across a boundary: min of the two tx dims (8x8 vs 16x16 -> 8).
    assert_eq(av1_lf_filter_size(1, 2, 0, 0), 8, "8x8|16x16 -> min 8");
    return 0;
}
# ---- limits (7.14.4) ----
fn test_limits() {
    var o = alloc(3 * 8);
    av1_lf_limits(10, 0, o);
    assert_eq(load64(o + 0), 10, "limit lvl10 sh0");
    assert_eq(load64(o + 8), 34, "blimit lvl10 sh0");     # 2*(10+2)+10
    assert_eq(load64(o + 16), 0, "thresh lvl10");         # 10>>4
    av1_lf_limits(20, 2, o);
    assert_eq(load64(o + 0), 7, "limit lvl20 sh2");       # clip3(1,7,10)
    assert_eq(load64(o + 8), 51, "blimit lvl20 sh2");     # 2*22+7
    assert_eq(load64(o + 16), 1, "thresh lvl20");         # 20>>4
    av1_lf_limits(40, 6, o);
    assert_eq(load64(o + 0), 3, "limit lvl40 sh6");       # shift 2 -> clip3(1,3,10)
    assert_eq(load64(o + 16), 2, "thresh lvl40");         # 40>>4
    return 0;
}
# ---- strength selection (7.14.5) ----
fn mk_fh(lvl0, lvl1, lvl2, lvl3, sharp, delta_en, intra_ref_delta): i64 {
    var fh = alloc(1024);
    store64(fh + AV1FH_LF_LEVEL + 0, lvl0);
    store64(fh + AV1FH_LF_LEVEL + 8, lvl1);
    store64(fh + AV1FH_LF_LEVEL + 16, lvl2);
    store64(fh + AV1FH_LF_LEVEL + 24, lvl3);
    store64(fh + AV1FH_LF_SHARPNESS, sharp);
    store64(fh + AV1FH_LF_DELTA_ENABLED, delta_en);
    store64(fh + AV1FH_LF_REF_DELTAS + (AV1_INTRA_FRAME * 8), intra_ref_delta);
    return fh;
}
fn test_strength() {
    var fh = mk_fh(10, 12, 14, 16, 0, 0, 1);
    # intra, delta disabled -> loop_filter_level[i], i = pass (luma) / plane+1 (chroma).
    assert_eq(av1_lf_strength(fh, 0, 0, AV1_INTRA_FRAME, 0, 0), 10, "luma pass0 -> lvl[0]");
    assert_eq(av1_lf_strength(fh, 0, 1, AV1_INTRA_FRAME, 0, 0), 12, "luma pass1 -> lvl[1]");
    assert_eq(av1_lf_strength(fh, 1, 0, AV1_INTRA_FRAME, 0, 0), 14, "U -> lvl[2]");
    assert_eq(av1_lf_strength(fh, 2, 0, AV1_INTRA_FRAME, 0, 0), 16, "V -> lvl[3]");
    # delta_lf adds; clamped to [0,63].
    assert_eq(av1_lf_strength(fh, 0, 0, AV1_INTRA_FRAME, 0, 5), 15, "luma + deltaLF 5");
    # delta enabled: intra ref delta 1, nshift = lvl>>5 = 0 -> +1.
    var fh2 = mk_fh(10, 12, 14, 16, 0, 1, 1);
    assert_eq(av1_lf_strength(fh2, 0, 0, AV1_INTRA_FRAME, 0, 0), 11, "luma + intra ref delta");
    return 0;
}

# ---- narrow filter (7.14.6.3): a step edge p=100 / q=140 (vertical, dx=1). ----
fn setpx(f, x, y, v): i64 { dr_frame_set(f, 0, x, y, v); return 0; }
fn test_narrow() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    # edge at x=8, y=4: p1=(6), p0=(7), q0=(8), q1=(9).
    setpx(f, 6, 4, 100); setpx(f, 7, 4, 100); setpx(f, 8, 4, 140); setpx(f, 9, 4, 140);
    av1_lf_narrow(f, 0, 8, 4, 1, 0, 0);        # hev = 0 -> 2 samples each side
    assert_eq(dr_frame_get(f, 0, 7, 4), 115, "narrow hev0 op0");
    assert_eq(dr_frame_get(f, 0, 8, 4), 125, "narrow hev0 oq0");
    assert_eq(dr_frame_get(f, 0, 6, 4), 108, "narrow hev0 op1");
    assert_eq(dr_frame_get(f, 0, 9, 4), 132, "narrow hev0 oq1");
    # hev = 1 -> only 1 sample each side (p1/q1 unchanged).
    setpx(f, 6, 4, 100); setpx(f, 7, 4, 100); setpx(f, 8, 4, 140); setpx(f, 9, 4, 140);
    av1_lf_narrow(f, 0, 8, 4, 1, 0, 1);
    assert_eq(dr_frame_get(f, 0, 7, 4), 110, "narrow hev1 op0");
    assert_eq(dr_frame_get(f, 0, 8, 4), 130, "narrow hev1 oq0");
    assert_eq(dr_frame_get(f, 0, 6, 4), 100, "narrow hev1 p1 unchanged");
    assert_eq(dr_frame_get(f, 0, 9, 4), 140, "narrow hev1 q1 unchanged");
    # REVERSED step p=140 / q=100 -> the internal `filter` goes NEGATIVE, so the
    # filter1/filter2 >>3 must be ARITHMETIC (a logical shift corrupts it).
    setpx(f, 6, 4, 140); setpx(f, 7, 4, 140); setpx(f, 8, 4, 100); setpx(f, 9, 4, 100);
    av1_lf_narrow(f, 0, 8, 4, 1, 0, 0);
    assert_eq(dr_frame_get(f, 0, 7, 4), 125, "narrow neg-filter op0");
    assert_eq(dr_frame_get(f, 0, 8, 4), 115, "narrow neg-filter oq0");
    assert_eq(dr_frame_get(f, 0, 6, 4), 133, "narrow neg-filter op1");
    assert_eq(dr_frame_get(f, 0, 9, 4), 107, "narrow neg-filter oq1");
    return 0;
}
# ---- wide filter (7.14.6.4): DC-preserving on a flat region; smooths a step. ----
fn test_wide() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    # flat region all 100 -> unchanged (unity DC gain).
    var x = 3;
    while (x < 14) { setpx(f, x, 4, 100); x = x + 1; }
    av1_lf_wide(f, 0, 8, 4, 1, 0, 3);          # log2Size 3, luma: n=3, n2=0
    assert_eq(dr_frame_get(f, 0, 8, 4), 100, "wide flat -> 100");
    assert_eq(dr_frame_get(f, 0, 6, 4), 100, "wide flat -> 100 (p)");
    # step p=100 / q=140: F[0] (x=8) = 125, F[-3] (x=5) = 105.
    x = 4;
    while (x < 12) { var v = 100; if (x >= 8) { v = 140; } setpx(f, x, 4, v); x = x + 1; }
    av1_lf_wide(f, 0, 8, 4, 1, 0, 3);
    assert_eq(dr_frame_get(f, 0, 8, 4), 125, "wide step F[0]");
    assert_eq(dr_frame_get(f, 0, 5, 4), 105, "wide step F[-3]");
    return 0;
}
# ---- mask (7.14.6.2) ----
fn fillrow(f, y, x0, x1, val): i64 { var x = x0; while (x < x1) { setpx(f, x, y, val); x = x + 1; } return 0; }
fn test_mask() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var o = alloc(4 * 8);
    # flat region (all 100) -> hev 0, filterMask 1, flatMask 1, flatMask2 1.
    fillrow(f, 4, 0, 20, 100);
    av1_lf_mask(f, 0, 8, 4, 1, 0, 10, 34, 2, 16, o);
    assert_eq(load64(o + 0), 0, "flat hev 0");
    assert_eq(load64(o + 8), 1, "flat filterMask 1");
    assert_eq(load64(o + 16), 1, "flat flatMask 1");
    assert_eq(load64(o + 24), 1, "flat flatMask2 1");
    # big jump across the boundary -> filterMask 0 (blimit exceeded).
    fillrow(f, 4, 0, 8, 100); fillrow(f, 4, 8, 20, 250);
    av1_lf_mask(f, 0, 8, 4, 1, 0, 10, 34, 2, 16, o);
    assert_eq(load64(o + 8), 0, "big jump -> filterMask 0");
    # high edge variance within a side -> hev 1.
    fillrow(f, 4, 0, 20, 100);
    setpx(f, 6, 4, 200);          # p1 far from p0 -> |p1-p0|=100 > thresh
    av1_lf_mask(f, 0, 8, 4, 1, 0, 200, 400, 2, 4, o);
    assert_eq(load64(o + 0), 1, "high variance -> hev 1");
    return 0;
}
# ---- sample dispatch (7.14.6.1): filter_size 4 routes to the narrow filter;
# a filterMask-0 edge is left untouched. ----
fn test_sample_dispatch() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    # step p=100 / q=140, filter_size 4 -> narrow (hev 0): the known op0/oq0.
    fillrow(f, 4, 0, 8, 100); fillrow(f, 4, 8, 20, 140);
    av1_lf_sample(f, 0, 8, 4, 30, 100, 2, 1, 0, 4);
    assert_eq(dr_frame_get(f, 0, 8, 4), 125, "dispatch -> narrow oq0");
    assert_eq(dr_frame_get(f, 0, 7, 4), 115, "dispatch -> narrow op0");
    # a big jump (blimit exceeded) -> filterMask 0 -> no filter, samples unchanged.
    fillrow(f, 4, 0, 8, 100); fillrow(f, 4, 8, 20, 250);
    av1_lf_sample(f, 0, 8, 4, 10, 34, 2, 1, 0, 4);
    assert_eq(dr_frame_get(f, 0, 8, 4), 250, "filterMask 0 -> unchanged q0");
    assert_eq(dr_frame_get(f, 0, 7, 4), 100, "filterMask 0 -> unchanged p0");
    return 0;
}

# ---- whole-frame deblock (7.14.1/2): a vertical block boundary is smoothed. ----
fn test_whole_frame() {
    var oe = alloc(8);
    var frame = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var tile = av1_tile_new(frame, 4, 4, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    # a decoded frame: BLOCK_8X8 blocks, TX_8X8, not skipped; left half 100 / right 140.
    var r = 0;
    while (r < 4) {
        var c = 0;
        while (c < 4) {
            av1_grid_set(tile, AV1TILE_MISIZES, r, c, 3);   # BLOCK_8X8
            av1_grid_set(tile, AV1TILE_SKIPS, r, c, 0);
            av1_lftx_set(tile, 0, r, c, 1);                 # TX_8X8
            c = c + 1;
        }
        r = r + 1;
    }
    var y = 0;
    while (y < 16) {
        var x = 0;
        while (x < 16) {
            var v = 100;
            if (x >= 8) { v = 140; }
            dr_frame_set(frame, 0, x, y, v);
            x = x + 1;
        }
        y = y + 1;
    }
    # loop_filter_level 40 -> the x=8 tx/block boundary gets the wide (log2 3) filter.
    var fh = mk_fh(40, 40, 0, 0, 0, 0, 0);
    av1_deblock(tile, fh);
    # the boundary column is smoothed to the wide-filter result (F[0]=125, F[-3]=105),
    # for every row; samples away from the edge are untouched.
    assert_eq(dr_frame_get(frame, 0, 8, 4), 125, "deblock boundary x=8 y=4");
    assert_eq(dr_frame_get(frame, 0, 5, 4), 105, "deblock x=5 y=4");
    assert_eq(dr_frame_get(frame, 0, 8, 12), 125, "deblock boundary whole column");
    assert_eq(dr_frame_get(frame, 0, 2, 4), 100, "deblock far-left unchanged");
    assert_eq(dr_frame_get(frame, 0, 13, 4), 140, "deblock far-right unchanged");
    # x=0 (frame edge) and x=4/12 (not tx edges for TX_8X8) are NOT filtered.
    assert_eq(dr_frame_get(frame, 0, 0, 4), 100, "frame-left edge not filtered");
    return 0;
}
# level 0 -> no filtering at all.
fn test_deblock_level0() {
    var oe = alloc(8);
    var frame = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var tile = av1_tile_new(frame, 4, 4, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    var r = 0;
    while (r < 4) {
        var c = 0;
        while (c < 4) {
            av1_grid_set(tile, AV1TILE_MISIZES, r, c, 3);
            av1_lftx_set(tile, 0, r, c, 1);
            c = c + 1;
        }
        r = r + 1;
    }
    var y = 0;
    while (y < 16) {
        var x = 0;
        while (x < 16) {
            var v = 100;
            if (x >= 8) { v = 140; }
            dr_frame_set(frame, 0, x, y, v);
            x = x + 1;
        }
        y = y + 1;
    }
    var fh = mk_fh(0, 0, 0, 0, 0, 0, 0);
    av1_deblock(tile, fh);
    assert_eq(dr_frame_get(frame, 0, 8, 4), 140, "level 0 -> boundary untouched");
    assert_eq(dr_frame_get(frame, 0, 7, 4), 100, "level 0 -> p side untouched");
    return 0;
}

fn main() {
    alloc_init();
    test_group("deblock strength / size / limits");
    test_filter_size();
    test_limits();
    test_strength();
    test_group("deblock sample filters");
    test_narrow();
    test_wide();
    test_mask();
    test_sample_dispatch();
    test_group("deblock edge loop + whole-frame driver");
    test_whole_frame();
    test_deblock_level0();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
