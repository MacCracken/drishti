# tests/av1_cdef.tcyr — AV1 CDEF kernels (spec 7.15.2 direction + 7.15.3 filter).
# The `constrain` non-linearity + direction/variance search by arithmetic
# known-answers, and the tap filter by a hand-computed deringing case. The
# direction/filter references were computed by an independent Python model of
# 7.15.2/7.15.3 (kept in the commit notes), cross-checked field-by-field.
include "src/main.cyr"
include "src/av1_cdef.cyr"

# ---- constrain (7.15.3) ----
fn test_constrain() {
    # thr=8, dampingAdj = max(0, 3 - floorlog2(8)=3) = 0: 8-(10>>0) = -2 -> clip 0.
    assert_eq(av1_cdef_constrain(10, 8, 3), 0, "constrain 10,8,3 saturates to 0");
    assert_eq(av1_cdef_constrain(0 - 10, 8, 3), 0, "constrain -10,8,3 -> 0 (sign*0)");
    # threshold 0 -> always 0.
    assert_eq(av1_cdef_constrain(5, 0, 3), 0, "constrain thr=0 -> 0");
    # thr=16, dampingAdj=0: 16-(3>>0)=13, clip3(0,3,13)=3, sign +.
    assert_eq(av1_cdef_constrain(3, 16, 4), 3, "constrain 3,16,4 -> 3");
    assert_eq(av1_cdef_constrain(0 - 3, 16, 4), 0 - 3, "constrain -3,16,4 -> -3");
    return 0;
}

# ---- direction search (7.15.2) ----
# Fill the 8x8 luma block at MI (0,0) via a per-pixel value function, then read
# out[0]=yDir, out[1]=var.
fn test_direction_flat() {
    var oe = alloc(8);
    var f = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 8) {
        var x = 0;
        while (x < 8) { dr_frame_set(f, 0, x, y, 128); x = x + 1; }
        y = y + 1;
    }
    var out = alloc(2 * 8);
    av1_cdef_direction(f, 0, 0, out);
    assert_eq(load64(out + 0), 0, "flat block yDir 0");
    assert_eq(load64(out + 8), 0, "flat block var 0");
    return 0;
}
fn test_direction_hgrad() {
    # sample = 128 + x*4 (columns increase) -> vertical edges -> yDir 6, var 4410.
    var oe = alloc(8);
    var f = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 8) {
        var x = 0;
        while (x < 8) { dr_frame_set(f, 0, x, y, 128 + (x * 4)); x = x + 1; }
        y = y + 1;
    }
    var out = alloc(2 * 8);
    av1_cdef_direction(f, 0, 0, out);
    assert_eq(load64(out + 0), 6, "hgrad yDir 6");
    assert_eq(load64(out + 8), 4410, "hgrad var 4410");
    return 0;
}
fn test_direction_vgrad() {
    # sample = 128 + y*4 (rows increase) -> horizontal edges -> yDir 2, var 4410.
    var oe = alloc(8);
    var f = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 8) {
        var x = 0;
        while (x < 8) { dr_frame_set(f, 0, x, y, 128 + (y * 4)); x = x + 1; }
        y = y + 1;
    }
    var out = alloc(2 * 8);
    av1_cdef_direction(f, 0, 0, out);
    assert_eq(load64(out + 0), 2, "vgrad yDir 2");
    assert_eq(load64(out + 8), 4410, "vgrad var 4410");
    return 0;
}
fn test_direction_diag() {
    # sample = 128 + (x+y)*3 (main diagonal) -> yDir 0, var 4961.
    var oe = alloc(8);
    var f = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 8) {
        var x = 0;
        while (x < 8) { dr_frame_set(f, 0, x, y, 128 + ((x + y) * 3)); x = x + 1; }
        y = y + 1;
    }
    var out = alloc(2 * 8);
    av1_cdef_direction(f, 0, 0, out);
    assert_eq(load64(out + 0), 0, "diag yDir 0");
    assert_eq(load64(out + 8), 4961, "diag var 4961");
    return 0;
}

# ---- filter (7.15.3): a gentle spike (132 amid flat 128) at the block center is
# deringed. Block at MI (2,2) in a 32x32 (mi 8x8) frame so every tap is inside.
# pri_str=16 (tapIdx=(16>>0)&1=0), sec_str=8, damping=5, dir=0. ----
fn fill_frame(f, w, h, v): i64 {
    var y = 0;
    while (y < h) {
        var x = 0;
        while (x < w) { dr_frame_set(f, 0, x, y, v); x = x + 1; }
        y = y + 1;
    }
    return 0;
}
fn test_filter_dering() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var cdef = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    fill_frame(curr, 32, 32, 128);
    dr_frame_set(curr, 0, 11, 11, 132);        # spike at block-relative (i=3,j=3)
    av1_cdef_filter(curr, cdef, 0, 2, 2, 16, 8, 5, 0, 8, 8);
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 128, "spike 132 deringed to 128");
    assert_eq(dr_frame_get(cdef, 0, 11, 10), 129, "left neighbor pulled to 129");
    assert_eq(dr_frame_get(cdef, 0, 10, 11), 129, "up neighbor pulled to 129");
    assert_eq(dr_frame_get(cdef, 0, 8, 8), 128, "block corner untouched 128");
    return 0;
}
# a perfectly flat block: no direction, constrain always 0 -> output == input.
fn test_filter_flat() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var cdef = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    fill_frame(curr, 32, 32, 128);
    av1_cdef_filter(curr, cdef, 0, 2, 2, 16, 8, 5, 0, 8, 8);
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 128, "flat block center unchanged");
    assert_eq(dr_frame_get(cdef, 0, 8, 8), 128, "flat block corner unchanged");
    assert_eq(dr_frame_get(cdef, 0, 15, 15), 128, "flat block far corner unchanged");
    return 0;
}

# ---- driver: CDEF process (7.15) + block process (7.15.1) ----
# A fake frame header carrying just the CDEF fields the block process reads.
fn mk_cdef_fh(damping, ypri0, ysec0, uvpri0, uvsec0): i64 {
    var fh = alloc(1200);
    store64(fh + AV1FH_CDEF_DAMPING, damping);
    store64(fh + AV1FH_CDEF_Y_PRI, ypri0);
    store64(fh + AV1FH_CDEF_Y_SEC, ysec0);
    store64(fh + AV1FH_CDEF_UV_PRI, uvpri0);
    store64(fh + AV1FH_CDEF_UV_SEC, uvsec0);
    return fh;
}
fn cdef_fill(f, p, w, h, v): i64 {
    var y = 0;
    while (y < h) {
        var x = 0;
        while (x < w) { dr_frame_set(f, p, x, y, v); x = x + 1; }
        y = y + 1;
    }
    return 0;
}
# 32x32 (MiCols=MiRows=8) tile: CdefIdx[0][0]=idx, every Skips entry = skip_all.
fn mk_cdef_tile(frame, num_planes, idx, skip_all): i64 {
    var tile = av1_tile_new(frame, 8, 8, 40, 1, 0, num_planes);
    av1_tile_grids_new(tile);
    av1_cdefidx_set(tile, 0, 0, idx);
    var r = 0;
    while (r < 8) {
        var c = 0;
        while (c < 8) { av1_grid_set(tile, AV1TILE_SKIPS, r, c, skip_all); c = c + 1; }
        r = r + 1;
    }
    return tile;
}
# idx>=0, not skipped: the block process runs direction + var-scaled luma filter.
fn test_process_luma_filter() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    cdef_fill(curr, 0, 32, 32, 128);
    dr_frame_set(curr, 0, 11, 11, 140);          # spike in the 8x8 block at MI (2,2)
    var cdef = av1_cdef_frame_new(curr, oe);
    var tile = mk_cdef_tile(curr, 1, 0, 0);       # idx 0, no skip
    var fh = mk_cdef_fh(4, 8, 4, 0, 0);           # damping 4, y_pri 8, y_sec 4
    assert_eq(av1_cdef_process(curr, cdef, fh, tile), DR_OK, "process returns DR_OK");
    # var=2 -> varStr 0 -> pri 8 scaled to 2; the spike is pulled 140 -> 138.
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 138, "spike 140 var-scaled-filtered to 138");
    assert_eq(dr_frame_get(cdef, 0, 11, 10), 128, "spike left neighbor 128");
    assert_eq(dr_frame_get(cdef, 0, 10, 11), 128, "spike up neighbor 128");
    assert_eq(dr_frame_get(cdef, 0, 0, 0), 128, "flat block copied through 128");
    assert_eq(dr_frame_get(cdef, 0, 20, 20), 128, "flat elsewhere 128");
    return 0;
}
# idx == -1: copy-through only, no filtering.
fn test_process_copy_through() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    cdef_fill(curr, 0, 32, 32, 128);
    dr_frame_set(curr, 0, 11, 11, 140);
    var cdef = av1_cdef_frame_new(curr, oe);
    var tile = mk_cdef_tile(curr, 1, 0 - 1, 0);   # idx -1
    var fh = mk_cdef_fh(4, 8, 4, 0, 0);
    assert_eq(av1_cdef_process(curr, cdef, fh, tile), DR_OK, "process DR_OK");
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 140, "idx -1 -> spike copied through 140");
    assert_eq(dr_frame_get(cdef, 0, 12, 12), 128, "idx -1 -> flat copied 128");
    return 0;
}
# all four 4x4 sub-blocks skipped: copy-through, no filtering.
fn test_process_all_skip() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    cdef_fill(curr, 0, 32, 32, 128);
    dr_frame_set(curr, 0, 11, 11, 140);
    var cdef = av1_cdef_frame_new(curr, oe);
    var tile = mk_cdef_tile(curr, 1, 0, 1);       # idx 0 but every Skips = 1
    var fh = mk_cdef_fh(4, 8, 4, 0, 0);
    assert_eq(av1_cdef_process(curr, cdef, fh, tile), DR_OK, "process DR_OK");
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 140, "all-skip -> spike copied, no filter");
    return 0;
}
# the Finding-1 coverage guard: an undersized (non-MI-covering) frame is rejected,
# never OOB; a bordered frame that covers the MI grid is accepted.
fn test_coverage_guard() {
    var oe = alloc(8);
    var fh = mk_cdef_fh(4, 8, 4, 0, 0);
    # 30x30, MiCols=MiRows=8 -> needs MiCols*4=32; border 0 -> cover 30 < 32 -> reject.
    var small = dr_frame_new(30, 30, 1, 0, 0, 8, 0, oe);
    cdef_fill(small, 0, 30, 30, 128);
    var cdef0 = dr_frame_new(30, 30, 1, 0, 0, 8, 0, oe);
    var t0 = mk_cdef_tile(small, 1, 0, 0);
    assert_eq(av1_cdef_process(small, cdef0, fh, t0), DR_ERR_BOUNDS, "undersized frame rejected");
    # border 8 -> cover 38 >= 32 -> accepted.
    var big = dr_frame_new(30, 30, 1, 0, 0, 8, 8, oe);
    cdef_fill(big, 0, 30, 30, 128);
    var cdefb = av1_cdef_frame_new(big, oe);
    var t1 = mk_cdef_tile(big, 1, 0, 0);
    assert_eq(av1_cdef_process(big, cdefb, fh, t1), DR_OK, "bordered frame accepted");
    return 0;
}
# chroma path: flat luma (yDir 0) + a chroma-U spike filtered with the uv strengths,
# uv-remapped direction, and damping-1; luma stays flat (y_pri/y_sec 0).
fn test_process_chroma() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 3, 0, 0, 8, 8, oe);   # 4:4:4 3-plane
    cdef_fill(curr, 0, 32, 32, 128);
    cdef_fill(curr, 1, 32, 32, 128);
    cdef_fill(curr, 2, 32, 32, 128);
    dr_frame_set(curr, 1, 11, 11, 132);          # gentle chroma-U spike
    var cdef = av1_cdef_frame_new(curr, oe);
    var tile = mk_cdef_tile(curr, 3, 0, 0);
    var fh = mk_cdef_fh(6, 0, 0, 15, 8);          # damping 6, uv_pri 15, uv_sec 8
    assert_eq(av1_cdef_process(curr, cdef, fh, tile), DR_OK, "process DR_OK (3-plane)");
    assert_eq(dr_frame_get(cdef, 1, 11, 11), 128, "chroma-U spike 132 filtered to 128");
    assert_eq(dr_frame_get(cdef, 1, 11, 10), 129, "chroma-U left neighbor 129");
    assert_eq(dr_frame_get(cdef, 1, 10, 11), 129, "chroma-U up neighbor 129");
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 128, "flat luma untouched (var 0 -> pri 0)");
    return 0;
}

# a garbage/out-of-range CdefIdx must NOT index the fh strength arrays (would
# OOB-read the frame header) — it degrades to copy-through, no filter, no crash.
fn test_process_garbage_idx() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    cdef_fill(curr, 0, 32, 32, 128);
    dr_frame_set(curr, 0, 11, 11, 140);
    var cdef = av1_cdef_frame_new(curr, oe);
    var tile = mk_cdef_tile(curr, 1, 100, 0);     # idx 100 >> 8-entry arrays
    var fh = mk_cdef_fh(4, 8, 4, 0, 0);
    assert_eq(av1_cdef_process(curr, cdef, fh, tile), DR_OK, "garbage idx -> DR_OK (no OOB)");
    assert_eq(dr_frame_get(cdef, 0, 11, 11), 140, "garbage idx -> copy-through, no filter");
    return 0;
}
# a null output frame (e.g. CdefFrame OOM) is rejected, not dereferenced.
fn test_process_null_frame() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    cdef_fill(curr, 0, 32, 32, 128);
    var tile = mk_cdef_tile(curr, 1, 0, 0);
    var fh = mk_cdef_fh(4, 8, 4, 0, 0);
    assert_eq(av1_cdef_process(curr, 0, fh, tile), DR_ERR_BOUNDS, "null cdef frame rejected");
    assert_eq(av1_cdef_process(0, curr, fh, tile), DR_ERR_BOUNDS, "null curr frame rejected");
    return 0;
}

fn main() {
    alloc_init();
    test_group("cdef constrain");
    test_constrain();
    test_group("cdef direction search");
    test_direction_flat();
    test_direction_hgrad();
    test_direction_vgrad();
    test_direction_diag();
    test_group("cdef filter");
    test_filter_dering();
    test_filter_flat();
    test_group("cdef process / block driver");
    test_process_luma_filter();
    test_process_copy_through();
    test_process_all_skip();
    test_coverage_guard();
    test_process_chroma();
    test_process_garbage_idx();
    test_process_null_frame();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
