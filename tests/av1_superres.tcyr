# tests/av1_superres.tcyr — AV1 superres upscaling kernel (spec 7.16):
# the Upscale_Filter[64][8] table + the per-pixel filter application.
include "src/main.cyr"

# ================================================================
# Upscale_Filter structural invariants — these mechanically catch a transcription
# or sign slip in the 512-value table (sourced from dav1d, negated to the spec's
# positive-centre form), so a wrong coefficient fails the build, not a decode.
# ================================================================
fn test_upscale_filter_invariants() {
    # every one of the 64 phase rows sums to 128 (= 1 << FILTER_BITS).
    var p = 0;
    while (p < 64) {
        var sum = 0;
        var k = 0;
        while (k < 8) { sum = sum + av1_upscale_filter(p, k); k = k + 1; }
        assert_eq(sum, 128, "phase row sums to 128");
        p = p + 1;
    }
    # phase 0 is the integer-pel identity [0,0,0,128,0,0,0,0].
    assert_eq(av1_upscale_filter(0, 0), 0, "phase 0 tap 0 = 0");
    assert_eq(av1_upscale_filter(0, 3), 128, "phase 0 tap 3 = 128 (integer-pel centre)");
    assert_eq(av1_upscale_filter(0, 7), 0, "phase 0 tap 7 = 0");
    # a couple of spot values (dav1d negated): phase 32 is the self-symmetric centre.
    assert_eq(av1_upscale_filter(32, 3), 79, "phase 32 tap 3 = 79");
    assert_eq(av1_upscale_filter(32, 4), 79, "phase 32 tap 4 = 79");
    assert_eq(av1_upscale_filter(1, 3), 128, "phase 1 tap 3 = 128");
    assert_eq(av1_upscale_filter(63, 4), 128, "phase 63 tap 4 = 128");
    # mirror symmetry: Upscale_Filter[p][k] == Upscale_Filter[64-p][7-k], p = 1..63.
    var q = 1;
    var bad = 0;
    while (q < 64) {
        var t = 0;
        while (t < 8) {
            if (av1_upscale_filter(q, t) != av1_upscale_filter(64 - q, 7 - t)) { bad = 1; }
            t = t + 1;
        }
        q = q + 1;
    }
    assert_eq(bad, 0, "mirror symmetry: phase p == reverse(phase 64-p)");
    return 0;
}

# ================================================================
# av1_superres_filter_pixel — one upscaled sample. subpel_x carries the phase in
# bits 8..13 and the integer base in bits >= 14.
# ================================================================
fn test_superres_filter_pixel() {
    # a downscaled row: src[i] = 10 + 20*i -> 10,30,50,70,90,110,130,150.
    var src = alloc(8 * 8);
    var i = 0;
    while (i < 8) { store64(src + (i * 8), 10 + (i * 20)); i = i + 1; }
    # integer-pel phase (bits 8..13 = 0): output = src[base] exactly.
    assert_eq(av1_superres_filter_pixel(src, 8, 3 << 14, 8), 70, "integer-pel base 3 -> src[3]");
    assert_eq(av1_superres_filter_pixel(src, 8, 5 << 14, 8), 110, "integer-pel base 5 -> src[5]");
    # flat row -> flat output for fractional phases (each row sums to 128).
    var flat = alloc(8 * 8);
    i = 0;
    while (i < 8) { store64(flat + (i * 8), 128); i = i + 1; }
    assert_eq(av1_superres_filter_pixel(flat, 8, (5 << 14) | (17 << 8), 8), 128, "flat -> flat (phase 17)");
    assert_eq(av1_superres_filter_pixel(flat, 8, (2 << 14) | (40 << 8), 8), 128, "flat -> flat (phase 40)");
    # genuine fractional interpolation (non-flat, non-integer phase): base 3, phase 17
    # = [-1,5,-18,111,40,-13,5,-1] over src[0..7] (base+k-3 == k). Hand-computed:
    # sum = -10+150-900+7770+3600-1430+650-150 = 9680; Round2(9680,7) = (9680+64)>>7 = 76.
    assert_eq(av1_superres_filter_pixel(src, 8, (3 << 14) | (17 << 8), 8), 76, "fractional phase 17 on a ramp -> 76");
    # edge clamp: base 0 reads src[0] for the negative taps (Clip3 to the plane edge).
    assert_eq(av1_superres_filter_pixel(src, 8, 0, 8), 10, "left edge, integer phase -> src[0]");
    assert_eq(av1_superres_filter_pixel(src, 8, 7 << 14, 8), 150, "right edge, integer phase -> src[7]");
    # bit-depth clip: a flat 1000 clips to 255 at 8-bit, passes at 10-bit.
    var big = alloc(8 * 8);
    i = 0;
    while (i < 8) { store64(big + (i * 8), 1000); i = i + 1; }
    assert_eq(av1_superres_filter_pixel(big, 8, 3 << 14, 8), 255, "8-bit clip: 1000 -> 255");
    assert_eq(av1_superres_filter_pixel(big, 8, 3 << 14, 10), 1000, "10-bit: 1000 passes (< 1023)");
    return 0;
}

# fill 8 consecutive golden checksums.
fn supg8(g, off, v0, v1, v2, v3, v4, v5, v6, v7) {
    store64(g + ((off + 0) * 8), v0);  store64(g + ((off + 1) * 8), v1);
    store64(g + ((off + 2) * 8), v2);  store64(g + ((off + 3) * 8), v3);
    store64(g + ((off + 4) * 8), v4);  store64(g + ((off + 5) * 8), v5);
    store64(g + ((off + 6) * 8), v6);  store64(g + ((off + 7) * 8), v7);
    return 0;
}
# Position-sensitive per-phase checksum: cs[p] = sum_k Upscale_Filter[p][k] * (k+1)^3.
# The cubic weights give every tap a distinct, non-symmetric position weight, so ANY
# within-row permutation changes cs[p] — closing the gap that row-sum + mirror symmetry
# miss (a palindrome scramble of the self-mirrored phase 32, or coordinated swaps in a
# mirror-partner pair). The 64 goldens are computed INDEPENDENTLY (scratchpad Python,
# a separate transcription of dav1d's raw dav1d_resize_filter), so a transcription slip
# in the cyrius table is caught rather than matched.
fn test_upscale_filter_position_checksum() {
    var w = alloc(8 * 8);
    store64(w + 0, 1);    store64(w + 8, 8);    store64(w + 16, 27);   store64(w + 24, 64);
    store64(w + 32, 125); store64(w + 40, 216); store64(w + 48, 343);  store64(w + 56, 512);
    var g = alloc(64 * 8);
    supg8(g,  0,  8192,  8199,  8466,  8473,  8613,  8681,  9030,  8981);
    supg8(g,  8,  8753,  9039,  8990,  9058,  9278,  9564,  9515,  9546);
    supg8(g, 16,  9766, 10052, 10083, 10186, 10217, 10248, 10686, 10717);
    supg8(g, 24, 10839, 10870, 10612, 11030, 11213, 11335, 11197, 11767);
    supg8(g, 32, 11502, 11561, 11807, 11885, 12007, 12190, 12338, 12566);
    supg8(g, 40, 12651, 12773, 12858, 13188, 13273, 13358, 13353, 13438);
    supg8(g, 48, 13670, 13944, 14029, 13926, 14158, 14432, 14608, 14505);
    supg8(g, 56, 14737, 14887, 14784, 15403, 15579, 15665, 15780, 15885);
    var p = 0;
    while (p < 64) {
        var cs = 0;
        var k = 0;
        while (k < 8) { cs = cs + (av1_upscale_filter(p, k) * load64(w + (k * 8))); k = k + 1; }
        assert_eq(cs, load64(g + (p * 8)), "phase position-weighted checksum (tap order pinned)");
        p = p + 1;
    }
    return 0;
}

# av1_superres_upscale_row vs a faithful Python port of dav1d resize_c (goldens from
# scratchpad/resize_ref.py). The driver's combined subpel accumulator is proven equal
# to dav1d's split src_x/mx form there, so these pin the whole row loop against the
# reference. dx/mx0 are supplied directly (their geometry grows next; roadmap.md).
fn test_superres_upscale_row() {
    var src = alloc(8 * 8);
    var i = 0;
    while (i < 8) { store64(src + (i * 8), 10 + (i * 20)); i = i + 1; }   # 10,30,..,150
    # 2x: src_w 8 -> dst_w 16, dx=8192, mx0=8321.
    var dst = alloc(16 * 8);
    av1_superres_upscale_row(src, 8, dst, 16, 8192, 8321, 8);
    var e2 = alloc(16 * 8);
    store64(e2 + 0, 8);    store64(e2 + 8, 10);   store64(e2 + 16, 18);  store64(e2 + 24, 30);
    store64(e2 + 32, 40);  store64(e2 + 40, 50);  store64(e2 + 48, 60);  store64(e2 + 56, 70);
    store64(e2 + 64, 80);  store64(e2 + 72, 90);  store64(e2 + 80, 100); store64(e2 + 88, 110);
    store64(e2 + 96, 120); store64(e2 + 104, 130); store64(e2 + 112, 142); store64(e2 + 120, 150);
    var bad = 0;
    var x = 0;
    while (x < 16) { if (load64(dst + (x * 8)) != load64(e2 + (x * 8))) { bad = 1; } x = x + 1; }
    assert_eq(bad, 0, "2x upscale row matches dav1d resize_c reference");
    # 1.5x: dst_w 12, dx=10923, mx0=5461.
    var dst2 = alloc(12 * 8);
    av1_superres_upscale_row(src, 8, dst2, 12, 10923, 5461, 8);
    var e15 = alloc(12 * 8);
    store64(e15 + 0, 9);   store64(e15 + 8, 10);  store64(e15 + 16, 22);  store64(e15 + 24, 37);
    store64(e15 + 32, 50); store64(e15 + 40, 63); store64(e15 + 48, 76);  store64(e15 + 56, 90);
    store64(e15 + 64, 103); store64(e15 + 72, 116); store64(e15 + 80, 130); store64(e15 + 88, 145);
    bad = 0;
    x = 0;
    while (x < 12) { if (load64(dst2 + (x * 8)) != load64(e15 + (x * 8))) { bad = 1; } x = x + 1; }
    assert_eq(bad, 0, "1.5x upscale row matches dav1d resize_c reference");
    # flat input -> flat output (every phase row sums to 128).
    var flat = alloc(8 * 8);
    i = 0;
    while (i < 8) { store64(flat + (i * 8), 200); i = i + 1; }
    var dstf = alloc(16 * 8);
    av1_superres_upscale_row(flat, 8, dstf, 16, 8192, 8321, 8);
    bad = 0;
    x = 0;
    while (x < 16) { if (load64(dstf + (x * 8)) != 200) { bad = 1; } x = x + 1; }
    assert_eq(bad, 0, "flat row -> flat upscaled row (all 200)");
    return 0;
}

# av1_superres_step / av1_superres_x0 (dav1d get_upscale_x0 + scale_fac) + the full
# geometry->driver chain, against the Python port (scratchpad/upscale_geom.py).
fn test_superres_geometry() {
    # step / x0 known-answers for several (down_w, up_w).
    assert_eq(av1_superres_step(8, 16), 8192, "step 8->16 = 8192");
    assert_eq(av1_superres_x0(8, 16, 8192), 12417, "x0 8->16 = 12417");
    assert_eq(av1_superres_step(8, 12), 10923, "step 8->12 = 10923");
    assert_eq(av1_superres_x0(8, 12, 10923), 13780, "x0 8->12 = 13780");
    assert_eq(av1_superres_step(8, 10), 13107, "step 8->10 = 13107");
    assert_eq(av1_superres_x0(8, 10, 13107), 14876, "x0 8->10 = 14876");
    assert_eq(av1_superres_step(13, 16), 13312, "step 13->16 = 13312");
    assert_eq(av1_superres_x0(13, 16, 13312), 14977, "x0 13->16 = 14977");
    assert_eq(av1_superres_step(6, 8), 12288, "step 6->8 = 12288");
    assert_eq(av1_superres_x0(6, 8, 12288), 14465, "x0 6->8 = 14465");
    assert_eq(av1_superres_step(100, 128), 12800, "step 100->128 = 12800");
    assert_eq(av1_superres_x0(100, 128, 12800), 14721, "x0 100->128 = 14721");
    # end-to-end: compute the geometry, then upscale a ramp -> the reference row.
    var src = alloc(8 * 8);
    var i = 0;
    while (i < 8) { store64(src + (i * 8), 10 + (i * 20)); i = i + 1; }
    # 8 -> 16 (2x).
    var s2 = av1_superres_step(8, 16);
    var x2 = av1_superres_x0(8, 16, s2);
    var d2 = alloc(16 * 8);
    av1_superres_upscale_row(src, 8, d2, 16, s2, x2, 8);
    var e2 = alloc(16 * 8);
    store64(e2 + 0, 8);    store64(e2 + 8, 13);    store64(e2 + 16, 24);  store64(e2 + 24, 35);
    store64(e2 + 32, 45);  store64(e2 + 40, 55);   store64(e2 + 48, 65);  store64(e2 + 56, 75);
    store64(e2 + 64, 85);  store64(e2 + 72, 95);   store64(e2 + 80, 105); store64(e2 + 88, 115);
    store64(e2 + 96, 125); store64(e2 + 104, 136); store64(e2 + 112, 147); store64(e2 + 120, 152);
    var bad = 0;
    var x = 0;
    while (x < 16) { if (load64(d2 + (x * 8)) != load64(e2 + (x * 8))) { bad = 1; } x = x + 1; }
    assert_eq(bad, 0, "8->16 full geometry+driver matches dav1d reference");
    # 8 -> 12.
    var s3 = av1_superres_step(8, 12);
    var x3 = av1_superres_x0(8, 12, s3);
    var d3 = alloc(12 * 8);
    av1_superres_upscale_row(src, 8, d3, 12, s3, x3, 8);
    var e3 = alloc(12 * 8);
    store64(e3 + 0, 9);    store64(e3 + 8, 18);    store64(e3 + 16, 33);  store64(e3 + 24, 47);
    store64(e3 + 32, 60);  store64(e3 + 40, 73);   store64(e3 + 48, 87);  store64(e3 + 56, 100);
    store64(e3 + 64, 113); store64(e3 + 72, 127);  store64(e3 + 80, 142); store64(e3 + 88, 151);
    bad = 0;
    x = 0;
    while (x < 12) { if (load64(d3 + (x * 8)) != load64(e3 + (x * 8))) { bad = 1; } x = x + 1; }
    assert_eq(bad, 0, "8->12 full geometry+driver matches dav1d reference");
    return 0;
}

# av1_superres_upscale_frame — upscale a whole downscaled frame into an upscaled one,
# per plane, against the dav1d reference (scratchpad/sr_ref.py). Covers mono and a
# 4:2:0 3-plane frame (chroma uses the subsampled widths 4->8).
fn test_superres_upscale_frame() {
    var oe = alloc(8);
    # 8->16 luma reference row (every downscaled row is the ramp 10,30,..,150).
    var lref = alloc(16 * 8);
    store64(lref + 0, 8);    store64(lref + 8, 13);   store64(lref + 16, 24);  store64(lref + 24, 35);
    store64(lref + 32, 45);  store64(lref + 40, 55);  store64(lref + 48, 65);  store64(lref + 56, 75);
    store64(lref + 64, 85);  store64(lref + 72, 95);  store64(lref + 80, 105); store64(lref + 88, 115);
    store64(lref + 96, 125); store64(lref + 104, 136); store64(lref + 112, 147); store64(lref + 120, 152);
    # --- mono 8x3 -> 16x3 ---
    var down = dr_frame_new(8, 3, 1, 0, 0, 8, 8, oe);
    var up = dr_frame_new(16, 3, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 3) {
        var x = 0;
        while (x < 8) { dr_frame_set(down, 0, x, y, 10 + (x * 20)); x = x + 1; }
        y = y + 1;
    }
    assert_eq(av1_superres_upscale_frame(down, up, 8), DR_OK, "mono upscale ok");
    var bad = 0;
    y = 0;
    while (y < 3) {
        var x = 0;
        while (x < 16) { if (dr_frame_get(up, 0, x, y) != load64(lref + (x * 8))) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "mono: every upscaled row matches the 8->16 reference");
    # --- 4:2:0 3-plane: luma 8x4->16x4, chroma 4x2->8x2 ---
    var d3 = dr_frame_new(8, 4, 3, 1, 1, 8, 8, oe);
    var u3 = dr_frame_new(16, 4, 3, 1, 1, 8, 8, oe);
    y = 0;
    while (y < 4) {
        var x = 0;
        while (x < 8) { dr_frame_set(d3, 0, x, y, 10 + (x * 20)); x = x + 1; }
        y = y + 1;
    }
    var pl = 1;
    while (pl < 3) {
        y = 0;
        while (y < 2) {
            var x = 0;
            while (x < 4) { dr_frame_set(d3, pl, x, y, 20 + (x * 40)); x = x + 1; }   # 20,60,100,140
            y = y + 1;
        }
        pl = pl + 1;
    }
    assert_eq(av1_superres_upscale_frame(d3, u3, 8), DR_OK, "4:2:0 upscale ok");
    bad = 0;
    y = 0;
    while (y < 4) {
        var x = 0;
        while (x < 16) { if (dr_frame_get(u3, 0, x, y) != load64(lref + (x * 8))) { bad = 1; } x = x + 1; }
        y = y + 1;
    }
    assert_eq(bad, 0, "4:2:0 luma upscaled rows match (8->16)");
    # chroma 4->8 reference [17,27,48,70,90,112,133,143].
    var cref = alloc(8 * 8);
    store64(cref + 0, 17);  store64(cref + 8, 27);  store64(cref + 16, 48);  store64(cref + 24, 70);
    store64(cref + 32, 90); store64(cref + 40, 112); store64(cref + 48, 133); store64(cref + 56, 143);
    pl = 1;
    while (pl < 3) {
        y = 0;
        while (y < 2) {
            var x = 0;
            while (x < 8) { if (dr_frame_get(u3, pl, x, y) != load64(cref + (x * 8))) { bad = 1; } x = x + 1; }
            y = y + 1;
        }
        pl = pl + 1;
    }
    assert_eq(bad, 0, "4:2:0 chroma upscaled rows match (subsampled 4->8)");
    return 0;
}

fn main() {
    alloc_init();
    test_group("Upscale_Filter table invariants (spec 7.16)");
    test_upscale_filter_invariants();
    test_group("superres per-plane frame upscale (spec 7.16)");
    test_superres_upscale_frame();
    test_group("superres geometry (dav1d get_upscale_x0)");
    test_superres_geometry();
    test_group("superres upscale row (dav1d resize_c reference)");
    test_superres_upscale_row();
    test_group("Upscale_Filter position checksum (tap-order pin)");
    test_upscale_filter_position_checksum();
    test_group("superres filter pixel (spec 7.16)");
    test_superres_filter_pixel();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
