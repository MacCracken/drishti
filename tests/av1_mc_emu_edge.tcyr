# tests/av1_mc_emu_edge.tcyr — AV1 inter prediction, the frame-boundary block fetch
# (av1_mc_emu_edge / dav1d emu_edge_c). Verified against a Python port of emu_edge_c
# (scratchpad/emu_edge.py): a fully-inside block (no extension) and the four out-of-frame
# cases (top-left, bottom-right, bottom-left, and wholly-left-of-frame — a single visible
# column replicated across the block). The reference edge pixels must clamp outward.
include "src/main.cyr"

# reference plane 6x5 (iw=6, ih=5, row stride 6), ref[r][c] = r*10 + c -- pixels read as
# "row.col", so the clamped value at any out-of-frame read is obvious by eye.
fn ee_ref(): i64 {
    var s = alloc(6 * 5 * 8);
    var r = 0;
    while (r < 5) {
        var c = 0;
        while (c < 6) {
            store64(s + (((r * 6) + c) * 8), (r * 10) + c);
            c = c + 1;
        }
        r = r + 1;
    }
    return s;
}
# position-weighted checksum sum_i dst[i]*(i+1) — any wrong output pixel changes it.
fn ee_checksum(dst, n): i64 {
    var cs = 0;
    var i = 0;
    while (i < n) { cs = cs + (load64(dst + (i * 8)) * (i + 1)); i = i + 1; }
    return cs;
}

fn test_emu_edge() {
    var ref = ee_ref();
    var d = alloc(16 * 8);        # 4x4 output block
    # 1. fully inside: 4x4 @ (1,1) -> ref[1..5)x[1..5), no extension.
    av1_mc_emu_edge(4, 4, 6, 5, 1, 1, d, 0, 4, ref, 0, 6);
    assert_eq(ee_checksum(d, 16), 4560, "emu_edge center 4x4 no extension");
    assert_eq(load64(d + 0), 11, "center out[0] = ref[1][1]");
    assert_eq(load64(d + (15 * 8)), 44, "center out[15] = ref[4][4]");
    # 2. off the top-left @ (-2,-1): left_ext=2, top_ext=1; the corner clamps to ref[0][0]=0.
    av1_mc_emu_edge(4, 4, 6, 5, 0 - 2, 0 - 1, d, 0, 4, ref, 0, 6);
    assert_eq(ee_checksum(d, 16), 1620, "emu_edge top-left extension");
    assert_eq(load64(d + 0), 0, "top-left out[0] clamps to ref[0][0]");
    assert_eq(load64(d + (3 * 8)), 1, "top-left out[3] = ref[0][1]");
    assert_eq(load64(d + (8 * 8)), 10, "top-left out[8] = ref[1][0]");
    # 3. off the bottom-right @ (4,3): right + bottom extension; the corner clamps to ref[4][5]=45.
    av1_mc_emu_edge(4, 4, 6, 5, 4, 3, d, 0, 4, ref, 0, 6);
    assert_eq(ee_checksum(d, 16), 5992, "emu_edge bottom-right extension");
    assert_eq(load64(d + 0), 34, "bottom-right out[0] = ref[3][4]");
    assert_eq(load64(d + (15 * 8)), 45, "bottom-right out[15] clamps to ref[4][5]");
    # 4. off the bottom-left @ (-1,3): left + bottom extension.
    av1_mc_emu_edge(4, 4, 6, 5, 0 - 1, 3, d, 0, 4, ref, 0, 6);
    assert_eq(ee_checksum(d, 16), 5456, "emu_edge bottom-left extension");
    assert_eq(load64(d + 0), 30, "bottom-left out[0] = ref[3][0]");
    # 5. wholly left of the frame @ (-6,1): only ref col 0 visible -> every column clamps to it.
    av1_mc_emu_edge(4, 4, 6, 5, 0 - 6, 1, d, 0, 4, ref, 0, 6);
    assert_eq(ee_checksum(d, 16), 4200, "emu_edge wholly-left (single visible column)");
    assert_eq(load64(d + 0), 10, "wholly-left out[0] = ref[1][0]");
    assert_eq(load64(d + (3 * 8)), 10, "wholly-left out[3] also = ref[1][0]");
    return 0;
}

fn main() {
    alloc_init();
    test_group("emu_edge frame-boundary block fetch (7.11.3.2)");
    test_emu_edge();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
