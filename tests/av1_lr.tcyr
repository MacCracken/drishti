# tests/av1_lr.tcyr — AV1 loop restoration Wiener kernels (spec 7.17.5-7.17.7).
# The symmetric coefficient expansion, the stripe-aware source fetch, and the
# separable 7-tap filter — the DC-gain (unity) passthrough plus non-flat cases
# cross-checked against an independent Python model of 7.17.5.
include "src/main.cyr"
include "src/av1_lr.cyr"

fn lr_fill(f, w, h, v): i64 {
    var y = 0;
    while (y < h) {
        var x = 0;
        while (x < w) { dr_frame_set(f, 0, x, y, v); x = x + 1; }
        y = y + 1;
    }
    return 0;
}
fn mk_coeff(a, b, c): i64 {
    var p = alloc(3 * 8);
    store64(p + 0, a);
    store64(p + 8, b);
    store64(p + 16, c);
    return p;
}

# ---- Wiener coefficient process (7.17.6) ----
fn test_wiener_coeff() {
    var out = alloc(7 * 8);
    av1_lr_wiener_coeff(mk_coeff(3, 0 - 7, 15), out);
    # filter = {3,-7,15, 128-2*(3-7+15)=106, 15,-7,3}; sum = 128.
    assert_eq(load64(out + 0), 3, "coeff[0]");
    assert_eq(load64(out + 8), 0 - 7, "coeff[1]");
    assert_eq(load64(out + 16), 15, "coeff[2]");
    assert_eq(load64(out + 24), 106, "center = 128 - 2*sum");
    assert_eq(load64(out + 32), 15, "mirror[4]");
    assert_eq(load64(out + 40), 0 - 7, "mirror[5]");
    assert_eq(load64(out + 48), 3, "mirror[6]");
    # chroma: coeff[0] == 0 -> 5-tap (filter[0] = filter[6] = 0).
    av1_lr_wiener_coeff(mk_coeff(0, 4, 20), out);
    assert_eq(load64(out + 0), 0, "chroma coeff[0] = 0");
    assert_eq(load64(out + 24), 80, "chroma center 128 - 2*24");
    assert_eq(load64(out + 48), 0, "chroma coeff[6] = 0");
    return 0;
}

# ---- get source sample (7.17.7): plane-extent clamp + stripe routing ----
fn test_get_source_sample() {
    var oe = alloc(8);
    var curr = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var cdef = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    lr_fill(curr, 16, 16, 50);
    lr_fill(cdef, 16, 16, 200);
    # stripe rows [4,11]: within -> cdef; above/below -> curr.
    assert_eq(av1_lr_get_source_sample(curr, cdef, 0, 8, 8, 15, 15, 4, 11), 200, "within stripe -> cdef");
    assert_eq(av1_lr_get_source_sample(curr, cdef, 0, 8, 14, 15, 15, 4, 11), 50, "below stripe -> curr");
    # x clamps to [0, PlaneEndX]: mark the boundary columns.
    dr_frame_set(cdef, 0, 0, 8, 201);
    dr_frame_set(cdef, 0, 15, 8, 202);
    assert_eq(av1_lr_get_source_sample(curr, cdef, 0, 0 - 5, 8, 15, 15, 4, 11), 201, "x<0 clamps to 0");
    assert_eq(av1_lr_get_source_sample(curr, cdef, 0, 100, 8, 15, 15, 4, 11), 202, "x>PlaneEndX clamps");
    # 3rd-line crop: above-stripe y clamped to Max(StripeStartY-2, y). y=0, ssy=4 -> row 2.
    dr_frame_set(curr, 0, 8, 2, 55);
    assert_eq(av1_lr_get_source_sample(curr, cdef, 0, 8, 0, 15, 15, 4, 11), 55, "above: 3rd line -> 2nd (row 2)");
    return 0;
}

# ---- Wiener filter (7.17.5) ----
# Unit DC gain: a flat block passes through unchanged (the strongest check).
fn test_wiener_dc_gain() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var cdef = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    lr_fill(curr, 32, 32, 100);
    lr_fill(cdef, 32, 32, 100);
    var f = alloc(7 * 8);
    av1_lr_wiener_coeff(mk_coeff(3, 0 - 7, 15), f);
    # block (8,8) 4x4; stripe covers the whole frame so all reads come from cdef.
    av1_lr_wiener_filter(curr, cdef, lr, 0, 8, 8, 4, 4, f, f, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 8, 8), 100, "flat DC-gain passthrough (8,8)");
    assert_eq(dr_frame_get(lr, 0, 11, 11), 100, "flat DC-gain passthrough (11,11)");
    return 0;
}
# A vertical ramp (cdef[y][x] = 100 + y) also passes through (unity gain, linear).
fn test_wiener_ramp() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var cdef = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) { dr_frame_set(curr, 0, x, y, 100 + y); dr_frame_set(cdef, 0, x, y, 100 + y); x = x + 1; }
        y = y + 1;
    }
    var f = alloc(7 * 8);
    av1_lr_wiener_coeff(mk_coeff(3, 0 - 7, 15), f);
    av1_lr_wiener_filter(curr, cdef, lr, 0, 8, 8, 4, 4, f, f, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 8, 8), 108, "vramp (8,8) -> 108");
    assert_eq(dr_frame_get(lr, 0, 8, 9), 109, "vramp (8,9) -> 109");
    assert_eq(dr_frame_get(lr, 0, 11, 11), 111, "vramp (11,11) -> 111");
    return 0;
}
# An impulse (200 amid flat 100) is spread by the 7-tap kernel per the Python model.
fn test_wiener_impulse() {
    var oe = alloc(8);
    var curr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var cdef = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    lr_fill(curr, 32, 32, 100);
    lr_fill(cdef, 32, 32, 100);
    dr_frame_set(curr, 0, 10, 10, 200);
    dr_frame_set(cdef, 0, 10, 10, 200);
    var f = alloc(7 * 8);
    av1_lr_wiener_coeff(mk_coeff(3, 0 - 7, 15), f);
    av1_lr_wiener_filter(curr, cdef, lr, 0, 8, 8, 4, 4, f, f, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 10, 10), 169, "impulse center (10,10) -> 169");
    assert_eq(dr_frame_get(lr, 0, 9, 10), 110, "impulse (9,10) -> 110");
    assert_eq(dr_frame_get(lr, 0, 8, 8), 100, "impulse far (8,8) -> 100");
    return 0;
}

# ---- SGR / self-guided (7.17.2 + 7.17.3) ----
fn test_sgr_params() {
    # set 0 = {2,12,1,4}; set 10 = {0,0,1,5}; set 14 = {2,30,0,0}.
    assert_eq(av1_lr_sgr_params(0, 0), 2, "set0 r0");
    assert_eq(av1_lr_sgr_params(0, 1), 12, "set0 eps0");
    assert_eq(av1_lr_sgr_params(0, 3), 4, "set0 eps1");
    assert_eq(av1_lr_sgr_params(10, 0), 0, "set10 r0 = 0");
    assert_eq(av1_lr_sgr_params(14, 2), 0, "set14 r1 = 0");
    assert_eq(av1_lr_sgr_params(15, 1), 75, "set15 eps0 = 75");
    return 0;
}
# Box filter on a flat block: the confidence collapses (p=0 -> a2=1), leaving a
# smooth output. set 0 pass 0 (r=2) -> 1602; pass 1 (r=1) -> 1600 (= 100<<4).
fn test_box_filter() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    lr_fill(f, 32, 32, 100);
    var out = alloc(4 * 4 * 8);
    assert_eq(av1_lr_box_filter(f, f, 0, 8, 8, 4, 4, 0, 0, out, 31, 31, 0, 31), 1, "set0 pass0 filtered");
    assert_eq(load64(out + 0), 1602, "set0 pass0 flat F[0][0] = 1602");
    assert_eq(load64(out + (((1 * 4) + 1) * 8)), 1602, "set0 pass0 flat F[1][1] = 1602");
    av1_lr_box_filter(f, f, 0, 8, 8, 4, 4, 0, 1, out, 31, 31, 0, 31);
    assert_eq(load64(out + 0), 1600, "set0 pass1 flat F[0][0] = 1600");
    # a radius-0 pass returns 0 and leaves out_f untouched.
    store64(out + 0, 0 - 999);
    assert_eq(av1_lr_box_filter(f, f, 0, 8, 8, 4, 4, 14, 1, out, 31, 31, 0, 31), 0, "set14 pass1 r=0 -> skip");
    assert_eq(load64(out + 0), 0 - 999, "r=0 leaves out_f untouched");
    return 0;
}
# Self-guided DC preservation: a flat block passes through unchanged.
fn test_self_guided_dc() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    lr_fill(f, 32, 32, 100);
    av1_lr_self_guided(f, f, lr, 0, 8, 8, 4, 4, 0, 32, 32, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 8, 8), 100, "sgr flat passthrough (8,8)");
    assert_eq(dr_frame_get(lr, 0, 11, 11), 100, "sgr flat passthrough (11,11)");
    return 0;
}
fn test_self_guided_ramp() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) { dr_frame_set(f, 0, x, y, 100 + y); x = x + 1; }
        y = y + 1;
    }
    av1_lr_self_guided(f, f, lr, 0, 8, 8, 4, 4, 0, 32, 32, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 8, 8), 108, "sgr vramp (8,8) -> 108");
    assert_eq(dr_frame_get(lr, 0, 8, 9), 109, "sgr vramp (8,9) -> 109");
    assert_eq(dr_frame_get(lr, 0, 11, 11), 111, "sgr vramp (11,11) -> 111");
    return 0;
}
fn test_self_guided_impulse() {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    lr_fill(f, 32, 32, 100);
    dr_frame_set(f, 0, 10, 10, 200);
    av1_lr_self_guided(f, f, lr, 0, 8, 8, 4, 4, 0, 32, 32, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 10, 10), 199, "sgr impulse (10,10) -> 199");
    assert_eq(dr_frame_get(lr, 0, 9, 10), 100, "sgr impulse (9,10) -> 100");
    assert_eq(dr_frame_get(lr, 0, 8, 8), 100, "sgr impulse far (8,8) -> 100");
    # set 10 has r0 == 0 -> pass 0 uses the source; the projection reconstructs 200.
    av1_lr_self_guided(f, f, lr, 0, 8, 8, 4, 4, 10, 32, 32, 31, 31, 0, 31);
    assert_eq(dr_frame_get(lr, 0, 10, 10), 200, "set10 (r0=0) impulse (10,10) -> 200");
    return 0;
}

# ---- LR driver: process (7.17.1) + loop_restore_block (7.17.2) ----
fn test_lr_count_units() {
    assert_eq(av1_lr_count_units(64, 64), 1, "64/64 -> 1 unit");
    assert_eq(av1_lr_count_units(64, 128), 2, "128 -> 2 units");
    assert_eq(av1_lr_count_units(64, 96), 2, "(96+32)/64 -> 2");
    assert_eq(av1_lr_count_units(256, 100), 1, "tiny frame -> min 1 unit");
    return 0;
}
# 64x64, flat 100 + impulse 200 at (32,32). rtype/uses_lr per args; single unit
# (unit_size 64) using Wiener coeffs [3,-7,15] and SGR set 0 xqd (32,32).
fn mk_lr(rtype, uses_lr): i64 {
    var params = av1_lr_params_new(64, 64, 1, 0, 0, uses_lr);
    av1_lr_params_set_plane(params, 0, rtype, 64);
    av1_lr_type_set(params, 0, 0, 0, rtype);
    av1_lr_wiener_set(params, 0, 0, 0, 0, 3, 0 - 7, 15);
    av1_lr_wiener_set(params, 0, 0, 0, 1, 3, 0 - 7, 15);
    av1_lr_sgrset_set(params, 0, 0, 0, 0);
    av1_lr_sgrxqd_set(params, 0, 0, 0, 32, 32);
    return params;
}
fn mk_impulse_frame(): i64 {
    var oe = alloc(8);
    var f = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    lr_fill(f, 64, 64, 100);
    dr_frame_set(f, 0, 32, 32, 200);
    return f;
}
fn run_lr(rtype, uses_lr): i64 {
    var cdef = mk_impulse_frame();
    var oe = alloc(8);
    var lr = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_lr_process(cdef, cdef, lr, mk_lr(rtype, uses_lr));   # curr = cdef for the test
    return lr;
}
# RESTORE_NONE plane -> the block loop skips it -> LrFrame is just the copy.
fn test_lr_process_none() {
    var lr = run_lr(AV1_RESTORE_NONE, 1);
    assert_eq(dr_frame_get(lr, 0, 32, 32), 200, "NONE -> impulse copied (200)");
    assert_eq(dr_frame_get(lr, 0, 8, 8), 100, "NONE -> flat copied (100)");
    return 0;
}
# UsesLr == 0 -> process returns right after the copy, no filtering.
fn test_lr_process_uses0() {
    var lr = run_lr(AV1_RESTORE_WIENER, 0);
    assert_eq(dr_frame_get(lr, 0, 32, 32), 200, "UsesLr 0 -> copy only (200)");
    return 0;
}
# WIENER unit: the impulse is Wiener-filtered (spec-matched 169).
fn test_lr_process_wiener() {
    var lr = run_lr(AV1_RESTORE_WIENER, 1);
    assert_eq(dr_frame_get(lr, 0, 32, 32), 169, "WIENER process impulse (32,32) -> 169");
    assert_eq(dr_frame_get(lr, 0, 33, 32), 110, "WIENER process (33,32) -> 110");
    assert_eq(dr_frame_get(lr, 0, 8, 8), 100, "WIENER flat region unchanged (100)");
    return 0;
}
# SGRPROJ unit: the impulse is self-guided-filtered (199) — proves the dispatch
# picks SGR (not Wiener/none) with the unit's set + xqd.
fn test_lr_process_sgr() {
    var lr = run_lr(AV1_RESTORE_SGRPROJ, 1);
    assert_eq(dr_frame_get(lr, 0, 32, 32), 199, "SGRPROJ process impulse (32,32) -> 199");
    return 0;
}
# Full-process DC passthrough: a flat frame is unchanged through copy+dispatch+filter.
fn test_lr_process_flat() {
    var oe = alloc(8);
    var cdef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var lr = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    lr_fill(cdef, 64, 64, 100);
    av1_lr_process(cdef, cdef, lr, mk_lr(AV1_RESTORE_WIENER, 1));
    assert_eq(dr_frame_get(lr, 0, 32, 32), 100, "WIENER flat process (32,32) -> 100");
    assert_eq(dr_frame_get(lr, 0, 60, 60), 100, "WIENER flat process (60,60) -> 100");
    return 0;
}

# ---- read_lr_unit / write_lr_unit round-trip (5.11.57) ----
# encode unit (0,0) of pre-planned `pe`, decode into a fresh `pd`, return pd.
fn lr_unit_rt(pe, frt): i64 {
    av1_lr_ref_reset(pe);
    var enc = av1_sym_enc_init(128, 1);
    var nce = av1_ncdf_new();
    av1_write_lr_unit(enc, nce, pe, 0, 0, 0);
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var pd = av1_lr_params_new(64, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pd, 0, frt, 64);
    av1_lr_ref_reset(pd);
    var sd = av1_sym_dec_init(out, olen, 1);
    var ncd = av1_ncdf_new();
    av1_read_lr_unit(sd, ncd, pd, 0, 0, 0);
    return pd;
}
fn test_lr_cdf_defaults() {
    var cc = av1_ncdf_new();
    assert_eq(load64(av1_ncdf_use_wiener(cc) + 0), 11570, "use_wiener cdf[0] = 11570");
    assert_eq(load64(av1_ncdf_use_sgrproj(cc) + 0), 16855, "use_sgrproj cdf[0] = 16855");
    assert_eq(load64(av1_ncdf_restoration_type(cc) + 0), 9413, "restoration_type cdf[0] = 9413");
    assert_eq(load64(av1_ncdf_restoration_type(cc) + 8), 22581, "restoration_type cdf[1] = 22581");
    return 0;
}
fn test_lr_unit_wiener() {
    var pe = av1_lr_params_new(64, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pe, 0, AV1_RESTORE_WIENER, 64);
    av1_lr_type_set(pe, 0, 0, 0, AV1_RESTORE_WIENER);
    av1_lr_wiener_set(pe, 0, 0, 0, 0, 3, 0 - 7, 15);       # pass 0 taps (in-range)
    av1_lr_wiener_set(pe, 0, 0, 0, 1, 0 - 2, 5, 20);       # pass 1 taps
    var pd = lr_unit_rt(pe, AV1_RESTORE_WIENER);
    assert_eq(av1_lr_type_get(pd, 0, 0, 0), AV1_RESTORE_WIENER, "wiener type round-trips");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 0, 0), 3, "p0 t0");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 0, 1), 0 - 7, "p0 t1");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 0, 2), 15, "p0 t2");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 1, 0), 0 - 2, "p1 t0");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 1, 1), 5, "p1 t1");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 1, 2), 20, "p1 t2");
    return 0;
}
fn test_lr_unit_sgr() {
    var pe = av1_lr_params_new(64, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pe, 0, AV1_RESTORE_SGRPROJ, 64);
    av1_lr_type_set(pe, 0, 0, 0, AV1_RESTORE_SGRPROJ);
    av1_lr_sgrset_set(pe, 0, 0, 0, 5);                     # set 5 = {2,29,1,11}: both radii != 0
    av1_lr_sgrxqd_set(pe, 0, 0, 0, 10, 0 - 20);
    var pd = lr_unit_rt(pe, AV1_RESTORE_SGRPROJ);
    assert_eq(av1_lr_type_get(pd, 0, 0, 0), AV1_RESTORE_SGRPROJ, "sgr type round-trips");
    assert_eq(av1_lr_sgrset_get(pd, 0, 0, 0), 5, "sgr set 5");
    assert_eq(av1_lr_sgrxqd_get_one(pd, 0, 0, 0, 0), 10, "xqd0 = 10");
    assert_eq(av1_lr_sgrxqd_get_one(pd, 0, 0, 0, 1), 0 - 20, "xqd1 = -20");
    return 0;
}
fn test_lr_unit_sgr_radius0() {
    # set 14 = {2,30,0,0}: radius1 == 0 -> xqd1 is COMPUTED (not coded).
    var pe = av1_lr_params_new(64, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pe, 0, AV1_RESTORE_SGRPROJ, 64);
    av1_lr_type_set(pe, 0, 0, 0, AV1_RESTORE_SGRPROJ);
    av1_lr_sgrset_set(pe, 0, 0, 0, 14);
    av1_lr_sgrxqd_set(pe, 0, 0, 0, 10, 0);
    var pd = lr_unit_rt(pe, AV1_RESTORE_SGRPROJ);
    assert_eq(av1_lr_sgrxqd_get_one(pd, 0, 0, 0, 0), 10, "set14 xqd0 coded = 10");
    assert_eq(av1_lr_sgrxqd_get_one(pd, 0, 0, 0, 1), 95, "set14 xqd1 = Clip3(-32,95,128-10) = 95");
    return 0;
}
fn test_lr_unit_switchable_none() {
    var pe = av1_lr_params_new(64, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pe, 0, AV1_RESTORE_SWITCHABLE, 64);
    av1_lr_type_set(pe, 0, 0, 0, AV1_RESTORE_NONE);
    var pd = lr_unit_rt(pe, AV1_RESTORE_SWITCHABLE);
    assert_eq(av1_lr_type_get(pd, 0, 0, 0), AV1_RESTORE_NONE, "switchable -> NONE round-trips");
    return 0;
}

# ---- read_lr per-superblock geometry (5.11.57) ----
# 128x64, unit_size 64 -> unit_rows 1, unit_cols 2. unit (0,0) coeffs A, (0,1) B.
fn mk_lr_2units(): i64 {
    var pe = av1_lr_params_new(128, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pe, 0, AV1_RESTORE_WIENER, 64);
    av1_lr_type_set(pe, 0, 0, 0, AV1_RESTORE_WIENER);
    av1_lr_wiener_set(pe, 0, 0, 0, 0, 3, 0 - 7, 15);
    av1_lr_wiener_set(pe, 0, 0, 0, 1, 3, 0 - 7, 15);
    av1_lr_type_set(pe, 0, 0, 1, AV1_RESTORE_WIENER);
    av1_lr_wiener_set(pe, 0, 0, 1, 0, 0 - 2, 5, 20);
    av1_lr_wiener_set(pe, 0, 0, 1, 1, 0 - 2, 5, 20);
    return pe;
}
fn mk_lr_dec(): i64 {
    var pd = av1_lr_params_new(128, 64, 1, 0, 0, 1);
    av1_lr_params_set_plane(pd, 0, AV1_RESTORE_WIENER, 64);
    return pd;
}
# two 64x64 superblocks (c=0, c=16): each reads exactly one unit (0,0) / (0,1).
fn test_read_lr_two_sbs() {
    var pe = mk_lr_2units();
    av1_lr_ref_reset(pe);
    var enc = av1_sym_enc_init(256, 1);
    var nce = av1_ncdf_new();
    av1_write_lr(enc, nce, pe, 0, 0, 12, 0, 0, 8);        # SB (0,0),  BLOCK_64X64
    av1_write_lr(enc, nce, pe, 0, 16, 12, 0, 0, 8);       # SB (0,16)
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var pd = mk_lr_dec();
    av1_lr_ref_reset(pd);
    var sd = av1_sym_dec_init(out, olen, 1);
    var ncd = av1_ncdf_new();
    av1_read_lr(sd, ncd, pd, 0, 0, 12, 0, 0, 8);
    av1_read_lr(sd, ncd, pd, 0, 16, 12, 0, 0, 8);
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 0, 2), 15, "SB(0,0) -> unit(0,0) coeff 15");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 1, 0, 2), 20, "SB(0,16) -> unit(0,1) coeff 20");
    return 0;
}
# one 128x128 superblock reads BOTH units (the col loop runs 2 iterations).
fn test_read_lr_sb_spans() {
    var pe = mk_lr_2units();
    av1_lr_ref_reset(pe);
    var enc = av1_sym_enc_init(256, 1);
    var nce = av1_ncdf_new();
    av1_write_lr(enc, nce, pe, 0, 0, 15, 0, 0, 8);        # BLOCK_128X128 spans units 0 + 1
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var pd = mk_lr_dec();
    av1_lr_ref_reset(pd);
    var sd = av1_sym_dec_init(out, olen, 1);
    var ncd = av1_ncdf_new();
    av1_read_lr(sd, ncd, pd, 0, 0, 15, 0, 0, 8);
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 0, 0, 2), 15, "spanning SB -> unit(0,0)");
    assert_eq(av1_lr_wiener_get_one(pd, 0, 0, 1, 0, 2), 20, "spanning SB -> unit(0,1)");
    return 0;
}
# allow_intrabc: read_lr returns immediately, reading nothing.
fn test_read_lr_intrabc() {
    var pd = mk_lr_dec();
    var buf = alloc(4);
    store64(buf, 0);
    var sd = av1_sym_dec_init(buf, 4, 1);
    var ncd = av1_ncdf_new();
    av1_read_lr(sd, ncd, pd, 0, 0, 12, 1, 0, 8);          # allow_intrabc = 1
    assert_eq(av1_lr_type_get(pd, 0, 0, 0), AV1_RESTORE_NONE, "intrabc -> no read (type stays NONE)");
    return 0;
}

fn main() {
    alloc_init();
    test_group("lr wiener coefficient (7.17.6)");
    test_wiener_coeff();
    test_group("lr get source sample (7.17.7)");
    test_get_source_sample();
    test_group("lr wiener filter (7.17.5)");
    test_wiener_dc_gain();
    test_wiener_ramp();
    test_wiener_impulse();
    test_group("lr sgr / self-guided (7.17.2 + 7.17.3)");
    test_sgr_params();
    test_box_filter();
    test_self_guided_dc();
    test_self_guided_ramp();
    test_self_guided_impulse();
    test_group("lr driver — process (7.17.1) + loop_restore_block (7.17.2)");
    test_lr_count_units();
    test_lr_process_none();
    test_lr_process_uses0();
    test_lr_process_wiener();
    test_lr_process_sgr();
    test_lr_process_flat();
    test_group("lr read_lr_unit / write_lr_unit round-trip (5.11.57)");
    test_lr_cdf_defaults();
    test_lr_unit_wiener();
    test_lr_unit_sgr();
    test_lr_unit_sgr_radius0();
    test_lr_unit_switchable_none();
    test_group("lr read_lr per-superblock geometry (5.11.57)");
    test_read_lr_two_sbs();
    test_read_lr_sb_spans();
    test_read_lr_intrabc();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
