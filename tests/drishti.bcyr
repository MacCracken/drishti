# tests/drishti.bcyr — drishti core benchmarks: bitreader on a real
# parse loop (the hot path every codec family sits on), plus the
# exp-Golomb reader.
#
# Pattern: bench_new -> bench_batch_start -> tight loop -> bench_batch_stop
# -> bench_report (batch >= 1000 amortizes clock_gettime overhead; see
# lib/bench.cyr header).
#
# Suites explicitly include the lib root: `cyrius test`/`cyrius bench`
# auto-include stdlib only, never [lib] modules.
include "src/main.cyr"

# 64 KiB pseudo-random buffer (xorshift) — realistic bit-mix, no zeros
# runs long enough to fault the ue reader.
fn bench_make_buf(n): i64 {
    var b = alloc(n);
    var s = 0x2545F491;
    var i = 0;
    while (i < n) {
        s = s ^ (s << 13);
        s = s ^ (s >> 7);
        s = s ^ (s << 17);
        s = s & 0x7FFFFFFFFFFFFFFF;
        store8(b + i, s & 255);
        i = i + 1;
    }
    return b;
}

# Drain a 64 KiB buffer bit-by-bit: 524288 dr_br_read_bit calls.
fn bench_read_bit(buf, n): i64 {
    var br = dr_br_init(buf, n);
    var acc = 0;
    var total = n << 3;
    var i = 0;
    while (i < total) {
        acc = acc + dr_br_read_bit(br);
        i = i + 1;
    }
    return acc;
}

# Drain the same buffer in 7-bit unaligned gulps (worst-case stride).
fn bench_read_bits7(buf, n): i64 {
    var br = dr_br_init(buf, n);
    var acc = 0;
    var reads = (n << 3) / 7;
    var i = 0;
    while (i < reads) {
        acc = acc + dr_br_read_bits(br, 7);
        i = i + 1;
    }
    return acc;
}

# ue(v) parse loop over the random buffer until it runs dry.
fn bench_ue_drain(buf, n): i64 {
    var br = dr_br_init(buf, n);
    var v = 0;
    var count = 0;
    while (dr_ue_read(br, &v) == DR_OK) {
        count = count + 1;
    }
    return count;
}

fn main(): i64 {
    alloc_init();
    var n = 65536;
    var buf = bench_make_buf(n);

    # read_bit: per-bit cost over 512 Kib.
    var b1 = bench_new("dr_br_read_bit x 524288 (64KiB)");
    bench_batch_start(b1);
    var i = 0;
    while (i < 20) { bench_read_bit(buf, n); i = i + 1; }
    bench_batch_stop(b1, 20);
    bench_report(b1);

    # read_bits(7): unaligned multi-bit stride.
    var b2 = bench_new("dr_br_read_bits(7) x 74898 (64KiB)");
    bench_batch_start(b2);
    i = 0;
    while (i < 20) { bench_read_bits7(buf, n); i = i + 1; }
    bench_batch_stop(b2, 20);
    bench_report(b2);

    # ue(v): the H.264/H.265 header-parse hot loop.
    var b3 = bench_new("dr_ue_read drain (64KiB random)");
    bench_batch_start(b3);
    i = 0;
    while (i < 20) { bench_ue_drain(buf, n); i = i + 1; }
    bench_batch_stop(b3, 20);
    bench_report(b3);

    return 0;
}

var r = main();
syscall(60, r);
