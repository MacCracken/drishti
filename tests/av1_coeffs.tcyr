# tests/av1_coeffs.tcyr — AV1 coefficient reading loop (spec 5.11.39) + the
# txb_skip / dc_sign / txSzCtx contexts (8.3.2). Contexts are pinned by
# hand-computed known-answers on constructed neighbour arrays; the coeffs()
# decode/encode pair is verified by round-trip (encode a known Quant[] with a
# fresh symbol coder, decode it back, assert equal).
include "src/main.cyr"
include "src/av1_coeffs.cyr"

fn az(p, n): i64 { var k = 0; while (k < n) { store64(p + (k * 8), 0); k = k + 1; } return 0; }

fn test_tx_size_ctx() {
    assert_eq(av1_tx_size_ctx(0), 0, "txSzCtx 4x4");
    assert_eq(av1_tx_size_ctx(1), 1, "txSzCtx 8x8");
    assert_eq(av1_tx_size_ctx(2), 2, "txSzCtx 16x16");
    assert_eq(av1_tx_size_ctx(3), 3, "txSzCtx 32x32");
    assert_eq(av1_tx_size_ctx(4), 4, "txSzCtx 64x64");
    assert_eq(av1_tx_size_ctx(5), 1, "txSzCtx 4x8");
    assert_eq(av1_tx_size_ctx(7), 2, "txSzCtx 8x16");
    assert_eq(av1_tx_size_ctx(9), 3, "txSzCtx 16x32");
    assert_eq(av1_tx_size_ctx(11), 4, "txSzCtx 32x64");
    assert_eq(av1_tx_size_ctx(17), 3, "txSzCtx 16x64");
    assert_eq(av1_tx_size_sqr(5), 0, "Tx_Size_Sqr 4x8 -> 4x4");
    assert_eq(av1_tx_size_sqr_up(5), 1, "Tx_Size_Sqr_Up 4x8 -> 8x8");
    return 0;
}

# txb_skip (all_zero) context. Isolated 4x4 block at (0,0): w4=h4=1, w=h=4.
fn test_txb_skip_ctx() {
    var al = alloc(8 * 8);
    var ll = alloc(8 * 8);
    var ad = alloc(8 * 8);
    var ld = alloc(8 * 8);
    az(al, 8); az(ll, 8); az(ad, 8); az(ld, 8);
    # plane 0, block == tx (bw==w, bh==h) -> ctx 0
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 4, 4, al, ll, ad, ld), 0, "txb bw==w -> 0");
    # plane 0, block > tx, no neighbour levels -> ctx 1
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 1, "txb empty -> 1");
    # top=5, left=0 -> one side only, max>3 -> ctx 3
    store64(al + 0, 5);
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 3, "txb top>3 -> 3");
    # top=2, left=0 -> one side only, max<=3 -> ctx 2
    store64(al + 0, 2);
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 2, "txb top<=3 -> 2");
    # top=2, left=1 -> both, max<=3 -> ctx 4
    store64(al + 0, 2); store64(ll + 0, 1);
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 4, "txb both<=3 -> 4");
    # top=5, left=2 -> both, max>3, min<=3 -> ctx 5
    store64(al + 0, 5); store64(ll + 0, 2);
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 5, "txb max>3 min<=3 -> 5");
    # top=10, left=8 -> both >3 -> ctx 6
    store64(al + 0, 10); store64(ll + 0, 8);
    assert_eq(av1_txb_skip_ctx(0, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 6, "txb both>3 -> 6");
    # chroma (plane 1). reset.
    az(al, 8); az(ll, 8); az(ad, 8); az(ld, 8);
    assert_eq(av1_txb_skip_ctx(1, 0, 0, 1, 1, 4, 4, 100, 100, 4, 4, al, ll, ad, ld), 7, "txb chroma empty -> 7");
    store64(al + 0, 3);
    assert_eq(av1_txb_skip_ctx(1, 0, 0, 1, 1, 4, 4, 100, 100, 4, 4, al, ll, ad, ld), 8, "txb chroma above -> 8");
    store64(ll + 0, 1);
    assert_eq(av1_txb_skip_ctx(1, 0, 0, 1, 1, 4, 4, 100, 100, 4, 4, al, ll, ad, ld), 9, "txb chroma both -> 9");
    # bw*bh (8*4=32) > w*h (16) -> +3
    assert_eq(av1_txb_skip_ctx(1, 0, 0, 1, 1, 4, 4, 100, 100, 8, 4, al, ll, ad, ld), 12, "txb chroma bigger blk -> 12");
    # dc-context also ORs in on chroma: only above_dc set
    az(al, 8); az(ll, 8); az(ad, 8); az(ld, 8);
    store64(ad + 0, 2);
    assert_eq(av1_txb_skip_ctx(1, 0, 0, 1, 1, 4, 4, 100, 100, 4, 4, al, ll, ad, ld), 8, "txb chroma above_dc -> 8");
    return 0;
}

fn test_dc_sign_ctx() {
    var ad = alloc(8 * 8);
    var ld = alloc(8 * 8);
    az(ad, 8); az(ld, 8);
    assert_eq(av1_dc_sign_ctx(0, 0, 1, 1, 100, 100, ad, ld), 0, "dc_sign empty -> 0");
    store64(ad + 0, 1);
    assert_eq(av1_dc_sign_ctx(0, 0, 1, 1, 100, 100, ad, ld), 1, "dc_sign neg -> 1");
    store64(ad + 0, 2);
    assert_eq(av1_dc_sign_ctx(0, 0, 1, 1, 100, 100, ad, ld), 2, "dc_sign pos -> 2");
    # above negative, left positive -> net 0
    store64(ad + 0, 1); store64(ld + 0, 2);
    assert_eq(av1_dc_sign_ctx(0, 0, 1, 1, 100, 100, ad, ld), 0, "dc_sign mix -> 0");
    # two positives (8-wide, w4=2) -> +2 -> ctx 2
    az(ad, 8); az(ld, 8);
    store64(ad + 0, 2); store64(ad + 8, 2);
    assert_eq(av1_dc_sign_ctx(0, 0, 2, 1, 100, 100, ad, ld), 2, "dc_sign two pos -> 2");
    return 0;
}

# Encode a known signed quant[] for one transform block, then decode it back
# and assert the coefficients + eob match. Neighbour arrays start zeroed on
# both sides (isolated block); a fresh mutable CDF context per side. disable
# selects read-only (1) vs adaptive (0) CDFs.
fn coeffs_roundtrip_d(tx_size, tx_type, plane, quant, seg_eob, eob, disable): i64 {
    var al = alloc(256 * 8);
    var ll = alloc(256 * 8);
    var ad = alloc(256 * 8);
    var ld = alloc(256 * 8);
    az(al, 256); az(ll, 256); az(ad, 256); az(ld, 256);
    var w = 1 << av1_tx_width_log2(tx_size);
    var h = 1 << av1_tx_height_log2(tx_size);
    var cce = av1_ccdf_new(0);
    var enc = av1_sym_enc_init(512, disable);
    av1_coeffs_encode(enc, cce, plane, tx_size, tx_type, 0, 0, 100, 100, w, h, al, ll, ad, ld, quant, eob);
    assert_eq(av1_sym_enc_err(enc), DR_OK, "encode ok");
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var dal = alloc(256 * 8);
    var dll = alloc(256 * 8);
    var dad = alloc(256 * 8);
    var dld = alloc(256 * 8);
    az(dal, 256); az(dll, 256); az(dad, 256); az(dld, 256);
    var dq = alloc(seg_eob * 8);
    var ccd = av1_ccdf_new(0);
    var sd = av1_sym_dec_init(out, olen, disable);
    var deob = av1_coeffs_decode(sd, ccd, plane, tx_size, tx_type, 0, 0, 100, 100, w, h, dal, dll, dad, dld, dq);
    assert_eq(deob, eob, "eob round-trips");
    var i = 0;
    while (i < seg_eob) {
        assert_eq(load64(dq + (i * 8)), load64(quant + (i * 8)), "coeff round-trips");
        i = i + 1;
    }
    return 0;
}
fn coeffs_roundtrip(tx_size, tx_type, plane, quant, seg_eob, eob): i64 {
    return coeffs_roundtrip_d(tx_size, tx_type, plane, quant, seg_eob, eob, 1);
}

# 4x4 DCT_DCT, exercising: DC base+br, a small negative, a golomb value, an
# interior zero, a level-3 negative, and an eob coefficient with golomb.
# Default_Scan_4x4 = [0,1,4,8,5,2,...]; eob=6 covers scan[0..5].
fn test_coeffs_4x4() {
    var quant = alloc(16 * 8);
    az(quant, 16);
    store64(quant + (0 * 8), 5);         # scan[0]=0: level 5 (base3+br2)
    store64(quant + (1 * 8), 0 - 1);     # scan[1]=1: -1
    store64(quant + (4 * 8), 20);        # scan[2]=4: 20 (golomb x=6)
    store64(quant + (8 * 8), 0);         # scan[3]=8: interior zero
    store64(quant + (5 * 8), 0 - 3);     # scan[4]=5: -3
    store64(quant + (2 * 8), 100);       # scan[5]=2: eob coeff, 100 (golomb x=86)
    coeffs_roundtrip(0, AV1_DCT_DCT, 0, quant, 16, 6);
    return 0;
}

# all_zero: eob=0 -> the block is skipped; decode returns eob 0, quant all zero.
fn test_coeffs_all_zero() {
    var quant = alloc(16 * 8);
    az(quant, 16);
    coeffs_roundtrip(0, AV1_DCT_DCT, 0, quant, 16, 0);
    return 0;
}

# 8x8 DCT_DCT with a single DC coefficient (eob=1 -> only the eob coeff).
fn test_coeffs_8x8_dc() {
    var quant = alloc(64 * 8);
    az(quant, 64);
    store64(quant + (0 * 8), 0 - 7);     # DC = -7 (eob coeff, level 7)
    coeffs_roundtrip(1, AV1_DCT_DCT, 0, quant, 64, 1);
    return 0;
}

# Chroma (plane 1) 4x4 with a couple of coefficients.
fn test_coeffs_chroma() {
    var quant = alloc(16 * 8);
    az(quant, 16);
    store64(quant + (0 * 8), 3);         # scan[0]=0
    store64(quant + (1 * 8), 0 - 2);     # scan[1]=1 (eob coeff)
    coeffs_roundtrip(0, AV1_DCT_DCT, 1, quant, 16, 2);
    return 0;
}

# Fill quant[] by SCAN order (vals[c] -> quant[scan[c]]) so every position
# beyond eob is guaranteed zero, then round-trip. vals[eob-1] must be nonzero.
fn coeffs_rt_scan(tx_size, tx_type, plane, vals, eob, seg_eob): i64 {
    var quant = alloc(seg_eob * 8);
    az(quant, seg_eob);
    var scan = av1_get_scan(tx_size, tx_type);
    var c = 0;
    while (c < eob) {
        store64(quant + (load64(scan + (c * 8)) * 8), load64(vals + (c * 8)));
        c = c + 1;
    }
    coeffs_roundtrip(tx_size, tx_type, plane, quant, seg_eob, eob);
    return 0;
}

# 4x4 V_DCT — exercises the mrow scan + the 1D (vertical) coeff_base/br
# contexts, distinct from the 2D path.
fn test_coeffs_1d() {
    var v = alloc(8 * 8);
    store64(v + 0, 4); store64(v + 8, 0 - 6); store64(v + 16, 0);
    store64(v + 24, 30);   # golomb, eob coeff
    coeffs_rt_scan(0, AV1_V_DCT, 0, v, 4, 16);
    return 0;
}

# 16x16 with a larger eob (exercises multi-bit eob_extra) and a spread of
# magnitudes filled in scan order.
fn test_coeffs_16x16() {
    var v = alloc(16 * 8);
    var k = 0;
    while (k < 16) { store64(v + (k * 8), (k % 5) - 2); k = k + 1; }   # -2..2, some zero
    store64(v + (15 * 8), 0 - 9);   # eob coeff must be nonzero
    coeffs_rt_scan(2, AV1_DCT_DCT, 0, v, 16, 256);
    return 0;
}

# Truncated / hostile input must TERMINATE (bounded loops, esp. the golomb
# length cap) — never hang. Reaching the assertion is the proof of no-hang.
fn test_coeffs_truncation() {
    var buf = alloc(8);
    store8(buf + 0, 255); store8(buf + 1, 255); store8(buf + 2, 255); store8(buf + 3, 255);
    var al = alloc(256 * 8);
    var ll = alloc(256 * 8);
    var ad = alloc(256 * 8);
    var ld = alloc(256 * 8);
    az(al, 256); az(ll, 256); az(ad, 256); az(ld, 256);
    var dq = alloc(1024 * 8);
    # A few tx sizes (4x4, 8x8, 16x16) over a 4-byte 0xFF buffer: the decode
    # reads far past the buffer into padding, exercising the exhausted reader.
    var sizes = alloc(3 * 8);
    store64(sizes + 0, 0); store64(sizes + 8, 1); store64(sizes + 16, 2);
    var k = 0;
    while (k < 3) {
        az(al, 256); az(ll, 256); az(ad, 256); az(ld, 256);
        var cc = av1_ccdf_new(0);
        var sd = av1_sym_dec_init(buf, 4, 1);
        av1_coeffs_decode(sd, cc, 0, load64(sizes + (k * 8)), AV1_DCT_DCT, 0, 0, 100, 100, 4, 4, al, ll, ad, ld, dq);
        assert_eq(1, 1, "truncated decode terminated (no hang)");
        k = k + 1;
    }
    return 0;
}

# ADAPTIVE round-trip (disable_cdf_update = 0): the mutable CDF context adapts
# as symbols are (en/de)coded. A single fresh context per side stays in sync.
fn test_coeffs_adaptive() {
    # scan[0..3] = [0,1,4,8]; the eob coeff (scan[3]=8) must be nonzero.
    var quant = alloc(16 * 8);
    az(quant, 16);
    store64(quant + (0 * 8), 6);
    store64(quant + (1 * 8), 0 - 4);
    store64(quant + (4 * 8), 25);
    store64(quant + (8 * 8), 0 - 2);
    coeffs_roundtrip_d(0, AV1_DCT_DCT, 0, quant, 16, 4, 0);
    return 0;
}

# ADAPTIVE across MULTIPLE blocks sharing one context: block 2 is (en/de)coded
# with the CDFs already adapted by block 1 — proving decode stays in sync with
# encode only if the adaptation is identical on both sides.
fn test_coeffs_adaptive_multiblock() {
    var w = 4;
    var h = 4;
    var cce = av1_ccdf_new(0);
    var ccd = av1_ccdf_new(0);
    # block A: scan[0..2] = [0,1,4], eob=3 (scan[2]=4 nonzero).
    var qa = alloc(16 * 8);
    az(qa, 16);
    store64(qa + (0 * 8), 9); store64(qa + (1 * 8), 0 - 3); store64(qa + (4 * 8), 40);
    # block B: scan[0..4] = [0,1,4,8,5], eob=5 (scan[4]=5 nonzero).
    var qb = alloc(16 * 8);
    az(qb, 16);
    store64(qb + (0 * 8), 0 - 5); store64(qb + (1 * 8), 2);
    store64(qb + (4 * 8), 0 - 1); store64(qb + (8 * 8), 3); store64(qb + (5 * 8), 0 - 2);
    var al = alloc(64 * 8);
    var ll = alloc(64 * 8);
    var ad = alloc(64 * 8);
    var ld = alloc(64 * 8);
    az(al, 64); az(ll, 64); az(ad, 64); az(ld, 64);
    var enc = av1_sym_enc_init(512, 0);
    av1_coeffs_encode(enc, cce, 0, 0, AV1_DCT_DCT, 0, 0, 100, 100, w, h, al, ll, ad, ld, qa, 3);
    av1_coeffs_encode(enc, cce, 0, 0, AV1_DCT_DCT, 0, 0, 100, 100, w, h, al, ll, ad, ld, qb, 5);
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var dal = alloc(64 * 8);
    var dll = alloc(64 * 8);
    var dad = alloc(64 * 8);
    var dld = alloc(64 * 8);
    az(dal, 64); az(dll, 64); az(dad, 64); az(dld, 64);
    var da = alloc(16 * 8);
    var db = alloc(16 * 8);
    var sd = av1_sym_dec_init(out, olen, 0);
    var ea = av1_coeffs_decode(sd, ccd, 0, 0, AV1_DCT_DCT, 0, 0, 100, 100, w, h, dal, dll, dad, dld, da);
    var eb = av1_coeffs_decode(sd, ccd, 0, 0, AV1_DCT_DCT, 0, 0, 100, 100, w, h, dal, dll, dad, dld, db);
    assert_eq(ea, 3, "block A eob");
    assert_eq(eb, 5, "block B eob");
    var i = 0;
    while (i < 16) {
        assert_eq(load64(da + (i * 8)), load64(qa + (i * 8)), "block A coeff (adaptive)");
        assert_eq(load64(db + (i * 8)), load64(qb + (i * 8)), "block B coeff (adaptive)");
        i = i + 1;
    }
    return 0;
}

# The freshly-initialised mutable CDF context must byte-for-byte equal the
# read-only defaults for its quantizer bucket (across all 7 families + all 4
# buckets). A wrong copy offset or accessor formula shows up here.
fn cmp_cdf(a, b, n): i64 {
    var i = 0;
    while (i < n) {
        if (load64(a + (i * 8)) != load64(b + (i * 8))) { return 0; }
        i = i + 1;
    }
    return 1;
}
fn test_ccdf_copy() {
    var q = 0;
    while (q < 4) {
        var cc = av1_ccdf_new(q);
        var ts = 0;
        while (ts < 5) {
            var c = 0;
            while (c < 13) {
                assert_eq(cmp_cdf(av1_ccdf_txb_skip(cc, ts, c), av1_txb_skip_cdf(q, ts, c), 3), 1, "ccdf txb_skip");
                c = c + 1;
            }
            ts = ts + 1;
        }
        var p = 0;
        while (p < 2) {
            var cx = 0;
            while (cx < 2) {
                assert_eq(cmp_cdf(av1_ccdf_eob_pt16(cc, p, cx), av1_eob_pt16_cdf(q, p, cx), 6), 1, "ccdf eob16");
                assert_eq(cmp_cdf(av1_ccdf_eob_pt256(cc, p, cx), av1_eob_pt256_cdf(q, p, cx), 10), 1, "ccdf eob256");
                cx = cx + 1;
            }
            assert_eq(cmp_cdf(av1_ccdf_eob_pt1024(cc, p), av1_eob_pt1024_cdf(q, p), 12), 1, "ccdf eob1024");
            var d = 0;
            while (d < 3) {
                assert_eq(cmp_cdf(av1_ccdf_dc_sign(cc, p, d), av1_dc_sign_cdf(q, p, d), 3), 1, "ccdf dc_sign");
                d = d + 1;
            }
            var t2 = 0;
            while (t2 < 5) {
                var e = 0;
                while (e < 42) {
                    var cbm = av1_ccdf_coeff_base(cc, t2, p, e);
                    assert_eq(cmp_cdf(cbm, av1_coeff_base_cdf(q, t2, p, e), 5), 1, "ccdf coeff_base");
                    e = e + 1;
                }
                var br = 0;
                while (br < 21) {
                    var brm = av1_ccdf_coeff_br(cc, t2, p, br);
                    assert_eq(cmp_cdf(brm, av1_coeff_br_cdf(q, t2, p, br), 5), 1, "ccdf coeff_br");
                    br = br + 1;
                }
                var be = 0;
                while (be < 4) {
                    var bem = av1_ccdf_coeff_base_eob(cc, t2, p, be);
                    assert_eq(cmp_cdf(bem, av1_coeff_base_eob_cdf(q, t2, p, be), 4), 1, "ccdf base_eob");
                    be = be + 1;
                }
                var ee = 0;
                while (ee < 9) {
                    var eem = av1_ccdf_eob_extra(cc, t2, p, ee);
                    assert_eq(cmp_cdf(eem, av1_eob_extra_cdf(q, t2, p, ee), 3), 1, "ccdf eob_extra");
                    ee = ee + 1;
                }
                t2 = t2 + 1;
            }
            p = p + 1;
        }
        q = q + 1;
    }
    return 0;
}

fn main() {
    alloc_init();
    test_group("adaptive cdf context copy");
    test_ccdf_copy();
    test_group("coeff contexts (txSzCtx / txb_skip / dc_sign)");
    test_tx_size_ctx();
    test_txb_skip_ctx();
    test_dc_sign_ctx();
    test_group("coeffs() decode/encode round-trip");
    test_coeffs_4x4();
    test_coeffs_all_zero();
    test_coeffs_8x8_dc();
    test_coeffs_chroma();
    test_coeffs_1d();
    test_coeffs_16x16();
    test_coeffs_truncation();
    test_group("coeffs() adaptive CDF context");
    test_coeffs_adaptive();
    test_coeffs_adaptive_multiblock();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
