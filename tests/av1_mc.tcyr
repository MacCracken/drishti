# tests/av1_mc.tcyr — AV1 inter prediction, sub-pel interpolation filter table
# (dav1d_mc_subpel_filters, spec 7.11.3.4): 6 sets x 15 phases x 8 taps, plus the
# set-SELECTION leaf av1_mc_filter_set.
include "src/main.cyr"

# ================================================================
# Structural invariants — every phase row sums to 64 (dav1d convention) and mirror
# symmetry holds within each set, so a transcription slip fails the build.
# ================================================================
fn test_subpel_invariants() {
    var s = 0;
    while (s < 6) {
        var p = 0;
        while (p < 15) {
            var sum = 0;
            var k = 0;
            while (k < 8) { sum = sum + av1_subpel_filter(s, p, k); k = k + 1; }
            assert_eq(sum, 64, "subpel phase row sums to 64");
            p = p + 1;
        }
        s = s + 1;
    }
    # mirror symmetry: Subpel_Filters[s][p][k] == Subpel_Filters[s][14-p][7-k].
    var bad = 0;
    s = 0;
    while (s < 6) {
        var p = 0;
        while (p < 15) {
            var k = 0;
            while (k < 8) {
                if (av1_subpel_filter(s, p, k) != av1_subpel_filter(s, 14 - p, 7 - k)) { bad = 1; }
                k = k + 1;
            }
            p = p + 1;
        }
        s = s + 1;
    }
    assert_eq(bad, 0, "subpel mirror symmetry (phase p <-> 14-p)");
    # spot values (half-pel phase 7 of each set + a distinctive tap).
    assert_eq(av1_subpel_filter(0, 7, 3), 38, "REGULAR half-pel tap 3 = 38");
    assert_eq(av1_subpel_filter(0, 7, 4), 38, "REGULAR half-pel tap 4 = 38");
    assert_eq(av1_subpel_filter(2, 7, 3), 40, "SHARP half-pel tap 3 = 40");
    assert_eq(av1_subpel_filter(1, 0, 2), 14, "SMOOTH phase 0 tap 2 = 14");
    assert_eq(av1_subpel_filter(5, 7, 3), 32, "bilin half-pel tap 3 = 32");
    assert_eq(av1_subpel_filter(0, 0, 3), 63, "REGULAR phase 0 tap 3 = 63");
    return 0;
}

# ================================================================
# av1_mc_filter_set — the Subpel_Filters SET selection (spec 7.11.3.4). Exercised indirectly
# by every put_8tap KAT; pinned directly here for the two cases no kernel fixture reaches:
# dim == 2, and hostile out-of-range input.
# ================================================================
fn test_filter_set_selection() {
    # wide/tall blocks take the 8-tap set matching the filter, unchanged.
    assert_eq(av1_mc_filter_set(0, 8), 0, "REGULAR dim 8 -> set 0");
    assert_eq(av1_mc_filter_set(1, 8), 1, "SMOOTH dim 8 -> set 1");
    assert_eq(av1_mc_filter_set(2, 8), 2, "SHARP dim 8 -> set 2");
    assert_eq(av1_mc_filter_set(0, 128), 0, "REGULAR dim 128 -> set 0");
    # dim 5 is the first width ABOVE the narrow threshold — pins the <= boundary from above.
    assert_eq(av1_mc_filter_set(0, 5), 0, "REGULAR dim 5 -> set 0 (just above threshold)");
    # dim <= 4 takes the narrow 4-tap variant: REGULAR and SHARP share set 3, SMOOTH set 4.
    assert_eq(av1_mc_filter_set(0, 4), 3, "REGULAR dim 4 -> set 3 (narrow)");
    assert_eq(av1_mc_filter_set(1, 4), 4, "SMOOTH dim 4 -> set 4 (narrow)");
    assert_eq(av1_mc_filter_set(2, 4), 3, "SHARP dim 4 -> set 3 (narrow, shares REGULAR)");
    # dim 2 is REACHABLE: predW = Block_Width[MiSize] >> subX (6.10.22), so a BLOCK_4X4 luma
    # block's 4:2:0 chroma plane is 2 samples wide. No kernel KAT covers it.
    assert_eq(av1_mc_filter_set(0, 2), 3, "REGULAR dim 2 -> set 3 (4:2:0 chroma of BLOCK_4X4)");
    assert_eq(av1_mc_filter_set(1, 2), 4, "SMOOTH dim 2 -> set 4");
    assert_eq(av1_mc_filter_set(2, 2), 3, "SHARP dim 2 -> set 3");
    assert_eq(av1_mc_filter_set(0, 1), 3, "REGULAR dim 1 -> set 3");
    # TOTALITY. av1_mc_subpel_row does no bounds check and the blob is exactly 6*15*8 i64, so
    # an out-of-range set index reads off the end. The leading `& 3` must keep EVERY input --
    # including negative and wide-of-range -- inside 0..AV1_SUBPEL_SETS-1.
    var bad = 0;
    var filt = 0 - 8;
    while (filt < 16) {
        var dim = 1;
        while (dim < 131) {
            var s = av1_mc_filter_set(filt, dim);
            if ((s < 0) || (s >= AV1_SUBPEL_SETS)) { bad = bad + 1; }
            dim = dim + 1;
        }
        filt = filt + 1;
    }
    assert_eq(bad, 0, "filter set stays in range over hostile filt x dim sweep");
    return 0;
}

# fill one set's 15 golden checksums.
fn av1_mcg15(g, set, v0, v1, v2, v3, v4, v5, v6, v7, v8, v9, v10, v11, v12, v13, v14) {
    var o = g + (set * 15 * 8);
    store64(o + 0, v0);    store64(o + 8, v1);    store64(o + 16, v2);   store64(o + 24, v3);
    store64(o + 32, v4);   store64(o + 40, v5);   store64(o + 48, v6);   store64(o + 56, v7);
    store64(o + 64, v8);   store64(o + 72, v9);   store64(o + 80, v10);  store64(o + 88, v11);
    store64(o + 96, v12);  store64(o + 104, v13); store64(o + 112, v14);
    return 0;
}
# Position-sensitive per-(set,phase) checksum: cs = sum_k Subpel_Filters[s][p][k]*(k+1)^3.
# The cubic weights pin tap ORDER (a within-row permutation changes cs), and the 90
# goldens are computed INDEPENDENTLY (scratchpad/mc_subpel.py, a separate transcription
# of dav1d) — so a transcription/permutation slip in the cyrius table is caught.
fn test_subpel_checksum() {
    var w = alloc(8 * 8);
    store64(w + 0, 1);    store64(w + 8, 8);    store64(w + 16, 27);   store64(w + 24, 64);
    store64(w + 32, 125); store64(w + 40, 216); store64(w + 48, 343);  store64(w + 56, 512);
    var g = alloc(90 * 8);
    av1_mcg15(g, 0, 4243, 4470, 4787, 4977, 5130, 5472, 5679, 5832, 6039, 6192, 6588, 6795, 7093, 7410, 7799);
    av1_mcg15(g, 1, 4711, 5017, 5213, 5463, 5713, 5963, 6232, 6264, 6458, 6835, 7085, 7335, 7585, 7889, 8357);
    av1_mcg15(g, 2, 4585, 4355, 4690, 4833, 5113, 5364, 5796, 5724, 5706, 6030, 6389, 6615, 7136, 7417, 7295);
    av1_mcg15(g, 3, 4262, 4489, 4679, 4869, 5022, 5364, 5571, 5724, 5931, 6084, 6480, 6687, 6985, 7283, 7672);
    av1_mcg15(g, 4, 4730, 5017, 5213, 5463, 5713, 5963, 6213, 6372, 6585, 6835, 7085, 7335, 7585, 7889, 8230);
    av1_mcg15(g, 5, 4340, 4584, 4828, 5072, 5316, 5560, 5804, 6048, 6292, 6536, 6780, 7024, 7268, 7512, 7756);
    var s = 0;
    while (s < 6) {
        var p = 0;
        while (p < 15) {
            var cs = 0;
            var k = 0;
            while (k < 8) { cs = cs + (av1_subpel_filter(s, p, k) * load64(w + (k * 8))); k = k + 1; }
            assert_eq(cs, load64(g + (((s * 15) + p) * 8)), "subpel position checksum (tap order pinned)");
            p = p + 1;
        }
        s = s + 1;
    }
    return 0;
}

# ---- Warped_Filters[193][8] (7.11.3.5) — anchored to dav1d via warp_filter_ref.py ----
fn test_warp_filter_invariants() {
    # every one of the 193 rows sums to exactly 128 (FILTER_BITS=7). A transpose fails this.
    var badsum = 0;
    var i = 0;
    while (i < 193) {
        var s = 0;
        var k = 0;
        while (k < 8) {
            s = s + av1_warp_filter(i, k);
            k = k + 1;
        }
        if (s != 128) { badsum = badsum + 1; }
        i = i + 1;
    }
    assert_eq(badsum, 0, "warp filter: every one of 193 rows sums to 128");
    # reversal symmetry: row[i] == reverse(row[192-i]) for i=1..191 (NOT i=0 — 192 is a dup).
    var badsym = 0;
    i = 1;
    while (i < 192) {
        var k2 = 0;
        while (k2 < 8) {
            if (av1_warp_filter(i, k2) != av1_warp_filter(192 - i, 7 - k2)) { badsym = badsym + 1; }
            k2 = k2 + 1;
        }
        i = i + 1;
    }
    assert_eq(badsym, 0, "warp filter: reversal symmetry row[i]==reverse(row[192-i]) (i=1..191)");
    # row 192 duplicates row 191 (guard-tail sentinel, NOT the mirror of row 0).
    var baddup = 0;
    var k3 = 0;
    while (k3 < 8) {
        if (av1_warp_filter(192, k3) != av1_warp_filter(191, k3)) { baddup = baddup + 1; }
        k3 = k3 + 1;
    }
    assert_eq(baddup, 0, "warp filter: row 192 == row 191 (sentinel dup)");
    # anchor rows — KNOWN values from scripts/refs/warp_filter_ref.py (independent oracle).
    assert_eq(av1_warp_filter(0, 2), 127, "warp[0][2]=127 (region A start)");
    assert_eq(av1_warp_filter(32, 1), 0 - 18, "warp[32][1]=-18");
    assert_eq(av1_warp_filter(32, 2), 78, "warp[32][2]=78 (region A half-pel)");
    assert_eq(av1_warp_filter(64, 3), 127, "warp[64][3]=127 (zero-frac — a real filter, not identity)");
    assert_eq(av1_warp_filter(96, 0), 0 - 2, "warp[96][0]=-2");
    assert_eq(av1_warp_filter(96, 3), 79, "warp[96][3]=79 (central half-pel, palindromic)");
    assert_eq(av1_warp_filter(128, 4), 127, "warp[128][4]=127 (region C start)");
    assert_eq(av1_warp_filter(160, 4), 78, "warp[160][4]=78 (=row 32 shifted right 2)");
    assert_eq(av1_warp_filter(191, 5), 127, "warp[191][5]=127 (last real row)");
    # cross-check the accessor formula against the RAW blob (absolute byte offset, not via
    # the same accessor that could hide a consistent index bug).
    assert_eq(load64(av1_warp_filter_tbl() + (((96 * 8) + 3) * 8)), 79, "warp raw[96][3]=79 (absolute)");
    assert_eq(av1_warp_filter_row(96) + (3 * 8), av1_warp_filter_tbl() + (((96 * 8) + 3) * 8),
    "warp_filter_row aligns with the accessor offset");
    return 0;
}
fn test_warp_filter_checksum() {
    # position-weighted checksum over all 1544 coeffs (tap order pinned) vs warp_filter_ref.py;
    # a single wrong coefficient changes it. The ref port asserts the dav1d MD5 that anchors it.
    var ck = 0;
    var i = 0;
    while (i < 193) {
        var k = 0;
        while (k < 8) {
            ck = ck + ((((i * 8) + k) + 1) * av1_warp_filter(i, k));
            k = k + 1;
        }
        i = i + 1;
    }
    assert_eq(ck, 19083838, "warp filter full position-weighted checksum (vs warp_filter_ref.py)");
    return 0;
}

fn main() {
    alloc_init();
    test_group("sub-pel filter table invariants (7.11.3.4)");
    test_subpel_invariants();
    test_group("sub-pel filter SET selection (7.11.3.4)");
    test_filter_set_selection();
    test_group("sub-pel filter position checksum");
    test_subpel_checksum();
    test_group("warp filter table (7.11.3.5) — invariants + anchors + digest");
    test_warp_filter_invariants();
    test_warp_filter_checksum();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
