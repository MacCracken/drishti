    assert_eq(av1_is_tx_type_in_set_inter(3, 1), 0, "inset[3][1]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 2), 0, "inset[3][2]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 3), 0, "inset[3][3]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 4), 0, "inset[3][4]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 5), 0, "inset[3][5]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 6), 0, "inset[3][6]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 7), 0, "inset[3][7]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 8), 0, "inset[3][8]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 9), 1, "inset[3][9]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 10), 0, "inset[3][10]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 11), 0, "inset[3][11]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 12), 0, "inset[3][12]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 13), 0, "inset[3][13]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 14), 0, "inset[3][14]");
    assert_eq(av1_is_tx_type_in_set_inter(3, 15), 0, "inset[3][15]");
    return 0;
}
# F4 (review): encode/decode chroma tx-type sync when the LUMA tx is all-zero.
# The plan carries a non-DCT luma type but eob0=0 (no transform_type symbol is
# written) -> the decoder derives DCT_DCT for the co-located chroma; the encoder
# must match. Chroma carries a real coeff so a desync shows in pixels.
# encode-only: return the tile payload buffer (out_len via ptr). Same setup as
# ir_roundtrip's encode half.
fn ir_enc_only(ref, fh, refs, seq, blk, nsplit, w, h, planes, sx, sy, mic, mir, out_len): i64 {
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var oe = alloc(8);
    var ef = dr_frame_new(w, h, planes, sx, sy, 8, 8, oe);
    var et = av1_tile_new(ef, mic, mir, 40, 1, 0, planes);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc((nsplit + 1) * 8);
    ir_plan(pp, nsplit);
    var pf = alloc(8);
    store64(pf + 0, blk);
    return av1_encode_inter_tile(et, pp, pf, 1, out_len);
}
fn ir_az_plan(luma_tt, cu, cv): i64 {
    var r = alloc(8 * 8);
    memset(r, 0, 8 * 8);
    store64(r + 0, luma_tt);
    store64(r + (1 * 8), 0);  store64(r + (2 * 8), 0);      # luma all_zero (eob 0)
    store64(r + (3 * 8), 2);  store64(r + (4 * 8), cu);     # chroma U: DC + AC (eob 2)
    store64(r + (5 * 8), 2);  store64(r + (6 * 8), cv);     # chroma V: DC + AC
    return r;
}
# F4 (review): when the LUMA tx is all-zero NO transform_type symbol is written, so
# the plan's luma tx type must be IGNORED for chroma co-location (the decoder derives
# DCT_DCT). Deterministic witness: encoding with a 1D-scan-class plan luma type
# (V_DCT — a DIFFERENT chroma scan) must produce BYTE-IDENTICAL output to encoding
# with DCT_DCT, because the effective luma type is DCT_DCT either way. Chroma carries
# an AC coeff so the scan (tx-class) actually matters. (Without the fix, V_DCT would
# scan the chroma coeffs differently -> different bytes -> the decoder, deriving
# DCT_DCT, would mis-read them: a write/read desync.)
fn test_ir_luma_allzero_chroma() {
    var ref = ir_ref(16, 16, 3, 1, 1);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(3, 1, 1);
    var cu = alloc(1024 * 8);
    memset(cu, 0, 1024 * 8);
    store64(cu + 0, 70);
    store64(cu + (1 * 8), 30);              # AC coeff -> scan class matters
    var cv = alloc(1024 * 8);
    memset(cv, 0, 1024 * 8);
    store64(cv + 0, 0 - 45);
    store64(cv + (1 * 8), 20);
    var lenV = 0;
    var tbV = ir_enc_only(ref, ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST), refs, seq,
    ir_blk(0 - 6, 10, ir_az_plan(AV1_V_DCT, cu, cv)), 2, 16, 16, 3, 1, 1, 4, 4, &lenV);
    var lenD = 0;
    var tbD = ir_enc_only(ref, ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST), refs, seq,
    ir_blk(0 - 6, 10, ir_az_plan(AV1_DCT_DCT, cu, cv)), 2, 16, 16, 3, 1, 1, 4, 4, &lenD);
    assert_eq(lenV > 0, 1, "luma-all-zero tile encoded");
    assert_eq(lenV, lenD, "luma all_zero: plan luma type ignored (same byte length)");
    var i = 0;
    var d = 0;
    while (i < lenV) {
        if (load8(tbV + i) != load8(tbD + i)) { d = d + 1; }
        i = i + 1;
    }
    assert_eq(d, 0, "luma all_zero: encode ignores the plan luma type (byte-identical)");
    # and the round-trip decodes cleanly (chroma tx type in sync).
    var df = ir_roundtrip(ref, ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST), refs, seq,
    ir_blk(0 - 6, 10, ir_az_plan(AV1_DCT_DCT, cu, cv)), 2, 16, 16, 3, 1, 1, 4, 4);
    assert_eq(df != 0, 1, "luma all_zero: decodes");
    return 0;
}
# F1 (review): a LOSSLESS (base_q 0) inter block records chroma LoopfilterTxSizes as
# TX_4X4 (0), not the uv max-rect — matching the intra path + spec 5.11.34.
fn test_ir_lossless_lftx() {
    var ref = ir_ref(16, 16, 3, 1, 1);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST);
    store64(fh + AV1FH_BASE_Q_IDX, 0);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(3, 1, 1);
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var oe = alloc(8);
    var ef = dr_frame_new(16, 16, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 4, 4, 0, 1, 0, 3);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(3 * 8);
    ir_plan(pp, 2);
    var pf = alloc(8);
    store64(pf + 0, ir_blk(16, 8, 0));    # zero residual (lossless WHT); the LFTX store is the point
    var tlen = 0;
    av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    # lossless forces TX_4X4 for EVERY plane; chroma LFTX must be 0, not TX_8X8.
    assert_eq(av1_lftx_get(et, 0, 0, 0), 0, "lossless luma LFTX = TX_4X4");
    assert_eq(av1_lftx_get(et, 1, 0, 0), 0, "lossless chroma LFTX = TX_4X4 (not uv max-rect)");
    return 0;
}
# F7 (review): reduced_tx_set routes a 16x16 inter block to INTER_3 (not INTER_2).
fn test_ir_reduced_tx() {
    var ref = ir_ref(16, 16, 1, 0, 0);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST);
    store64(fh + AV1FH_REDUCED_TX_SET, 1);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    var coeff = alloc(1024 * 8);
    memset(coeff, 0, 1024 * 8);
    store64(coeff + 0, 150);
    var resid = ir_resid1(AV1_IDTX, 1, coeff);   # IDTX is in INTER_3
    var blk = ir_blk(16, 8, resid);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 1, 0, 0, 4, 4);
    var xf = ir_oracle(ref, 16, 8, resid, 16, 16, 1, 0, 0, 6, 2, AV1_IDTX, 0);
    assert_eq(ir_diff(df, xf, 16, 16, 1, 0, 0), 0, "reduced_tx_set 16x16: INTER_3 IDTX round-trips");
    # the tile carries reduced_tx into the ttx: get_tx_set(TX_16X16, inter, reduced=1) = INTER_3.
    assert_eq(av1_get_tx_set(2, 1, 1), AV1_TX_SET_INTER_3, "reduced_tx: 16x16 -> INTER_3");
    assert_eq(av1_get_tx_set(2, 1, 0), AV1_TX_SET_INTER_2, "non-reduced: 16x16 -> INTER_2");
    return 0;
}
# F7 (review): RECTANGULAR (non-square) tx sizes route through the inter tx-set
# selection (via Tx_Size_Sqr / Tx_Size_Sqr_Up) and round-trip through the CDF path.
# the co-location PRECONDITION (0.7.85 review): every reachable block (<=64x64,
# sizes 0..12; the codebase is 64x64-SB only, sbMask=15) is exactly ONE luma tx
# under TX_MODE_LARGEST — so the single AV1TTC_LUMA_TXTYPE holds the whole block's
# luma tx type and chroma co-location is exact. (Sizes 13..15 are 128-superblock
# blocks, unreachable without use_128x128 which the decoder does not support.)
fn test_ir_one_luma_tx() {
    var b = 0;
    var multi = 0;
    while (b < 13) {
        var tx = av1_max_tx_size_rect(b);
        var stepx = av1_tx_width(tx) >> 2;
        var stepy = av1_tx_height(tx) >> 2;
        var nx = 0;
        var x = 0;
        while (x < av1_num_4x4_w(b)) { nx = nx + 1; x = x + stepx; }
        var ny = 0;
        var y = 0;
        while (y < av1_num_4x4_h(b)) { ny = ny + 1; y = y + stepy; }
        if ((nx * ny) > 1) { multi = multi + 1; }
        b = b + 1;
    }
    assert_eq(multi, 0, "every reachable block (<=64x64) is ONE luma tx (co-location precondition)");
    return 0;
}
fn test_ir_rect_txset() {
    var t168 = av1_max_tx_size_rect(5);        # BLOCK_16X8  -> TX_16X8
    var t816 = av1_max_tx_size_rect(4);        # BLOCK_8X16  -> TX_8X16
    var t1632 = av1_max_tx_size_rect(7);       # BLOCK_16X32 -> TX_16X32
    # TX_16X8/8X16: sqr=TX_8X8, sqr_up=TX_16X16 -> INTER_1 (16 sym).
    assert_eq(av1_get_tx_set(t168, 1, 0), AV1_TX_SET_INTER_1, "rect TX_16X8 -> INTER_1");
    assert_eq(av1_get_tx_set(t816, 1, 0), AV1_TX_SET_INTER_1, "rect TX_8X16 -> INTER_1");
    # TX_16X32: sqr_up=TX_32X32 -> INTER_3 (2 sym).
    assert_eq(av1_get_tx_set(t1632, 1, 0), AV1_TX_SET_INTER_3, "rect TX_16X32 -> INTER_3");
    # transform_type round-trips at each rect tx (exercises the CDF + inverse for rect).
    assert_eq(ir_tt_rt(t168, AV1_ADST_DCT, 16), AV1_ADST_DCT, "rt rect TX_16X8 ADST_DCT");
    assert_eq(ir_tt_rt(t816, AV1_H_FLIPADST, 16), AV1_H_FLIPADST, "rt rect TX_8X16 H_FLIPADST");
    assert_eq(ir_tt_rt(t1632, AV1_IDTX, 2), AV1_IDTX, "rt rect TX_16X32 IDTX (INTER_3)");
    return 0;
}

# ================================================================
# VAR-TX (0.7.86) foundations: the txfm_split ctx (spec 9.3) vs
# scripts/refs/var_tx_ref.py, and the txfm_partition CDF absolute-offset
# pins (21 ctx, 3-source verified) — closing the round-trip-circularity gap
# ([[cdf-blob-tests-must-pin-absolute-offsets]]) before the recursion is wired.
# ================================================================
# plant the above/left InterTxSizes neighbours of an INTERNAL cell (8,8) and return
# the txfm_split ctx. Internal (row!=mi_row, col!=mi_col) so get_above/left just read
# Tx_Width/Height[InterTxSizes[neighbour]] — a clean test of the ctx FORMULA.
fn vt_ctx(tile, tx_sz, mi_size, above_tx, left_tx): i64 {
    av1_grid_set(tile, AV1TILE_INTERTX, 7, 8, above_tx);   # above of (8,8)
    av1_grid_set(tile, AV1TILE_INTERTX, 8, 7, left_tx);    # left of (8,8)
    return av1_txfm_split_ctx(tile, 8, 8, tx_sz, mi_size, 0, 0, 1, 1);
}
fn vt_tile(): i64 {
    var oe = alloc(8);
    var f = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var t = av1_tile_new(f, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(t);
    return t;
}
fn test_vt_ctx() {
    var t = vt_tile();
    # against scripts/refs/var_tx_ref.py (spec 9.3). TxSize enum: TX_8X8=1, TX_16X16=2,
    # TX_32X32=3, TX_64X64=4. BLOCK_8X8=3, 16X16=6, 32X32=9, 64X64=12.
    assert_eq(vt_ctx(t, 2, 6, 2, 2), 12, "ctx: 16x16 tx, 16 block, eq neighbours");
    assert_eq(vt_ctx(t, 2, 6, 1, 2), 13, "ctx: above smaller (+1)");
    assert_eq(vt_ctx(t, 2, 6, 2, 1), 13, "ctx: left smaller (+1)");
    assert_eq(vt_ctx(t, 2, 6, 1, 1), 14, "ctx: both smaller (+2)");
    assert_eq(vt_ctx(t, 1, 6, 1, 1), 15, "ctx: 8x8 sub-split tx in 16 block (+3)");
    assert_eq(vt_ctx(t, 3, 9, 3, 3), 6, "ctx: 32x32 tx, 32 block");
    assert_eq(vt_ctx(t, 2, 9, 2, 2), 9, "ctx: 16x16 sub-split in 32 block (+3)");
    assert_eq(vt_ctx(t, 1, 3, 1, 1), 18, "ctx: 8x8 tx, 8 block (group 18..20)");
    assert_eq(vt_ctx(t, 4, 12, 4, 4), 0, "ctx: 64x64 tx, 64 block (group 0..5)");
    assert_eq(vt_ctx(t, 3, 12, 3, 3), 3, "ctx: 32x32 sub-split in 64 block (+3)");
    return 0;
}
# the TOP-EDGE branch: an unavailable above neighbour reports width 64.
fn test_vt_ctx_edge() {
    var t = vt_tile();
    # at the block origin (row==mi_row==0), avail_u=0 -> above width 64; a 16x16 tx
    # (width 16) < 64 is FALSE so above=0. left likewise unavailable -> 64, left=0.
    assert_eq(av1_txfm_split_ctx(t, 0, 0, 2, 6, 0, 0, 0, 0), 12, "edge: unavail neighbours -> above/left 0");
    return 0;
}
# the block-EDGE skip-inter neighbour branch of get_above/left (spec 9.3): a SKIPPED
# inter neighbour reports its BLOCK dim (width above / height left). Uses NON-SQUARE
# neighbour blocks so Block_Width != Block_Height — pins that get_above uses the WIDTH
# and get_left the HEIGHT (review: this branch was dead / block_width<->height survived).
fn test_vt_ctx_skip_neighbour() {
    var t = vt_tile();
    store64(t + AV1TILE_MVGRID, av1_mv_grid_new(16, 16));   # for the IsInter read
    # ABOVE: block at (4,4); its above neighbour (3,4) is a skip inter BLOCK_16X8
    # (width 16, height 8). get_above_tx_width -> Block_Width = 16.
    av1_grid_set(t, AV1TILE_SKIPS, 3, 4, 1);
    av1_grid_set(t, AV1TILE_MISIZES, 3, 4, 5);   # BLOCK_16X8
    store64(av1_mv_grid_cell(load64(t + AV1TILE_MVGRID), 16, 3, 4) + AV1MIR_ISINTER, 1);
    # above_txw = 16, tx TX_16X16 width 16 -> above=(16<16)=0. left unavail -> 0. ctx 12.
    assert_eq(av1_txfm_split_ctx(t, 4, 4, 2, 6, 4, 4, 1, 0), 12,
    "ctx: skip-inter above neighbour uses Block_Width (16X8 -> 16, above=0)");
    # LEFT: left neighbour (4,3) a skip inter BLOCK_8X16 (width 8, height 16).
    # get_left_tx_height -> Block_Height = 16 -> left=(16<16)=0. ctx 12.
    av1_grid_set(t, AV1TILE_SKIPS, 4, 3, 1);
    av1_grid_set(t, AV1TILE_MISIZES, 4, 3, 4);   # BLOCK_8X16
    store64(av1_mv_grid_cell(load64(t + AV1TILE_MVGRID), 16, 4, 3) + AV1MIR_ISINTER, 1);
    assert_eq(av1_txfm_split_ctx(t, 4, 4, 2, 6, 4, 4, 1, 1), 12,
    "ctx: skip-inter left neighbour uses Block_Height (8X16 -> 16, left=0)");
    # and a skip-inter neighbour SMALLER than the tx flips above/left to 1: an above
    # BLOCK_8X8 (width 8 < 16) -> above=1.
    av1_grid_set(t, AV1TILE_MISIZES, 3, 4, 3);   # BLOCK_8X8
    assert_eq(av1_txfm_split_ctx(t, 4, 4, 2, 6, 4, 4, 1, 0), 13,
    "ctx: skip-inter above 8x8 (width 8 < 16) -> above=1");
    return 0;
}
fn test_vt_cdf_pins() {
    var cc = av1_ncdf_new();
    assert_eq(load64(cc + (1693 * 8)), 28581, "txfm_split cdf@1693");
    assert_eq(load64(cc + (1696 * 8)), 23846, "txfm_split cdf@1696");
    assert_eq(load64(cc + (1699 * 8)), 20847, "txfm_split cdf@1699");
    assert_eq(load64(cc + (1702 * 8)), 24315, "txfm_split cdf@1702");
    assert_eq(load64(cc + (1705 * 8)), 18196, "txfm_split cdf@1705");
    assert_eq(load64(cc + (1708 * 8)), 12133, "txfm_split cdf@1708");
    assert_eq(load64(cc + (1711 * 8)), 18791, "txfm_split cdf@1711");
    assert_eq(load64(cc + (1714 * 8)), 10887, "txfm_split cdf@1714");
    assert_eq(load64(cc + (1717 * 8)), 11005, "txfm_split cdf@1717");
    assert_eq(load64(cc + (1720 * 8)), 27179, "txfm_split cdf@1720");
    assert_eq(load64(cc + (1723 * 8)), 20004, "txfm_split cdf@1723");
    assert_eq(load64(cc + (1726 * 8)), 11281, "txfm_split cdf@1726");
    assert_eq(load64(cc + (1729 * 8)), 26549, "txfm_split cdf@1729");
    assert_eq(load64(cc + (1732 * 8)), 19308, "txfm_split cdf@1732");
    assert_eq(load64(cc + (1735 * 8)), 14224, "txfm_split cdf@1735");
    assert_eq(load64(cc + (1738 * 8)), 28015, "txfm_split cdf@1738");
    assert_eq(load64(cc + (1741 * 8)), 21546, "txfm_split cdf@1741");
    assert_eq(load64(cc + (1744 * 8)), 14400, "txfm_split cdf@1744");
    assert_eq(load64(cc + (1747 * 8)), 28165, "txfm_split cdf@1747");
    assert_eq(load64(cc + (1750 * 8)), 22401, "txfm_split cdf@1750");
    assert_eq(load64(cc + (1753 * 8)), 16088, "txfm_split cdf@1753");
    assert_eq(load64(cc + (1694 * 8)), 32768, "txfm_split terminator");
    assert_eq(load64(cc + (1695 * 8)), 0, "txfm_split count");
    assert_eq(av1_ncdf_txfm_partition(cc, 0), cc + (1693 * 8), "txfm_partition(0) accessor");
    assert_eq(av1_ncdf_txfm_partition(cc, 20), cc + (1753 * 8), "txfm_partition(20) accessor");
    return 0;
}

# COMPOUND AVERAGE (0.7.87): a skip=1 two-reference block predicts from BOTH refs +
# averages. Round-trip (encode -> decode) with pixels EXHAUSTIVELY equal to the
# verified av1_mc_pred_compound oracle. skip=1 keeps it pure prediction (no residual).
fn it_blk_comp(mvr0, mvc0, mvr1, mvc1): i64 {
    var b = av1_blockinfo_new();
    store64(b + AV1FB_SKIP, 1);
    store64(b + AV1FB_ISINTER, 1);
    var ib = b + AV1FB_IB;
    store64(ib + AV1IB_ISCOMP, 1);
    store64(ib + AV1IB_REF0, AV1_LAST_FRAME);
    store64(ib + AV1IB_REF1, AV1_ALTREF_FRAME);
    store64(ib + AV1IB_YMODE, AV1_NEW_NEWMV);
    store64(ib + AV1IB_MV0 + AV1MV_ROW, mvr0);
    store64(ib + AV1IB_MV0 + AV1MV_COL, mvc0);
    store64(ib + AV1IB_MV1 + AV1MV_ROW, mvr1);
    store64(ib + AV1IB_MV1 + AV1MV_COL, mvc1);
    store64(ib + AV1IB_MOTIONMODE, AV1_MM_SIMPLE);
    store64(ib + AV1IB_INTERP + 0, AV1_EIGHTTAP);
    store64(ib + AV1IB_INTERP + 8, AV1_EIGHTTAP);
    store64(ib + AV1IB_CT + AV1CT_TYPE, AV1_COMPOUND_AVERAGE);
    store64(ib + AV1IB_CT + AV1CT_COMPIDX, 1);
    return b;
}
fn test_ir_compound() {
    var oe = alloc(8);
    var r0 = it_ref_frame();
    var r1 = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) { dr_frame_set(r1, 0, x, y, ((3 * x) + y) & 255); x = x + 1; }
        y = y + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_REFERENCE_SELECT, 1);
    store64(fh + AV1FH_REF_FRAME_IDX + (6 * 8), 6);
    var dpb = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 1);
    av1_dpb_store(dpb, fh, r0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 64);
    av1_dpb_store(dpb, fh, r1);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_H + (6 * 8), 64);
    var seq = it_seq();
    var blk = it_blk_comp(16, 8, 0 - 8, 24);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "compound tile encoded");
    assert_eq(av1_sym_enc_err(load64(et + AV1TILE_ENC)), DR_OK, "compound no enc err");
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "compound tile decodes");
    var xf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_compound(xf, r0, r1, 0, 0, 0, 64, 64, 16, 8, 0 - 8, 24, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "compound AVERAGE block: decode == av1_mc_pred_compound oracle (4096)");
    return 0;
}

# ADVERSARIAL (0.7.87): a compound block whose ALTREF ref resolves to an EMPTY DPB slot
# must be rejected with DR_ERR_BOUNDS (av1_intertile.cyr ref1frame==0 guard) — never an
# OOB read into a null frame. The bytes are a valid compound stream; only the decode-side
# DPB is starved (slot 6 never stored), mirroring a stream that names an unavailable ref.
fn test_ir_compound_missing_ref() {
    var oe = alloc(8);
    var r0 = it_ref_frame();
    var r1 = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) { dr_frame_set(r1, 0, x, y, ((3 * x) + y) & 255); x = x + 1; }
        y = y + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_REFERENCE_SELECT, 1);
    store64(fh + AV1FH_REF_FRAME_IDX + (6 * 8), 6);
    var dpb = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 1);
    av1_dpb_store(dpb, fh, r0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 64);
    av1_dpb_store(dpb, fh, r1);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_H + (6 * 8), 64);
    var seq = it_seq();
    var blk = it_blk_comp(16, 8, 0 - 8, 24);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "missing-ref: compound tile encoded");
    # decode with a STARVED DPB: only slot 0 populated, slot 6 (ALTREF) absent.
    var dpb2 = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 1);
    av1_dpb_store(dpb2, fh, r0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb2);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_ERR_BOUNDS,
    "missing-ref: compound with empty ALTREF slot -> BOUNDS (no OOB)");
    return 0;
}

# SCOPE-GATE REJECT (0.7.87, review-driven): only COMPOUND_AVERAGE (comp_group_idx==0 &&
# compound_idx==1) is in scope. A DISTANCE (compound_idx=0, needs enable_jnt_comp) or a
# DIFFWTD (comp_group_idx=1, needs enable_masked_compound) compound block must be REFUSED
# with DR_ERR_UNSUPPORTED on BOTH lanes — never silently mis-predicted as plain average.
# The encode tile writes the mode-info then latches the gate (discarding the tile), so we
# finish the symbol encoder BY HAND to mint the genuine non-AVERAGE stream and drive it
# straight into the decode gate. Covers both gate clauses: DISTANCE exercises compound_idx,
# DIFFWTD exercises comp_group_idx (mutating the gate || -> && lets one family through).
fn it_comp_gate_reject(en_masked, en_jnt, groupidx, compidx, ctype, tag): i64 {
    var oe = alloc(8);
    var r0 = it_ref_frame();
    var r1 = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) { dr_frame_set(r1, 0, x, y, ((3 * x) + y) & 255); x = x + 1; }
        y = y + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_REFERENCE_SELECT, 1);
    store64(fh + AV1FH_REF_FRAME_IDX + (6 * 8), 6);
    var dpb = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 1);
    av1_dpb_store(dpb, fh, r0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 64);
    av1_dpb_store(dpb, fh, r1);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_H + (6 * 8), 64);
    var seq = it_seq();
    store64(seq + AV1_SEQ_ENABLE_MASKED, en_masked);
    store64(seq + AV1_SEQ_ENABLE_JNT_COMP, en_jnt);
    var blk = it_blk_comp(16, 8, 0 - 8, 24);
    var ct = (blk + AV1FB_IB) + AV1IB_CT;
    store64(ct + AV1CT_GROUPIDX, groupidx);
    store64(ct + AV1CT_COMPIDX, compidx);
    store64(ct + AV1CT_TYPE, ctype);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(load64(et + AV1TILE_IERR), DR_ERR_UNSUPPORTED, "non-avg compound: encode gate refuses");
    assert_eq(tlen, 0, "non-avg compound: encode finalizes no tile");
    var blen = 0;
    var bb = av1_sym_enc_finish(load64(et + AV1TILE_ENC), &blen);
    assert_eq(blen > 0, 1, "non-avg compound: partial mode-info bytes present");
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, bb, blen, 1), DR_ERR_UNSUPPORTED, tag);
    return 0;
}
fn test_ir_compound_gates() {
    # DISTANCE: comp_group_idx=0, compound_idx=0 (enable_jnt_comp) -> the compound_idx clause.
    it_comp_gate_reject(0, 1, 0, 0, AV1_COMPOUND_DISTANCE,
    "decode gate: DISTANCE (compound_idx=0) refused, not mis-read as AVERAGE");
    # DIFFWTD: comp_group_idx=1 (enable_masked_compound) -> the comp_group_idx clause.
    it_comp_gate_reject(1, 0, 1, 1, AV1_COMPOUND_DIFFWTD,
    "decode gate: DIFFWTD (comp_group_idx=1) refused, not mis-read as AVERAGE");
    return 0;
}

