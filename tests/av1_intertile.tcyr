# tests/av1_intertile.tcyr — the INTER TILE DECODE (0.7.84): the milestone.
#
# A genuine inter frame decodes end-to-end: a gradient reference sits in the DPB,
# an all-skip 64x64 NEWMV block round-trips through the inter tile lane, and the
# decoded pixels are compared EXHAUSTIVELY against an INDEPENDENT motion-compensated
# prediction computed straight through the 0.7.60-verified MC driver — the decode
# path and the expectation share no code above av1_mc_pred_block itself.
include "src/main.cyr"

# the reference frame: value (x + 2*y) & 255 — a gradient distinct at every small
# shift, so a wrong MV, plane, reference, or filter shows immediately.
fn it_ref_frame(): i64 {
    var oe = alloc(8);
    var f = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            dr_frame_set(f, 0, x, y, (x + (2 * y)) & 255);
            x = x + 1;
        }
        y = y + 1;
    }
    return f;
}
# an INTER frame header record (FRAME_IS_INTRA stays 0): 64x64 mono, base_q 40,
# single tile, fixed EIGHTTAP (no interp symbols), skip_mode_present off,
# reference_select off (forced single), is_motion_mode_switchable off (SIMPLE
# forced, no motion-mode symbols), every ref_frame_idx -> slot 0.
fn it_fh(): i64 {
    var fh = alloc(AV1FH_SIZE);
    memset(fh, 0, AV1FH_SIZE);
    store64(fh + AV1FH_FRAME_WIDTH, 64);
    store64(fh + AV1FH_FRAME_HEIGHT, 64);
    store64(fh + AV1FH_UPSCALED_WIDTH, 64);
    store64(fh + AV1FH_MI_COLS, 16);
    store64(fh + AV1FH_MI_ROWS, 16);
    store64(fh + AV1FH_BASE_Q_IDX, 40);
    store64(fh + AV1FH_TX_MODE, AV1_TX_MODE_SELECT);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 1);
    store64(fh + AV1FH_ALLOW_HIGH_PREC_MV, 1);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    store64(fh + AV1FH_TILE_COLS, 1);
    store64(fh + AV1FH_TILE_ROWS, 1);
    store64(fh + AV1FH_TILE_SIZE_BYTES, 1);
    store64(fh + AV1FH_MI_COL_STARTS + 0, 0);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 16);
    store64(fh + AV1FH_MI_ROW_STARTS + 0, 0);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 16);
    return fh;
}
fn it_refs(): i64 {
    var refs = av1_ref_state_new();
    store64(refs + AV1REF_UPSCALED_W + 0, 64);
    store64(refs + AV1REF_FRAME_W + 0, 64);
    store64(refs + AV1REF_FRAME_H + 0, 64);
    return refs;
}
fn it_seq(): i64 {
    var s = alloc(AV1_SEQ_SIZE);
    memset(s, 0, AV1_SEQ_SIZE);
    store64(s + AV1_SEQ_BITDEPTH, 8);
    store64(s + AV1_SEQ_NUM_PLANES, 1);
    return s;
}
# the block source: an all-skip single-ref NEWMV block (the 0.7.84 scope).
fn it_blk(mvr, mvc): i64 {
    var b = av1_blockinfo_new();
    store64(b + AV1FB_SKIP, 1);
    store64(b + AV1FB_ISINTER, 1);
    var ib = b + AV1FB_IB;
    store64(ib + AV1IB_REF0, AV1_LAST_FRAME);
    store64(ib + AV1IB_REF1, AV1_REF_NONE);
    store64(ib + AV1IB_YMODE, AV1_NEWMV);
    store64(ib + AV1IB_MV0 + AV1MV_ROW, mvr);
    store64(ib + AV1IB_MV0 + AV1MV_COL, mvc);
    store64(ib + AV1IB_MOTIONMODE, AV1_MM_SIMPLE);
    store64(ib + AV1IB_INTERP + 0, AV1_EIGHTTAP);
    store64(ib + AV1IB_INTERP + 8, AV1_EIGHTTAP);
    store64(ib + AV1IB_CT + AV1CT_COMPIDX, 1);
    return b;
}
# encode one 64x64 all-skip inter SB (PARTITION_NONE) into a tile payload.
fn it_enc_tile(dpb, refs, seq, fh, blk, out_len): i64 {
    var oe = alloc(8);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    assert_eq(av1_tile_set_inter_ctx(et, fh, refs, seq, dpb), DR_OK, "encode tile inter ctx");
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, blk);
    return av1_encode_inter_tile(et, pp, pf, 1, out_len);
}
# THE MILESTONE: a genuine inter tile decodes to motion-compensated pixels.
fn test_inter_tile_e2e() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, ref);                 # the reference into every slot
    var refs = it_refs();
    var seq = it_seq();
    # MV (16, 8) 1/8-pel = 2 luma rows down, 1 col right — integer, so the MC is an
    # exact shift with edge clamping.
    var blk = it_blk(16, 8);
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, blk, &tlen);
    assert_eq(tlen > 0, 1, "encoded an inter tile payload");
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    assert_eq(av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb), DR_OK, "decode tile inter ctx");
    av1_grid_set(dt, AV1TILE_SKIPMODES, 4, 4, 7);    # the store-observability sentinel
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK,
    "THE MILESTONE: an inter tile decodes end-to-end");
    # the expectation, computed INDEPENDENTLY through the MC driver.
    var xf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    assert_eq(av1_mc_pred_block(xf, ref, 0, 0, 0, 64, 64, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP),
    DR_OK, "independent MC prediction");
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "decoded pixels == the independent MC prediction (all 4096)");
    # spot known answer: the MV points INTO the reference (7.11.3.3 adds it), so
    # out(x, y) = ref(x + 1, y + 2) — at (10, 10): 11 + 2*12 = 35.
    assert_eq(dr_frame_get(df, 0, 10, 10), ((10 + 1) + (2 * (10 + 2))) & 255,
    "spot KA: the shifted gradient");
    # far-edge clamp: out(63, 63) <- ref(64, 65), clamped to ref(63, 63) = 189.
    assert_eq(dr_frame_get(df, 0, 63, 63), (63 + (2 * 63)) & 255,
    "edge clamp: out-of-frame reference samples clamp to the edge");
    # the MI grid was populated (future blocks' scans read what this block stored).
    var cell = av1_mv_grid_cell(load64(dt + AV1TILE_MVGRID), 16, 4, 4);
    assert_eq(load64(cell + AV1MIR_REF0), AV1_LAST_FRAME, "MI grid: ref stored");
    assert_eq(load64(cell + AV1MIR_MV0ROW), 16, "MI grid: mv row stored");
    assert_eq(load64(cell + AV1MIR_AVAIL), 1, "MI grid: avail marked");
    # the SkipModes grid too (the 5.11.11 ctx source for later blocks) — SENTINEL:
    # sm = 0 is also the unwritten default, so plant 7 pre-decode; the store must
    # overwrite it (the grid is unread within the 0.7.84 scope; roadmap.md).
    assert_eq(av1_grid_get(dt, AV1TILE_SKIPMODES, 4, 4), 0, "SkipModes stored (0)");
    assert_eq(av1_grid_get(dt, AV1TILE_SKIPS, 4, 4), 1, "Skips stored (1)");
    # the LoopfilterTxSizes fill (the future inter deblock's tx source): max-rect.
    assert_eq(av1_lftx_get(dt, 0, 4, 4), av1_max_tx_size_rect(12), "LFTX stored (max rect)");
    return 0;
}
# a second MV + a second block value: quarter-pel motion exercises the 8-tap filter
# through the whole lane (the independent MC is the oracle).
fn test_inter_tile_subpel() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var blk = it_blk(0 - 6, 10);                 # (-0.75, +1.25) luma px: subpel taps
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, blk, &tlen);
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "subpel inter tile decodes");
    var xf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 64, 64, 0 - 6, 10, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "subpel decoded pixels == the independent 8-tap MC");
    return 0;
}
# the frame-level route (av1_frame_dec_group's inter branch) yields the same pixels;
# without a DPB the same frame is REJECTED, never silently garbage.
fn test_inter_frame_route() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var blk = it_blk(16, 8);
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, blk, &tlen);
    var oe = alloc(8);
    var out = av1_decode_frame_ref(seq, fh, dpb, refs, tb, tlen, oe);
    assert_eq(load64(oe), DR_OK, "frame-level inter decode ok");
    assert_eq(out != 0, 1, "frame returned");
    assert_eq(dr_frame_get(out, 0, 10, 10), ((10 + 1) + (2 * (10 + 2))) & 255,
    "frame-level pixels match the tile-level decode");
    var oe2 = alloc(8);
    assert_eq(av1_decode_frame_ref(seq, fh, 0, 0, tb, tlen, oe2), 0, "no DPB -> no frame");
    assert_eq(load64(oe2), DR_ERR_UNSUPPORTED, "no DPB -> UNSUPPORTED, never garbage");
    return 0;
}
# THE PRODUCER SAVE HOOK (0.7.102): a frame-level inter decode (through av1_frame_dec_finish) saves this
# frame's per-8x8 motion field into every DPB slot it refreshes, aliasing ONE buffer. A fresh refs has
# null saved-MF slots (pre-decode); after the decode all 8 slots (refresh_frame_flags 255) alias one
# non-null buffer. Nothing reads the field yet (0.7.102 producer) — this pins that the save FIRES + aliases.
fn test_tmvs_save_hook() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    assert_eq(av1_ref_saved_mf(refs, 0), 0, "tmvs hook: fresh refs slot is null (pre-decode)");
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk(16, 8), &tlen);
    var oe = alloc(8);
    var out = av1_decode_frame_ref(seq, fh, dpb, refs, tb, tlen, oe);
    assert_eq(load64(oe), DR_OK, "tmvs hook: inter frame decodes");
    assert_eq(out != 0, 1, "tmvs hook: frame returned");
    assert_eq(av1_ref_saved_mf(refs, 0) != 0, 1, "tmvs hook: the save FIRED (slot 0 non-null)");
    assert_eq(av1_ref_saved_mf(refs, 5), av1_ref_saved_mf(refs, 0),
    "tmvs hook: all refreshed slots ALIAS one buffer");
    return 0;
}

# ================================================================
# The BYTE-STREAM E2E: a real (non-still) sequence header + a KEY frame + an INTER
# frame, every field's bit packing commented, through av1_decode_stream. The intra
# encode lane is skip-only, so the in-stream keyframe is flat 128 — this layer
# therefore pins the HEADER PARSE -> refs/DPB threading -> routing (the MV-pixel
# strength lives in the gradient record-level tests above); a content-bearing
# stream E2E arrives with the non-skip encode lane (roadmap.md).
# ================================================================
fn its_append(bw, src, n): i64 {
    var i = 0;
    while (i < n) { dr_bw_put_bits(bw, load8(src + i), 8); i = i + 1; }
    return 0;
}
fn its_wrap(bw, type, payload, plen): i64 {
    av1_obu_write_header(bw, type, 0, 0, 0, 1, plen);
    if (plen > 0) { its_append(bw, payload, plen); }
    return 0;
}
# a NON-still sequence header: profile 0, 8-bit mono, 64x64 max, one operating
# point, every optional tool off. Field-for-field against av1_seq_parse.
fn its_build_seq(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bits(bw, 0, 3);        # seq_profile = 0                       f(3)
    dr_bw_put_bit(bw, 0);            # still_picture = 0                     f(1)
    dr_bw_put_bit(bw, 0);            # reduced_still_picture_header = 0      f(1)
    dr_bw_put_bit(bw, 0);            # timing_info_present_flag = 0          f(1)
    dr_bw_put_bit(bw, 0);            # initial_display_delay_present = 0     f(1)
    dr_bw_put_bits(bw, 0, 5);        # operating_points_cnt_minus_1 = 0      f(5)
    dr_bw_put_bits(bw, 0, 12);       # operating_point_idc[0] = 0            f(12)
    dr_bw_put_bits(bw, 0, 5);        # seq_level_idx[0] = 0 (<= 7: no tier)  f(5)
    dr_bw_put_bits(bw, 15, 4);       # frame_width_bits_minus_1 = 15         f(4)
    dr_bw_put_bits(bw, 15, 4);       # frame_height_bits_minus_1 = 15        f(4)
    dr_bw_put_bits(bw, 63, 16);      # max_frame_width_minus_1 = 63 -> 64    f(16)
    dr_bw_put_bits(bw, 63, 16);      # max_frame_height_minus_1 = 63 -> 64   f(16)
    dr_bw_put_bit(bw, 0);            # frame_id_numbers_present_flag = 0     f(1)
    dr_bw_put_bit(bw, 0);            # use_128x128_superblock = 0            f(1)
    dr_bw_put_bit(bw, 0);            # enable_filter_intra = 0               f(1)
    dr_bw_put_bit(bw, 0);            # enable_intra_edge_filter = 0          f(1)
    dr_bw_put_bit(bw, 0);            # enable_interintra_compound = 0        f(1)
    dr_bw_put_bit(bw, 0);            # enable_masked_compound = 0            f(1)
    dr_bw_put_bit(bw, 0);            # enable_warped_motion = 0              f(1)
    dr_bw_put_bit(bw, 0);            # enable_dual_filter = 0                f(1)
    dr_bw_put_bit(bw, 0);            # enable_order_hint = 0 (no jnt/refmvs) f(1)
    dr_bw_put_bit(bw, 0);            # seq_choose_screen_content_tools = 0   f(1)
    dr_bw_put_bit(bw, 0);            # seq_force_screen_content_tools = 0    f(1)
    dr_bw_put_bit(bw, 0);            # enable_superres = 0                   f(1)
    dr_bw_put_bit(bw, 0);            # enable_cdef = 0                       f(1)
    dr_bw_put_bit(bw, 0);            # enable_restoration = 0                f(1)
    dr_bw_put_bit(bw, 0);            # color_config: high_bitdepth = 0       f(1)
    dr_bw_put_bit(bw, 1);            # mono_chrome = 1                       f(1)
    dr_bw_put_bit(bw, 0);            # color_description_present_flag = 0    f(1)
    dr_bw_put_bit(bw, 0);            # color_range = 0                       f(1)
    dr_bw_put_bit(bw, 0);            # film_grain_params_present = 0         f(1)
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# the KEY frame header for that sequence (error_resilient implied 1, refresh
# implied 255, sizes from the sequence maxima).
fn its_build_key_fh(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bit(bw, 0);            # show_existing_frame = 0               f(1)
    dr_bw_put_bits(bw, 0, 2);        # frame_type = KEY                      f(2)
    dr_bw_put_bit(bw, 1);            # show_frame = 1 (KEY+show: err_res implied) f(1)
    dr_bw_put_bit(bw, 1);            # disable_cdf_update = 1                f(1)
    #                                  allow_sct: force_sct = 0 -> no bit
    dr_bw_put_bit(bw, 0);            # frame_size_override_flag = 0          f(1)
    #                                  order_hint: 0 bits; primary_ref: intra
    #                                  refresh: KEY+show -> implied 255
    #                                  frame_size: override 0 -> no bits
    dr_bw_put_bit(bw, 0);            # render_and_frame_size_different = 0   f(1)
    #                                  allow_intrabc: allow_sct 0 -> no bit
    #                                  disable_fe_update: implied (cdf off)
    dr_bw_put_bit(bw, 1);            # uniform_tile_spacing_flag = 1 (1 SB: no incr bits) f(1)
    dr_bw_put_bits(bw, 40, 8);       # base_q_idx = 40                       f(8)
    dr_bw_put_bit(bw, 0);            # DeltaQYDc delta_coded = 0             f(1)
    dr_bw_put_bit(bw, 0);            # using_qmatrix = 0                     f(1)
    dr_bw_put_bit(bw, 0);            # segmentation_enabled = 0              f(1)
    dr_bw_put_bit(bw, 0);            # delta_q_present = 0                   f(1)
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[0] = 0              f(6)
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[1] = 0              f(6)
    dr_bw_put_bits(bw, 0, 3);        # loop_filter_sharpness = 0             f(3)
    dr_bw_put_bit(bw, 0);            # loop_filter_delta_enabled = 0         f(1)
    #                                  cdef/lr: enables off -> no bits
    dr_bw_put_bit(bw, 1);            # tx_mode_select = 1 -> TX_MODE_SELECT  f(1)
    #                                  reference_mode/skip_mode/warp: intra -> none
    dr_bw_put_bit(bw, 0);            # reduced_tx_set = 0                    f(1)
    #                                  global motion: intra -> no bits
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# the INTER frame header: error_resilient 1 (primary_ref/use_ref_mvs/warp gated
# off), refresh 255, every ref_frame_idx = 0, fixed EIGHTTAP, base_q 40.
fn its_build_inter_fh(out_len): i64 {
    var bw = dr_bw_init(16);
    dr_bw_put_bit(bw, 0);            # show_existing_frame = 0               f(1)
    dr_bw_put_bits(bw, 1, 2);        # frame_type = INTER                    f(2)
    dr_bw_put_bit(bw, 1);            # show_frame = 1                        f(1)
    dr_bw_put_bit(bw, 1);            # error_resilient_mode = 1              f(1)
    dr_bw_put_bit(bw, 1);            # disable_cdf_update = 1                f(1)
    #                                  allow_sct/force_int: no bits (force_sct 0)
    dr_bw_put_bit(bw, 0);            # frame_size_override_flag = 0          f(1)
    #                                  order_hint 0 bits; primary_ref: err_res
    dr_bw_put_bits(bw, 255, 8);      # refresh_frame_flags = 255             f(8)
    #                                  ref_order_hint loop: order hints off
    #                                  short_signaling: order hints off -> no bit
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[0] = 0 (LAST -> slot 0) f(3)
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[1] = 0                  f(3)
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[2] = 0                  f(3)
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[3] = 0                  f(3)
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[4] = 0                  f(3)
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[5] = 0                  f(3)
    dr_bw_put_bits(bw, 0, 3);        # ref_frame_idx[6] = 0                  f(3)
    #                                  frame_size: override 0 -> no bits
    dr_bw_put_bit(bw, 0);            # render_and_frame_size_different = 0   f(1)
    dr_bw_put_bit(bw, 1);            # allow_high_precision_mv = 1           f(1)
    dr_bw_put_bit(bw, 0);            # is_filter_switchable = 0              f(1)
    dr_bw_put_bits(bw, 0, 2);        # interpolation_filter = EIGHTTAP       f(2)
    dr_bw_put_bit(bw, 0);            # is_motion_mode_switchable = 0         f(1)
    #                                  use_ref_frame_mvs: err_res -> no bit
    #                                  disable_fe_update: implied (cdf off)
    dr_bw_put_bit(bw, 1);            # uniform_tile_spacing_flag = 1         f(1)
    dr_bw_put_bits(bw, 40, 8);       # base_q_idx = 40                       f(8)
    dr_bw_put_bit(bw, 0);            # DeltaQYDc delta_coded = 0             f(1)
    dr_bw_put_bit(bw, 0);            # using_qmatrix = 0                     f(1)
    dr_bw_put_bit(bw, 0);            # segmentation_enabled = 0              f(1)
    dr_bw_put_bit(bw, 0);            # delta_q_present = 0                   f(1)
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[0] = 0              f(6)
    dr_bw_put_bits(bw, 0, 6);        # loop_filter_level[1] = 0              f(6)
    dr_bw_put_bits(bw, 0, 3);        # loop_filter_sharpness = 0             f(3)
    dr_bw_put_bit(bw, 0);            # loop_filter_delta_enabled = 0         f(1)
    dr_bw_put_bit(bw, 1);            # tx_mode_select = 1                    f(1)
    dr_bw_put_bit(bw, 0);            # reference_select = 0                  f(1)
    #                                  skip_mode: not allowed -> no bit
    #                                  allow_warped_motion: err_res -> no bit
    dr_bw_put_bit(bw, 0);            # reduced_tx_set = 0                    f(1)
    dr_bw_put_bit(bw, 0);            # is_global[LAST] = 0                   f(1)
    dr_bw_put_bit(bw, 0);            # is_global[LAST2] = 0                  f(1)
    dr_bw_put_bit(bw, 0);            # is_global[LAST3] = 0                  f(1)
    dr_bw_put_bit(bw, 0);            # is_global[GOLDEN] = 0                 f(1)
    dr_bw_put_bit(bw, 0);            # is_global[BWDREF] = 0                 f(1)
    dr_bw_put_bit(bw, 0);            # is_global[ALTREF2] = 0                f(1)
    dr_bw_put_bit(bw, 0);            # is_global[ALTREF] = 0                 f(1)
    store64(out_len, dr_bw_flush(bw));
    return dr_bw_buf(bw);
}
# the flat-128 KEY tile payload (skip DC, one 64x64 SB).
fn its_enc_key_tile(out_len): i64 {
    var mi = av1_modeinfo_new();
    store64(mi + AV1MI_SKIP, 1);
    store64(mi + AV1MI_YMODE, AV1_DC_PRED);
    store64(mi + AV1MI_UVMODE, AV1_DC_PRED);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pm = alloc(8);
    store64(pm + 0, mi);
    var pt = alloc(8);
    store64(pt + 0, av1_max_tx_size_rect(12));
    var oe = alloc(8);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 0, 0, 1);
    av1_tile_grids_new(et);
    return av1_encode_intra_tile(et, pp, pm, pt, 1, out_len);
}
# the inter header round-trips through the REAL parser: every field lands where the
# builder put it (this pins the builder AND the parse path symmetrically).
fn test_inter_header_parseback() {
    var slen = 0;
    var sb = its_build_seq(&slen);
    var se = alloc(8);
    var seq = av1_seq_parse(sb, slen, se);
    assert_eq(load64(se), DR_OK, "the non-still sequence header parses");
    assert_eq(av1_seq_num_planes(seq), 1, "seq: mono");
    assert_eq(av1_seq_enable_order_hint(seq), 0, "seq: order hints off");
    var flen = 0;
    var fb = its_build_inter_fh(&flen);
    var refs = av1_ref_state_new();
    var fe = alloc(8);
    var fh = av1_frame_parse_uncompressed_header(seq, refs, 0, 0, fb, flen, fe);
    assert_eq(load64(fe), DR_OK, "the INTER frame header parses");
    assert_eq(av1_fh_frame_type(fh), 1, "fh: INTER");
    assert_eq(av1_fh_frame_is_intra(fh), 0, "fh: not intra");
    assert_eq(av1_fh_frame_width(fh), 64, "fh: width 64");
    assert_eq(av1_fh_frame_height(fh), 64, "fh: height 64");
    assert_eq(av1_fh_refresh_frame_flags(fh), 255, "fh: refresh 255");
    assert_eq(av1_fh_ref_frame_idx(fh, 0), 0, "fh: LAST -> slot 0");
    assert_eq(av1_fh_allow_high_precision_mv(fh), 1, "fh: allow_hp");
    assert_eq(av1_fh_interpolation_filter(fh), 0, "fh: EIGHTTAP fixed");
    assert_eq(av1_fh_is_motion_mode_switchable(fh), 0, "fh: mm not switchable");
    assert_eq(av1_fh_skip_mode_present(fh), 0, "fh: skip_mode off");
    assert_eq(av1_fh_reference_select(fh), 0, "fh: single reference");
    assert_eq(av1_fh_base_q_idx(fh), 40, "fh: base_q 40");
    assert_eq(av1_fh_disable_cdf_update(fh), 1, "fh: cdf update off");
    assert_eq((av1_fh_bits_consumed(fh) + 7) >> 3, flen, "every built byte consumed");
    return 0;
}
# THE STREAM MILESTONE LAYER: TD + SEQ + KEY(fh+tile) + INTER(fh+tile) through
# av1_decode_stream — real parsed headers drive the inter tile lane.
fn test_inter_stream_e2e() {
    var slen = 0;
    var sb = its_build_seq(&slen);
    var kflen = 0;
    var kfb = its_build_key_fh(&kflen);
    var ktlen = 0;
    var ktb = its_enc_key_tile(&ktlen);
    assert_eq(ktlen > 0, 1, "key tile encoded");
    # the inter tile payload: the encode-side recs MATCH what the parser will
    # produce (allow_hp 1, fixed EIGHTTAP, skip_mode off, single ref, base_q 40).
    var dpb0 = av1_dpb_new();
    var ref0 = it_ref_frame();
    var fh0 = it_fh();
    av1_dpb_store(dpb0, fh0, ref0);
    var itlen = 0;
    var itb = it_enc_tile(dpb0, it_refs(), it_seq(), fh0, it_blk(16, 8), &itlen);
    assert_eq(itlen > 0, 1, "inter tile encoded");
    var iflen = 0;
    var ifb = its_build_inter_fh(&iflen);
    var bw = dr_bw_init(512);
    its_wrap(bw, AV1_OBU_TEMPORAL_DELIMITER, 0, 0);
    its_wrap(bw, AV1_OBU_SEQUENCE_HEADER, sb, slen);
    its_wrap(bw, AV1_OBU_FRAME_HEADER, kfb, kflen);
    its_wrap(bw, AV1_OBU_TILE_GROUP, ktb, ktlen);
    its_wrap(bw, AV1_OBU_FRAME_HEADER, ifb, iflen);
    its_wrap(bw, AV1_OBU_TILE_GROUP, itb, itlen);
    var n = dr_bw_flush(bw);
    var dpb = av1_dpb_new();
    var oc = alloc(8);
    var oe = alloc(8);
    var out = av1_decode_stream(dpb, dr_bw_buf(bw), n, oc, oe);
    assert_eq(load64(oe), DR_OK, "THE STREAM MILESTONE: key + INTER decode from bytes");
    assert_eq(load64(oc), 2, "two frames decoded");
    assert_eq(out != 0, 1, "the inter frame is the output");
    # the keyframe is flat 128 (skip-only intra lane), so the MC output is 128 —
    # this layer pins parse + threading + routing; pixels are pinned by the
    # gradient record-level tests above.
    assert_eq(dr_frame_get(out, 0, 20, 20), 128, "inter frame pixels (flat reference)");
    assert_eq(av1_dpb_count(dpb), 8, "the inter frame refreshed the DPB");
    assert_eq(av1_dpb_frame(dpb, 0), out, "DPB slot 0 = the inter frame");
    return 0;
}

# FOUR superblocks (128x128, 2x2) with DISTINCT MVs: pins the plane-coordinate
# wiring, the per-block scan-ctx reconfiguration, and BOTH neighbour-threading
# directions (SB4 reads SB2 above and SB3 left). KNOWN RESIDUAL: the skip-ctx
# THREADING itself (above/left_skip -> av1_skip_ctx) is mutation-resistant here —
# in an all-skip tile every candidate CDF row favors skip = 1, so a one-sided
# zeroing survives by value-luck; it becomes load-bearing (and killable) with
# mixed skip patterns when the non-skip inter residual lands (roadmap.md).
fn test_inter_tile_two_sb() {
    var oe = alloc(8);
    var ref = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var y0 = 0;
    while (y0 < 128) {
        var x0 = 0;
        while (x0 < 128) {
            dr_frame_set(ref, 0, x0, y0, (x0 + (2 * y0)) & 255);
            x0 = x0 + 1;
        }
        y0 = y0 + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_FRAME_HEIGHT, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_ROWS, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 32);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 0, 128);
    store64(refs + AV1REF_FRAME_W + 0, 128);
    store64(refs + AV1REF_FRAME_H + 0, 128);
    var seq = it_seq();
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var ef = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(32);
    var pf = alloc(32);
    var k = 0;
    while (k < 4) { store64(pp + (k * 8), AV1_PARTITION_NONE); k = k + 1; }
    store64(pf + 0, it_blk(16, 8));
    store64(pf + 8, it_blk(0 - 8, 24));
    store64(pf + 16, it_blk(8, 0 - 16));
    store64(pf + 24, it_blk(0 - 24, 0 - 8));
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "four-SB inter tile encoded");
    var df = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "four-SB inter tile decodes");
    var xf = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 64, 64, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(xf, ref, 0, 64, 0, 64, 64, 0 - 8, 24, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(xf, ref, 0, 0, 64, 64, 64, 8, 0 - 16, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(xf, ref, 0, 64, 64, 64, 64, 0 - 24, 0 - 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 128) {
        var x = 0;
        while (x < 128) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "all four SBs' pixels == the per-block MC oracle (16384 px)");
    # each SB's MI cells carry THEIR mv (per-block reconfiguration, all quadrants).
    var g2 = av1_mv_grid_cell(load64(dt + AV1TILE_MVGRID), 32, 4, 20);
    assert_eq(load64(g2 + AV1MIR_MV0COL), 24, "SB2's MI mv col");
    var g4 = av1_mv_grid_cell(load64(dt + AV1TILE_MVGRID), 32, 20, 20);
    assert_eq(load64(g4 + AV1MIR_MV0ROW), 0 - 24, "SB4's MI mv row");
    return 0;
}
# a LOCALWARP block record (mirrors it_blk but motion_mode = LOCALWARP).
fn it_blk_warp(mvr, mvc): i64 {
    var b = it_blk(mvr, mvc);
    store64((b + AV1FB_IB) + AV1IB_MOTIONMODE, AV1_MM_LOCALWARP);
    return b;
}
# THE WARP MILESTONE: a LOCALWARP inter block decodes to WARPED pixels end-to-end. 4 SBs
# (128x128): SB1-3 SIMPLE inter (populate the MI grid), SB4 (bottom-right) LOCALWARP — it finds
# SB2 (above) + SB3 (left) as warp samples, so the decode runs warp_estimation -> setup_shear ->
# av1_warp_pred_block. Verified against a DIRECT warp call on the post-decode samples (the
# complementary-oracle pattern: the math is pinned by the 0.7.93/94/97 Python refs; this proves
# the decode WIRING), plus a != translation check (proves warp actually fired, not the fallback).
fn test_inter_tile_localwarp() {
    var oe = alloc(8);
    var ref = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var y0 = 0;
    while (y0 < 128) {
        var x0 = 0;
        while (x0 < 128) {
            dr_frame_set(ref, 0, x0, y0, (x0 + (2 * y0)) & 255);
            x0 = x0 + 1;
        }
        y0 = y0 + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_FRAME_HEIGHT, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_ROWS, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 32);
    store64(fh + AV1FH_MOTION_MODE_SWITCHABLE, 1);   # allow the @@motion_mode read/write
    store64(fh + AV1FH_ALLOW_WARPED, 1);             # allow LOCALWARP
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 0, 128);
    store64(refs + AV1REF_FRAME_W + 0, 128);
    store64(refs + AV1REF_FRAME_H + 0, 128);
    var seq = it_seq();
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var ef = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(32);
    var pf = alloc(32);
    var k = 0;
    while (k < 4) {
        store64(pp + (k * 8), AV1_PARTITION_NONE);
        k = k + 1;
    }
    store64(pf + 0, it_blk(16, 8));
    store64(pf + 8, it_blk(0 - 8, 24));
    store64(pf + 16, it_blk(8, 0 - 16));
    store64(pf + 24, it_blk_warp(0, 0));           # SB4 LOCALWARP, Mv[0] = (0,0)
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "warp: 4-SB tile encoded (LOCALWARP SB4)");
    var df = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "warp: 4-SB tile decodes (SB4 warps)");
    # SB4's samples (the reusable tile ws holds the LAST decoded block's CandList) -> build the
    # model + warp-predict DIRECTLY on a fresh frame: the decode's SB4 must equal it (wiring proof).
    var ws = load64(dt + AV1TILE_WS);
    assert_eq(av1_warp_num(ws) > 0, 1, "warp: SB4 found >= 1 warp sample");
    var model = av1_warp_model_new();
    av1_warp_estimation(ws, 16, 16, 12, 0, 0, model);   # BLOCK_64X64=12, SB4 at MI (16,16), mv (0,0)
    assert_eq(av1_warp_model_valid(model), 1, "warp: SB4 estimation valid (det != 0)");
    av1_setup_shear(model);
    assert_eq(av1_warp_model_shear_valid(model), 1, "warp: SB4 shear realizable");
    var rf = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    assert_eq(av1_warp_pred_block(rf, ref, 0, 64, 64, 64, 64, model), DR_OK, "warp: reference predict");
    var diffw = 0;
    var yy = 64;
    while (yy < 128) {
        var xx = 64;
        while (xx < 128) {
            if (dr_frame_get(df, 0, xx, yy) != dr_frame_get(rf, 0, xx, yy)) { diffw = diffw + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(diffw, 0, "warp: SB4 decoded == the direct warp reference (4096 px)");
    # and SB4 is NOT a translation MC of its Mv[0]=(0,0) -> warp actually fired, not the fallback.
    var tf = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 0, 64, 64, 64, 64, 0, 0, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difft = 0;
    yy = 64;
    while (yy < 128) {
        var xx = 64;
        while (xx < 128) {
            if (dr_frame_get(df, 0, xx, yy) != dr_frame_get(tf, 0, xx, yy)) { difft = difft + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difft > 0, 1, "warp: SB4 != translation MC (warp actually happened)");
    # ---- the AV1WM_VALID guard is LOAD-BEARING: det==0 IS reachable. A LOCALWARP block whose
    # Mv[0] is >= 256 (1/8-pel) from every neighbour -> find_warp_samples force-keeps the sole
    # large-MV sample (NUM=1, the "no small MV found, return the first large one" case), which
    # then FAILS warp_estimation's per-axis LS_MV_MAX (256) inlier filter -> all accumulators 0 ->
    # det==0 -> AV1WM_VALID==0 -> the guard skips setup_shear -> TRANSLATION fallback. Dropping the
    # guard would warp with the identity default (shearValid on wmmat[2]=65536) = a wrong
    # zero-motion copy != the block-MV translation.
    store64(pf + 24, it_blk_warp(0, 300));       # far Mv: |300-24|,|300-(-16)| both >= 256
    var tlen2 = 0;
    var ef2 = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var et2 = av1_tile_new(ef2, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(et2);
    av1_tile_set_inter_ctx(et2, fh, refs, seq, dpb);
    var tb2 = av1_encode_inter_tile(et2, pp, pf, 1, &tlen2);
    assert_eq(tlen2 > 0, 1, "warp det==0: far-MV LOCALWARP tile encoded");
    var df2 = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var dt2 = av1_tile_new(df2, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(dt2);
    av1_tile_set_inter_ctx(dt2, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt2, tb2, tlen2, 1), DR_OK, "warp det==0: tile decodes");
    # the estimation IS invalid for these force-kept far samples (the reachability).
    var m2 = av1_warp_model_new();
    av1_warp_estimation(load64(dt2 + AV1TILE_WS), 16, 16, 12, 0, 300, m2);
    assert_eq(av1_warp_model_valid(m2), 0, "warp det==0: estimation invalid (all samples filtered)");
    # SB4 == translation MC of Mv[0]=(0,300), NOT an identity copy -> the guard held.
    var tf2 = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tf2, ref, 0, 64, 64, 64, 64, 0, 300, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difft2 = 0;
    var yy2 = 64;
    while (yy2 < 128) {
        var xx2 = 64;
        while (xx2 < 128) {
            if (dr_frame_get(df2, 0, xx2, yy2) != dr_frame_get(tf2, 0, xx2, yy2)) { difft2 = difft2 + 1; }
            xx2 = xx2 + 1;
        }
        yy2 = yy2 + 1;
    }
    assert_eq(difft2, 0, "warp det==0: SB4 falls back to translation MC (guard held, no identity copy)");
    return 0;
}
# CHROMA warp (4:2:0): the per-plane useWarp gate warps a plane iff its NOMINAL block is >= 8x8.
# A 64x64-luma LOCALWARP block -> 32x32 chroma (>= 8) -> chroma warps too. Asserts the decoded U
# plane's SB4 quadrant == a DIRECT chroma warp; witnesses the >>subx/>>suby chroma projection +
# the per-plane dispatch (a `plane == 0` gate that forced chroma to translation would go red).
fn test_inter_tile_localwarp_chroma() {
    var oe = alloc(8);
    var ref = dr_frame_new(128, 128, 3, 1, 1, 8, 8, oe);
    var p = 0;
    while (p < 3) {
        var pw = dr_frame_plane_width(ref, p);
        var ph = dr_frame_plane_height(ref, p);
        var yy = 0;
        while (yy < ph) {
            var xx = 0;
            while (xx < pw) {
                dr_frame_set(ref, p, xx, yy, ((xx + (2 * yy)) + (p * 13)) & 255);
                xx = xx + 1;
            }
            yy = yy + 1;
        }
        p = p + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_FRAME_HEIGHT, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_ROWS, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 32);
    store64(fh + AV1FH_MOTION_MODE_SWITCHABLE, 1);
    store64(fh + AV1FH_ALLOW_WARPED, 1);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 0, 128);
    store64(refs + AV1REF_FRAME_W + 0, 128);
    store64(refs + AV1REF_FRAME_H + 0, 128);
    var seq = it_seq();
    store64(seq + AV1_SEQ_NUM_PLANES, 3);
    store64(seq + AV1_SEQ_SUBX, 1);
    store64(seq + AV1_SEQ_SUBY, 1);
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var ef = dr_frame_new(128, 128, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 32, 32, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(32);
    var pf = alloc(32);
    var k = 0;
    while (k < 4) {
        store64(pp + (k * 8), AV1_PARTITION_NONE);
        k = k + 1;
    }
    store64(pf + 0, it_blk(16, 8));
    store64(pf + 8, it_blk(0 - 8, 24));
    store64(pf + 16, it_blk(8, 0 - 16));
    store64(pf + 24, it_blk_warp(0, 0));
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "warp chroma: 4:2:0 tile encoded");
    var df = dr_frame_new(128, 128, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 32, 32, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "warp chroma: 4:2:0 tile decodes");
    var model = av1_warp_model_new();
    av1_warp_estimation(load64(dt + AV1TILE_WS), 16, 16, 12, 0, 0, model);
    assert_eq(av1_warp_model_valid(model), 1, "warp chroma: SB4 estimation valid");
    av1_setup_shear(model);
    assert_eq(av1_warp_model_shear_valid(model), 1, "warp chroma: SB4 shear valid");
    # the U plane (plane 1) SB4 quadrant is 32x32 at chroma (32,32) -> WARPS. Direct reference:
    var rf = dr_frame_new(128, 128, 3, 1, 1, 8, 8, oe);
    assert_eq(av1_warp_pred_block(rf, ref, 1, 32, 32, 32, 32, model), DR_OK, "warp chroma: U reference");
    var difU = 0;
    var yy = 32;
    while (yy < 64) {
        var xx = 32;
        while (xx < 64) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(rf, 1, xx, yy)) { difU = difU + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difU, 0, "warp chroma: decoded U plane SB4 == direct chroma warp (1024 px)");
    # and the U plane warped (!= translation MC) -> the chroma dispatch chose warp, not fallback.
    var tf = dr_frame_new(128, 128, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 1, 32, 32, 32, 32, 0, 0, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difUt = 0;
    yy = 32;
    while (yy < 64) {
        var xx = 32;
        while (xx < 64) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(tf, 1, xx, yy)) { difUt = difUt + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difUt > 0, 1, "warp chroma: U plane warped, != translation");
    return 0;
}
# a 4:2:0 inter ctx for a W x H frame: a per-plane gradient ref in the DPB, warp +
# switchable-motion-mode enabled. Fills fh/refs/seq and stores the ref; returns the ref
# frame. (Shared by the three nested-SPLIT warp-gate witnesses below.)
fn itw_ctx420(w, h, mic, mir, fh, refs, seq, dpb): i64 {
    var oe = alloc(8);
    var ref = dr_frame_new(w, h, 3, 1, 1, 8, 8, oe);
    var p = 0;
    while (p < 3) {
        var pw = dr_frame_plane_width(ref, p);
        var ph = dr_frame_plane_height(ref, p);
        var yy = 0;
        while (yy < ph) {
            var xx = 0;
            while (xx < pw) {
                dr_frame_set(ref, p, xx, yy, ((xx + (2 * yy)) + (p * 13)) & 255);
                xx = xx + 1;
            }
            yy = yy + 1;
        }
        p = p + 1;
    }
    store64(fh + AV1FH_FRAME_WIDTH, w);
    store64(fh + AV1FH_FRAME_HEIGHT, h);
    store64(fh + AV1FH_UPSCALED_WIDTH, w);
    store64(fh + AV1FH_MI_COLS, mic);
    store64(fh + AV1FH_MI_ROWS, mir);
    store64(fh + AV1FH_MI_COL_STARTS + 8, mic);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, mir);
    store64(fh + AV1FH_MOTION_MODE_SWITCHABLE, 1);
    store64(fh + AV1FH_ALLOW_WARPED, 1);
    store64(refs + AV1REF_UPSCALED_W + 0, w);
    store64(refs + AV1REF_FRAME_W + 0, w);
    store64(refs + AV1REF_FRAME_H + 0, h);
    store64(seq + AV1_SEQ_NUM_PLANES, 3);
    store64(seq + AV1_SEQ_SUBX, 1);
    store64(seq + AV1_SEQ_SUBY, 1);
    av1_dpb_store(dpb, fh, ref);
    return ref;
}
# WITNESS (0.7.99): the per-plane useWarp gate at the CHROMA nw==8 BOUNDARY. A 16x16-luma
# LOCALWARP block (4:2:0) -> 8x8 chroma -> nominal chroma nw == 8 EXACTLY -> chroma WARPS.
# Placed by a nested SPLIT (64 forced-split -> 32 SPLIT -> 4x 16x16) so the BR 16x16 at pixel
# (16,16) finds its TR (above) + BL (left) 16x16 siblings as warp samples. Kills the 0.7.98
# review's F2b survivor: `nw = (bw4*4) >> sx` mutated to `>> (sx+1)` makes chroma nw = 16>>2 = 4
# < 8, gating the chroma to TRANSLATION -> "decoded U == direct chroma warp" goes red.
fn test_inter_tile_localwarp_chroma8() {
    var oe = alloc(8);
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    var dpb = av1_dpb_new();
    var ref = itw_ctx420(32, 32, 8, 8, fh, refs, seq, dpb);
    var pp = alloc(48);
    store64(pp + 0, AV1_PARTITION_SPLIT);     # 64 SB (forced: frame < 64)
    store64(pp + 8, AV1_PARTITION_SPLIT);     # 32 TL (the only in-frame 32-quad)
    store64(pp + 16, AV1_PARTITION_NONE);     # 16 (0,0)
    store64(pp + 24, AV1_PARTITION_NONE);     # 16 (0,4)
    store64(pp + 32, AV1_PARTITION_NONE);     # 16 (4,0)
    store64(pp + 40, AV1_PARTITION_NONE);     # 16 (4,4) -> LOCALWARP
    # neighbour MVs keep |mv| within the warp-sample threshold (16 for a <=16x16 block,
    # av1_mv.cyr add_sample) so both are VALID samples -> a genuine num==2 affine model
    # (not the force-kept single-sample degenerate case).
    var pf = alloc(32);
    store64(pf + 0, it_blk(16, 8));            # 16(0,0) TL (not a BR neighbour)
    store64(pf + 8, it_blk(0, 16));            # 16(0,4) TR = BR's ABOVE sample
    store64(pf + 16, it_blk(16, 0));           # 16(4,0) BL = BR's LEFT sample
    store64(pf + 24, it_blk_warp(0, 0));       # 16(4,4) BR LOCALWARP, Mv (0,0)
    var ef = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "chroma8: 16x16-warp 4:2:0 tile encoded");
    var df = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "chroma8: tile decodes");
    # rebuild the model from the warp block's samples (BLOCK_16X16 = 6, mi (4,4), Mv (0,0)).
    var ws = load64(dt + AV1TILE_WS);
    assert_eq(av1_warp_num(ws) > 0, 1, "chroma8: warp block found >= 1 sample");
    var model = av1_warp_model_new();
    av1_warp_estimation(ws, 4, 4, 6, 0, 0, model);
    assert_eq(av1_warp_model_valid(model), 1, "chroma8: estimation valid (det != 0)");
    av1_setup_shear(model);
    assert_eq(av1_warp_model_shear_valid(model), 1, "chroma8: shear realizable");
    # U plane: 8x8 chroma at (8,8) -> nominal nw == 8 -> WARPS. Direct chroma warp reference:
    var rf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    assert_eq(av1_warp_pred_block(rf, ref, 1, 8, 8, 8, 8, model), DR_OK, "chroma8: U reference warp");
    var difU = 0;
    var yy = 8;
    while (yy < 16) {
        var xx = 8;
        while (xx < 16) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(rf, 1, xx, yy)) { difU = difU + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difU, 0, "chroma8: decoded U == direct chroma warp (nw==8 boundary WARPS)");
    # and != translation -> chroma really warped (kills >>(sx+1) / `> 8` gate mutations).
    var tf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 1, 8, 8, 8, 8, 0, 0, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difUt = 0;
    yy = 8;
    while (yy < 16) {
        var xx = 8;
        while (xx < 16) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(tf, 1, xx, yy)) { difUt = difUt + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difUt > 0, 1, "chroma8: U warped, != translation");
    return 0;
}
# WITNESS (0.7.99): the per-plane useWarp gate FALLBACK below the chroma boundary. An 8x8-luma
# LOCALWARP block (4:2:0) -> 4x4 chroma -> nominal chroma nw == 4 < 8 -> chroma TRANSLATES while
# luma (nw == 8) WARPS. Nested SPLIT to an 8x8 at pixel (24,24) whose 8x8 siblings are its warp
# samples. Kills the OTHER side of the gate: dropping `&& (nw >= 8)` (or `nw >= 4`) WARPS the 4x4
# chroma -> "decoded U == chroma TRANSLATION" goes red; the luma-warp assert proves the model is
# genuinely valid (so the chroma fallback is the gate, not a globally-invalid model).
fn test_inter_tile_localwarp_chroma4() {
    var oe = alloc(8);
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    var dpb = av1_dpb_new();
    var ref = itw_ctx420(32, 32, 8, 8, fh, refs, seq, dpb);
    var pp = alloc(80);
    store64(pp + 0, AV1_PARTITION_SPLIT);     # 64
    store64(pp + 8, AV1_PARTITION_SPLIT);     # 32 TL
    store64(pp + 16, AV1_PARTITION_NONE);     # 16 (0,0)
    store64(pp + 24, AV1_PARTITION_NONE);     # 16 (0,4)
    store64(pp + 32, AV1_PARTITION_NONE);     # 16 (4,0)
    store64(pp + 40, AV1_PARTITION_SPLIT);    # 16 (4,4) -> split to 8x8
    store64(pp + 48, AV1_PARTITION_NONE);     # 8 (4,4)
    store64(pp + 56, AV1_PARTITION_NONE);     # 8 (4,6)
    store64(pp + 64, AV1_PARTITION_NONE);     # 8 (6,4)
    store64(pp + 72, AV1_PARTITION_NONE);     # 8 (6,6) -> LOCALWARP
    # small neighbour MVs (|mv| <= the 16-threshold) so all three of the warp block's
    # samples (above 8(4,6), left 8(6,4), top-left 8(4,4)) are VALID -> num==3 -> a genuine,
    # shear-realizable 8x8 affine (a degenerate model would fail setup_shear -> both planes
    # translate and the luma-warp assert below would go red).
    var pf = alloc(56);
    store64(pf + 0, it_blk(16, 8));            # 16(0,0)
    store64(pf + 8, it_blk(0 - 8, 24));        # 16(0,4)
    store64(pf + 16, it_blk(8, 0 - 16));       # 16(4,0)
    store64(pf + 24, it_blk(0, 0));            # 8(4,4) = warp's TOP-LEFT sample
    store64(pf + 32, it_blk(8, 8));            # 8(4,6) = warp's ABOVE sample
    store64(pf + 40, it_blk(0 - 8, 8));        # 8(6,4) = warp's LEFT sample
    store64(pf + 48, it_blk_warp(0, 0));       # 8(6,6) LOCALWARP, Mv (0,0)
    var ef = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "chroma4: 8x8-warp 4:2:0 tile encoded");
    var df = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "chroma4: tile decodes");
    var ws = load64(dt + AV1TILE_WS);
    assert_eq(av1_warp_num(ws) > 0, 1, "chroma4: warp block found >= 1 sample");
    var model = av1_warp_model_new();
    av1_warp_estimation(ws, 6, 6, 3, 0, 0, model);            # BLOCK_8X8 = 3, mi (6,6)
    assert_eq(av1_warp_model_valid(model), 1, "chroma4: estimation valid (det != 0)");
    av1_setup_shear(model);
    assert_eq(av1_warp_model_shear_valid(model), 1, "chroma4: shear realizable");
    # LUMA: 8x8 at (24,24), nominal nw == 8 -> WARPS. decoded Y == direct luma warp.
    var rf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    assert_eq(av1_warp_pred_block(rf, ref, 0, 24, 24, 8, 8, model), DR_OK, "chroma4: Y reference warp");
    var difY = 0;
    var yy = 24;
    while (yy < 32) {
        var xx = 24;
        while (xx < 32) {
            if (dr_frame_get(df, 0, xx, yy) != dr_frame_get(rf, 0, xx, yy)) { difY = difY + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difY, 0, "chroma4: decoded Y == direct luma warp (nw==8 WARPS)");
    # CHROMA U: 4x4 at (12,12), nominal nw == 4 < 8 -> TRANSLATES. decoded U == translation MC.
    var tf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 1, 12, 12, 4, 4, 0, 0, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difU = 0;
    yy = 12;
    while (yy < 16) {
        var xx = 12;
        while (xx < 16) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(tf, 1, xx, yy)) { difU = difU + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difU, 0, "chroma4: decoded U == translation MC (nw==4 FALLS BACK, not warp)");
    return 0;
}
# WITNESS (0.7.99): the useWarp gate keys off the NOMINAL block, not the edge-CLAMPED w/h. A
# 16x16-luma LOCALWARP block at pixel (16,16) in a 32x28 frame overhangs the bottom -> visible
# 12 luma rows -> 6 chroma rows. Nominal chroma nh = 8 (>= 8 -> WARPS the visible strip); a gate
# on the CLAMPED chroma h (= 6 < 8) would TRANSLATE. Same nested SPLIT + neighbour MVs as
# chroma8 (identical model); only the frame height changes -> the clamp binds.
fn test_inter_tile_localwarp_edge_chroma() {
    var oe = alloc(8);
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    var dpb = av1_dpb_new();
    var ref = itw_ctx420(32, 28, 8, 7, fh, refs, seq, dpb);    # 28 tall (mir=7): bottom cut
    var pp = alloc(48);
    store64(pp + 0, AV1_PARTITION_SPLIT);     # 64
    store64(pp + 8, AV1_PARTITION_SPLIT);     # 32 TL
    store64(pp + 16, AV1_PARTITION_NONE);     # 16 (0,0)
    store64(pp + 24, AV1_PARTITION_NONE);     # 16 (0,4) = BR's ABOVE (fully in frame)
    store64(pp + 32, AV1_PARTITION_NONE);     # 16 (4,0) = BR's LEFT (also bottom-cut)
    store64(pp + 40, AV1_PARTITION_NONE);     # 16 (4,4) -> LOCALWARP (bottom-cut)
    var pf = alloc(32);
    store64(pf + 0, it_blk(16, 8));
    store64(pf + 8, it_blk(0, 16));            # above sample (same MVs as chroma8)
    store64(pf + 16, it_blk(16, 0));           # left sample
    store64(pf + 24, it_blk_warp(0, 0));
    var ef = dr_frame_new(32, 28, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "edge chroma: 32x28 4:2:0 tile encoded");
    var df = dr_frame_new(32, 28, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "edge chroma: tile decodes");
    var ws = load64(dt + AV1TILE_WS);
    var model = av1_warp_model_new();
    av1_warp_estimation(ws, 4, 4, 6, 0, 0, model);
    assert_eq(av1_warp_model_valid(model), 1, "edge chroma: estimation valid");
    av1_setup_shear(model);
    assert_eq(av1_warp_model_shear_valid(model), 1, "edge chroma: shear realizable");
    # U plane: nominal 8x8 chroma at (8,8) CLAMPED to 8x6 (chroma plane is 16x14) -> WARPS the
    # visible strip. Direct reference warps the SAME 8x6 clamped extent (warp_pred_block crops).
    var rf = dr_frame_new(32, 28, 3, 1, 1, 8, 8, oe);
    assert_eq(av1_warp_pred_block(rf, ref, 1, 8, 8, 8, 6, model), DR_OK, "edge chroma: U reference warp");
    var difU = 0;
    var yy = 8;
    while (yy < 14) {
        var xx = 8;
        while (xx < 16) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(rf, 1, xx, yy)) { difU = difU + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difU, 0, "edge chroma: decoded U == direct clamped chroma warp (gate uses NOMINAL nh)");
    # and != translation of the same clamped strip -> the nominal gate WARPED, not the clamped gate.
    var tf = dr_frame_new(32, 28, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 1, 8, 8, 8, 6, 0, 0, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difUt = 0;
    yy = 8;
    while (yy < 14) {
        var xx = 8;
        while (xx < 16) {
            if (dr_frame_get(df, 1, xx, yy) != dr_frame_get(tf, 1, xx, yy)) { difUt = difUt + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(difUt > 0, 1, "edge chroma: U warped (clamped-h gate would translate)");
    return 0;
}
# set the frame's global-motion model for LAST_FRAME (ref slot 1): GmType + gm_params[0..5]
# (the six are the warp matrix wmmat[0..5] at 1<<16 precision — [0/1]=x/y translation, [2..5]=2x2).
fn it_fh_set_gm(fh, gtype, w0, w1, w2, w3, w4, w5) {
    store64(fh + AV1FH_GM_TYPE + ((AV1_LAST_FRAME - 1) * 8), gtype);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_LAST_FRAME - 1) * 6 + 0) * 8), w0);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_LAST_FRAME - 1) * 6 + 1) * 8), w1);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_LAST_FRAME - 1) * 6 + 2) * 8), w2);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_LAST_FRAME - 1) * 6 + 3) * 8), w3);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_LAST_FRAME - 1) * 6 + 4) * 8), w4);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_LAST_FRAME - 1) * 6 + 5) * 8), w5);
    return 0;
}
# a single-ref GLOBALMV block record (ymode=GLOBALMV). Mv[0] is DERIVED from gm_params by both
# encode + decode (assign_mv → GlobalMvs), so the record's MV0 is ignored (left 0).
fn it_blk_global(): i64 {
    var b = av1_blockinfo_new();
    store64(b + AV1FB_SKIP, 1);
    store64(b + AV1FB_ISINTER, 1);
    var ib = b + AV1FB_IB;
    store64(ib + AV1IB_REF0, AV1_LAST_FRAME);
    store64(ib + AV1IB_REF1, AV1_REF_NONE);
    store64(ib + AV1IB_YMODE, AV1_GLOBALMV);
    store64(ib + AV1IB_MOTIONMODE, AV1_MM_SIMPLE);
    store64(ib + AV1IB_INTERP + 0, AV1_EIGHTTAP);
    store64(ib + AV1IB_INTERP + 8, AV1_EIGHTTAP);
    store64(ib + AV1IB_CT + AV1CT_COMPIDX, 1);
    return b;
}
# GLOBALWARP UNIT (0.7.100): av1_warp_model_from_global copies gm_params[ref][0..5] into the model's
# wmmat, sets AV1WM_VALID=1, and runs setup_shear. Pins the copy + the valid flag directly.
fn test_globalwarp_model_build() {
    var fh = it_fh();
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 111, 222, 67584, 1024, 0 - 1024, 67584);
    var m = av1_warp_model_new();
    assert_eq(av1_warp_model_from_global(m, fh, AV1_LAST_FRAME), DR_OK, "gm model: built");
    assert_eq(av1_warp_model_valid(m), 1, "gm model: VALID forced to 1 (no estimation det)");
    assert_eq(av1_warp_model_param(m, 0), 111, "gm model: wmmat[0] = gm_param[0]");
    assert_eq(av1_warp_model_param(m, 1), 222, "gm model: wmmat[1] = gm_param[1]");
    assert_eq(av1_warp_model_param(m, 2), 67584, "gm model: wmmat[2] = gm_param[2]");
    assert_eq(av1_warp_model_param(m, 3), 1024, "gm model: wmmat[3] = gm_param[3] (off-diagonal)");
    assert_eq(av1_warp_model_param(m, 4), 0 - 1024, "gm model: wmmat[4] = gm_param[4] (off-diagonal)");
    assert_eq(av1_warp_model_param(m, 5), 67584, "gm model: wmmat[5] = gm_param[5]");
    assert_eq(av1_warp_model_shear_valid(m), 1, "gm model: gentle rotzoom is shear-realizable");
    return 0;
}
# THE GLOBALWARP MILESTONE (0.7.100): a single-ref GLOBALMV block whose reference carries a ROTZOOM
# global-motion model decodes to GLOBALLY-WARPED pixels (spec 7.11.3.1 useWarp==2). The inter tile
# decode builds the model straight from gm_params (av1_warp_model_from_global → setup_shear) and warps
# each plane. Verified vs a DIRECT warp on a model from the same gm_params (complementary oracle: the
# math is pinned by the 0.7.94/97 refs; this proves the WIRING) AND != the global-MV translation (proves
# the global warp fired, not the useWarp==0 fallback).
fn test_inter_tile_globalwarp() {
    var ref = it_ref_frame();                        # 64x64 gradient (x + 2y)
    var dpb = av1_dpb_new();
    var fh = it_fh();
    # a gentle ROTZOOM: zoom (wmmat[2]=one+2048) + rotation (wmmat[3]=1024), zero translation. one=65536.
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk_global(), &tlen);
    assert_eq(tlen > 0, 1, "globalwarp: GLOBALMV rotzoom tile encoded");
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "globalwarp: tile decodes");
    # direct oracle: build the SAME global model + warp-predict the 64x64 block.
    var model = av1_warp_model_new();
    assert_eq(av1_warp_model_from_global(model, fh, AV1_LAST_FRAME), DR_OK, "globalwarp: model built");
    assert_eq(av1_warp_model_shear_valid(model), 1, "globalwarp: global model shear-realizable");
    var rf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    assert_eq(av1_warp_pred_block(rf, ref, 0, 0, 0, 64, 64, model), DR_OK, "globalwarp: direct warp");
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(rf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "globalwarp: decoded == direct global warp (gm_params) (4096 px)");
    # != translation of the GLOBAL MV (the useWarp==0 fallback) -> the global warp actually fired.
    var gmv = alloc(16);
    av1_setup_global_mv(gmv, fh, AV1_LAST_FRAME, 0, 0, 12);       # BLOCK_64X64=12, block at (0,0)
    var tf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 0, 0, 0, 64, 64, av1_mv_row(gmv), av1_mv_col(gmv),
    AV1_EIGHTTAP, AV1_EIGHTTAP);
    var difft = 0;
    y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(tf, 0, x, y)) { difft = difft + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(difft > 0, 1, "globalwarp: != global-MV translation (warp fired, not the fallback)");
    return 0;
}
# ================================================================
# THE is_scaled GATES ON GLOBALWARP (0.7.111) — spec 7.11.3.1 step 7 lists
# `is_scaled( refFrame ) is equal to 0` among the conditions for useWarp == 2.
#
# These three gates were OUTCOME-NEUTRAL until 0.7.110: a scaled reference was rejected by
# the MC layer whatever the warp gate decided, so deleting the conjunct changed nothing
# observable. Now that scaled references decode, the gate is LOAD-BEARING — dropping it makes
# the block build a global warp model and call av1_warp_pred_gen on a scaled reference, which
# still (correctly) refuses, latching DR_ERR_UNSUPPORTED where pixels were expected. All three
# were confirmed to SURVIVE mutation before these tests were written.
#
# This is the GLOBALWARP half only. LOCALWARP is unreachable with a scaled reference by a
# DIFFERENT mechanism — read_motion_mode (5.11.27) refuses to code the motion_mode symbol at
# all — which is a symbol-schedule property, witnessed with the 0xA5 marker idiom in
# tests/av1_intermode.tcyr ("K scaled ref -> @@use_obmc" and its decode-side conformance
# twin). Two distinct rules, two distinct witnesses; do not conflate them.
# ================================================================

# a 32x32 reference — HALF the 64x64 current frame, so is_scaled is true on both axes.
# NON-LINEAR fill: every AV1 sub-pel filter reproduces a linear ramp exactly, so the
# gradient it_ref_frame uses cannot distinguish one prediction from another.
fn it_ref_frame_scaled(): i64 {
    var oe = alloc(8);
    var f = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < 32) {
        var x = 0;
        while (x < 32) {
            dr_frame_set(f, 0, x, y, (((x * 37) + (y * 53)) + (((x * y) % 7) * 29)) & 255);
            x = x + 1;
        }
        y = y + 1;
    }
    return f;
}

# compare the decoded frame against an oracle frame over the whole 64x64 plane.
fn it_gws_diff(a, b): i64 {
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(a, 0, x, y) != dr_frame_get(b, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    return diff;
}

# GATE 1 (single-ref): a GLOBALMV block whose reference carries a would-warp ROTZOOM model but
# is SCALED must NOT warp — it falls back to translating by its global MV, which since 0.7.110
# produces pixels through the scaled convolve rather than an error.
fn test_inter_tile_globalwarp_scaled() {
    var oe = alloc(8);
    var ref = it_ref_frame_scaled();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    # The METADATA is what av1_is_scaled reads (the DPB pixels are what MC reads) — set both.
    store64(refs + AV1REF_UPSCALED_W + 0, 32);
    store64(refs + AV1REF_FRAME_W + 0, 32);
    store64(refs + AV1REF_FRAME_H + 0, 32);
    assert_eq(av1_is_scaled(fh, refs, AV1_LAST_FRAME), 1, "gw-scaled: the reference IS scaled");
    var seq = it_seq();
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk_global(), &tlen);
    assert_eq(tlen > 0, 1, "gw-scaled: tile encoded");
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    # THE WITNESS: dropping the is_scaled conjunct makes this latch DR_ERR_UNSUPPORTED.
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK,
    "gw-scaled: decodes (no warp attempted on a scaled ref)");
    # ...and the pixels are the global-MV translation through the SCALED MC path.
    var gmv = alloc(16);
    av1_setup_global_mv(gmv, fh, AV1_LAST_FRAME, 0, 0, 12);
    var tf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    assert_eq(av1_mc_pred_block(tf, ref, 0, 0, 0, 64, 64, av1_mv_row(gmv), av1_mv_col(gmv),
    AV1_EIGHTTAP, AV1_EIGHTTAP), DR_OK, "gw-scaled: scaled translation oracle predicts");
    assert_eq(it_gws_diff(df, tf), 0, "gw-scaled: decoded == scaled global-MV translation (4096 px)");
    # and the warp really is refused for this reference, not merely unused.
    var wm = av1_warp_model_new();
    assert_eq(av1_warp_model_from_global(wm, fh, AV1_LAST_FRAME), DR_OK, "gw-scaled: model would build");
    assert_eq(av1_warp_model_shear_valid(wm), 1, "gw-scaled: ...and would be shear-realizable");
    var wf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    assert_eq(av1_warp_pred_block(wf, ref, 0, 0, 0, 64, 64, wm), DR_ERR_UNSUPPORTED,
    "gw-scaled: warping a scaled ref is refused (what the gate spares us)");
    return 0;
}

# GATES 2 and 3 (compound GLOBAL_GLOBALMV, one per reference). A fixture with BOTH references
# scaled cannot tell the two gates apart, so each is witnessed with exactly ONE scaled
# reference: `which` selects whether ref0 (LAST, slot 0) or ref1 (ALTREF, slot 6) is the
# scaled one. The unscaled lane still warps; the scaled lane translates.
fn it_gws_compound(which, tag): i64 {
    var oe = alloc(8);
    var big = it_ref_frame();                # 64x64, unscaled
    var small = it_ref_frame_scaled();       # 32x32, scaled
    var r0 = big;
    var r1 = small;
    if (which != 0) {
        r0 = small;
        r1 = big;
    }
    var fh = it_fh();
    store64(fh + AV1FH_REFERENCE_SELECT, 1);
    store64(fh + AV1FH_REF_FRAME_IDX + (6 * 8), 6);
    # would-warp ROTZOOM models for BOTH refs, DISTINCT so the two lanes cannot alias.
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);
    store64(fh + AV1FH_GM_TYPE + ((AV1_ALTREF_FRAME - 1) * 8), AV1_GM_ROTZOOM);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_ALTREF_FRAME - 1) * 6 + 0) * 8), 0);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_ALTREF_FRAME - 1) * 6 + 1) * 8), 0);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_ALTREF_FRAME - 1) * 6 + 2) * 8), 66560);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_ALTREF_FRAME - 1) * 6 + 3) * 8), 512);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_ALTREF_FRAME - 1) * 6 + 4) * 8), 0 - 512);
    store64(fh + AV1FH_GM_PARAMS + (((AV1_ALTREF_FRAME - 1) * 6 + 5) * 8), 66560);
    var dpb = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 1);
    av1_dpb_store(dpb, fh, r0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 64);
    av1_dpb_store(dpb, fh, r1);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_W + (6 * 8), 64);
    store64(refs + AV1REF_FRAME_H + (6 * 8), 64);
    var slot = 0;
    if (which != 0) { slot = 0; } else { slot = 6; }
    store64(refs + AV1REF_UPSCALED_W + (slot * 8), 32);
    store64(refs + AV1REF_FRAME_W + (slot * 8), 32);
    store64(refs + AV1REF_FRAME_H + (slot * 8), 32);
    assert_eq(av1_is_scaled(fh, refs, AV1_LAST_FRAME), which == 1, tag);
    assert_eq(av1_is_scaled(fh, refs, AV1_ALTREF_FRAME), which == 0, tag);
    var seq = it_seq();
    var blk = it_blk_comp(0, 0, 0, 0);
    store64((blk + AV1FB_IB) + AV1IB_YMODE, AV1_GLOBAL_GLOBALMV);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, tag);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    # THE WITNESS: with that reference's is_scaled conjunct dropped, its lane builds a warp
    # model, av1_warp_pred_gen refuses the scaled reference, and this latches UNSUPPORTED.
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, tag);
    return df;
}

fn test_inter_tile_globalwarp_scaled_compound() {
    # ref1 (ALTREF) scaled, ref0 (LAST) not -> witnesses the ref1 gate.
    var d1 = it_gws_compound(0, "gg-scaled ref1: compound decodes, ref1 lane does not warp");
    # ref0 (LAST) scaled, ref1 (ALTREF) not -> witnesses the ref0 gate.
    var d0 = it_gws_compound(1, "gg-scaled ref0: compound decodes, ref0 lane does not warp");
    # the two must DIFFER: they scale opposite lanes, so a fixture that accidentally treated
    # both references alike would produce the same pixels twice.
    assert_eq(it_gws_diff(d0, d1) > 0, 1,
    "gg-scaled: scaling ref0 vs ref1 gives different pixels (the lanes are independent)");
    return 0;
}

# TWO SOURCES OF TRUTH (0.7.111). "Is this reference scaled?" is answered from two places
# that a conformant stream keeps in step but nothing structurally forces to agree:
#   - Av1RefState (AV1REF_UPSCALED_W / _FRAME_H) — the frame-header METADATA, which is what
#     av1_is_scaled reads, and therefore what GATES warp;
#   - the DPB's stored DrFrame dimensions — the actual PIXELS, which is what av1_mc_pred_core
#     measures and therefore what drives MC GEOMETRY.
# This pins which governs which, and — more importantly — that a DISAGREEMENT between them
# degrades cleanly. Encoded video is hostile: the answer must be a sticky error code or
# correct-per-the-pixels output, never a crash, an OOB read, or silent garbage.
fn test_inter_tile_scaled_metadata_vs_pixels() {
    var oe = alloc(8);
    # CASE A — metadata says UNSCALED, pixels are HALF SIZE.
    # Gating believes the metadata, so the GLOBALWARP model IS built and the block tries to
    # warp; av1_warp_pred_gen then measures the real DrFrame, finds it scaled, and refuses.
    # A clean latched DR_ERR_UNSUPPORTED — not a wrong-sized read.
    var small = it_ref_frame_scaled();          # 32x32 pixels
    var fhA = it_fh();
    it_fh_set_gm(fhA, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);
    var dpbA = av1_dpb_new();
    av1_dpb_store(dpbA, fhA, small);
    var refsA = it_refs();                      # metadata still claims 64x64
    assert_eq(av1_is_scaled(fhA, refsA, AV1_LAST_FRAME), 0,
    "meta/pixel A: metadata claims UNSCALED (gating believes it)");
    var seq = it_seq();
    var tlenA = 0;
    var tbA = it_enc_tile(dpbA, refsA, seq, fhA, it_blk_global(), &tlenA);
    assert_eq(tlenA > 0, 1, "meta/pixel A: tile encoded");
    var dfA = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dtA = av1_tile_new(dfA, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dtA);
    av1_tile_set_inter_ctx(dtA, fhA, refsA, seq, dpbA);
    assert_eq(av1_decode_inter_tile(dtA, tbA, tlenA, 1), DR_ERR_UNSUPPORTED,
    "meta/pixel A: lying metadata -> clean reject from the warp path, no crash");
    # CASE B — metadata says SCALED, pixels are FULL SIZE.
    # Gating believes the metadata and suppresses the warp; MC then measures the real
    # DrFrame, finds it matches the current frame exactly, and takes the UNSCALED fast path.
    # So it decodes, and to the plain global-MV translation.
    var full = it_ref_frame();                  # 64x64 pixels
    var fhB = it_fh();
    it_fh_set_gm(fhB, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);
    var dpbB = av1_dpb_new();
    av1_dpb_store(dpbB, fhB, full);
    var refsB = it_refs();
    store64(refsB + AV1REF_UPSCALED_W + 0, 32);   # metadata lies the other way
    store64(refsB + AV1REF_FRAME_W + 0, 32);
    store64(refsB + AV1REF_FRAME_H + 0, 32);
    assert_eq(av1_is_scaled(fhB, refsB, AV1_LAST_FRAME), 1,
    "meta/pixel B: metadata claims SCALED (gating believes it -> no warp)");
    var tlenB = 0;
    var tbB = it_enc_tile(dpbB, refsB, seq, fhB, it_blk_global(), &tlenB);
    assert_eq(tlenB > 0, 1, "meta/pixel B: tile encoded");
    var dfB = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dtB = av1_tile_new(dfB, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dtB);
    av1_tile_set_inter_ctx(dtB, fhB, refsB, seq, dpbB);
    assert_eq(av1_decode_inter_tile(dtB, tbB, tlenB, 1), DR_OK,
    "meta/pixel B: decodes — MC measures the PIXELS, which are unscaled");
    var gmv = alloc(16);
    av1_setup_global_mv(gmv, fhB, AV1_LAST_FRAME, 0, 0, 12);
    var tfB = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tfB, full, 0, 0, 0, 64, 64, av1_mv_row(gmv), av1_mv_col(gmv),
    AV1_EIGHTTAP, AV1_EIGHTTAP);
    assert_eq(it_gws_diff(dfB, tfB), 0,
    "meta/pixel B: == UNSCALED global-MV translation (geometry came from the pixels)");
    return 0;
}

# THE GATE CONTROL (0.7.100): the SAME GLOBALMV block with a TRANSLATION global model (GmType ==
# TRANSLATION, NOT > TRANSLATION) does NOT warp — useWarp stays 0 and the block translates by its
# global MV. Witnesses the `GmType > TRANSLATION` conjunct of the useWarp==2 gate.
fn test_inter_tile_globalwarp_translation() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    # TRANSLATION model: identity 2x2 (wmmat[2]=wmmat[5]=one), a translation in wmmat[0/1].
    it_fh_set_gm(fh, AV1_GM_TRANSLATION, 8 << 13, 16 << 13, 65536, 0, 0, 65536);
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk_global(), &tlen);
    assert_eq(tlen > 0, 1, "globalwarp-trans: TRANSLATION-GM GLOBALMV tile encoded");
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "globalwarp-trans: tile decodes");
    # decoded == a plain translation MC of the block's global MV -> NO warp (GmType == TRANSLATION).
    var gmv = alloc(16);
    av1_setup_global_mv(gmv, fh, AV1_LAST_FRAME, 0, 0, 12);
    var tf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 0, 0, 0, 64, 64, av1_mv_row(gmv), av1_mv_col(gmv),
    AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(tf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "globalwarp-trans: decoded == global-MV translation (GmType==TRANSLATION: NO warp)");
    return 0;
}
# THE ymode GATE CONTROL (0.7.100): a NEWMV block in a frame that HAS a >TRANSLATION global model must
# still translate by its OWN decoded MV — global warp is `YMode == GLOBALMV`-gated, NOT applied to every
# inter block. Witnesses the ymode conjunct of the useWarp==2 gate (dropping it warps this NEWMV block).
fn test_inter_tile_globalwarp_newmv_gated() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);   # same rotzoom as above
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk(16, 8), &tlen);         # a NEWMV block, Mv (16,8)
    assert_eq(tlen > 0, 1, "globalwarp-newmv: NEWMV tile encoded (rotzoom GM present)");
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "globalwarp-newmv: tile decodes");
    var xf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 64, 64, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "globalwarp-newmv: NEWMV translates by its own MV (global warp is ymode-gated)");
    return 0;
}
# THE shearValid FALLBACK (0.7.100 review): a GLOBALMV block whose reference has a >TRANSLATION but
# SHEAR-UNREALIZABLE global model (setup_shear rejects it) must NOT warp — warp_valid keys off
# AV1WM_SHEARVALID (which setup_shear sets), NOT the always-1 AV1WM_VALID. The block translates by its
# global MV. Witnesses the `warp_valid = shear_valid` link (the GLOBALWARP analog of the LOCALWARP det==0
# fallback): mutating it to `= av1_warp_model_valid(wm)` would warp with the leftover strong shear.
fn test_inter_tile_globalwarp_unrealizable() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    # ROTZOOM (>TRANSLATION) but a STEEP off-diagonal: beta reduces to 32768, 7*32768 >= 65536 -> reject.
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 65536, 32767, 0 - 32767, 65536);
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    # the model IS >TRANSLATION but setup_shear rejects it -> shearValid 0 (VALID stays 1).
    var m = av1_warp_model_new();
    av1_warp_model_from_global(m, fh, AV1_LAST_FRAME);
    assert_eq(av1_warp_model_valid(m), 1, "gw-unreal: VALID forced 1");
    assert_eq(av1_warp_model_shear_valid(m), 0, "gw-unreal: steep rotzoom is NOT shear-realizable");
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk_global(), &tlen);
    assert_eq(tlen > 0, 1, "gw-unreal: tile encoded");
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "gw-unreal: tile decodes");
    # decoded == translation of the global MV -> NO warp (shearValid==0 fell back).
    var gmv = alloc(16);
    av1_setup_global_mv(gmv, fh, AV1_LAST_FRAME, 0, 0, 12);
    var tf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 0, 0, 0, 64, 64, av1_mv_row(gmv), av1_mv_col(gmv),
    AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(tf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "gw-unreal: decoded == global-MV translation (unrealizable shear -> NO warp)");
    return 0;
}
# THE force_integer_mv GATE (0.7.100 review): a GLOBALMV block with a realizable >TRANSLATION model in a
# force_integer_mv frame does NOT warp (spec 7.11.3.1 / dav1d gmv_warp_allowed forbid warp under
# force_integer_mv) — it translates by its integer global MV. Witnesses the `!force_integer_mv` conjunct.
fn test_inter_tile_globalwarp_force_int() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);   # realizable rotzoom
    store64(fh + AV1FH_FORCE_INT_MV, 1);                                     # but force_integer_mv on
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, it_blk_global(), &tlen);
    assert_eq(tlen > 0, 1, "gw-forceint: tile encoded");
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "gw-forceint: tile decodes");
    var gmv = alloc(16);
    av1_setup_global_mv(gmv, fh, AV1_LAST_FRAME, 0, 0, 12);
    var tf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(tf, ref, 0, 0, 0, 64, 64, av1_mv_row(gmv), av1_mv_col(gmv),
    AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(tf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "gw-forceint: decoded == integer global-MV translation (force_integer_mv -> NO warp)");
    return 0;
}
# GLOBALWARP + inter-intra WARP-BLEND (0.7.105): a GLOBALMV inter-intra block whose >TRANSLATION global model
# warps (useWarp==2) now WARPS the inter part per plane and blends the intra — no longer rejected. The block
# is SKIP, so its decoded pixels ARE the warp-blend prediction; the decode's 32x32 block must equal a direct
# warp-blend reference (global model -> av1_mc_pred_interintra_w with use_warp=1). A dispatch mutation forcing
# translation (use_warp=0 for the is_ii branch) would make df a translation-blend != this reference.
fn test_inter_tile_globalwarp_ii_warpblend() {
    var oe = alloc(8);
    var r0 = it_ref_frame();
    var fh = it_fh();
    it_fh_set_gm(fh, AV1_GM_ROTZOOM, 0, 0, 67584, 1024, 0 - 1024, 67584);   # would-warp GM
    var dpb = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 1);
    av1_dpb_store(dpb, fh, r0);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    var refs = it_refs();
    var seq = it_seq();
    store64(seq + AV1_SEQ_ENABLE_INTERINTRA, 1);
    # a 32x32 GLOBALMV SMOOTH inter-intra block (via SPLIT) as sub-block 0; MV ignored (GLOBALMV).
    var iiblk = it_blk_ii(0, 0, 0, 0, 0);
    store64((iiblk + AV1FB_IB) + AV1IB_YMODE, AV1_GLOBALMV);
    var plain = it_blk(0 - 8, 24);
    var pp = alloc(5 * 8);
    store64(pp + 0, AV1_PARTITION_SPLIT);
    store64(pp + 8, AV1_PARTITION_NONE);
    store64(pp + 16, AV1_PARTITION_NONE);
    store64(pp + 24, AV1_PARTITION_NONE);
    store64(pp + 32, AV1_PARTITION_NONE);
    var pf = alloc(4 * 8);
    store64(pf + 0, iiblk);
    store64(pf + 8, plain);
    store64(pf + 16, plain);
    store64(pf + 24, plain);
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "gw-ii: tile encoded");
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK,
    "gw-ii: GLOBALMV inter-intra + would-warp GM now decodes (warp-blend, 0.7.105)");
    # direct warp-blend reference: the global warp model + av1_mc_pred_interintra_w(use_warp=1) on a fresh
    # frame. The block is SKIP + at (0,0) with no neighbours, so the decode's 32x32 luma == this reference.
    var wm = av1_warp_model_new();
    av1_warp_model_from_global(wm, fh, AV1_LAST_FRAME);
    av1_setup_shear(wm);
    var rf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_interintra_w(rf, r0, 0, 0, 0, 32, 32, 0, 0, AV1_EIGHTTAP, AV1_EIGHTTAP, 0, 0, 0,
    AV1_BLOCK_32X32, 0, 0, load64(dt + AV1TILE_FMI_COLS), load64(dt + AV1TILE_FMI_ROWS), wm, 1);
    var diffw = 0;
    var yy = 0;
    while (yy < 32) {
        var xx = 0;
        while (xx < 32) {
            if (dr_frame_get(df, 0, xx, yy) != dr_frame_get(rf, 0, xx, yy)) { diffw = diffw + 1; }
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(diffw, 0, "gw-ii: decoded block == direct warp-blend reference (1024 px)");
    return 0;
}
# an OBMC block record (mirrors it_blk but motion_mode = OBMC).
fn it_blk_obmc(mvr, mvc): i64 {
    var b = it_blk(mvr, mvc);
    store64((b + AV1FB_IB) + AV1IB_MOTIONMODE, AV1_MM_OBMC);
    return b;
}
# THE Obmc_Mask KAT (0.7.101): av1_obmc_mask(len,i) == the spec own-weight == 64 - dav1d_obmc_masks[len+i].
# The dav1d values are the INDEPENDENT anchor (a different representation from the spec table drishti
# stores) — pinned as literals, so a single flipped table entry fails its assert. Also the defensive
# guards (invalid len / out-of-range i -> 64, the trust-no-input backstop).
fn test_obmc_mask() {
    var dv = alloc(64 * 8);          # dav1d_obmc_masks, self-indexed [len+i]; drishti = 64 - dv
    store64(dv + (2 * 8), 19);  store64(dv + (3 * 8), 0);
    store64(dv + (4 * 8), 25);  store64(dv + (5 * 8), 14); store64(dv + (6 * 8), 5);  store64(dv + (7 * 8), 0);
    store64(dv + (8 * 8), 28);  store64(dv + (9 * 8), 22); store64(dv + (10 * 8), 16); store64(dv + (11 * 8), 11);
    store64(dv + (12 * 8), 7);  store64(dv + (13 * 8), 3); store64(dv + (14 * 8), 0);  store64(dv + (15 * 8), 0);
    store64(dv + (16 * 8), 30); store64(dv + (17 * 8), 27); store64(dv + (18 * 8), 24); store64(dv + (19 * 8), 21);
    store64(dv + (20 * 8), 18); store64(dv + (21 * 8), 15); store64(dv + (22 * 8), 12); store64(dv + (23 * 8), 10);
    store64(dv + (24 * 8), 8);  store64(dv + (25 * 8), 6); store64(dv + (26 * 8), 4);  store64(dv + (27 * 8), 3);
    store64(dv + (28 * 8), 0);  store64(dv + (29 * 8), 0); store64(dv + (30 * 8), 0);  store64(dv + (31 * 8), 0);
    store64(dv + (32 * 8), 31); store64(dv + (33 * 8), 29); store64(dv + (34 * 8), 28); store64(dv + (35 * 8), 26);
    store64(dv + (36 * 8), 24); store64(dv + (37 * 8), 23); store64(dv + (38 * 8), 21); store64(dv + (39 * 8), 20);
    store64(dv + (40 * 8), 19); store64(dv + (41 * 8), 17); store64(dv + (42 * 8), 16); store64(dv + (43 * 8), 14);
    store64(dv + (44 * 8), 13); store64(dv + (45 * 8), 12); store64(dv + (46 * 8), 11); store64(dv + (47 * 8), 9);
    store64(dv + (48 * 8), 8);  store64(dv + (49 * 8), 7); store64(dv + (50 * 8), 6);  store64(dv + (51 * 8), 5);
    store64(dv + (52 * 8), 4);  store64(dv + (53 * 8), 4); store64(dv + (54 * 8), 3);  store64(dv + (55 * 8), 2);
    store64(dv + (56 * 8), 0);  store64(dv + (57 * 8), 0); store64(dv + (58 * 8), 0);  store64(dv + (59 * 8), 0);
    store64(dv + (60 * 8), 0);  store64(dv + (61 * 8), 0); store64(dv + (62 * 8), 0);  store64(dv + (63 * 8), 0);
    var lens = alloc(5 * 8);
    store64(lens + 0, 2); store64(lens + 8, 4); store64(lens + 16, 8); store64(lens + 24, 16); store64(lens + 32, 32);
    var li = 0;
    while (li < 5) {
        var ln = load64(lens + (li * 8));
        var i = 0;
        while (i < ln) {
            assert_eq(av1_obmc_mask(ln, i), 64 - load64(dv + ((ln + i) * 8)), "obmc mask entry == 64 - dav1d");
            i = i + 1;
        }
        li = li + 1;
    }
    assert_eq(av1_obmc_mask(3, 0), 64, "obmc mask: non-mask len -> 64");
    assert_eq(av1_obmc_mask(8, 8), 64, "obmc mask: i >= len -> 64");
    assert_eq(av1_obmc_mask(8, 0 - 1), 64, "obmc mask: i < 0 -> 64");
    assert_eq(av1_obmc_mask(2, 0), 45, "obmc mask: len2[0] spot");
    return 0;
}
# THE OBMC MILESTONE (0.7.101): an OBMC inter block decodes to overlap-blended pixels end-to-end. 4 SBs
# (128x128): TL any, TR (above) Mv (0,40), BL (left) Mv (40,0), BR OBMC Mv (16,8) — all integer MVs so the
# MC is a pure edge-clamped shift (the OBMC-specific scan/extents/mask/blend is what's under test; the
# 8-tap MC is pinned by 0.7.58). The BR block's own MC is committed, then OBMC blends TR onto the top 64x32
# (mask by row) + BL onto the left 32x64 (mask by col), the top-left 32x32 corner blended twice. Verified
# pixel-exact against the spec-literal scripts/refs/obmc_ref.py (independent known-answer: checksum + spots).
fn test_obmc_e2e() {
    var oe = alloc(8);
    var ref = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var y0 = 0;
    while (y0 < 128) {
        var x0 = 0;
        while (x0 < 128) {
            dr_frame_set(ref, 0, x0, y0, (x0 + (2 * y0)) & 255);
            x0 = x0 + 1;
        }
        y0 = y0 + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_FRAME_HEIGHT, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_ROWS, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 32);
    store64(fh + AV1FH_MOTION_MODE_SWITCHABLE, 1);   # allow the @@use_obmc read/write
    store64(fh + AV1FH_ALLOW_WARPED, 0);             # warp disabled -> the use_obmc branch (not the 3-way)
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 0, 128);
    store64(refs + AV1REF_FRAME_W + 0, 128);
    store64(refs + AV1REF_FRAME_H + 0, 128);
    var seq = it_seq();
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var ef = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(32);
    var pf = alloc(32);
    var k = 0;
    while (k < 4) { store64(pp + (k * 8), AV1_PARTITION_NONE); k = k + 1; }
    store64(pf + 0, it_blk(16, 8));         # TL (not a BR neighbour)
    store64(pf + 8, it_blk(0, 24));         # TR = BR's ABOVE neighbour, Mv (0, 24)
    store64(pf + 16, it_blk(40, 0));        # BL = BR's LEFT neighbour, Mv (40, 0)
    store64(pf + 24, it_blk_obmc(16, 8));   # BR OBMC, Mv (16, 8)
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "obmc: 4-SB tile encoded (OBMC BR)");
    var df = dr_frame_new(128, 128, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 32, 32, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "obmc: 4-SB tile decodes (BR OBMC blends)");
    # the BR 64x64 block == the spec-literal obmc_ref.py known answer (checksum over all 4096 px).
    var cs = 0;
    var yy = 64;
    while (yy < 128) {
        var xx = 64;
        while (xx < 128) {
            cs = cs + dr_frame_get(df, 0, xx, yy);
            xx = xx + 1;
        }
        yy = yy + 1;
    }
    assert_eq(cs, 375934, "obmc: BR block checksum == spec-literal obmc_ref.py");
    assert_eq(dr_frame_get(df, 0, 64, 64), 199, "obmc: top-left corner (above THEN left, double-blend)");
    assert_eq(dr_frame_get(df, 0, 104, 64), 236, "obmc: above-only strip (col 40 >= 32)");
    assert_eq(dr_frame_get(df, 0, 64, 104), 23, "obmc: left-only strip (row 40 >= 32)");
    assert_eq(dr_frame_get(df, 0, 104, 104), 61, "obmc: interior unchanged (own MC only)");
    assert_eq(dr_frame_get(df, 0, 127, 64), 125, "obmc: top-row right edge");
    return 0;
}
# populate one MI cell as an 8x8 inter neighbour (av1_mv_grid_set omits the interp filters OBMC needs).
fn obmc_set_nb(grid, fmi_cols, r, c, mvr, mvc) {
    var cell = av1_mv_grid_cell(grid, fmi_cols, r, c);
    store64(cell + AV1MIR_AVAIL, 1);
    store64(cell + AV1MIR_ISINTER, 1);
    store64(cell + AV1MIR_MISIZE, AV1_BLOCK_8X8);
    store64(cell + AV1MIR_REF0, AV1_LAST_FRAME);
    store64(cell + AV1MIR_REF1, AV1_REF_NONE);
    store64(cell + AV1MIR_MV0ROW, mvr);
    store64(cell + AV1MIR_MV0COL, mvc);
    store64(cell + AV1MIR_INTERP0, AV1_EIGHTTAP);
    store64(cell + AV1MIR_INTERP1, AV1_EIGHTTAP);
    return 0;
}
# THE CHROMA ABOVE-GATE ASYMMETRY (0.7.101, the one reconciled spec disagreement): the above pass is
# gated on the plane's residual size >= BLOCK_8X8, but the LEFT pass is NOT. So a 4:2:0 8x8-luma OBMC
# block (chroma 4x4 = BLOCK_4X4 < BLOCK_8X8) blends its LEFT chroma neighbour but NOT its ABOVE — while
# LUMA (8x8 >= BLOCK_8X8) blends both. Direct av1_obmc_predict call on a hand-built neighbour grid.
# Witnesses the residual-size gate: a mutation moving it onto the left pass (or dropping it) would blend
# the chroma ABOVE and the "chroma above unchanged" asserts go red.
fn test_obmc_chroma_gate() {
    var oe = alloc(8);
    var ref = dr_frame_new(64, 64, 3, 1, 1, 8, 8, oe);
    var p = 0;
    while (p < 3) {
        var pw = dr_frame_plane_width(ref, p);
        var ph = dr_frame_plane_height(ref, p);
        var yy = 0;
        while (yy < ph) {
            var xx = 0;
            while (xx < pw) {
                dr_frame_set(ref, p, xx, yy, ((xx + (2 * yy)) + (p * 13)) & 255);
                xx = xx + 1;
            }
            yy = yy + 1;
        }
        p = p + 1;
    }
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    store64(seq + AV1_SEQ_NUM_PLANES, 3);
    store64(seq + AV1_SEQ_SUBX, 1);
    store64(seq + AV1_SEQ_SUBY, 1);
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var frame = dr_frame_new(64, 64, 3, 1, 1, 8, 8, oe);
    var tile = av1_tile_new(frame, 16, 16, 40, 1, 0, 3);
    av1_tile_grids_new(tile);
    av1_tile_set_inter_ctx(tile, fh, refs, seq, dpb);
    var grid = load64(tile + AV1TILE_MVGRID);
    var fmi_cols = load64(tile + AV1TILE_FMI_COLS);
    # OBMC block: 8x8 at mi (4,4) = pixel (16,16). Fill the above row (mi 3) + left col (mi 3) with
    # 8x8 inter neighbours (MVs set in the loop below: above (32,0) = 4px down, left (0,32) = 4px right).
    # INTEGER-chroma MVs (luma multiples of 16 -> pure chroma shift, no subpel) with DISTINCT gradient
    # (x+2y) contributions dx+2*dy so every blended pixel provably differs from own in BOTH luma and
    # chroma: own luma12/chroma6, above luma8/chroma4, left luma4/chroma2.
    var k = 0;
    while (k < 8) {
        obmc_set_nb(grid, fmi_cols, 3, k, 32, 0);       # above row: luma (0,4)->8, chroma (0,2)->4
        obmc_set_nb(grid, fmi_cols, k, 3, 0, 32);       # left col:  luma (4,0)->4, chroma (2,0)->2
        k = k + 1;
    }
    # commit the block's own MC (Mv (32,32) -> luma (4,4)->12, chroma (2,2)->6) to all 3 planes.
    av1_mc_pred_block(frame, ref, 0, 16, 16, 8, 8, 32, 32, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(frame, ref, 1, 8, 8, 4, 4, 32, 32, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(frame, ref, 2, 8, 8, 4, 4, 32, 32, AV1_EIGHTTAP, AV1_EIGHTTAP);
    # snapshot own chroma-U at the ABOVE-only pixels (row 0, cols 2/3 — above-region but NOT left-region)
    # and a LEFT pixel (col 0, row 3 — left-region but NOT above-region), plus a luma above-only pixel.
    var own_u_20 = dr_frame_get(frame, 1, 10, 8);       # chroma U col 2 row 0
    var own_u_30 = dr_frame_get(frame, 1, 11, 8);       # chroma U col 3 row 0
    var own_u_03 = dr_frame_get(frame, 1, 8, 11);       # chroma U col 0 row 3
    var own_y_60 = dr_frame_get(frame, 0, 22, 16);      # luma col 6 row 0 (above-only)
    # run OBMC per plane (luma subX/subY 0; chroma 1/1).
    assert_eq(av1_obmc_predict(tile, frame, 0, 4, 4, AV1_BLOCK_8X8, 0, 0), DR_OK, "obmc chroma: luma pass");
    assert_eq(av1_obmc_predict(tile, frame, 1, 4, 4, AV1_BLOCK_8X8, 1, 1), DR_OK, "obmc chroma: U pass");
    assert_eq(av1_obmc_predict(tile, frame, 2, 4, 4, AV1_BLOCK_8X8, 1, 1), DR_OK, "obmc chroma: V pass");
    # LUMA above blends (8x8 >= BLOCK_8X8): the above-only luma pixel changed.
    assert_eq(dr_frame_get(frame, 0, 22, 16) != own_y_60, 1, "obmc chroma: LUMA above blends");
    # CHROMA above is SKIPPED (4x4 < BLOCK_8X8): the above-only chroma pixels are UNCHANGED.
    assert_eq(dr_frame_get(frame, 1, 10, 8), own_u_20, "obmc chroma: U above SKIPPED (col 2 row 0 unchanged)");
    assert_eq(dr_frame_get(frame, 1, 11, 8), own_u_30, "obmc chroma: U above SKIPPED (col 3 row 0 unchanged)");
    # CHROMA left DOES blend (no size gate): the left-only chroma pixel changed.
    assert_eq(dr_frame_get(frame, 1, 8, 11) != own_u_03, 1, "obmc chroma: U left blends (col 0 row 3 changed)");
    return 0;
}
# THE TILE-BOUNDARY GATES (0.7.101): the above pass runs only for mi_row > tile row-start, the left only
# for mi_col > tile col-start — so an OBMC block on the tile's top / left edge does NOT scan the
# nonexistent row / col -1. A top-edge block (LEFT neighbour only) and a left-edge block (ABOVE neighbour
# only) both decode cleanly (DR_OK); mutating `>` to `>=` makes the skipped pass read cell -1, whose
# garbage MiSize trips the bounds-guard -> DR_ERR_BOUNDS (the assert then reddens).
fn test_obmc_edge_gate() {
    var oe = alloc(8);
    var ref = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var y0 = 0;
    while (y0 < 64) {
        var x0 = 0;
        while (x0 < 64) { dr_frame_set(ref, 0, x0, y0, (x0 + (2 * y0)) & 255); x0 = x0 + 1; }
        y0 = y0 + 1;
    }
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var fmi_cols = 16;
    # TOP-EDGE block at mi(0,4) = pixel (16,0): a LEFT neighbour (col 3), NO above (row -1).
    var frame = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var tile = av1_tile_new(frame, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    av1_tile_set_inter_ctx(tile, fh, refs, seq, dpb);
    var grid = load64(tile + AV1TILE_MVGRID);
    var k = 0;
    while (k < 8) { obmc_set_nb(grid, fmi_cols, k, 3, 0, 32); k = k + 1; }
    av1_mc_pred_block(frame, ref, 0, 16, 0, 8, 8, 32, 32, AV1_EIGHTTAP, AV1_EIGHTTAP);
    assert_eq(av1_obmc_predict(tile, frame, 0, 0, 4, AV1_BLOCK_8X8, 0, 0), DR_OK,
    "obmc edge: top-edge block decodes (above pass skipped, no row -1 read)");
    # LEFT-EDGE block at mi(4,0) = pixel (0,16): an ABOVE neighbour (row 3), NO left (col -1).
    var frame2 = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var tile2 = av1_tile_new(frame2, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(tile2);
    av1_tile_set_inter_ctx(tile2, fh, refs, seq, dpb);
    var grid2 = load64(tile2 + AV1TILE_MVGRID);
    var k2 = 0;
    while (k2 < 8) {
        obmc_set_nb(grid2, fmi_cols, 3, k2, 32, 0);      # above row (row 3) for the left-edge block
        # col 15: the cell that grid index (candRow*fmi_cols - 1) WRAPS to when a `>=` mutation reads
        # col -1 — populated inter so the mutated left pass wrongly blends it (else the wrap is empty).
        obmc_set_nb(grid2, fmi_cols, k2, 15, 0, 32);
        k2 = k2 + 1;
    }
    av1_mc_pred_block(frame2, ref, 0, 0, 16, 8, 8, 32, 32, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var own2_04 = dr_frame_get(frame2, 0, 0, 20);        # block (0,16) row 4: below the above strip, col 0
    assert_eq(av1_obmc_predict(tile2, frame2, 0, 4, 0, AV1_BLOCK_8X8, 0, 0), DR_OK,
    "obmc edge: left-edge block decodes (left pass skipped, no col -1 read)");
    # the left strip below the above region stays own (left pass skipped); a `>=` mutation would blend
    # the wrapped col-15 neighbour here.
    assert_eq(dr_frame_get(frame2, 0, 0, 20), own2_04, "obmc edge: left-edge left pass skipped (col 0 unchanged)");
    return 0;
}
# populate one MI cell as an 8x8 INTRA block (REF0 = INTRA_FRAME) — an OBMC scan must STEP OVER it.
fn obmc_set_intra(grid, fmi_cols, r, c) {
    var cell = av1_mv_grid_cell(grid, fmi_cols, r, c);
    store64(cell + AV1MIR_AVAIL, 1);
    store64(cell + AV1MIR_MISIZE, AV1_BLOCK_8X8);
    store64(cell + AV1MIR_REF0, AV1_INTRA_FRAME);
    store64(cell + AV1MIR_REF1, AV1_REF_NONE);
    return 0;
}
# THE MULTI-NEIGHBOUR SCAN + INTRA STEP-OVER (0.7.101): a 32x32 OBMC block whose above row is A(inter),
# B(INTRA), C(inter), D(inter) 8x8 blocks. The scan blends A/C/D (up to nLimit=min(4,MiWidthLog2=3)=3) and
# STEPS OVER B (the step advances UNCONDITIONALLY — moving it inside the inter test would infinite-loop, a
# hard-rule violation; this test COMPLETING witnesses the no-hang, and B's slice staying == own witnesses
# the REF0>INTRA_FRAME skip). Direct av1_obmc_predict call.
fn test_obmc_scan_intra() {
    var oe = alloc(8);
    var ref = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var y0 = 0;
    while (y0 < 64) {
        var x0 = 0;
        while (x0 < 64) { dr_frame_set(ref, 0, x0, y0, (x0 + (2 * y0)) & 255); x0 = x0 + 1; }
        y0 = y0 + 1;
    }
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var frame = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var tile = av1_tile_new(frame, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(tile);
    av1_tile_set_inter_ctx(tile, fh, refs, seq, dpb);
    var grid = load64(tile + AV1TILE_MVGRID);
    var fmi_cols = 16;
    # 32x32 OBMC block at mi(8,8) = pixel (32,32). Above row (mi 7): four 8x8 neighbours (each spans 2
    # cells) with DISTINCT integer MVs; B (cells 10-11) is INTRA. own MV (16,16).
    obmc_set_nb(grid, fmi_cols, 7, 8, 32, 0);  obmc_set_nb(grid, fmi_cols, 7, 9, 32, 0);    # A cols 32-39
    obmc_set_intra(grid, fmi_cols, 7, 10);     obmc_set_intra(grid, fmi_cols, 7, 11);        # B (intra) 40-47
    obmc_set_nb(grid, fmi_cols, 7, 12, 0, 32); obmc_set_nb(grid, fmi_cols, 7, 13, 0, 32);    # C cols 48-55
    obmc_set_nb(grid, fmi_cols, 7, 14, 32, 32); obmc_set_nb(grid, fmi_cols, 7, 15, 32, 32);  # D cols 56-63
    av1_mc_pred_block(frame, ref, 0, 32, 32, 32, 32, 16, 16, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var own_a = dr_frame_get(frame, 0, 36, 32);    # A slice, top row
    var own_b = dr_frame_get(frame, 0, 44, 32);    # B slice (intra -> stays own)
    var own_c = dr_frame_get(frame, 0, 52, 32);    # C slice
    # BLOCK_32X32 = 9. The call COMPLETING is the no-infinite-loop witness (mutation: advance-inside-if).
    assert_eq(av1_obmc_predict(tile, frame, 0, 8, 8, 9, 0, 0), DR_OK,
    "obmc scan: 32x32 block, intra neighbour stepped over (no hang)");
    assert_eq(dr_frame_get(frame, 0, 44, 32), own_b, "obmc scan: B (intra) slice unchanged (REF0>INTRA skip)");
    assert_eq(dr_frame_get(frame, 0, 36, 32) != own_a, 1, "obmc scan: A (inter) slice blended");
    assert_eq(dr_frame_get(frame, 0, 52, 32) != own_c, 1, "obmc scan: C (inter) slice blended (past the intra)");
    return 0;
}
# distinct x/y filters through the lane (en_dual on, SWITCHABLE): a filt_x/filt_y
# swap in the MC wiring changes the taps and the oracle catches it.
fn test_inter_tile_dual_filter() {
    var ref = it_ref_frame();
    var dpb = av1_dpb_new();
    var fh = it_fh();
    store64(fh + AV1FH_INTERP_FILTER, AV1_INTERP_SWITCHABLE);
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var s = it_seq();
    store64(s + AV1_SEQ_ENABLE_DUAL_FILTER, 1);
    var blk = it_blk(0 - 6, 10);                 # subpel: the taps matter
    store64(blk + AV1FB_IB + AV1IB_INTERP + 0, 2);   # dir 0 (y): SHARP
    store64(blk + AV1FB_IB + AV1IB_INTERP + 8, 1);   # dir 1 (x): SMOOTH
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, s, fh, blk, &tlen);
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, s, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "dual-filter tile decodes");
    var xf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    # the oracle: filt_x = InterpFilters[1] = SMOOTH(1), filt_y = [0] = SHARP(2).
    av1_mc_pred_block(xf, ref, 0, 0, 0, 64, 64, 0 - 6, 10, 1, 2);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "dual-filter pixels == the (SMOOTH x, SHARP y) oracle");
    return 0;
}
fn ib_ctx_like(g): i64 {
    var ctx = av1_mvctx_new();
    av1_mvctx_set_grid(ctx, g, 16, 16);
    av1_mvctx_set_tile(ctx, 0, 16, 0, 16);
    av1_mvctx_set_block(ctx, 0, 0, 12);
    av1_mvctx_set_precision(ctx, 1, 0);
    av1_mvctx_set_stack(ctx, av1_mv_stack_new());
    return ctx;
}

# ================================================================
# The 0.7.84 REVIEW HARDENING (wf_966b51ca): chroma coverage, reference-frame
# selection, the non-aligned-frame clamps, tile-window availability, grid
# sharing, lossless TxSize, the cdef-plan encode refusal.
# ================================================================
# a parameterized encode-tile builder (it_enc_tile is hardcoded 64x64 mono).
fn itx_enc_tile(dpb, refs, seq, fh, blk, w, h, planes, sx, sy, mic, mir, bq, out_len): i64 {
    var oe = alloc(8);
    var ef = dr_frame_new(w, h, planes, sx, sy, 8, 8, oe);
    var et = av1_tile_new(ef, mic, mir, bq, 1, 0, planes);
    av1_tile_grids_new(et);
    assert_eq(av1_tile_set_inter_ctx(et, fh, refs, seq, dpb), DR_OK, "itx encode tile ctx");
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, blk);
    return av1_encode_inter_tile(et, pp, pf, 1, out_len);
}
# 4:2:0 CHROMA: a three-plane, TWO-superblock inter tile (128x64) decodes with
# EVERY plane exhaustively equal to the per-plane MC oracle (the review found the
# chroma lane had ZERO coverage — every prior fixture was mono). Two SBs so the
# second block sits at a NONZERO column: the chroma coordinate subsampling
# ((c*4)>>subx) is load-bearing there — at the origin the extent clamps mask it.
fn test_inter_tile_chroma_e2e() {
    var oe = alloc(8);
    var ref = dr_frame_new(128, 64, 3, 1, 1, 8, 8, oe);
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 128) {
            dr_frame_set(ref, 0, x, y, (x + (2 * y)) & 255);
            if ((x < 64) && (y < 32)) {
                dr_frame_set(ref, 1, x, y, ((2 * x) + y) & 255);       # U gradient
                dr_frame_set(ref, 2, x, y, (x + (3 * y)) & 255);       # V gradient
            }
            x = x + 1;
        }
        y = y + 1;
    }
    var dpb = av1_dpb_new();
    var fh = it_fh();
    store64(fh + AV1FH_FRAME_WIDTH, 128);
    store64(fh + AV1FH_UPSCALED_WIDTH, 128);
    store64(fh + AV1FH_MI_COLS, 32);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 32);
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 0, 128);
    store64(refs + AV1REF_FRAME_W + 0, 128);
    var seq = it_seq();
    store64(seq + AV1_SEQ_NUM_PLANES, 3);
    store64(seq + AV1_SEQ_SUBX, 1);
    store64(seq + AV1_SEQ_SUBY, 1);
    var ef = dr_frame_new(128, 64, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 32, 16, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(16);
    store64(pp + 0, AV1_PARTITION_NONE);
    store64(pp + 8, AV1_PARTITION_NONE);
    var pf = alloc(16);
    store64(pf + 0, it_blk(16, 8));
    store64(pf + 8, it_blk(0 - 8, 24));
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "4:2:0 two-SB inter tile encoded");
    var df = dr_frame_new(128, 64, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 32, 16, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "4:2:0 inter tile decodes");
    # the oracle, per plane per block: the MV stays in 1/8 LUMA pel; the driver
    # derives the chroma subsampling split (compute_prediction, 7.11.3). SB2's
    # chroma sits at plane col 32 = (16 mi * 4) >> 1.
    var xf = dr_frame_new(128, 64, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 64, 64, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(xf, ref, 0, 64, 0, 64, 64, 0 - 8, 24, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var p = 1;
    while (p < 3) {
        av1_mc_pred_block(xf, ref, p, 0, 0, 32, 32, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
        av1_mc_pred_block(xf, ref, p, 32, 0, 32, 32, 0 - 8, 24, AV1_EIGHTTAP, AV1_EIGHTTAP);
        p = p + 1;
    }
    p = 0;
    while (p < 3) {
        var lw = 128 >> (p != 0);
        var lh = 64 >> (p != 0);
        var diff = 0;
        var y2 = 0;
        while (y2 < lh) {
            var x2 = 0;
            while (x2 < lw) {
                if (dr_frame_get(df, p, x2, y2) != dr_frame_get(xf, p, x2, y2)) { diff = diff + 1; }
                x2 = x2 + 1;
            }
            y2 = y2 + 1;
        }
        assert_eq(diff, 0, "4:2:0 plane == the per-plane MC oracle (exhaustive)");
        p = p + 1;
    }
    return 0;
}
# the SIBLING-SPAN CHROMA GATE: a sub-8x8 block whose chroma unit spans siblings
# (spec compute_prediction predicts the full unit from the MI grid's sibling MVs —
# its own bite, roadmap.md) is REJECTED on both lanes, never silent garbage. The
# decode payload is LEAF-BUILT: partition VERT at 8x8 + block (0,0)'s symbols;
# block (0,1) has chroma (odd MiCol) and must gate BEFORE reading any symbol.
# ================================================================
# SUB-8x8 CHROMA SIBLING-MV PREDICTION (0.7.113) — spec 5.11.5 compute_prediction.
#
# At 4:2:0 four BLOCK_4X4 luma blocks share ONE 4x4 chroma unit. The spec does not predict
# that unit with a single motion vector: it emits FOUR 2x2 quadrants, each borrowing the MV
# of the sibling whose luma quarter it covers, read back out of the MI grid at
# (candRow + r, candCol + c). Only the bottom-right sibling (odd MiRow AND odd MiCol) carries
# the chroma, so it is the one that performs all four.
#
# A NON-LINEAR reference is mandatory here. itw_ctx420 fills with x + 2y, and a translation
# of a linear ramp shifts by dx + 2*dy — so two different motion vectors sharing that sum
# produce IDENTICAL pixels and the fixture silently witnesses nothing (the trap OBMC hit at
# 0.7.101). The MVs below are additionally chosen with distinct dx + 2*dy, and the test
# asserts the four quadrants differ pairwise so a future edit cannot make them alias.
# ================================================================
fn itw_ref420_hc(w, h, mic, mir, fh, refs, seq, dpb): i64 {
    var oe = alloc(8);
    var ref = dr_frame_new(w, h, 3, 1, 1, 8, 8, oe);
    var p = 0;
    while (p < 3) {
        var pw = dr_frame_plane_width(ref, p);
        var ph = dr_frame_plane_height(ref, p);
        var yy = 0;
        while (yy < ph) {
            var xx = 0;
            while (xx < pw) {
                dr_frame_set(ref, p, xx, yy,
                ((((xx * 37) + (yy * 53)) + (((xx * yy) % 7) * 29)) + (p * 11)) & 255);
                xx = xx + 1;
            }
            yy = yy + 1;
        }
        p = p + 1;
    }
    store64(fh + AV1FH_FRAME_WIDTH, w);
    store64(fh + AV1FH_FRAME_HEIGHT, h);
    store64(fh + AV1FH_UPSCALED_WIDTH, w);
    store64(fh + AV1FH_MI_COLS, mic);
    store64(fh + AV1FH_MI_ROWS, mir);
    store64(fh + AV1FH_MI_COL_STARTS + 8, mic);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, mir);
    store64(refs + AV1REF_UPSCALED_W + 0, w);
    store64(refs + AV1REF_FRAME_W + 0, w);
    store64(refs + AV1REF_FRAME_H + 0, h);
    store64(seq + AV1_SEQ_NUM_PLANES, 3);
    store64(seq + AV1_SEQ_SUBX, 1);
    store64(seq + AV1_SEQ_SUBY, 1);
    av1_dpb_store(dpb, fh, ref);
    return ref;
}

# The borrowed INTERPOLATION FILTERS. The MV witness above uses integer motion vectors, where
# every filter is an identity — so swapping the borrowed dir0/dir1 pair survives it. Here each
# sibling carries a DUAL filter pair (enable_dual_filter + SWITCHABLE) and a SUB-PEL motion
# vector on both axes, which is the only configuration in which the pair is observable.
#
# The filter classes must differ, not merely the values: every sub-8x8 chroma quadrant is
# 2x2, so BOTH w <= 4 and h <= 4 and the spec's narrow-block remap collapses EIGHTTAP and
# EIGHTTAP_SHARP onto the same 4-tap set. Only {EIGHTTAP, SHARP} / {SMOOTH} / {BILINEAR} are
# distinguishable, so the pairs below mix EIGHTTAP with EIGHTTAP_SMOOTH.
# someUseIntra (spec 5.11.5) at LEAF level. The driver's use of it has NO stream witness and
# this test does not pretend otherwise: drishti's inter tile decode has no is_inter == 0 path,
# so no sibling can carry an INTRA reference in a well-formed stream, and deleting the
# driver's call leaves the whole suite green. It is nonetheless transcribed (the spec has it,
# and a future intra-in-inter bite makes it live) and its ONE reachable effect today is the
# one D9 exposed: without the 0.7.112 storage hoist, a block's own unwritten cell reads as
# INTRA_FRAME and this scan is what turns that into a collapsed prediction rather than a
# borrow of garbage. So the leaf is pinned directly.
fn test_some_use_intra_leaf() {
    var g = av1_mv_grid_new(8, 8);
    # a 2x2 luma footprint at (6,6) — the sub-8x8 chroma carrier's scan range — all INTER.
    var rr = 6;
    while (rr < 8) {
        var cc = 6;
        while (cc < 8) {
            av1_mv_grid_set(g, 8, rr, cc, 1, 1, 0, AV1_NEWMV, AV1_LAST_FRAME, AV1_REF_NONE, 0, 0, 0, 0);
            cc = cc + 1;
        }
        rr = rr + 1;
    }
    assert_eq(av1_inter_some_use_intra(g, 8, 8, 6, 6, 1, 1, 1, 1), 0, "someUseIntra: all inter -> 0");
    # each of the four cells in turn makes it fire — no cell is skipped by the scan.
    var k = 0;
    while (k < 4) {
        var tr = 6 + (k >>> 1);
        var tc = 6 + (k & 1);
        av1_mv_grid_set(g, 8, tr, tc, 1, 1, 0, AV1_NEWMV, AV1_INTRA_FRAME, AV1_REF_NONE, 0, 0, 0, 0);
        assert_eq(av1_inter_some_use_intra(g, 8, 8, 6, 6, 1, 1, 1, 1), 1,
        "someUseIntra: an intra sibling fires");
        av1_mv_grid_set(g, 8, tr, tc, 1, 1, 0, AV1_NEWMV, AV1_LAST_FRAME, AV1_REF_NONE, 0, 0, 0, 0);
        k = k + 1;
    }
    # the scan RANGE is (n4h << subY) x (n4w << subX): with no subsampling it is 1x1, so an
    # intra cell at (6,7) is OUTSIDE it and must NOT fire. This pins the shift — dropping it
    # would widen the scan and make luma see its neighbours.
    av1_mv_grid_set(g, 8, 6, 7, 1, 1, 0, AV1_NEWMV, AV1_INTRA_FRAME, AV1_REF_NONE, 0, 0, 0, 0);
    assert_eq(av1_inter_some_use_intra(g, 8, 8, 6, 6, 1, 1, 0, 0), 0,
    "someUseIntra: subsampling 0 scans 1x1 — the neighbour is out of range");
    assert_eq(av1_inter_some_use_intra(g, 8, 8, 6, 6, 1, 1, 1, 0), 1,
    "someUseIntra: subX 1 widens the scan to include it");
    av1_mv_grid_set(g, 8, 6, 7, 1, 1, 0, AV1_NEWMV, AV1_LAST_FRAME, AV1_REF_NONE, 0, 0, 0, 0);
    # CLIPPING: a scan that would run off the grid must stop, not read past it. Cells at
    # row/col 8 do not exist in an 8x8 grid; an unclipped scan reads them as whatever follows
    # the allocation. Asking for a 4x4 scan from (6,6) covers (6..9, 6..9).
    assert_eq(av1_inter_some_use_intra(g, 8, 8, 6, 6, 4, 4, 0, 0), 0,
    "someUseIntra: an overhanging scan is clipped, not read out of bounds");
    return 0;
}

fn itw_blk_filt(mvr, mvc, dir0, dir1): i64 {
    var b = it_blk(mvr, mvc);
    store64((b + AV1FB_IB) + AV1IB_INTERP + 0, dir0);   # dir 0 = vertical = filt_y
    store64((b + AV1FB_IB) + AV1IB_INTERP + 8, dir1);   # dir 1 = horizontal = filt_x
    return b;
}

fn test_inter_chroma_sibling_filters() {
    var oe = alloc(8);
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    store64(seq + AV1_SEQ_ENABLE_DUAL_FILTER, 1);
    store64(fh + AV1FH_INTERP_FILTER, AV1_INTERP_SWITCHABLE);
    var dpb = av1_dpb_new();
    var ref = itw_ref420_hc(32, 32, 8, 8, fh, refs, seq, dpb);
    # sub-pel on BOTH axes in CHROMA: the chroma phase is mv & 15, so the motion vectors must
    # not be multiples of 16 or the filters go unexercised.
    var m0r = 4;      var m0c = 8;
    var m1r = 8;      var m1c = 4;
    var m2r = 0 - 4;  var m2c = 0 - 8;
    var m3r = 12;     var m3c = 4;
    var f0d0 = 1;     var f0d1 = 0;    # SMOOTH vertical, EIGHTTAP horizontal
    var f1d0 = 0;     var f1d1 = 1;    # the mirror — this pair is what a dir0/dir1 swap moves
    var f2d0 = 1;     var f2d1 = 1;
    var f3d0 = 0;     var f3d1 = 0;
    var pp = alloc(10 * 8);
    store64(pp + (0 * 8), AV1_PARTITION_SPLIT);
    store64(pp + (1 * 8), AV1_PARTITION_SPLIT);
    store64(pp + (2 * 8), AV1_PARTITION_NONE);
    store64(pp + (3 * 8), AV1_PARTITION_NONE);
    store64(pp + (4 * 8), AV1_PARTITION_NONE);
    store64(pp + (5 * 8), AV1_PARTITION_SPLIT);
    store64(pp + (6 * 8), AV1_PARTITION_NONE);
    store64(pp + (7 * 8), AV1_PARTITION_NONE);
    store64(pp + (8 * 8), AV1_PARTITION_NONE);
    store64(pp + (9 * 8), AV1_PARTITION_SPLIT);
    var pf = alloc(10 * 8);
    store64(pf + (0 * 8), it_blk(8, 8));
    store64(pf + (1 * 8), it_blk(8, 8));
    store64(pf + (2 * 8), it_blk(8, 8));
    store64(pf + (3 * 8), it_blk(8, 8));
    store64(pf + (4 * 8), it_blk(8, 8));
    store64(pf + (5 * 8), it_blk(8, 8));
    store64(pf + (6 * 8), itw_blk_filt(m0r, m0c, f0d0, f0d1));
    store64(pf + (7 * 8), itw_blk_filt(m1r, m1c, f1d0, f1d1));
    store64(pf + (8 * 8), itw_blk_filt(m2r, m2c, f2d0, f2d1));
    store64(pf + (9 * 8), itw_blk_filt(m3r, m3c, f3d0, f3d1));
    var ef = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    assert_eq(av1_tile_set_inter_ctx(et, fh, refs, seq, dpb), DR_OK, "sub8 filt: enc ctx");
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "sub8 filt: tile encoded");
    var df = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "sub8 filt: tile decodes");
    # each 2x2 chroma quadrant uses its sibling's MV AND its sibling's filter pair, with
    # filt_x = dir1 and filt_y = dir0.
    var cf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(cf, ref, 1, 12, 12, 2, 2, m0r, m0c, f0d1, f0d0);
    av1_mc_pred_block(cf, ref, 1, 14, 12, 2, 2, m1r, m1c, f1d1, f1d0);
    av1_mc_pred_block(cf, ref, 1, 12, 14, 2, 2, m2r, m2c, f2d1, f2d0);
    av1_mc_pred_block(cf, ref, 1, 14, 14, 2, 2, m3r, m3c, f3d1, f3d0);
    var cd = 0;
    var cy = 12;
    while (cy < 16) {
        var cx = 12;
        while (cx < 16) {
            if (dr_frame_get(df, 1, cx, cy) != dr_frame_get(cf, 1, cx, cy)) { cd = cd + 1; }
            cx = cx + 1;
        }
        cy = cy + 1;
    }
    assert_eq(cd, 0, "sub8 filt: each quadrant borrows its sibling's dir0/dir1 filter pair");
    # the fixture is only live if swapping the pair actually moves pixels — prove it here
    # rather than trusting the mutation to be meaningful.
    var sw = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(sw, ref, 1, 12, 12, 2, 2, m0r, m0c, f0d0, f0d1);
    var moved = 0;
    var sy2 = 12;
    while (sy2 < 14) {
        var sx2 = 12;
        while (sx2 < 14) {
            if (dr_frame_get(sw, 1, sx2, sy2) != dr_frame_get(cf, 1, sx2, sy2)) { moved = moved + 1; }
            sx2 = sx2 + 1;
        }
        sy2 = sy2 + 1;
    }
    assert_eq(moved > 0, 1, "sub8 filt: a dir0/dir1 swap DOES move pixels (fixture is live)");
    return 0;
}

fn test_inter_chroma_sibling_mvs() {
    var oe = alloc(8);
    var fh = it_fh();
    var refs = it_refs();
    var seq = it_seq();
    var dpb = av1_dpb_new();
    var ref = itw_ref420_hc(32, 32, 8, 8, fh, refs, seq, dpb);
    # four DISTINCT MVs, each with a distinct dx + 2*dy so they cannot alias even on a ramp.
    var m0r = 0;      var m0c = 16;     # sibling (6,6) -> chroma quadrant (12,12)
    var m1r = 16;     var m1c = 0;      # sibling (6,7) -> chroma quadrant (14,12)
    var m2r = 0 - 16; var m2c = 0 - 16; # sibling (7,6) -> chroma quadrant (12,14)
    var m3r = 32;     var m3c = 16;     # sibling (7,7) -> chroma quadrant (14,14)
    # the walker consumes one plan entry per >=8x8 recursion level, so the full nested chain
    # down to the four 4x4 leaves at MI (6..7, 6..7) must be spelled out.
    var pp = alloc(10 * 8);
    store64(pp + (0 * 8), AV1_PARTITION_SPLIT);   # 64 SB (forced: frame is 32x32)
    store64(pp + (1 * 8), AV1_PARTITION_SPLIT);   # 32 TL — the only in-frame quadrant
    store64(pp + (2 * 8), AV1_PARTITION_NONE);    # 16 @ (0,0)
    store64(pp + (3 * 8), AV1_PARTITION_NONE);    # 16 @ (0,4)
    store64(pp + (4 * 8), AV1_PARTITION_NONE);    # 16 @ (4,0)
    store64(pp + (5 * 8), AV1_PARTITION_SPLIT);   # 16 @ (4,4)
    store64(pp + (6 * 8), AV1_PARTITION_NONE);    # 8 @ (4,4)
    store64(pp + (7 * 8), AV1_PARTITION_NONE);    # 8 @ (4,6)
    store64(pp + (8 * 8), AV1_PARTITION_NONE);    # 8 @ (6,4)
    store64(pp + (9 * 8), AV1_PARTITION_SPLIT);   # 8 @ (6,6) -> the four 4x4 leaves
    var pf = alloc(10 * 8);
    store64(pf + (0 * 8), it_blk(8, 8));          # filler 16x16 blocks
    store64(pf + (1 * 8), it_blk(8, 8));
    store64(pf + (2 * 8), it_blk(8, 8));
    store64(pf + (3 * 8), it_blk(8, 8));          # filler 8x8 blocks
    store64(pf + (4 * 8), it_blk(8, 8));
    store64(pf + (5 * 8), it_blk(8, 8));
    store64(pf + (6 * 8), it_blk(m0r, m0c));      # the four 4x4 leaves, in walk order
    store64(pf + (7 * 8), it_blk(m1r, m1c));
    store64(pf + (8 * 8), it_blk(m2r, m2c));
    store64(pf + (9 * 8), it_blk(m3r, m3c));
    var ef = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var et = av1_tile_new(ef, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(et);
    assert_eq(av1_tile_set_inter_ctx(et, fh, refs, seq, dpb), DR_OK, "sub8 chroma: enc ctx");
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "sub8 chroma: tile encoded (the encode gate is lifted)");
    var df = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    var dt = av1_tile_new(df, 8, 8, 40, 1, 0, 3);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK,
    "sub8 chroma: tile decodes (was DR_ERR_UNSUPPORTED)");
    # LUMA: each 4x4 leaf predicted with its OWN motion vector.
    var lf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(lf, ref, 0, 24, 24, 4, 4, m0r, m0c, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(lf, ref, 0, 28, 24, 4, 4, m1r, m1c, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(lf, ref, 0, 24, 28, 4, 4, m2r, m2c, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(lf, ref, 0, 28, 28, 4, 4, m3r, m3c, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var ld = 0;
    var y = 24;
    while (y < 32) {
        var x = 24;
        while (x < 32) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(lf, 0, x, y)) { ld = ld + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(ld, 0, "sub8 chroma: each 4x4 LUMA leaf uses its own MV (64 px)");
    # CHROMA: the 4x4 unit at (12,12) is FOUR 2x2 quadrants, each borrowing its sibling's MV.
    # This is the assertion the whole bite exists for — and the only one that can redden if
    # the 0.7.112 storage-loop hoist is reverted, since luma never reads the MI grid.
    var p1 = 1;
    while (p1 < 3) {
        var cf = dr_frame_new(32, 32, 3, 1, 1, 8, 8, oe);
        av1_mc_pred_block(cf, ref, p1, 12, 12, 2, 2, m0r, m0c, AV1_EIGHTTAP, AV1_EIGHTTAP);
        av1_mc_pred_block(cf, ref, p1, 14, 12, 2, 2, m1r, m1c, AV1_EIGHTTAP, AV1_EIGHTTAP);
        av1_mc_pred_block(cf, ref, p1, 12, 14, 2, 2, m2r, m2c, AV1_EIGHTTAP, AV1_EIGHTTAP);
        av1_mc_pred_block(cf, ref, p1, 14, 14, 2, 2, m3r, m3c, AV1_EIGHTTAP, AV1_EIGHTTAP);
        var cd = 0;
        var cy = 12;
        while (cy < 16) {
            var cx = 12;
            while (cx < 16) {
                if (dr_frame_get(df, p1, cx, cy) != dr_frame_get(cf, p1, cx, cy)) { cd = cd + 1; }
                cx = cx + 1;
            }
            cy = cy + 1;
        }
        assert_eq(cd, 0, "sub8 chroma: each 2x2 quadrant borrows ITS sibling's MV (16 px)");
        # the four quadrants must differ PAIRWISE — otherwise the borrow is untested and a
        # wrong-sibling mutation would pass. Compare each quadrant's top-left sample.
        var q0 = dr_frame_get(cf, p1, 12, 12);
        var q1 = dr_frame_get(cf, p1, 14, 12);
        var q2 = dr_frame_get(cf, p1, 12, 14);
        var q3 = dr_frame_get(cf, p1, 14, 14);
        var same = 0;
        if (q0 == q1) { same = same + 1; }
        if (q0 == q2) { same = same + 1; }
        if (q0 == q3) { same = same + 1; }
        if (q1 == q2) { same = same + 1; }
        if (q1 == q3) { same = same + 1; }
        if (q2 == q3) { same = same + 1; }
        assert_eq(same, 0, "sub8 chroma: the four quadrants are pairwise DISTINCT (fixture is live)");
        p1 = p1 + 1;
    }
    return 0;
}
# REFERENCE-FRAME SELECTION: GOLDEN maps to DPB slot 3 (the gradient); slot 0
# holds a DIFFERENT frame (flat 200) — a decoder that hardcodes LAST or slot 0
# yields flat pixels and the oracle catches it (the review found every prior
# fixture used LAST -> slot 0, so the selection was oracle-invisible).
fn test_inter_ref_selection() {
    var oe = alloc(8);
    var flat = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    dr_frame_fill(flat, 0, 200);
    var grad = it_ref_frame();
    var fh = it_fh();
    var dpb = av1_dpb_new();
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 247);    # slots 0..7 except 3: flat
    av1_dpb_store(dpb, fh, flat);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 8);      # slot 3: the gradient
    av1_dpb_store(dpb, fh, grad);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    store64(fh + AV1FH_REF_FRAME_IDX + 24, 3);       # ref_frame_idx[GOLDEN-LAST] = 3
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 24, 64);
    store64(refs + AV1REF_FRAME_W + 24, 64);
    store64(refs + AV1REF_FRAME_H + 24, 64);
    var seq = it_seq();
    var blk = it_blk(16, 8);
    store64(blk + AV1FB_IB + AV1IB_REF0, AV1_GOLDEN_FRAME);
    var tlen = 0;
    var tb = it_enc_tile(dpb, refs, seq, fh, blk, &tlen);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "GOLDEN-ref tile decodes");
    var xf = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, grad, 0, 0, 0, 64, 64, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 64) {
        var x = 0;
        while (x < 64) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "pixels come from GOLDEN's slot (the gradient), not slot 0");
    assert_eq(load64(av1_mv_grid_cell(load64(dt + AV1TILE_MVGRID), 16, 4, 4) + AV1MIR_REF0),
    AV1_GOLDEN_FRAME, "MI grid: GOLDEN stored");
    return 0;
}
# a NON-SB-ALIGNED frame (48x48, one 64x64 block overhanging): the visible-extent
# clamps bind. The decode must (a) match the 48x48 oracle exhaustively and (b)
# write NOTHING outside the visible frame — the border stays zero (the review
# found deleting both clamps survived: every prior fixture was SB-aligned).
fn test_inter_edge_clamp() {
    var oe = alloc(8);
    var ref = dr_frame_new(48, 48, 1, 0, 0, 8, 8, oe);
    var y0 = 0;
    while (y0 < 48) {
        var x0 = 0;
        while (x0 < 48) {
            dr_frame_set(ref, 0, x0, y0, (x0 + (2 * y0)) & 255);
            x0 = x0 + 1;
        }
        y0 = y0 + 1;
    }
    var fh = it_fh();
    store64(fh + AV1FH_FRAME_WIDTH, 48);
    store64(fh + AV1FH_FRAME_HEIGHT, 48);
    store64(fh + AV1FH_UPSCALED_WIDTH, 48);
    store64(fh + AV1FH_MI_COLS, 12);
    store64(fh + AV1FH_MI_ROWS, 12);
    store64(fh + AV1FH_MI_COL_STARTS + 8, 12);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, 12);
    var refs = it_refs();
    store64(refs + AV1REF_UPSCALED_W + 0, 48);
    store64(refs + AV1REF_FRAME_W + 0, 48);
    store64(refs + AV1REF_FRAME_H + 0, 48);
    var seq = it_seq();
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var tlen = 0;
    var tb = itx_enc_tile(dpb, refs, seq, fh, it_blk(16, 8), 48, 48, 1, 0, 0, 12, 12, 40, &tlen);
    assert_eq(tlen > 0, 1, "48x48 inter tile encoded");
    var df = dr_frame_new(48, 48, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 12, 12, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "48x48 inter tile decodes");
    var xf = dr_frame_new(48, 48, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 48, 48, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var diff = 0;
    var y = 0;
    while (y < 48) {
        var x = 0;
        while (x < 48) {
            if (dr_frame_get(df, 0, x, y) != dr_frame_get(xf, 0, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    assert_eq(diff, 0, "visible 48x48 == the MC oracle (exhaustive)");
    # the overhang wrote NOTHING: rows/cols past the visible frame stay zero
    # (read the plane raw — dr_frame_get would be defined only for the frame).
    var pptr = load64(df + DR_FRAME_PLANE_PTR);
    var pstride = load64(df + DR_FRAME_PLANE_STRIDE);
    assert_eq(load16(pptr + (((50 * pstride) + 10) * 2)), 0, "no writes below the frame");
    assert_eq(load16(pptr + (((10 * pstride) + 50) * 2)), 0, "no writes right of the frame");
    return 0;
}
# LOSSLESS (base_q 0): read_tx_size's Lossless early-out forces TX_4X4 for skip
# inter blocks too — the recorded LoopfilterTxSizes must be 0, not max-rect.
fn test_inter_lossless_tx4x4() {
    var oe = alloc(8);
    var ref = it_ref_frame();
    var fh = it_fh();
    store64(fh + AV1FH_BASE_Q_IDX, 0);
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var refs = it_refs();
    var seq = it_seq();
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 0, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, it_blk(16, 8));
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    # BOTH lanes record TX_4X4 into their grids (the write side stores too).
    assert_eq(av1_lftx_get(et, 0, 4, 4), 0, "lossless LFTX on the WRITE side too");
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 0, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "lossless inter tile decodes");
    assert_eq(dr_frame_get(df, 0, 10, 10), ((10 + 1) + (2 * (10 + 2))) & 255,
    "lossless pixels: the shifted gradient");
    assert_eq(av1_lftx_get(dt, 0, 4, 4), 0, "lossless LFTX = TX_4X4, not max-rect");
    return 0;
}
# TILE-WINDOW availability (5.11.4): a windowed tile's above/left availability is
# tile-relative, not frame-absolute — pinned DIRECTLY on av1_inter_block_setup
# (the review found replacing av1_is_inside with r>0/c>0 survived the suite).
fn test_inter_window_avail() {
    var oe = alloc(8);
    var df = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_window(dt, 8, 0, 16, 16);           # cols 8..16: a right-half tile
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, it_ref_frame());
    av1_tile_set_inter_ctx(dt, fh, it_refs(), it_seq(), dpb);
    var st = alloc(40);
    # the tile-origin block: LEFT (frame col 7) is outside the WINDOW -> avail 0
    # (frame-absolute c>0 would say 1); ABOVE is outside the frame -> avail 0.
    av1_inter_block_setup(dt, 0, 8, 3, st);
    assert_eq(load64(st + 0), 0, "window origin: avail_u 0");
    assert_eq(load64(st + 8), 0, "window origin: avail_l 0 (tile-relative, not frame)");
    # an interior block reads its planted neighbours through the grids.
    av1_grid_set(dt, AV1TILE_SKIPS, 3, 12, 1);
    av1_grid_set(dt, AV1TILE_SKIPS, 4, 11, 1);
    av1_grid_set(dt, AV1TILE_SKIPMODES, 3, 12, 1);
    av1_grid_set(dt, AV1TILE_SKIPMODES, 4, 11, 1);
    av1_inter_block_setup(dt, 4, 12, 3, st);
    assert_eq(load64(st + 0), 1, "interior: avail_u 1");
    assert_eq(load64(st + 8), 1, "interior: avail_l 1");
    assert_eq(load64(st + 16), 1, "interior: above_skip read");
    assert_eq(load64(st + 24), 1, "interior: left_skip read");
    assert_eq(load64(st + 32), 2, "interior: skip-mode ctx = above + left");
    return 0;
}
# GRID SHARING: av1_tile_share_grids hands the frame-addressed MV grid and the
# SkipModes grid to the next tile, and set_inter_ctx PRESERVES them (alloc only
# if absent) — pinned structurally (the review found the two share lines had no
# witness).
fn test_inter_share_grids() {
    var oe = alloc(8);
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, it_ref_frame());
    var refs = it_refs();
    var seq = it_seq();
    var t1 = av1_tile_new(dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe), 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(t1);
    av1_tile_set_inter_ctx(t1, fh, refs, seq, dpb);
    assert_eq(load64(t1 + AV1TILE_MVGRID) != 0, 1, "tile 1 allocated the MV grid");
    var t2 = av1_tile_new(dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe), 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(t2);
    av1_tile_share_grids(t2, t1);
    av1_tile_set_inter_ctx(t2, fh, refs, seq, dpb);
    assert_eq(load64(t2 + AV1TILE_MVGRID), load64(t1 + AV1TILE_MVGRID),
    "tile 2 SHARES tile 1's MV grid (set_inter_ctx preserved it)");
    assert_eq(load64(t2 + AV1TILE_SKIPMODES), load64(t1 + AV1TILE_SKIPMODES),
    "tile 2 SHARES tile 1's SkipModes grid");
    return 0;
}
# a CDEF-wired encode tile WITHOUT a cdef plan is REFUSED (the plan slot is the
# write lane's; unset it would null-deref in av1_write_cdef on a non-skip block).
fn test_inter_cdef_plan_refused() {
    var oe = alloc(8);
    var dpb = av1_dpb_new();
    var fh = it_fh();
    av1_dpb_store(dpb, fh, it_ref_frame());
    var ef = dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    assert_eq(av1_tile_set_cdef_ctx(et, 1, 3, 0, 0, 0), DR_OK, "cdef ctx wired, NO plan");
    av1_tile_set_inter_ctx(et, fh, it_refs(), it_seq(), dpb);
    var pp = alloc(8);
    store64(pp + 0, AV1_PARTITION_NONE);
    var pf = alloc(8);
    store64(pf + 0, it_blk(16, 8));
    var elen = 0;
    assert_eq(av1_encode_inter_tile(et, pp, pf, 1, &elen), 0,
    "a cdef-wired encode tile without a plan is REFUSED, never a null deref");
    assert_eq(elen, 0, "the refused cdef encode emits no bytes");
    # and a WIRED plan is carried into the ICDEF bundle (the write lane's slot).
    var plan = alloc(8);
    var e2 = av1_tile_new(dr_frame_new(64, 64, 1, 0, 0, 8, 8, oe), 16, 16, 40, 1, 0, 1);
    av1_tile_grids_new(e2);
    av1_tile_set_cdef_ctx(e2, 1, 3, 0, 0, plan);
    av1_tile_set_inter_ctx(e2, fh, it_refs(), it_seq(), dpb);
    assert_eq(load64(load64(e2 + AV1TILE_ICDEF) + 48), plan, "ICDEF carries the cdef plan");
    return 0;
}
# the KEY header builder round-trips through the REAL parser too (the review
# found its only witness was the stream E2E's flat pixels).
fn test_key_header_parseback() {
    var slen = 0;
    var sb = its_build_seq(&slen);
    var se = alloc(8);
    var seq = av1_seq_parse(sb, slen, se);
    var klen = 0;
    var kb = its_build_key_fh(&klen);
    var refs = av1_ref_state_new();
    var fe = alloc(8);
    var fh = av1_frame_parse_uncompressed_header(seq, refs, 0, 0, kb, klen, fe);
    assert_eq(load64(fe), DR_OK, "the KEY frame header parses");
    assert_eq(av1_fh_frame_type(fh), 0, "key fh: KEY");
    assert_eq(av1_fh_frame_is_intra(fh), 1, "key fh: intra");
    assert_eq(av1_fh_frame_width(fh), 64, "key fh: width 64");
    assert_eq(av1_fh_frame_height(fh), 64, "key fh: height 64");
    assert_eq(av1_fh_refresh_frame_flags(fh), 255, "key fh: refresh 255 (implied)");
    assert_eq(av1_fh_base_q_idx(fh), 40, "key fh: base_q 40");
    assert_eq(av1_fh_tx_mode(fh), AV1_TX_MODE_SELECT, "key fh: TX_MODE_SELECT");
    assert_eq(av1_fh_disable_cdf_update(fh), 1, "key fh: cdf update off");
    assert_eq((av1_fh_bits_consumed(fh) + 7) >> 3, klen, "every KEY byte consumed");
    return 0;
}

# ================================================================
# THE NON-SKIP INTER RESIDUAL (0.7.85, UNIFORM-TX): a genuine non-skip inter
# block decodes with the reconstructed residual added onto the MC prediction.
# Round-trip (encode -> decode) with an INDEPENDENT oracle: MC (av1_mc_pred_block)
# + reconstruct (av1_reconstruct) composed here, both already reference-verified,
# with the KNOWN planted coeffs + tx types. The inter tx-type derivation is cross-
# checked against scripts/refs/inter_residual_ref.py. Per-set coverage (INTER_1/2/3),
# mono + 4:2:0, and the var-tx scope gate.
# ================================================================
fn ir_ref(w, h, planes, sx, sy): i64 {
    var oe = alloc(8);
    var f = dr_frame_new(w, h, planes, sx, sy, 8, 8, oe);
    var p = 0;
    while (p < planes) {
        var pw = w;
        var ph = h;
        if (p > 0) { pw = w >> sx; ph = h >> sy; }
        var y = 0;
        while (y < ph) {
            var x = 0;
            while (x < pw) {
                var v = (x + (2 * y)) & 255;
                if (p == 1) { v = ((2 * x) + y) & 255; }
                if (p == 2) { v = (x + (3 * y)) & 255; }
                dr_frame_set(f, p, x, y, v);
                x = x + 1;
            }
            y = y + 1;
        }
        p = p + 1;
    }
    return f;
}
# A HIGH-CONTRAST, NON-LINEAR mono reference plane.
#
# ir_ref above fills with v = x + 2*y — a linear ramp. Every AV1 sub-pel filter is designed
# to reproduce a linear function exactly, so on that plane BILINEAR, EIGHTTAP and SHARP all
# return bit-identical pixels: the fixture cannot witness WHICH filter ran (the same
# secretly-an-identity trap OBMC hit at 0.7.101, where the x+2y gradient made a blend a
# no-op). Any test that discriminates between interpolation filters must use this instead.
fn ir_ref_hc(w, h): i64 {
    var oe = alloc(8);
    var f = dr_frame_new(w, h, 1, 0, 0, 8, 8, oe);
    var y = 0;
    while (y < h) {
        var x = 0;
        while (x < w) {
            dr_frame_set(f, 0, x, y, (((x * 37) + (y * 53)) + (((x * y) % 7) * 29)) & 255);
            x = x + 1;
        }
        y = y + 1;
    }
    return f;
}
fn ir_fh(w, h, mic, mir, tx_mode): i64 {
    var fh = alloc(AV1FH_SIZE);
    memset(fh, 0, AV1FH_SIZE);
    store64(fh + AV1FH_FRAME_WIDTH, w);
    store64(fh + AV1FH_FRAME_HEIGHT, h);
    store64(fh + AV1FH_UPSCALED_WIDTH, w);
    store64(fh + AV1FH_MI_COLS, mic);
    store64(fh + AV1FH_MI_ROWS, mir);
    store64(fh + AV1FH_BASE_Q_IDX, 40);
    store64(fh + AV1FH_TX_MODE, tx_mode);
    store64(fh + AV1FH_DISABLE_CDF_UPDATE, 1);
    store64(fh + AV1FH_ALLOW_HIGH_PREC_MV, 1);
    store64(fh + AV1FH_REFRESH_FRAME_FLAGS, 255);
    store64(fh + AV1FH_TILE_COLS, 1);
    store64(fh + AV1FH_TILE_ROWS, 1);
    store64(fh + AV1FH_TILE_SIZE_BYTES, 1);
    store64(fh + AV1FH_MI_COL_STARTS + 8, mic);
    store64(fh + AV1FH_MI_ROW_STARTS + 8, mir);
    return fh;
}
fn ir_refs(w, h): i64 {
    var refs = av1_ref_state_new();
    store64(refs + AV1REF_UPSCALED_W + 0, w);
    store64(refs + AV1REF_FRAME_W + 0, w);
    store64(refs + AV1REF_FRAME_H + 0, h);
    return refs;
}
fn ir_seq(planes, sx, sy): i64 {
    var s = alloc(AV1_SEQ_SIZE);
    memset(s, 0, AV1_SEQ_SIZE);
    store64(s + AV1_SEQ_BITDEPTH, 8);
    store64(s + AV1_SEQ_NUM_PLANES, planes);
    store64(s + AV1_SEQ_SUBX, sx);
    store64(s + AV1_SEQ_SUBY, sy);
    return s;
}
fn ir_blk(mvr, mvc, resid): i64 {
    var b = av1_blockinfo_new();
    store64(b + AV1FB_SKIP, 0);
    store64(b + AV1FB_ISINTER, 1);
    var ib = b + AV1FB_IB;
    store64(ib + AV1IB_REF0, AV1_LAST_FRAME);
    store64(ib + AV1IB_REF1, AV1_REF_NONE);
    store64(ib + AV1IB_YMODE, AV1_NEWMV);
    store64(ib + AV1IB_MV0 + AV1MV_ROW, mvr);
    store64(ib + AV1IB_MV0 + AV1MV_COL, mvc);
    store64(ib + AV1IB_MOTIONMODE, AV1_MM_SIMPLE);
    store64(ib + AV1IB_INTERP + 0, AV1_EIGHTTAP);
    store64(ib + AV1IB_INTERP + 8, AV1_EIGHTTAP);
    store64(ib + AV1IB_CT + AV1CT_COMPIDX, 1);
    av1_fb_set_resid(b, resid);
    return b;
}
fn ir_plan(pp, nsplit): i64 {
    var i = 0;
    while (i < nsplit) { store64(pp + (i * 8), AV1_PARTITION_SPLIT); i = i + 1; }
    store64(pp + (nsplit * 8), AV1_PARTITION_NONE);
    return 0;
}
# encode a single non-skip block frame, decode it, return the decoded frame.
fn ir_roundtrip(ref, fh, refs, seq, blk, nsplit, w, h, planes, sx, sy, mic, mir): i64 {
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var oe = alloc(8);
    var ef = dr_frame_new(w, h, planes, sx, sy, 8, 8, oe);
    var et = av1_tile_new(ef, mic, mir, 40, 1, 0, planes);
    av1_tile_grids_new(et);
    assert_eq(av1_tile_set_inter_ctx(et, fh, refs, seq, dpb), DR_OK, "ir enc ctx");
    var pp = alloc((nsplit + 1) * 8);
    ir_plan(pp, nsplit);
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "ir encoded payload");
    assert_eq(av1_sym_enc_err(load64(et + AV1TILE_ENC)), DR_OK, "ir no enc err");
    var df = dr_frame_new(w, h, planes, sx, sy, 8, 8, oe);
    var dt = av1_tile_new(df, mic, mir, 40, 1, 0, planes);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "ir decodes");
    return df;
}
# oracle: MC each plane + reconstruct(residual) with the given per-plane tx types.
# ir_oracle keeps its original 13-arg shape (EIGHTTAP) and delegates; ir_oracle_f takes the
# interpolation filter. A new param was NOT added to ir_oracle itself because Cyrius does not
# hard-fail a wrong ARG COUNT (the 0.7.77 lesson) — every existing call site would have
# compiled while silently reading garbage for the new trailing argument.
fn ir_oracle(ref, mvr, mvc, resid, w, h, planes, sx, sy, sub_size, tx_size_luma, tx_luma, chroma_tt): i64 {
    return ir_oracle_f(ref, mvr, mvc, resid, w, h, planes, sx, sy, sub_size, tx_size_luma,
    tx_luma, chroma_tt, AV1_EIGHTTAP);
}
fn ir_oracle_f(ref, mvr, mvc, resid, w, h, planes, sx, sy, sub_size, tx_size_luma, tx_luma,
chroma_tt, filt): i64 {
    var oe = alloc(8);
    var xf = dr_frame_new(w, h, planes, sx, sy, 8, 8, oe);
    var q_dc = av1_get_dc_quant(8, 40, 0);
    var q_ac = av1_get_ac_quant(8, 40, 0);
    var p = 0;
    while (p < planes) {
        var pw = w;
        var ph = h;
        if (p > 0) { pw = w >> sx; ph = h >> sy; }
        av1_mc_pred_block(xf, ref, p, 0, 0, pw, ph, mvr, mvc, filt, filt);
        var eob = load64(resid + ((1 + (p * 2)) * 8));
        var coeff = load64(resid + ((2 + (p * 2)) * 8));
        if (eob > 0) {
            var ptx = av1_get_tx_size(p, tx_size_luma, sub_size, sx, sy);
            var tt = tx_luma;
            if (p > 0) { tt = chroma_tt; }
            av1_reconstruct(xf, p, 0, 0, ptx, tt, 0, coeff, q_dc, q_ac);
        }
        p = p + 1;
    }
    return xf;
}
fn ir_diff(a, b, w, h, planes, sx, sy): i64 {
    var diff = 0;
    var p = 0;
    while (p < planes) {
        var pw = w;
        var ph = h;
        if (p > 0) { pw = w >> sx; ph = h >> sy; }
        var y = 0;
        while (y < ph) {
            var x = 0;
            while (x < pw) {
                if (dr_frame_get(a, p, x, y) != dr_frame_get(b, p, x, y)) { diff = diff + 1; }
                x = x + 1;
            }
            y = y + 1;
        }
        p = p + 1;
    }
    return diff;
}
fn ir_diff_p(a, b, plane, pw, ph): i64 {
    var diff = 0;
    var y = 0;
    while (y < ph) {
        var x = 0;
        while (x < pw) {
            if (dr_frame_get(a, plane, x, y) != dr_frame_get(b, plane, x, y)) { diff = diff + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    return diff;
}
# a 1-plane residual plan (luma tx type + eob + coeff buffer).
fn ir_resid1(luma_tt, eob, coeff): i64 {
    var r = alloc(8 * 8);
    memset(r, 0, 8 * 8);
    store64(r + 0, luma_tt);
    store64(r + (1 * 8), eob);
    store64(r + (2 * 8), coeff);
    return r;
}

# ============ per-set residual round-trip (mono) ============
# INTER_1 (BLOCK_8X8 -> TX_8X8): a DC + AC residual, ADST_DCT luma tx.
fn test_ir_inter1() {
    var ref = ir_ref(8, 8, 1, 0, 0);
    var fh = ir_fh(8, 8, 2, 2, AV1_TX_MODE_LARGEST);
    var refs = ir_refs(8, 8);
    var seq = ir_seq(1, 0, 0);
    var coeff = alloc(1024 * 8);
    memset(coeff, 0, 1024 * 8);
    store64(coeff + 0, 90);              # DC
    store64(coeff + (1 * 8), 0 - 40);    # scan[1]
    var resid = ir_resid1(AV1_ADST_DCT, 2, coeff);
    var blk = ir_blk(8, 0 - 4, resid);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 3, 8, 8, 1, 0, 0, 2, 2);
    var xf = ir_oracle(ref, 8, 0 - 4, resid, 8, 8, 1, 0, 0, AV1_BLOCK_8X8, 1, AV1_ADST_DCT, 0);
    assert_eq(ir_diff(df, xf, 8, 8, 1, 0, 0), 0, "INTER_1 8x8: decode == MC+residual oracle (64)");
    return 0;
}
# BILINEAR end-to-end (0.7.108): the frame header's interpolation_filter f(2) == BILINEAR.
# This is the ONLY way BILINEAR reaches a block — the SWITCHABLE per-block symbol has a
# 3-value alphabet (EIGHTTAP/SMOOTH/SHARP) and can never code it, so a fixture that sets the
# BLOCK's filter instead of the HEADER's would prove nothing: av1_read_interp_filters
# overwrites both directions from the frame-level value whenever it is not SWITCHABLE.
# The MV is deliberately sub-pel on BOTH axes — at an integer position every filter
# degenerates to a copy and the test would pass no matter which set were selected.
#
# WHAT THIS TEST PROVES, AND WHAT IT DOES NOT. Its oracle calls av1_mc_pred_block with
# BILINEAR, so it shares av1_mc_filter_set with the code under test — a COMPLEMENTARY
# oracle, not an independent one. Verified by mutation: deleting the `f == 3` branch in
# av1_mc_filter_set leaves this test GREEN (decode and oracle move together), while
# breaking the header->block plumbing (forcing EIGHTTAP in av1_read_interp_filters) turns
# it RED. So this test witnesses the PLUMBING — that a BILINEAR frame header actually
# reaches the kernel — and the set-selection MATHS is pinned elsewhere, by the
# tests/av1_mc_driver.tcyr b01..b14 known answers, whose goldens come from the
# spec-convention scripts/refs/bilinear_mc_ref.py and share no code with drishti.
fn test_ir_bilinear() {
    var ref = ir_ref_hc(16, 16);   # NOT ir_ref — a linear ramp cannot distinguish filters
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST);
    store64(fh + AV1FH_INTERP_FILTER, AV1_BILINEAR);
    assert_eq(av1_fh_interpolation_filter(fh), 3, "fh: interpolation_filter = BILINEAR");
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    var coeff = alloc(1024 * 8);
    memset(coeff, 0, 1024 * 8);
    store64(coeff + 0, 0 - 120);
    store64(coeff + (1 * 8), 55);
    var resid = ir_resid1(AV1_DCT_ADST, 2, coeff);
    var blk = ir_blk(0 - 6, 10, resid);          # mvr/mvc both sub-pel (1/8 pel, not /8)
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 1, 0, 0, 4, 4);
    # decodes to BILINEAR-filtered pixels...
    var xb = ir_oracle_f(ref, 0 - 6, 10, resid, 16, 16, 1, 0, 0, 6, 2, AV1_DCT_ADST, 0,
    AV1_BILINEAR);
    assert_eq(ir_diff(df, xb, 16, 16, 1, 0, 0), 0, "BILINEAR e2e: decode == bilinear oracle");
    # ...and NOT to EIGHTTAP pixels. Without this the test would pass even if the header
    # value never reached the kernel.
    var xe = ir_oracle_f(ref, 0 - 6, 10, resid, 16, 16, 1, 0, 0, 6, 2, AV1_DCT_ADST, 0,
    AV1_EIGHTTAP);
    assert_eq(ir_diff(df, xe, 16, 16, 1, 0, 0) > 0, 1, "BILINEAR e2e: differs from EIGHTTAP");
    return 0;
}

# INTER_2 (BLOCK_16X16 -> TX_16X16): DCT_ADST luma tx (in INTER_2).
fn test_ir_inter2() {
    var ref = ir_ref(16, 16, 1, 0, 0);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    var coeff = alloc(1024 * 8);
    memset(coeff, 0, 1024 * 8);
    store64(coeff + 0, 0 - 120);
    store64(coeff + (1 * 8), 55);
    var resid = ir_resid1(AV1_DCT_ADST, 2, coeff);
    var blk = ir_blk(0 - 6, 10, resid);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 1, 0, 0, 4, 4);
    var xf = ir_oracle(ref, 0 - 6, 10, resid, 16, 16, 1, 0, 0, 6, 2, AV1_DCT_ADST, 0);
    assert_eq(ir_diff(df, xf, 16, 16, 1, 0, 0), 0, "INTER_2 16x16: decode == oracle (256)");
    return 0;
}
# INTER_3 (BLOCK_32X32 -> TX_32X32): only DCT_DCT / IDTX. Use IDTX.
fn test_ir_inter3() {
    var ref = ir_ref(32, 32, 1, 0, 0);
    var fh = ir_fh(32, 32, 8, 8, AV1_TX_MODE_LARGEST);
    var refs = ir_refs(32, 32);
    var seq = ir_seq(1, 0, 0);
    var coeff = alloc(1024 * 8);
    memset(coeff, 0, 1024 * 8);
    store64(coeff + 0, 200);
    var resid = ir_resid1(AV1_IDTX, 1, coeff);
    var blk = ir_blk(16, 8, resid);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 1, 32, 32, 1, 0, 0, 8, 8);
    var xf = ir_oracle(ref, 16, 8, resid, 32, 32, 1, 0, 0, 9, 3, AV1_IDTX, 0);
    assert_eq(ir_diff(df, xf, 32, 32, 1, 0, 0), 0, "INTER_3 32x32 IDTX: decode == oracle (1024)");
    return 0;
}
# 4:2:0 chroma residual: 16x16 luma (INTER_2), 8x8 chroma. Luma ADST_DCT (in
# INTER_2 AND the chroma 8x8 set INTER_1) -> chroma tx type ADST_DCT (co-located).
fn test_ir_420() {
    var ref = ir_ref(16, 16, 3, 1, 1);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(3, 1, 1);
    var cy = alloc(1024 * 8);
    memset(cy, 0, 1024 * 8);
    store64(cy + 0, 80);
    store64(cy + (1 * 8), 0 - 30);
    var cu = alloc(1024 * 8);
    memset(cu, 0, 1024 * 8);
    store64(cu + 0, 60);
    var cv = alloc(1024 * 8);
    memset(cv, 0, 1024 * 8);
    store64(cv + 0, 0 - 50);
    var r = alloc(8 * 8);
    memset(r, 0, 8 * 8);
    store64(r + 0, AV1_ADST_DCT);
    store64(r + (1 * 8), 2);  store64(r + (2 * 8), cy);
    store64(r + (3 * 8), 1);  store64(r + (4 * 8), cu);
    store64(r + (5 * 8), 1);  store64(r + (6 * 8), cv);
    var blk = ir_blk(0 - 6, 10, r);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 3, 1, 1, 4, 4);
    # chroma tx type = co-located luma ADST_DCT (spec-literal ref: in INTER_1 -> kept).
    var xf = ir_oracle(ref, 0 - 6, 10, r, 16, 16, 3, 1, 1, 6, 2, AV1_ADST_DCT, AV1_ADST_DCT);
    assert_eq(ir_diff(df, xf, 16, 16, 1, 0, 0), 0, "4:2:0 luma == oracle");
    assert_eq(ir_diff_p(df, xf, 1, 8, 8), 0, "4:2:0 U == oracle");
    assert_eq(ir_diff_p(df, xf, 2, 8, 8), 0, "4:2:0 V == oracle");
    return 0;
}
# non-skip with ZERO residual (all_zero path) == pure MC.
fn test_ir_zero() {
    var ref = ir_ref(16, 16, 1, 0, 0);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_LARGEST);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    var resid = ir_resid1(AV1_DCT_DCT, 0, 0);   # eob 0 -> all_zero
    var blk = ir_blk(16, 8, resid);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 1, 0, 0, 4, 4);
    var oe = alloc(8);
    var mcf = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(mcf, ref, 0, 0, 0, 16, 16, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    assert_eq(ir_diff(df, mcf, 16, 16, 1, 0, 0), 0, "zero residual non-skip == pure MC");
    return 0;
}

# ============ var-tx gate ============
# a var-tx leaf-coeff buffer: DC (+ optional AC at raster 1) for an 8x8 leaf.
fn ir_leaf_coeff(dc, ac): i64 {
    var b = alloc(1024 * 8);
    memset(b, 0, 1024 * 8);
    store64(b + 0, dc);
    if (ac != 0) { store64(b + (1 * 8), ac); }
    return b;
}
# THE VAR-TX ROUND-TRIP (0.7.86): a 16x16 luma block SPLIT into 4x TX_8X8, each leaf
# a DISTINCT tx type + residual. Encode (write_var_tx_size + per-leaf coeffs) ->
# decode -> pixels compared EXHAUSTIVELY against an INDEPENDENT oracle (MC + per-leaf
# reconstruct). transform_tree visits leaves TL, TR, BL, BR.
fn test_ir_vartx() {
    var ref = ir_ref(16, 16, 1, 0, 0);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_SELECT);   # var-tx
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    # target layout: every 4x4 luma cell -> TX_8X8 (1) = a single-level split.
    var target = alloc(16 * 8);
    var i = 0;
    while (i < 16) { store64(target + (i * 8), 1); i = i + 1; }
    var c0 = ir_leaf_coeff(60, 0 - 20);
    var c1 = ir_leaf_coeff(0 - 40, 25);
    var c2 = ir_leaf_coeff(50, 0);
    var c3 = ir_leaf_coeff(0 - 30, 0);
    var leaves = alloc(4 * 3 * 8);
    store64(leaves + (0 * 8), AV1_ADST_DCT);   store64(leaves + (1 * 8), 2);  store64(leaves + (2 * 8), c0);
    store64(leaves + (3 * 8), AV1_DCT_ADST);   store64(leaves + (4 * 8), 2);  store64(leaves + (5 * 8), c1);
    store64(leaves + (6 * 8), AV1_ADST_ADST);  store64(leaves + (7 * 8), 1);  store64(leaves + (8 * 8), c2);
    store64(leaves + (9 * 8), AV1_IDTX);       store64(leaves + (10 * 8), 1); store64(leaves + (11 * 8), c3);
    var vplan = alloc(8 * 8);
    memset(vplan, 0, 8 * 8);
    store64(vplan + 0, target);
    store64(vplan + (2 * 8), 4);
    store64(vplan + (3 * 8), leaves);
    var blk = ir_blk(16, 8, 0);
    av1_fb_set_vartx(blk, vplan);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 1, 0, 0, 4, 4);
    # oracle: MC the 16x16, then reconstruct each 8x8 leaf (TX_8X8=1) with its type.
    var oe = alloc(8);
    var xf = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 16, 16, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var q_dc = av1_get_dc_quant(8, 40, 0);
    var q_ac = av1_get_ac_quant(8, 40, 0);
    av1_reconstruct(xf, 0, 0, 0, 1, AV1_ADST_DCT, 0, ir_leaf_coeff(60, 0 - 20), q_dc, q_ac);
    av1_reconstruct(xf, 0, 8, 0, 1, AV1_DCT_ADST, 0, ir_leaf_coeff(0 - 40, 25), q_dc, q_ac);
    av1_reconstruct(xf, 0, 0, 8, 1, AV1_ADST_ADST, 0, ir_leaf_coeff(50, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 8, 8, 1, AV1_IDTX, 0, ir_leaf_coeff(0 - 30, 0), q_dc, q_ac);
    assert_eq(ir_diff(df, xf, 16, 16, 1, 0, 0), 0,
    "var-tx 16x16 -> 4x TX_8X8: decode == independent per-leaf oracle (256)");
    return 0;
}
# VAR-TX edge clamp (review CRITICAL): a var-tx leaf-fill that overhangs the tile
# window must NOT write past ROW_END/COL_END — the InterTxSizes grid is frame-sized
# (no SB padding). A CANARY past the grid must survive; without the clamp the fill
# OOBs the heap / corrupts a neighbour's InterTxSizes.
fn test_ir_vartx_edge_clamp() {
    var oe = alloc(8);
    var f = dr_frame_new(48, 48, 1, 0, 0, 8, 8, oe);
    var t = av1_tile_new(f, 12, 12, 40, 1, 0, 1);
    av1_tile_grids_new(t);
    store64(t + AV1TILE_FMI_COLS, 12);
    store64(t + AV1TILE_COL_END, 12);
    store64(t + AV1TILE_ROW_END, 12);
    # a 12x12 (=144-cell) InterTxSizes grid + 32 canary cells past the end.
    var grid = alloc((144 + 32) * 8);
    var k = 0;
    while (k < 176) { store64(grid + (k * 8), 0); k = k + 1; }
    var can = 0;
    while (can < 32) { store64(grid + ((144 + can) * 8), 0 - 999); can = can + 1; }
    store64(t + AV1TILE_INTERTX, grid);
    # a TX_32X32 forced leaf (depth == MAX_VARTX_DEPTH -> no symbol) at (8,8): its 8x8
    # footprint spans cols/rows 8..15, but only 8..11 are inside the 12x12 window.
    av1_read_var_tx_size(t, 8, 8, 3, AV1_MAX_VARTX_DEPTH, 9, 8, 8, 0, 0);
    var bad = 0;
    can = 0;
    while (can < 32) {
        if (load64(grid + ((144 + can) * 8)) != (0 - 999)) { bad = bad + 1; }
        can = can + 1;
    }
    assert_eq(bad, 0, "var-tx edge leaf-fill clamps to the window (no OOB past the grid)");
    assert_eq(load64(grid + ((8 * 12 + 8) * 8)), 3, "in-window leaf cell filled");
    assert_eq(load64(grid + ((11 * 12 + 11) * 8)), 3, "in-window leaf corner filled");
    return 0;
}
# VAR-TX at depth 2 with a NON-4x4 forced leaf: a 32x32 block split 32->16->8, so
# the 8x8 leaves are forced (depth == MAX_VARTX_DEPTH, no symbol) — NOT by the
# TX_4X4 gate. Kills the depth-gate mutant. Uniform leaves (order-independent).
fn test_ir_vartx_32() {
    var ref = ir_ref(32, 32, 1, 0, 0);
    var fh = ir_fh(32, 32, 8, 8, AV1_TX_MODE_SELECT);
    var refs = ir_refs(32, 32);
    var seq = ir_seq(1, 0, 0);
    var target = alloc(64 * 8);
    var i = 0;
    while (i < 64) { store64(target + (i * 8), 1); i = i + 1; }   # all TX_8X8
    var leaves = alloc(16 * 3 * 8);
    i = 0;
    while (i < 16) {
        store64(leaves + ((i * 3 + 0) * 8), AV1_DCT_DCT);
        store64(leaves + ((i * 3 + 1) * 8), 1);
        store64(leaves + ((i * 3 + 2) * 8), ir_leaf_coeff(30, 0));
        i = i + 1;
    }
    var vplan = alloc(8 * 8);
    memset(vplan, 0, 8 * 8);
    store64(vplan + 0, target);
    store64(vplan + (2 * 8), 16);
    store64(vplan + (3 * 8), leaves);
    var blk = ir_blk(16, 8, 0);
    av1_fb_set_vartx(blk, vplan);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 1, 32, 32, 1, 0, 0, 8, 8);
    var oe = alloc(8);
    var xf = dr_frame_new(32, 32, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 32, 32, 16, 8, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var q_dc = av1_get_dc_quant(8, 40, 0);
    var q_ac = av1_get_ac_quant(8, 40, 0);
    var yy = 0;
    while (yy < 32) {
        var xx = 0;
        while (xx < 32) {
            av1_reconstruct(xf, 0, xx, yy, 1, AV1_DCT_DCT, 0, ir_leaf_coeff(30, 0), q_dc, q_ac);
            xx = xx + 8;
        }
        yy = yy + 8;
    }
    assert_eq(ir_diff(df, xf, 32, 32, 1, 0, 0), 0,
    "var-tx 32x32 -> 16x TX_8X8 (depth-2 forced leaf): decode == oracle (1024)");
    return 0;
}
# the InterTxSizes grid records the PER-LEAF tx after a var-tx decode+store (NOT the
# block max) — witnesses that the store suppresses the uniform InterTxSizes write,
# which the self-consistent round-trip cannot see (a conformance-only detail).
fn test_ir_vartx_intertx_grid() {
    var ref = ir_ref(16, 16, 1, 0, 0);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_SELECT);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    var target = alloc(16 * 8);
    var i = 0;
    while (i < 16) { store64(target + (i * 8), 1); i = i + 1; }
    var leaves = alloc(4 * 3 * 8);
    i = 0;
    while (i < 4) {
        store64(leaves + ((i * 3 + 0) * 8), AV1_DCT_DCT);
        store64(leaves + ((i * 3 + 1) * 8), 1);
        store64(leaves + ((i * 3 + 2) * 8), ir_leaf_coeff(20, 0));
        i = i + 1;
    }
    var vplan = alloc(8 * 8);
    memset(vplan, 0, 8 * 8);
    store64(vplan + 0, target);
    store64(vplan + (2 * 8), 4);
    store64(vplan + (3 * 8), leaves);
    var blk = ir_blk(16, 8, 0);
    av1_fb_set_vartx(blk, vplan);
    # encode
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var oe = alloc(8);
    var ef = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 4, 4, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(3 * 8);
    ir_plan(pp, 2);
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    # decode, keeping the tile to inspect its InterTxSizes grid.
    var df = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 4, 4, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "var-tx grid tile decodes");
    # every 4x4 cell holds TX_8X8 (1), not the block-max TX_16X16 (2).
    assert_eq(av1_grid_get(dt, AV1TILE_INTERTX, 0, 0), 1, "InterTxSizes[0][0] = TX_8X8 (per-leaf)");
    assert_eq(av1_grid_get(dt, AV1TILE_INTERTX, 3, 3), 1, "InterTxSizes[3][3] = TX_8X8 (per-leaf, not max)");
    return 0;
}
# VAR-TX NON-SQUARE (review: transform_tree w>h branch was dead): a 16x8 block
# (BLOCK_16X8, via PARTITION_HORZ) splits to 2x TX_8X8; transform_tree(16,8) takes
# the w>h branch (two horizontal halves). Round-trip vs a per-leaf oracle.
fn test_ir_vartx_rect() {
    var ref = ir_ref(16, 8, 1, 0, 0);
    var fh = ir_fh(16, 8, 4, 2, AV1_TX_MODE_SELECT);
    var refs = ir_refs(16, 8);
    var seq = ir_seq(1, 0, 0);
    var target = alloc(8 * 8);                       # fmi 4x2 = 8 cells
    var i = 0;
    while (i < 8) { store64(target + (i * 8), 1); i = i + 1; }   # TX_8X8
    var leaves = alloc(2 * 3 * 8);
    store64(leaves + (0 * 8), AV1_ADST_DCT);
    store64(leaves + (1 * 8), 2);
    store64(leaves + (2 * 8), ir_leaf_coeff(50, 0 - 20));
    store64(leaves + (3 * 8), AV1_DCT_ADST);
    store64(leaves + (4 * 8), 1);
    store64(leaves + (5 * 8), ir_leaf_coeff(0 - 35, 0));
    var vplan = alloc(8 * 8);
    memset(vplan, 0, 8 * 8);
    store64(vplan + 0, target);
    store64(vplan + (2 * 8), 2);
    store64(vplan + (3 * 8), leaves);
    var blk = ir_blk(8, 0 - 4, 0);
    av1_fb_set_vartx(blk, vplan);
    var dpb = av1_dpb_new();
    av1_dpb_store(dpb, fh, ref);
    var oe = alloc(8);
    var ef = dr_frame_new(16, 8, 1, 0, 0, 8, 8, oe);
    var et = av1_tile_new(ef, 4, 2, 40, 1, 0, 1);
    av1_tile_grids_new(et);
    av1_tile_set_inter_ctx(et, fh, refs, seq, dpb);
    var pp = alloc(3 * 8);
    store64(pp + 0, AV1_PARTITION_SPLIT);
    store64(pp + (1 * 8), AV1_PARTITION_SPLIT);
    store64(pp + (2 * 8), AV1_PARTITION_HORZ);       # 16x16 -> two 16x8 (top is inside)
    var pf = alloc(8);
    store64(pf + 0, blk);
    var tlen = 0;
    var tb = av1_encode_inter_tile(et, pp, pf, 1, &tlen);
    assert_eq(tlen > 0, 1, "rect var-tx encoded");
    var df = dr_frame_new(16, 8, 1, 0, 0, 8, 8, oe);
    var dt = av1_tile_new(df, 4, 2, 40, 1, 0, 1);
    av1_tile_grids_new(dt);
    av1_tile_set_inter_ctx(dt, fh, refs, seq, dpb);
    assert_eq(av1_decode_inter_tile(dt, tb, tlen, 1), DR_OK, "rect var-tx decodes");
    var xf = dr_frame_new(16, 8, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 16, 8, 8, 0 - 4, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var q_dc = av1_get_dc_quant(8, 40, 0);
    var q_ac = av1_get_ac_quant(8, 40, 0);
    av1_reconstruct(xf, 0, 0, 0, 1, AV1_ADST_DCT, 0, ir_leaf_coeff(50, 0 - 20), q_dc, q_ac);
    av1_reconstruct(xf, 0, 8, 0, 1, AV1_DCT_ADST, 0, ir_leaf_coeff(0 - 35, 0), q_dc, q_ac);
    assert_eq(ir_diff(df, xf, 16, 8, 1, 0, 0), 0,
    "rect var-tx 16x8 -> 2x TX_8X8 (transform_tree w>h): decode == oracle (128)");
    return 0;
}
# VAR-TX 4:2:0: the same 4x TX_8X8 luma split with chroma. The 8x8 chroma tx
# co-locates the TOP-LEFT luma leaf's tx type via the TxTypes grid (the whole reason
# for the grid) — witnessed by exhaustive per-plane oracle equality.
fn test_ir_vartx_420() {
    var ref = ir_ref(16, 16, 3, 1, 1);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_SELECT);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(3, 1, 1);
    var target = alloc(16 * 8);
    var i = 0;
    while (i < 16) { store64(target + (i * 8), 1); i = i + 1; }   # TX_8X8
    var leaves = alloc(4 * 3 * 8);
    store64(leaves + (0 * 8), AV1_ADST_DCT);
    store64(leaves + (1 * 8), 2);
    store64(leaves + (2 * 8), ir_leaf_coeff(60, 0 - 20));
    store64(leaves + (3 * 8), AV1_DCT_ADST);
    store64(leaves + (4 * 8), 1);
    store64(leaves + (5 * 8), ir_leaf_coeff(0 - 40, 0));
    store64(leaves + (6 * 8), AV1_ADST_ADST);
    store64(leaves + (7 * 8), 1);
    store64(leaves + (8 * 8), ir_leaf_coeff(50, 0));
    store64(leaves + (9 * 8), AV1_IDTX);
    store64(leaves + (10 * 8), 1);
    store64(leaves + (11 * 8), ir_leaf_coeff(0 - 30, 0));
    var vplan = alloc(8 * 8);
    memset(vplan, 0, 8 * 8);
    store64(vplan + 0, target);
    store64(vplan + (2 * 8), 4);
    store64(vplan + (3 * 8), leaves);
    store64(vplan + (4 * 8), 1);  store64(vplan + (5 * 8), ir_leaf_coeff(40, 0));   # U
    store64(vplan + (6 * 8), 1);  store64(vplan + (7 * 8), ir_leaf_coeff(0 - 35, 0)); # V
    var blk = ir_blk(0 - 6, 10, 0);
    av1_fb_set_vartx(blk, vplan);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 3, 1, 1, 4, 4);
    var oe = alloc(8);
    var xf = dr_frame_new(16, 16, 3, 1, 1, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 16, 16, 0 - 6, 10, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(xf, ref, 1, 0, 0, 8, 8, 0 - 6, 10, AV1_EIGHTTAP, AV1_EIGHTTAP);
    av1_mc_pred_block(xf, ref, 2, 0, 0, 8, 8, 0 - 6, 10, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var q_dc = av1_get_dc_quant(8, 40, 0);
    var q_ac = av1_get_ac_quant(8, 40, 0);
    av1_reconstruct(xf, 0, 0, 0, 1, AV1_ADST_DCT, 0, ir_leaf_coeff(60, 0 - 20), q_dc, q_ac);
    av1_reconstruct(xf, 0, 8, 0, 1, AV1_DCT_ADST, 0, ir_leaf_coeff(0 - 40, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 0, 8, 1, AV1_ADST_ADST, 0, ir_leaf_coeff(50, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 8, 8, 1, AV1_IDTX, 0, ir_leaf_coeff(0 - 30, 0), q_dc, q_ac);
    # chroma co-locates the TL luma leaf tx type = ADST_DCT (in the 8x8 inter set).
    av1_reconstruct(xf, 1, 0, 0, 1, AV1_ADST_DCT, 0, ir_leaf_coeff(40, 0), q_dc, q_ac);
    av1_reconstruct(xf, 2, 0, 0, 1, AV1_ADST_DCT, 0, ir_leaf_coeff(0 - 35, 0), q_dc, q_ac);
    assert_eq(ir_diff(df, xf, 16, 16, 3, 1, 1), 0,
    "var-tx 4:2:0: all planes == oracle; chroma co-locates the TL leaf type");
    return 0;
}
# VAR-TX mixed-depth: 16x16 -> 4x TX_8X8, and the TOP-LEFT 8x8 further -> 4x TX_4X4
# (depth 2, the forced-leaf-no-symbol path). 7 luma leaves.
fn test_ir_vartx_mixed() {
    var ref = ir_ref(16, 16, 1, 0, 0);
    var fh = ir_fh(16, 16, 4, 4, AV1_TX_MODE_SELECT);
    var refs = ir_refs(16, 16);
    var seq = ir_seq(1, 0, 0);
    # target: TL 2x2 mi cells (0,0)(0,1)(1,0)(1,1) = TX_4X4 (0); the rest TX_8X8 (1).
    var target = alloc(16 * 8);
    var i = 0;
    while (i < 16) { store64(target + (i * 8), 1); i = i + 1; }
    store64(target + (0 * 8), 0);  store64(target + (1 * 8), 0);
    store64(target + (4 * 8), 0);  store64(target + (5 * 8), 0);   # row 1 (stride 4): cells (1,0),(1,1)
    # leaves in transform_tree order: TL 8x8 splits to 4x TX_4X4 (its own quadrants),
    # then TR, BL, BR 8x8. => 4 TX_4X4 + 3 TX_8X8 = 7.
    var leaves = alloc(7 * 3 * 8);
    store64(leaves + (0 * 8), AV1_DCT_DCT);
    store64(leaves + (1 * 8), 1);
    store64(leaves + (2 * 8), ir_leaf_coeff(30, 0));
    store64(leaves + (3 * 8), AV1_DCT_DCT);
    store64(leaves + (4 * 8), 1);
    store64(leaves + (5 * 8), ir_leaf_coeff(0 - 25, 0));
    store64(leaves + (6 * 8), AV1_DCT_DCT);
    store64(leaves + (7 * 8), 1);
    store64(leaves + (8 * 8), ir_leaf_coeff(20, 0));
    store64(leaves + (9 * 8), AV1_DCT_DCT);
    store64(leaves + (10 * 8), 1);
    store64(leaves + (11 * 8), ir_leaf_coeff(0 - 18, 0));
    store64(leaves + (12 * 8), AV1_ADST_DCT);
    store64(leaves + (13 * 8), 1);
    store64(leaves + (14 * 8), ir_leaf_coeff(45, 0));
    store64(leaves + (15 * 8), AV1_DCT_ADST);
    store64(leaves + (16 * 8), 1);
    store64(leaves + (17 * 8), ir_leaf_coeff(0 - 40, 0));
    store64(leaves + (18 * 8), AV1_IDTX);
    store64(leaves + (19 * 8), 1);
    store64(leaves + (20 * 8), ir_leaf_coeff(35, 0));
    var vplan = alloc(8 * 8);
    memset(vplan, 0, 8 * 8);
    store64(vplan + 0, target);
    store64(vplan + (2 * 8), 7);
    store64(vplan + (3 * 8), leaves);
    var blk = ir_blk(8, 0 - 4, 0);
    av1_fb_set_vartx(blk, vplan);
    var df = ir_roundtrip(ref, fh, refs, seq, blk, 2, 16, 16, 1, 0, 0, 4, 4);
    var oe = alloc(8);
    var xf = dr_frame_new(16, 16, 1, 0, 0, 8, 8, oe);
    av1_mc_pred_block(xf, ref, 0, 0, 0, 16, 16, 8, 0 - 4, AV1_EIGHTTAP, AV1_EIGHTTAP);
    var q_dc = av1_get_dc_quant(8, 40, 0);
    var q_ac = av1_get_ac_quant(8, 40, 0);
    # the 4 TX_4X4 leaves of the TL 8x8 (transform_tree quadrant order within it).
    av1_reconstruct(xf, 0, 0, 0, 0, AV1_DCT_DCT, 0, ir_leaf_coeff(30, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 4, 0, 0, AV1_DCT_DCT, 0, ir_leaf_coeff(0 - 25, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 0, 4, 0, AV1_DCT_DCT, 0, ir_leaf_coeff(20, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 4, 4, 0, AV1_DCT_DCT, 0, ir_leaf_coeff(0 - 18, 0), q_dc, q_ac);
    # then the TR, BL, BR 8x8 leaves.
    av1_reconstruct(xf, 0, 8, 0, 1, AV1_ADST_DCT, 0, ir_leaf_coeff(45, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 0, 8, 1, AV1_DCT_ADST, 0, ir_leaf_coeff(0 - 40, 0), q_dc, q_ac);
    av1_reconstruct(xf, 0, 8, 8, 1, AV1_IDTX, 0, ir_leaf_coeff(35, 0), q_dc, q_ac);
    assert_eq(ir_diff(df, xf, 16, 16, 1, 0, 0), 0,
    "var-tx mixed-depth (8x8 -> 4x TX_4X4): decode == per-leaf oracle (256)");
    return 0;
}

# ============ CDF + table offset pins ============
fn test_ir_cdf_pins() {
    var cc = av1_ncdf_new();
    # inter tx CDF absolute offsets (mutation-anchored: fresh cc, not the accessor's math).
    assert_eq(load64(cc + (1634 * 8)), 4458, "inter set1[0][0] @1634");
    assert_eq(load64(cc + (1649 * 8)), 32768, "inter set1[0] terminator @1649");
    assert_eq(load64(cc + (1650 * 8)), 0, "inter set1[0] count @1650");
    assert_eq(load64(cc + (1651 * 8)), 1645, "inter set1[1][0] @1651");
    assert_eq(load64(cc + (1668 * 8)), 770, "inter set2[0] @1668");
    assert_eq(load64(cc + (1681 * 8)), 16384, "inter set3[0] @1681");
    assert_eq(load64(cc + (1690 * 8)), 748, "inter set3[3] @1690");
    # accessors point at those offsets.
    assert_eq(av1_ncdf_inter_tx_set1(cc, 0), cc + (1634 * 8), "set1(0) accessor");
    assert_eq(av1_ncdf_inter_tx_set1(cc, 1), cc + (1651 * 8), "set1(1) accessor");
    assert_eq(av1_ncdf_inter_tx_set2(cc), cc + (1668 * 8), "set2 accessor");
    assert_eq(av1_ncdf_inter_tx_set3(cc, 3), cc + (1690 * 8), "set3(3) accessor");
    # inverse maps (spec-literal ref: INV_SET1/2/3).
    assert_eq(av1_inter_tx_inv_set1(0), AV1_IDTX, "inv_set1[0]=IDTX");
    assert_eq(av1_inter_tx_inv_set1(7), AV1_DCT_DCT, "inv_set1[7]=DCT_DCT");
    assert_eq(av1_inter_tx_inv_set1(15), AV1_FLIPADST_ADST, "inv_set1[15]");
    assert_eq(av1_inter_tx_inv_set2(0), AV1_IDTX, "inv_set2[0]=IDTX");
    assert_eq(av1_inter_tx_inv_set2(3), AV1_DCT_DCT, "inv_set2[3]=DCT_DCT");
    assert_eq(av1_inter_tx_inv_set2(11), AV1_FLIPADST_ADST, "inv_set2[11]");
    assert_eq(av1_inter_tx_inv_set3(0), AV1_IDTX, "inv_set3[0]=IDTX");
    assert_eq(av1_inter_tx_inv_set3(1), AV1_DCT_DCT, "inv_set3[1]=DCT_DCT");
    # membership (spec-literal ref: IN_SET rows).
    assert_eq(av1_is_tx_type_in_set_inter(1, AV1_H_FLIPADST), 1, "INTER_1 all16");
    assert_eq(av1_is_tx_type_in_set_inter(2, 12), 0, "INTER_2 excludes tx 12");
    assert_eq(av1_is_tx_type_in_set_inter(2, 11), 1, "INTER_2 includes tx 11");
    assert_eq(av1_is_tx_type_in_set_inter(3, AV1_DCT_DCT), 1, "INTER_3 DCT_DCT");
    assert_eq(av1_is_tx_type_in_set_inter(3, AV1_IDTX), 1, "INTER_3 IDTX");
    assert_eq(av1_is_tx_type_in_set_inter(3, AV1_ADST_DCT), 0, "INTER_3 excludes ADST_DCT");
    return 0;
}

# ============ tx_type round-trip (encode -> decode) ============
fn ir_tt_rt(tx_size, tx_type, nsym): i64 {
    var nce = av1_ncdf_new();
    var ttx = av1_txtypectx_new();
    store64(ttx + AV1TTC_IS_INTER, 1);
    store64(ttx + AV1TTC_BASE_Q, 40);
    var enc = av1_sym_enc_init(64, 1);
    av1_transform_type_encode(enc, nce, tx_size, ttx, tx_type);
    var olen = 0;
    var ob = av1_sym_enc_finish(enc, &olen);
    var ncd = av1_ncdf_new();
    var sd = av1_sym_dec_init(ob, olen, 1);
    return av1_transform_type_decode(sd, ncd, tx_size, ttx);
}
fn test_ir_txtype_roundtrip() {
    # INTER_1 (TX_8X8): every-ish type round-trips.
    assert_eq(ir_tt_rt(1, AV1_DCT_DCT, 16), AV1_DCT_DCT, "rt INTER_1 DCT_DCT");
    assert_eq(ir_tt_rt(1, AV1_ADST_DCT, 16), AV1_ADST_DCT, "rt INTER_1 ADST_DCT");
    assert_eq(ir_tt_rt(1, AV1_H_FLIPADST, 16), AV1_H_FLIPADST, "rt INTER_1 H_FLIPADST");
    assert_eq(ir_tt_rt(1, AV1_IDTX, 16), AV1_IDTX, "rt INTER_1 IDTX");
    # INTER_2 (TX_16X16): the 12-type set.
    assert_eq(ir_tt_rt(2, AV1_DCT_DCT, 12), AV1_DCT_DCT, "rt INTER_2 DCT_DCT");
    assert_eq(ir_tt_rt(2, AV1_FLIPADST_ADST, 12), AV1_FLIPADST_ADST, "rt INTER_2 FLIPADST_ADST");
    assert_eq(ir_tt_rt(2, AV1_H_DCT, 12), AV1_H_DCT, "rt INTER_2 H_DCT");
    # INTER_3 (TX_32X32): DCT_DCT / IDTX.
    assert_eq(ir_tt_rt(3, AV1_DCT_DCT, 2), AV1_DCT_DCT, "rt INTER_3 DCT_DCT");
    assert_eq(ir_tt_rt(3, AV1_IDTX, 2), AV1_IDTX, "rt INTER_3 IDTX");
    return 0;
}

# ============ compute_tx_type inter chroma (matches inter_residual_ref.py) ============
fn ir_ctt(sqr, luma_tt): i64 {
    var ttx = av1_txtypectx_new();
    store64(ttx + AV1TTC_IS_INTER, 1);
    store64(ttx + AV1TTC_BASE_Q, 40);
    store64(ttx + AV1TTC_LUMA_TXTYPE, luma_tt);
    var txsz = 1;                        # sqr 1
    if (sqr == 2) { txsz = 2; }
    if (sqr == 3) { txsz = 3; }
    return av1_compute_tx_type(1, txsz, ttx, luma_tt);
}
fn test_ir_chroma_txtype() {
    assert_eq(ir_ctt(1, AV1_ADST_ADST), AV1_ADST_ADST, "chroma sqr1 ADST_ADST kept");
    assert_eq(ir_ctt(1, AV1_V_DCT), AV1_V_DCT, "chroma sqr1 V_DCT kept");
    assert_eq(ir_ctt(2, AV1_H_ADST), AV1_DCT_DCT, "chroma sqr2 H_ADST -> DCT_DCT (INTER_2)");
    assert_eq(ir_ctt(3, AV1_ADST_ADST), AV1_DCT_DCT, "chroma sqr3 ADST_ADST -> DCT_DCT (INTER_3)");
    assert_eq(ir_ctt(3, AV1_IDTX), AV1_IDTX, "chroma sqr3 IDTX kept (INTER_3)");
    return 0;
}

