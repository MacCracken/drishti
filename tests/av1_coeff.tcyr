# tests/av1_coeff.tcyr — AV1 coefficient level contexts (spec 8.3.2). The
# get_tx_class / eob_pt / get_coeff_base_ctx / get_br_ctx context functions
# are pinned by hand-computed known-answers on constructed Quant[] arrays
# (every neighbour sum + offset traced by hand), and the offset tables by a
# weighted checksum + spot values.
include "src/main.cyr"
include "src/av1_coeff.cyr"

fn qset(q, idx, v): i64 { store64(q + (idx * 8), v); return 0; }
fn qzero(q, n): i64 { var k = 0; while (k < n) { store64(q + (k * 8), 0); k = k + 1; } return 0; }

# get_tx_class — VERT for V_*, HORIZ for H_*, else 2D.
fn test_tx_class() {
    assert_eq(av1_get_tx_class(AV1_DCT_DCT), AV1_TX_CLASS_2D, "DCT_DCT -> 2D");
    assert_eq(av1_get_tx_class(AV1_ADST_ADST), AV1_TX_CLASS_2D, "ADST_ADST -> 2D");
    assert_eq(av1_get_tx_class(AV1_IDTX), AV1_TX_CLASS_2D, "IDTX -> 2D");
    assert_eq(av1_get_tx_class(AV1_V_DCT), AV1_TX_CLASS_VERT, "V_DCT -> VERT");
    assert_eq(av1_get_tx_class(AV1_V_ADST), AV1_TX_CLASS_VERT, "V_ADST -> VERT");
    assert_eq(av1_get_tx_class(AV1_V_FLIPADST), AV1_TX_CLASS_VERT, "V_FLIPADST -> VERT");
    assert_eq(av1_get_tx_class(AV1_H_DCT), AV1_TX_CLASS_HORIZ, "H_DCT -> HORIZ");
    assert_eq(av1_get_tx_class(AV1_H_FLIPADST), AV1_TX_CLASS_HORIZ, "H_FLIPADST -> HORIZ");
    assert_eq(av1_eob_pt_ctx(AV1_DCT_DCT), 0, "eob_pt ctx 2D -> 0");
    assert_eq(av1_eob_pt_ctx(AV1_V_DCT), 1, "eob_pt ctx VERT -> 1");
    assert_eq(av1_eob_pt_ctx(AV1_H_DCT), 1, "eob_pt ctx HORIZ -> 1");
    assert_eq(av1_eob_pt_ctx(AV1_IDTX), 0, "eob_pt ctx IDTX -> 0");
    return 0;
}

# coeff_base_eob context (raw get_coeff_base_ctx return, isEob=1):
# c==0 -> SIG_COEF_CONTEXTS-4=38; c<=(h<<bwl)/8 -> 39; <=/4 -> 40; else 41.
# The caller maps these to 0..3 via (ctx - SIG_COEF_CONTEXTS + SIG_COEF_CONTEXTS_EOB).
# 4x4: h<<bwl = 4<<2 = 16, /8=2, /4=4.
fn test_coeff_base_eob_ctx() {
    var q = alloc(16 * 8);
    qzero(q, 16);
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 3, 0, 1, q), 38, "eob c=0 -> 38");
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 3, 1, 1, q), 39, "eob c=1 -> 39");
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 3, 2, 1, q), 39, "eob c=2 -> 39");
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 3, 3, 1, q), 40, "eob c=3 -> 40");
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 3, 4, 1, q), 40, "eob c=4 -> 40");
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 3, 5, 1, q), 41, "eob c=5 -> 41");
    return 0;
}

# coeff_base, TX_CLASS_2D. pos=0 (DC) always ctx 0. pos=1 (row0,col1): the
# 5 diagonal neighbours (0,2)(1,1)(1,2)(0,3)(2,1) with levels {5,1,2,0,4}
# give mag = 3+1+2+0+3 = 9, ctx = Min((9+1)>>1,4)=4, + offset[0][0][1]=1 -> 5.
fn test_coeff_base_ctx_2d() {
    var q = alloc(16 * 8);
    qzero(q, 16);
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 0, 3, 0, q), 0, "2D DC pos -> 0");
    qset(q, 2, 5); qset(q, 5, 1); qset(q, 6, 2); qset(q, 3, 0); qset(q, 9, 4);
    assert_eq(av1_get_coeff_base_ctx(0, AV1_DCT_DCT, 1, 3, 0, q), 5, "2D pos1 -> 5");
    # 8x8 (bwl=3), pos=9 (row1,col1). neighbours (1,2)(2,1)(2,2) each level 1
    # -> mag=3, ctx=Min((3+1)>>1,4)=2, + offset[1][1][1]=6 -> 8.
    var q8 = alloc(64 * 8);
    qzero(q8, 64);
    qset(q8, 10, 1); qset(q8, 17, 1); qset(q8, 18, 1);
    assert_eq(av1_get_coeff_base_ctx(1, AV1_DCT_DCT, 9, 3, 0, q8), 8, "8x8 2D pos9 -> 8");
    return 0;
}

# coeff_base, 1D classes. VERT: pos=5 (row1,col1), vert neighbours
# (1,2)(2,1)(3,1) [rows 4,5 out of range] levels {2,5,1} -> mag=6,
# ctx=Min((6+1)>>1,4)=3, + Pos_Ctx_Offset[Min(row=1,2)=1]=31 -> 34.
# HORIZ: pos=6 (row1,col2), horiz neighbours (1,3)(2,2) [cols 4,5,6 OOR]
# levels {2,5} -> mag=2+3=5, ctx=Min(3,4)=3, + Pos_Ctx_Offset[Min(col=2,2)=2]=36 -> 39.
fn test_coeff_base_ctx_1d() {
    var q = alloc(16 * 8);
    qzero(q, 16);
    qset(q, 6, 2); qset(q, 9, 5); qset(q, 13, 1);
    assert_eq(av1_get_coeff_base_ctx(0, AV1_V_DCT, 5, 3, 0, q), 34, "VERT pos5 -> 34");
    var q2 = alloc(16 * 8);
    qzero(q2, 16);
    qset(q2, 7, 2); qset(q2, 10, 5);
    assert_eq(av1_get_coeff_base_ctx(0, AV1_H_DCT, 6, 3, 0, q2), 39, "HORIZ pos6 -> 39");
    return 0;
}

# get_br_ctx. 4x4. Neighbours from Mag_Ref_Offset_With_Tx_Class; levels are
# raw (clamped to 15). D: pos=0, 2D, (0,1)(1,0)(1,1)={3,10,20->15} mag=28,
# Min((28+1)>>1,6)=6 -> pos0 returns mag=6. E: pos=5(1,1) 2D row<2&col<2,
# (1,2)(2,1)(2,2)={1,2,3} mag=6, Min(3,6)=3 -> mag+7=10. F: pos=10(2,2) 2D,
# (2,3)(3,2)(3,3)={5,0,0} mag=5, Min(3,6)=3 -> mag+14=17.
fn test_br_ctx_2d() {
    var q = alloc(16 * 8);
    qzero(q, 16); qset(q, 1, 3); qset(q, 4, 10); qset(q, 5, 20);
    assert_eq(av1_get_br_ctx(0, AV1_DCT_DCT, 0, q), 6, "br 2D pos0 -> 6");
    var qe = alloc(16 * 8);
    qzero(qe, 16); qset(qe, 6, 1); qset(qe, 9, 2); qset(qe, 10, 3);
    assert_eq(av1_get_br_ctx(0, AV1_DCT_DCT, 5, qe), 10, "br 2D pos5 near -> 10");
    var qf = alloc(16 * 8);
    qzero(qf, 16); qset(qf, 11, 5);
    assert_eq(av1_get_br_ctx(0, AV1_DCT_DCT, 10, qf), 17, "br 2D pos10 far -> 17");
    return 0;
}

# get_br_ctx 1D. G: HORIZ pos=4(1,0) col==0, (1,1)(2,0)(1,2)={4,6,2} mag=12,
# Min((12+1)>>1,6)=6 -> mag+7=13. H: VERT pos=1(0,1) row==0, (0,2)(1,1)(2,1)
# ={1,1,1} mag=3, Min(2,6)=2 -> mag+7=9.
fn test_br_ctx_1d() {
    var qg = alloc(16 * 8);
    qzero(qg, 16); qset(qg, 5, 4); qset(qg, 8, 6); qset(qg, 6, 2);
    assert_eq(av1_get_br_ctx(0, AV1_H_DCT, 4, qg), 13, "br HORIZ col0 -> 13");
    var qh = alloc(16 * 8);
    qzero(qh, 16); qset(qh, 2, 1); qset(qh, 5, 1); qset(qh, 9, 1);
    assert_eq(av1_get_br_ctx(0, AV1_V_DCT, 1, qh), 9, "br VERT row0 -> 9");
    return 0;
}

# Offset tables: weighted checksum over all 475 Coeff_Base_Ctx_Offset entries
# + spot values of every small table.
fn test_coeff_tables() {
    var s = 0;
    var tx = 0;
    while (tx < 19) {
        var r = 0;
        while (r < 5) {
            var c = 0;
            while (c < 5) {
                var flat = ((tx * 5) + r) * 5 + c;
                s = s + ((flat + 1) * av1_coeff_base_ctx_offset(tx, r, c));
                c = c + 1;
            }
            r = r + 1;
        }
        tx = tx + 1;
    }
    assert_eq(s, 1683471, "Coeff_Base_Ctx_Offset weighted checksum");
    assert_eq(av1_coeff_base_ctx_offset(0, 0, 0), 0, "cbco[0][0][0]");
    assert_eq(av1_coeff_base_ctx_offset(0, 0, 2), 6, "cbco[0][0][2]");
    assert_eq(av1_coeff_base_ctx_offset(0, 2, 2), 21, "cbco[0][2][2]");
    assert_eq(av1_coeff_base_ctx_offset(18, 4, 4), 21, "cbco[18][4][4]");
    # Adjusted_Tx_Size: 64-dim clamps to 32.
    assert_eq(av1_adjusted_tx_size(0), 0, "adj 4x4");
    assert_eq(av1_adjusted_tx_size(4), 3, "adj 64x64 -> 32x32");
    assert_eq(av1_adjusted_tx_size(11), 3, "adj 32x64 -> 32x32");
    assert_eq(av1_adjusted_tx_size(17), 9, "adj 16x64 -> 16x32");
    assert_eq(av1_adjusted_tx_size(18), 10, "adj 64x16 -> 32x16");
    # Sig_Ref_Diff_Offset[txClass][idx][dim].
    assert_eq(av1_sig_ref_diff(0, 0, 1), 1, "sig 2D[0]={0,1}");
    assert_eq(av1_sig_ref_diff(2, 4, 0), 4, "sig VERT[4]={4,0}");
    assert_eq(av1_sig_ref_diff(1, 4, 1), 4, "sig HORIZ[4]={0,4}");
    # Mag_Ref_Offset_With_Tx_Class[txClass][idx][dim].
    assert_eq(av1_mag_ref_off(0, 2, 0), 1, "mag 2D[2]={1,1}");
    assert_eq(av1_mag_ref_off(2, 2, 0), 2, "mag VERT[2]={2,0}");
    assert_eq(av1_mag_ref_off(1, 2, 1), 2, "mag HORIZ[2]={0,2}");
    # Coeff_Base_Pos_Ctx_Offset[3] = {26, 31, 36}.
    assert_eq(av1_coeff_base_pos_ctx(0), 26, "pos ctx 0");
    assert_eq(av1_coeff_base_pos_ctx(1), 31, "pos ctx 1");
    assert_eq(av1_coeff_base_pos_ctx(2), 36, "pos ctx 2");
    return 0;
}

fn main() {
    alloc_init();
    test_group("tx class + eob_pt ctx");
    test_tx_class();
    test_group("coeff_base / coeff_base_eob ctx");
    test_coeff_base_eob_ctx();
    test_coeff_base_ctx_2d();
    test_coeff_base_ctx_1d();
    test_group("coeff_br ctx");
    test_br_ctx_2d();
    test_br_ctx_1d();
    test_group("context offset tables");
    test_coeff_tables();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
