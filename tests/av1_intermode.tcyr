# tests/av1_intermode.tcyr — inter mode-info: the MV component decode (read_mv /
# read_mv_component, spec 5.11.32) + its CDF family, verified by ROUND-TRIP through
# the symbol coder (encode a motion-vector difference, decode it back, assert
# equality) plus a CDF-structure sanity check. The paired write_mv is the inverse
# of read_mv, so a matching round-trip cross-validates both directions; the class
# boundaries (16/17/32/33/...) exercise every mv_class path.
include "src/main.cyr"

# encode (diff_row, diff_col) through write_mv, decode via read_mv with PredMv 0,
# assert the reconstructed Mv == the difference. disable selects static (1) vs
# adaptive (0) CDFs; each side gets its own context (shared blob when static).
fn mv_rt(diff_row, diff_col, mv_ctx, allow_hp, force_int, disable, tag): i64 {
    var cce = av1_mvcdf_blob();
    var ccd = av1_mvcdf_blob();
    if (disable == 0) { cce = av1_mvcdf_new(); ccd = av1_mvcdf_new(); }
    var enc = av1_sym_enc_init(64, disable);
    av1_write_mv(enc, cce, mv_ctx, allow_hp, force_int, diff_row, diff_col);
    assert_eq(av1_sym_enc_err(enc), DR_OK, "enc ok");
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, disable);
    var mv = av1_mv_new();
    av1_read_mv(sd, ccd, mv_ctx, allow_hp, force_int, 0, 0, mv);
    assert_eq(av1_sym_dec_err(sd), DR_OK, "dec ok");
    assert_eq(av1_mv_row(mv), diff_row, tag);
    assert_eq(av1_mv_col(mv), diff_col, tag);
    return 0;
}
# round-trip in BOTH cdf modes (static + adaptive).
fn mv_rt_both(dr, dc, allow_hp, force_int, tag): i64 {
    mv_rt(dr, dc, 0, allow_hp, force_int, 1, tag);
    mv_rt(dr, dc, 0, allow_hp, force_int, 0, tag);
    return 0;
}

# ================================================================
# CDF structure — the accessors return the §10 default values, well-formed
# (cumulative, ending 32768, then the adaptation counter).
# ================================================================
fn test_mvcdf_structure() {
    var cc = av1_mvcdf_blob();
    # joint: {4096, 11264, 19328, 32768, 0}
    assert_eq(load64(av1_mvcdf_joint(cc, 0) + 0), 4096, "joint c0");
    assert_eq(load64(av1_mvcdf_joint(cc, 0) + 24), 32768, "joint ends 32768");
    assert_eq(load64(av1_mvcdf_joint(cc, 0) + 32), 0, "joint counter 0");
    # sign / class-0 defaults.
    assert_eq(load64(av1_mvcdf_sign(cc, 0, 0) + 0), 16384, "sign 128*128");
    assert_eq(load64(av1_mvcdf_class(cc, 1, 1) + 0), 28672, "class c0 (both ctx/comp)");
    assert_eq(load64(av1_mvcdf_class(cc, 1, 1) + 80), 32768, "class ends 32768 (11-sym)");
    assert_eq(load64(av1_mvcdf_class0_bit(cc, 0, 0) + 0), 27648, "class0_bit 216*128");
    assert_eq(load64(av1_mvcdf_class0_fr(cc, 0, 1, 0) + 0), 16384, "class0_fr[bit0] c0");
    assert_eq(load64(av1_mvcdf_class0_fr(cc, 0, 1, 1) + 0), 12288, "class0_fr[bit1] c0");
    assert_eq(load64(av1_mvcdf_fr(cc, 0, 0) + 0), 8192, "fr c0");
    assert_eq(load64(av1_mvcdf_hp(cc, 0, 0) + 0), 16384, "hp 128*128");
    assert_eq(load64(av1_mvcdf_class0_hp(cc, 0, 0) + 0), 20480, "class0_hp 160*128");
    # bit i=0 -> 136*128, i=9 -> 240*128 (distinct per offset bit).
    assert_eq(load64(av1_mvcdf_bit(cc, 0, 0, 0) + 0), 17408, "bit[0] 136*128");
    assert_eq(load64(av1_mvcdf_bit(cc, 1, 1, 9) + 0), 30720, "bit[9] 240*128 (both ctx/comp)");
    return 0;
}

# ================================================================
# read_mv round-trip — full precision (allow_hp=1, force_int=0): EVERY difference
# reconstructs exactly.
# ================================================================
fn test_mv_roundtrip_full() {
    mv_rt_both(0, 0, 1, 0, "zero (MV_JOINT_ZERO)");
    mv_rt_both(5, 0, 1, 0, "row only");
    mv_rt_both(0, 7, 1, 0, "col only");
    mv_rt_both(5, 0 - 7, 1, 0, "both, mixed sign");
    mv_rt_both(0 - 5, 7, 1, 0, "both, mixed sign 2");
    mv_rt_both(1, 1, 1, 0, "mag 1");
    mv_rt_both(0 - 1, 0 - 1, 1, 0, "mag -1");
    return 0;
}
# class boundaries: class 0 covers |d| 1..16; class c covers (2^(c+3), 2^(c+4)].
fn test_mv_roundtrip_classes() {
    mv_rt_both(16, 0, 1, 0, "class0 max (16)");
    mv_rt_both(17, 0, 1, 0, "class1 min (17)");
    mv_rt_both(0 - 31, 0, 1, 0, "class1 (-31)");
    mv_rt_both(32, 0, 1, 0, "class1 max (32)");
    mv_rt_both(33, 0, 1, 0, "class2 min (33)");
    mv_rt_both(0, 64, 1, 0, "class2 max col (64)");
    mv_rt_both(65, 0, 1, 0, "class3 min (65)");
    mv_rt_both(100, 0 - 200, 1, 0, "class larger, both");
    mv_rt_both(1000, 0, 1, 0, "class ~7 (1000)");
    mv_rt_both(0 - 8000, 8000, 1, 0, "class ~10 (8000)");
    return 0;
}
# precision modes — diffs whose fractional part is consistent with the forced
# values (fr=3 under force_integer_mv; hp=1 under !allow_high_precision_mv). 16 and
# 24 both decompose to fr=3, hp=1, so they round-trip in the constrained modes.
fn test_mv_roundtrip_precision() {
    mv_rt_both(16, 0 - 16, 0, 1, "force_int, !hp: fr=3 hp=1 (16)");
    mv_rt_both(24, 0 - 24, 0, 1, "force_int, !hp class1: fr=3 hp=1 (24)");
    mv_rt_both(16, 24, 1, 1, "force_int, hp coded (16/24)");
    mv_rt_both(16, 0 - 24, 0, 0, "!hp, fr coded (16/24)");
    return 0;
}
# PredMv add: the decoded Mv is PredMv + diff.
fn test_mv_predmv_add() {
    var cc = av1_mvcdf_blob();
    var enc = av1_sym_enc_init(64, 1);
    av1_write_mv(enc, cc, 0, 1, 0, 5, 0 - 7);        # diff (5,-7)
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, 1);
    var mv = av1_mv_new();
    av1_read_mv(sd, cc, 0, 1, 0, 100, 200, mv);      # PredMv (100,200)
    assert_eq(av1_mv_row(mv), 105, "mv row = pred 100 + diff 5");
    assert_eq(av1_mv_col(mv), 193, "mv col = pred 200 + diff -7");
    return 0;
}
# the intrabc MV context (MvCtx = 1) is a distinct CDF context.
fn test_mv_intrabc_ctx() {
    mv_rt(20, 0 - 30, AV1_MV_INTRABC_CTX, 1, 0, 1, "intrabc ctx static");
    mv_rt(20, 0 - 30, AV1_MV_INTRABC_CTX, 1, 0, 0, "intrabc ctx adaptive");
    return 0;
}

# ================================================================
# Single-prediction inter mode reads (5.11.32): read_inter_mode + read_drl_idx +
# assign_mv, round-tripped through the symbol coder. Build an Av1MvCtx carrying the
# entropy contexts + a candidate stack + GlobalMvs, then encode (mode + drl + the
# NEWMV difference) and decode (mode -> drl -> assign_mv), asserting YMode /
# RefMvIdx / Mv.
# ================================================================
fn im_ctx(new_ctx, zero_ctx, ref_ctx): i64 {
    var mvctx = av1_mvctx_new();
    av1_mvctx_set_stack(mvctx, av1_mv_stack_new());
    store64(mvctx + AV1MVC_NEWMVCTX, new_ctx);
    store64(mvctx + AV1MVC_ZEROCTX, zero_ctx);
    store64(mvctx + AV1MVC_REFMVCTX, ref_ctx);
    return mvctx;
}
# add a candidate MV to the stack (hp=1 -> stored as-is; distinct rows -> no dedup).
fn im_add(mvctx, row, col): i64 {
    av1_mv_stack_add(load64(mvctx + AV1MVC_STACK), row, col, 0, 0, 0, AV1_NEARESTMV, 4, 1, 0);
    return 0;
}
# compose round-trip: encode mode + drl (+ NEWMV diff), decode, assert YMode /
# RefMvIdx / Mv. `disable` selects static (1) vs adaptive (0) CDFs.
fn im_rt(mvctx, y_mode, ref_mv_idx, diff_row, diff_col, exp_row, exp_col, disable, tag): i64 {
    var imcc = av1_imcdf_blob();
    var mvcc = av1_mvcdf_blob();
    var imcd = av1_imcdf_blob();
    var mvcd = av1_mvcdf_blob();
    if (disable == 0) {
        imcc = av1_imcdf_new(); mvcc = av1_mvcdf_new();
        imcd = av1_imcdf_new(); mvcd = av1_mvcdf_new();
    }
    var enc = av1_sym_enc_init(64, disable);
    av1_write_inter_mode(enc, imcc, mvctx, y_mode);
    av1_write_drl_idx(enc, imcc, mvctx, y_mode, ref_mv_idx);
    if (y_mode == AV1_NEWMV) { av1_write_mv(enc, mvcc, 0, 1, 0, diff_row, diff_col); }
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, disable);
    var dm = av1_read_inter_mode(sd, imcd, mvctx);
    assert_eq(dm, y_mode, tag);
    var dridx = av1_read_drl_idx(sd, imcd, mvctx, dm);
    assert_eq(dridx, ref_mv_idx, tag);
    var mv = av1_mv_new();
    av1_assign_mv_single(sd, mvcd, mvctx, dm, dridx, 0, 1, 0, mv);
    assert_eq(av1_sym_dec_err(sd), DR_OK, tag);
    assert_eq(av1_mv_row(mv), exp_row, tag);
    assert_eq(av1_mv_col(mv), exp_col, tag);
    return 0;
}

# inter-mode CDF structure — the §10 default values.
fn test_imcdf_structure() {
    var cc = av1_imcdf_blob();
    assert_eq(load64(av1_imcdf_newmv(cc, 0) + 0), 24035, "new_mv[0]");
    assert_eq(load64(av1_imcdf_newmv(cc, 5) + 0), 4676, "new_mv[5]");
    assert_eq(load64(av1_imcdf_newmv(cc, 0) + 8), 32768, "new_mv ends 32768");
    assert_eq(load64(av1_imcdf_zeromv(cc, 0) + 0), 2175, "zero_mv[0]");
    assert_eq(load64(av1_imcdf_zeromv(cc, 1) + 0), 1054, "zero_mv[1]");
    assert_eq(load64(av1_imcdf_refmv(cc, 0) + 0), 23974, "ref_mv[0]");
    assert_eq(load64(av1_imcdf_refmv(cc, 5) + 0), 19923, "ref_mv[5]");
    assert_eq(load64(av1_imcdf_drl(cc, 0) + 0), 13104, "drl[0]");
    assert_eq(load64(av1_imcdf_drl(cc, 2) + 0), 18945, "drl[2]");
    return 0;
}

# read_inter_mode — every single YMode round-trips (mode determination only, no DRL
# past idx 0). GLOBALMV -> GlobalMvs; NEARESTMV/NEARMV -> RefStackMv[pos].
fn test_inter_mode_rt() {
    var m = im_ctx(2, 1, 3);
    im_add(m, 10, 20); im_add(m, 30, 40); im_add(m, 50, 60);   # NumMvFound 3
    av1_mvctx_set_global(m, 100, 0 - 50, 0, 0, 0, 0);           # GlobalMvs[0]=(100,-50)
    im_rt(m, AV1_NEWMV, 0, 5, 0 - 7, 15, 13, 1, "NEWMV idx0 -> RefStackMv[0]+diff");
    im_rt(m, AV1_GLOBALMV, 0, 0, 0, 100, 0 - 50, 1, "GLOBALMV -> GlobalMvs[0]");
    im_rt(m, AV1_NEARESTMV, 0, 0, 0, 10, 20, 1, "NEARESTMV -> RefStackMv[0]");
    im_rt(m, AV1_NEARMV, 1, 0, 0, 30, 40, 1, "NEARMV idx1 -> RefStackMv[1]");
    return 0;
}

# read_drl_idx — the DRL predictor index across NumMvFound and RefMvIdx values.
fn test_drl_idx_rt() {
    var m = im_ctx(0, 0, 0);
    im_add(m, 10, 20); im_add(m, 30, 40); im_add(m, 50, 60);   # NumMvFound 3
    # NEWMV: drl over idx 0..1.
    im_rt(m, AV1_NEWMV, 0, 1, 0, 11, 20, 1, "NEWMV drl idx0");
    im_rt(m, AV1_NEWMV, 1, 1, 0, 31, 40, 1, "NEWMV drl idx1 -> RefStackMv[1]+diff");
    im_rt(m, AV1_NEWMV, 2, 1, 0, 51, 60, 1, "NEWMV drl idx2 -> RefStackMv[2]+diff");
    # NEARMV: RefMvIdx starts 1, drl over idx 1..2.
    im_rt(m, AV1_NEARMV, 1, 0, 0, 30, 40, 1, "NEARMV drl idx1");
    im_rt(m, AV1_NEARMV, 2, 0, 0, 50, 60, 1, "NEARMV drl idx2");
    return 0;
}

# a single-candidate stack: no DRL read; NEWMV forces pos 0 (NumMvFound <= 1).
fn test_drl_single_candidate() {
    var m = im_ctx(0, 0, 0);
    im_add(m, 7, 9);   # NumMvFound 1
    im_rt(m, AV1_NEWMV, 0, 3, 4, 10, 13, 1, "NEWMV num=1 -> pos 0 + diff");
    im_rt(m, AV1_NEARESTMV, 0, 0, 0, 7, 9, 1, "NEARESTMV num=1 -> RefStackMv[0]");
    return 0;
}

# adaptive CDFs — the encoder and decoder adapt in lockstep.
fn test_inter_mode_adaptive() {
    var m = im_ctx(1, 0, 2);
    im_add(m, 10, 20); im_add(m, 30, 40); im_add(m, 50, 60);
    im_rt(m, AV1_NEWMV, 1, 5, 0 - 7, 35, 33, 0, "NEWMV idx1 adaptive");
    im_rt(m, AV1_NEARMV, 2, 0, 0, 50, 60, 0, "NEARMV idx2 adaptive");
    return 0;
}

# ================================================================
# Reference-selection reads (5.11.30 is_inter + 5.11.25 single_ref), round-tripped
# through the symbol coder. A refctx of six contexts (one per single_ref_pN) drives
# the CDF selection; each single reference LAST..ALTREF must round-trip exactly.
# ================================================================
# a 6-context array for single_ref_p1..p6 (varied, valid in 0..REF_CONTEXTS-1).
fn ref_ctxs(): i64 {
    var rc = alloc(6 * 8);
    store64(rc + 0, 0); store64(rc + 8, 1); store64(rc + 16, 2);
    store64(rc + 24, 0); store64(rc + 32, 1); store64(rc + 40, 2);
    return rc;
}
# encode RefFrame[0]=rf via write_single_ref, decode, assert RefFrame[0]==rf and
# RefFrame[1]==NONE. `disable` selects static (1) vs adaptive (0) CDFs.
fn ref_rt(rf, disable, tag): i64 {
    var cce = av1_refcdf_blob();
    var ccd = av1_refcdf_blob();
    if (disable == 0) { cce = av1_refcdf_new(); ccd = av1_refcdf_new(); }
    var rc = ref_ctxs();
    var enc = av1_sym_enc_init(64, disable);
    av1_write_single_ref(enc, cce, rc, rf);
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, disable);
    var outref = alloc(2 * 8);
    var got = av1_read_single_ref(sd, ccd, rc, outref);
    assert_eq(av1_sym_dec_err(sd), DR_OK, tag);
    assert_eq(got, rf, tag);
    assert_eq(load64(outref + 0), rf, tag);
    assert_eq(load64(outref + 8), AV1_REF_NONE, tag);
    return 0;
}

fn test_refcdf_structure() {
    var cc = av1_refcdf_blob();
    assert_eq(load64(av1_refcdf_isinter(cc, 0) + 0), 806, "is_inter[0]");
    assert_eq(load64(av1_refcdf_isinter(cc, 3) + 0), 26538, "is_inter[3]");
    assert_eq(load64(av1_refcdf_isinter(cc, 0) + 8), 32768, "is_inter ends 32768");
    assert_eq(load64(av1_refcdf_singleref(cc, 0, 0) + 0), 4897, "single_ref[0][0]");
    assert_eq(load64(av1_refcdf_singleref(cc, 0, 5) + 0), 1444, "single_ref[0][5]");
    assert_eq(load64(av1_refcdf_singleref(cc, 2, 0) + 0), 29744, "single_ref[2][0]");
    assert_eq(load64(av1_refcdf_singleref(cc, 2, 5) + 0), 30304, "single_ref[2][5]");
    assert_eq(load64(av1_refcdf_singleref(cc, 1, 3) + 0), 24773, "single_ref[1][3]");
    # compound CDFs (spec 10)
    assert_eq(load64(av1_refcdf_compmode(cc, 0) + 0), 26828, "comp_mode[0]");
    assert_eq(load64(av1_refcdf_compmode(cc, 4) + 0), 2901, "comp_mode[4]");
    assert_eq(load64(av1_refcdf_comprftype(cc, 0) + 0), 1198, "comp_ref_type[0]");
    assert_eq(load64(av1_refcdf_comprftype(cc, 4) + 0), 22475, "comp_ref_type[4]");
    assert_eq(load64(av1_refcdf_compref(cc, 0, 0) + 0), 4946, "comp_ref[0][0]");
    assert_eq(load64(av1_refcdf_compref(cc, 2, 2) + 0), 27544, "comp_ref[2][2]");
    assert_eq(load64(av1_refcdf_compbwdref(cc, 0, 0) + 0), 2235, "comp_bwd_ref[0][0]");
    assert_eq(load64(av1_refcdf_compbwdref(cc, 2, 1) + 0), 30489, "comp_bwd_ref[2][1]");
    assert_eq(load64(av1_refcdf_unicompref(cc, 0, 0) + 0), 5284, "uni_comp_ref[0][0]");
    assert_eq(load64(av1_refcdf_unicompref(cc, 2, 2) + 0), 26710, "uni_comp_ref[2][2]");
    return 0;
}

# ================================================================
# Compound reference reads (5.11.25 compound path): comp_mode + read_compound_ref,
# round-tripped. All 16 compound reference pairs (4 unidirectional + 12
# bidirectional) each code a unique tree path.
# ================================================================
fn comp_ctxs(): i64 {
    var cc = alloc(AV1CCTX_SIZE);
    store64(cc + AV1CCTX_REF_TYPE, 2);   # 0..COMP_REF_TYPE_CONTEXTS-1
    store64(cc + AV1CCTX_UNI, 0); store64(cc + AV1CCTX_UNI_P1, 1); store64(cc + AV1CCTX_UNI_P2, 2);
    store64(cc + AV1CCTX_REF, 0); store64(cc + AV1CCTX_REF_P1, 1); store64(cc + AV1CCTX_REF_P2, 2);
    store64(cc + AV1CCTX_BWDREF, 0); store64(cc + AV1CCTX_BWDREF_P1, 1);
    return cc;
}
# encode the (r0, r1) compound pair, decode, assert both.
fn cref_rt(r0, r1, disable, tag): i64 {
    var cce = av1_refcdf_blob();
    var ccd = av1_refcdf_blob();
    if (disable == 0) { cce = av1_refcdf_new(); ccd = av1_refcdf_new(); }
    var cctx = comp_ctxs();
    var enc = av1_sym_enc_init(64, disable);
    av1_write_compound_ref(enc, cce, cctx, r0, r1);
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, disable);
    var outref = alloc(2 * 8);
    av1_read_compound_ref(sd, ccd, cctx, outref);
    assert_eq(av1_sym_dec_err(sd), DR_OK, tag);
    assert_eq(load64(outref + 0), r0, tag);
    assert_eq(load64(outref + 8), r1, tag);
    return 0;
}

# comp_mode round-trip — both values, every context.
fn test_comp_mode_rt() {
    var ctx = 0;
    while (ctx < AV1_COMP_INTER_CONTEXTS) {
        var cc = av1_refcdf_blob();
        var enc = av1_sym_enc_init(32, 1);
        av1_write_comp_mode(enc, cc, ctx, AV1_COMPOUND_REFERENCE);
        av1_write_comp_mode(enc, cc, ctx, AV1_SINGLE_REFERENCE);
        var olen = 0;
        var out = av1_sym_enc_finish(enc, &olen);
        var sd = av1_sym_dec_init(out, olen, 1);
        assert_eq(av1_read_comp_mode(sd, cc, ctx), AV1_COMPOUND_REFERENCE, "comp_mode compound");
        assert_eq(av1_read_comp_mode(sd, cc, ctx), AV1_SINGLE_REFERENCE, "comp_mode single");
        ctx = ctx + 1;
    }
    return 0;
}

# the four UNIDIRECTIONAL compound pairs.
fn test_compound_ref_unidir() {
    cref_rt(AV1_BWDREF_FRAME, AV1_ALTREF_FRAME, 1, "unidir BWDREF+ALTREF (uni=1)");
    cref_rt(AV1_LAST_FRAME, AV1_LAST2_FRAME, 1, "unidir LAST+LAST2 (uni=0,p1=0)");
    cref_rt(AV1_LAST_FRAME, AV1_LAST3_FRAME, 1, "unidir LAST+LAST3 (uni=0,p1=1,p2=0)");
    cref_rt(AV1_LAST_FRAME, AV1_GOLDEN_FRAME, 1, "unidir LAST+GOLDEN (uni=0,p1=1,p2=1)");
    return 0;
}
# the twelve BIDIRECTIONAL pairs: fwd RefFrame[0] x bwd RefFrame[1].
fn test_compound_ref_bidir() {
    var fwd = alloc(4 * 8);
    store64(fwd + 0, AV1_LAST_FRAME); store64(fwd + 8, AV1_LAST2_FRAME);
    store64(fwd + 16, AV1_LAST3_FRAME); store64(fwd + 24, AV1_GOLDEN_FRAME);
    var bwd = alloc(3 * 8);
    store64(bwd + 0, AV1_BWDREF_FRAME); store64(bwd + 8, AV1_ALTREF2_FRAME);
    store64(bwd + 16, AV1_ALTREF_FRAME);
    var i = 0;
    while (i < 4) {
        var j = 0;
        while (j < 3) {
            cref_rt(load64(fwd + (i * 8)), load64(bwd + (j * 8)), 1, "bidir fwd x bwd");
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}
# adaptive CDFs for a couple of compound pairs.
fn test_compound_ref_adaptive() {
    cref_rt(AV1_LAST_FRAME, AV1_GOLDEN_FRAME, 0, "unidir adaptive");
    cref_rt(AV1_GOLDEN_FRAME, AV1_ALTREF2_FRAME, 0, "bidir adaptive");
    return 0;
}

# is_inter round-trip — both symbol values, every context, both CDF modes.
fn test_is_inter_rt() {
    var ctx = 0;
    while (ctx < AV1_IS_INTER_CONTEXTS) {
        var cc = av1_refcdf_blob();
        var enc = av1_sym_enc_init(32, 1);
        av1_write_is_inter_sym(enc, cc, ctx, 1);
        av1_write_is_inter_sym(enc, cc, ctx, 0);
        var olen = 0;
        var out = av1_sym_enc_finish(enc, &olen);
        var sd = av1_sym_dec_init(out, olen, 1);
        assert_eq(av1_read_is_inter_sym(sd, cc, ctx), 1, "is_inter 1");
        assert_eq(av1_read_is_inter_sym(sd, cc, ctx), 0, "is_inter 0");
        ctx = ctx + 1;
    }
    return 0;
}

# single_ref round-trip — each of the seven references (LAST..ALTREF) codes a unique
# p1..p6 path; static + adaptive CDFs.
fn test_single_ref_rt() {
    ref_rt(AV1_LAST_FRAME, 1, "LAST (p1=0,p3=0,p4=0)");
    ref_rt(AV1_LAST2_FRAME, 1, "LAST2 (p1=0,p3=0,p4=1)");
    ref_rt(AV1_LAST3_FRAME, 1, "LAST3 (p1=0,p3=1,p5=0)");
    ref_rt(AV1_GOLDEN_FRAME, 1, "GOLDEN (p1=0,p3=1,p5=1)");
    ref_rt(AV1_BWDREF_FRAME, 1, "BWDREF (p1=1,p2=0,p6=0)");
    ref_rt(AV1_ALTREF2_FRAME, 1, "ALTREF2 (p1=1,p2=0,p6=1)");
    ref_rt(AV1_ALTREF_FRAME, 1, "ALTREF (p1=1,p2=1)");
    # adaptive CDFs (encoder/decoder adapt in lockstep).
    ref_rt(AV1_LAST_FRAME, 0, "LAST adaptive");
    ref_rt(AV1_GOLDEN_FRAME, 0, "GOLDEN adaptive");
    ref_rt(AV1_ALTREF2_FRAME, 0, "ALTREF2 adaptive");
    return 0;
}

# ================================================================
# Compound mode reads (5.11.32): compound_mode (8-symbol) + get_mode + the two-list
# assign_mv, round-tripped. Build an Av1MvCtx with a COMPOUND candidate stack (both
# lists), GlobalMvs[0..1], and the entropy contexts, then encode (compound_mode +
# drl + the NEW MV diffs in list order) and decode (mode -> drl -> assign_mv), asserting
# YMode / RefMvIdx / Mv[0] / Mv[1].
# ================================================================
fn cm_ctx(new_ctx, ref_ctx): i64 {
    var mvctx = av1_mvctx_new();
    av1_mvctx_set_stack(mvctx, av1_mv_stack_new());
    store64(mvctx + AV1MVC_NEWMVCTX, new_ctx);
    store64(mvctx + AV1MVC_REFMVCTX, ref_ctx);
    var s = load64(mvctx + AV1MVC_STACK);
    av1_mv_stack_add(s, 10, 20, 110, 120, 1, AV1_NEAREST_NEARESTMV, 4, 1, 0);
    av1_mv_stack_add(s, 30, 40, 130, 140, 1, AV1_NEAREST_NEARESTMV, 4, 1, 0);
    av1_mv_stack_add(s, 50, 60, 150, 160, 1, AV1_NEAREST_NEARESTMV, 4, 1, 0);
    av1_mvctx_set_global(mvctx, 1000, 2000, 3000, 4000, 0, 0);   # GlobalMvs[0]=(1000,2000), [1]=(3000,4000)
    return mvctx;
}
fn cm_rt(mvctx, y_mode, ref_mv_idx, d0r, d0c, d1r, d1c, e0r, e0c, e1r, e1c, tag): i64 {
    var imcc = av1_imcdf_blob();
    var mvcc = av1_mvcdf_blob();
    var enc = av1_sym_enc_init(64, 1);
    av1_write_compound_mode(enc, imcc, mvctx, y_mode);
    av1_write_drl_idx(enc, imcc, mvctx, y_mode, ref_mv_idx);
    if (av1_get_mode(y_mode, 0) == AV1_NEWMV) { av1_write_mv(enc, mvcc, 0, 1, 0, d0r, d0c); }
    if (av1_get_mode(y_mode, 1) == AV1_NEWMV) { av1_write_mv(enc, mvcc, 0, 1, 0, d1r, d1c); }
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, 1);
    var dm = av1_read_compound_mode(sd, imcc, mvctx);
    assert_eq(dm, y_mode, tag);
    var dridx = av1_read_drl_idx(sd, imcc, mvctx, dm);
    assert_eq(dridx, ref_mv_idx, tag);
    var mv0 = av1_mv_new();
    var mv1 = av1_mv_new();
    av1_assign_mv_compound(sd, mvcc, mvctx, dm, dridx, 0, 1, 0, mv0, mv1);
    assert_eq(av1_sym_dec_err(sd), DR_OK, tag);
    assert_eq(av1_mv_row(mv0), e0r, tag);
    assert_eq(av1_mv_col(mv0), e0c, tag);
    assert_eq(av1_mv_row(mv1), e1r, tag);
    assert_eq(av1_mv_col(mv1), e1c, tag);
    return 0;
}

# compound_mode CDF structure + context map.
fn test_compound_mode_cdf() {
    var cc = av1_imcdf_blob();
    assert_eq(load64(av1_imcdf_compmode(cc, 0) + 0), 7760, "compound_mode[0] c0");
    assert_eq(load64(av1_imcdf_compmode(cc, 0) + 48), 26891, "compound_mode[0] c6");
    assert_eq(load64(av1_imcdf_compmode(cc, 0) + 56), 32768, "compound_mode ends 32768 (8-sym)");
    assert_eq(load64(av1_imcdf_compmode(cc, 7) + 0), 13046, "compound_mode[7] c0");
    # Compound_Mode_Ctx_Map[RefMvContext>>1][Min(NewMvContext,4)].
    assert_eq(av1_compound_mode_ctx(0, 0), 0, "ctx map [0][0] = 0");
    assert_eq(av1_compound_mode_ctx(1, 0), 0, "ctx map [0][0] (refmv 1>>1=0)");
    assert_eq(av1_compound_mode_ctx(2, 2), 3, "ctx map [1][2] = 3");
    assert_eq(av1_compound_mode_ctx(5, 9), 7, "ctx map [2][min(9,4)=4] = 7");
    return 0;
}

# get_mode — the per-list mode split for every compound YMode.
fn test_get_mode() {
    # single modes (refList 0 returns YMode).
    assert_eq(av1_get_mode(AV1_NEWMV, 0), AV1_NEWMV, "get_mode NEWMV/0");
    # NEW_NEWMV -> both NEWMV.
    assert_eq(av1_get_mode(AV1_NEW_NEWMV, 0), AV1_NEWMV, "NEW_NEWMV list0");
    assert_eq(av1_get_mode(AV1_NEW_NEWMV, 1), AV1_NEWMV, "NEW_NEWMV list1");
    # NEAREST_NEWMV -> list0 NEARESTMV, list1 NEWMV.
    assert_eq(av1_get_mode(AV1_NEAREST_NEWMV, 0), AV1_NEARESTMV, "NEAREST_NEWMV list0");
    assert_eq(av1_get_mode(AV1_NEAREST_NEWMV, 1), AV1_NEWMV, "NEAREST_NEWMV list1");
    # NEW_NEARMV -> list0 NEWMV, list1 NEARMV.
    assert_eq(av1_get_mode(AV1_NEW_NEARMV, 0), AV1_NEWMV, "NEW_NEARMV list0");
    assert_eq(av1_get_mode(AV1_NEW_NEARMV, 1), AV1_NEARMV, "NEW_NEARMV list1");
    # GLOBAL_GLOBALMV -> both GLOBALMV.
    assert_eq(av1_get_mode(AV1_GLOBAL_GLOBALMV, 0), AV1_GLOBALMV, "GLOBAL_GLOBALMV list0");
    assert_eq(av1_get_mode(AV1_GLOBAL_GLOBALMV, 1), AV1_GLOBALMV, "GLOBAL_GLOBALMV list1");
    # NEAR_NEARMV -> both NEARMV.
    assert_eq(av1_get_mode(AV1_NEAR_NEARMV, 0), AV1_NEARMV, "NEAR_NEARMV list0");
    assert_eq(av1_get_mode(AV1_NEAR_NEARMV, 1), AV1_NEARMV, "NEAR_NEARMV list1");
    return 0;
}

# the eight compound modes, each round-tripped end to end.
fn test_compound_mode_rt() {
    var m = cm_ctx(2, 3);
    # NEAREST_NEARESTMV: both NEARESTMV (pos 0), no DRL, no read_mv.
    cm_rt(m, AV1_NEAREST_NEARESTMV, 0, 0, 0, 0, 0, 10, 20, 110, 120, "NEAREST_NEARESTMV");
    # NEAR_NEARMV: both NEARMV, DRL idx 1 -> RefStackMv[1].
    cm_rt(m, AV1_NEAR_NEARMV, 1, 0, 0, 0, 0, 30, 40, 130, 140, "NEAR_NEARMV idx1");
    # NEAREST_NEWMV: list0 NEARESTMV(pos0), list1 NEWMV(pos0)+diff1.
    cm_rt(m, AV1_NEAREST_NEWMV, 0, 0, 0, 5, 0 - 7, 10, 20, 115, 113, "NEAREST_NEWMV");
    # NEW_NEARESTMV: list0 NEWMV(pos0)+diff0, list1 NEARESTMV(pos0).
    cm_rt(m, AV1_NEW_NEARESTMV, 0, 5, 0 - 7, 0, 0, 15, 13, 110, 120, "NEW_NEARESTMV");
    # NEAR_NEWMV: list0 NEARMV(pos1), list1 NEWMV(pos1)+diff1.
    cm_rt(m, AV1_NEAR_NEWMV, 1, 0, 0, 5, 0 - 7, 30, 40, 135, 133, "NEAR_NEWMV idx1");
    # NEW_NEARMV: list0 NEWMV(pos1)+diff0, list1 NEARMV(pos1).
    cm_rt(m, AV1_NEW_NEARMV, 1, 5, 0 - 7, 0, 0, 35, 33, 130, 140, "NEW_NEARMV idx1");
    # GLOBAL_GLOBALMV: both GlobalMvs.
    cm_rt(m, AV1_GLOBAL_GLOBALMV, 0, 0, 0, 0, 0, 1000, 2000, 3000, 4000, "GLOBAL_GLOBALMV");
    # NEW_NEWMV: both NEWMV(pos1) + diffs (DRL idx 1).
    cm_rt(m, AV1_NEW_NEWMV, 1, 5, 0 - 7, 3, 4, 35, 33, 133, 144, "NEW_NEWMV idx1");
    return 0;
}

# ================================================================
# The remaining inter mode-info reads (5.11.27 motion_mode + 5.11.30 interp_filter),
# round-tripped through the symbol coder. interp_filter [16 ctx][3-sym]; motion_mode
# [22 MiSize][3-sym]; use_obmc [22 MiSize][binary].
# ================================================================
# 3-symbol row check {c0, c1, 32768}; 2-symbol {c0, 32768}. A self-round-trip passes
# through ANY monotone CDF ending at 32768, so a wrong default value is invisible to it —
# every USED default row is diffed per-value against spec 10 here (the sole value ground-truth).
# Each checker also asserts the trailing ADAPTATION-COUNT slot == 0. That is not
# decoration: if a base/stride were wrong such that rows overlap, the count slot is the
# one an ascending fill would clobber — leaving c0 and the terminator intact. Without
# this assert a stride bug is invisible (proven: stride 3->2 passed the whole suite).
fn av1_t_chk3(p, c0, c1): i64 {
    assert_eq(load64(p + 0), c0, "cdf c0");
    assert_eq(load64(p + 8), c1, "cdf c1");
    assert_eq(load64(p + 16), 32768, "cdf 3-sym terminator");
    assert_eq(load64(p + 24), 0, "cdf 3-sym count slot");
    return 0;
}
fn av1_t_chk2(p, c0): i64 {
    assert_eq(load64(p + 0), c0, "cdf c0");
    assert_eq(load64(p + 8), 32768, "cdf 2-sym terminator");
    assert_eq(load64(p + 16), 0, "cdf 2-sym count slot");
    return 0;
}
fn test_interp_motion_cdf() {
    var cc = av1_imcdf_blob();
    # Default_Interp_Filter_Cdf[16][3] — exhaustive vs spec 10.additional.tables.md.
    av1_t_chk3(av1_imcdf_interp(cc, 0), 31935, 32720);
    av1_t_chk3(av1_imcdf_interp(cc, 1), 5568, 32719);
    av1_t_chk3(av1_imcdf_interp(cc, 2), 422, 2938);
    av1_t_chk3(av1_imcdf_interp(cc, 3), 28244, 32608);
    av1_t_chk3(av1_imcdf_interp(cc, 4), 31206, 31953);
    av1_t_chk3(av1_imcdf_interp(cc, 5), 4862, 32121);
    av1_t_chk3(av1_imcdf_interp(cc, 6), 770, 1152);
    av1_t_chk3(av1_imcdf_interp(cc, 7), 20889, 25637);
    av1_t_chk3(av1_imcdf_interp(cc, 8), 31910, 32724);
    av1_t_chk3(av1_imcdf_interp(cc, 9), 4120, 32712);
    av1_t_chk3(av1_imcdf_interp(cc, 10), 305, 2247);
    av1_t_chk3(av1_imcdf_interp(cc, 11), 27403, 32636);
    av1_t_chk3(av1_imcdf_interp(cc, 12), 31022, 32009);
    av1_t_chk3(av1_imcdf_interp(cc, 13), 2963, 32093);
