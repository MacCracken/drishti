    av1_t_chk3(av1_imcdf_motionmode(cc, 3), 7651, 24760);
    av1_t_chk3(av1_imcdf_motionmode(cc, 4), 4738, 24765);
    av1_t_chk3(av1_imcdf_motionmode(cc, 5), 5391, 25528);
    av1_t_chk3(av1_imcdf_motionmode(cc, 6), 19419, 26810);
    av1_t_chk3(av1_imcdf_motionmode(cc, 7), 5123, 23606);
    av1_t_chk3(av1_imcdf_motionmode(cc, 8), 11606, 24308);
    av1_t_chk3(av1_imcdf_motionmode(cc, 9), 26260, 29116);
    av1_t_chk3(av1_imcdf_motionmode(cc, 10), 20360, 28062);
    av1_t_chk3(av1_imcdf_motionmode(cc, 11), 21679, 26830);
    av1_t_chk3(av1_imcdf_motionmode(cc, 12), 29516, 30701);
    av1_t_chk3(av1_imcdf_motionmode(cc, 13), 28898, 30397);
    av1_t_chk3(av1_imcdf_motionmode(cc, 14), 30878, 31335);
    av1_t_chk3(av1_imcdf_motionmode(cc, 15), 32507, 32558);
    av1_t_chk3(av1_imcdf_motionmode(cc, 16), 10923, 21845);
    av1_t_chk3(av1_imcdf_motionmode(cc, 17), 10923, 21845);
    av1_t_chk3(av1_imcdf_motionmode(cc, 18), 28799, 31390);
    av1_t_chk3(av1_imcdf_motionmode(cc, 19), 26431, 30774);
    av1_t_chk3(av1_imcdf_motionmode(cc, 20), 28973, 31594);
    av1_t_chk3(av1_imcdf_motionmode(cc, 21), 29742, 31203);
    # Default_Use_Obmc_Cdf[22][2] — exhaustive.
    av1_t_chk2(av1_imcdf_useobmc(cc, 0), 16384);
    av1_t_chk2(av1_imcdf_useobmc(cc, 1), 16384);
    av1_t_chk2(av1_imcdf_useobmc(cc, 2), 16384);
