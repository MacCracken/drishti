    av1_t_chk2(av1_imcdf_useobmc(cc, 21), 26879);
    # the [0,123) region (compound_mode / new_mv) is unchanged after the blob grew.
    assert_eq(load64(av1_imcdf_compmode(cc, 0) + 0), 7760, "compound_mode[0] unchanged");
    assert_eq(load64(av1_imcdf_newmv(cc, 0) + 0), 24035, "new_mv[0] unchanged");
    return 0;
}
# interp_filter — every value (0..2) round-trips at every context.
fn test_interp_filter_rt() {
    var ctx = 0;
    while (ctx < AV1_INTERP_FILTER_CONTEXTS) {
        var cc = av1_imcdf_blob();
        var enc = av1_sym_enc_init(32, 1);
        av1_write_interp_filter(enc, cc, ctx, 0);
        av1_write_interp_filter(enc, cc, ctx, 1);
        av1_write_interp_filter(enc, cc, ctx, 2);
        var olen = 0;
        var out = av1_sym_enc_finish(enc, &olen);
        var sd = av1_sym_dec_init(out, olen, 1);
        assert_eq(av1_read_interp_filter(sd, cc, ctx), 0, "interp EIGHTTAP");
        assert_eq(av1_read_interp_filter(sd, cc, ctx), 1, "interp SMOOTH");
        assert_eq(av1_read_interp_filter(sd, cc, ctx), 2, "interp SHARP");
        ctx = ctx + 1;
    }
    return 0;
}
# use_obmc + motion_mode — every value round-trips at every MiSize.
fn test_motion_mode_rt() {
    var sz = 0;
    while (sz < AV1_BLOCK_SIZES) {
        var cc = av1_imcdf_blob();
        var enc = av1_sym_enc_init(32, 1);
        av1_write_use_obmc(enc, cc, sz, 0);
        av1_write_use_obmc(enc, cc, sz, 1);
        av1_write_motion_mode(enc, cc, sz, AV1_MM_SIMPLE);
        av1_write_motion_mode(enc, cc, sz, AV1_MM_OBMC);
        av1_write_motion_mode(enc, cc, sz, AV1_MM_LOCALWARP);
        var olen = 0;
        var out = av1_sym_enc_finish(enc, &olen);
        var sd = av1_sym_dec_init(out, olen, 1);
        assert_eq(av1_read_use_obmc(sd, cc, sz), 0, "use_obmc 0 (SIMPLE)");
        assert_eq(av1_read_use_obmc(sd, cc, sz), 1, "use_obmc 1 (OBMC)");
        assert_eq(av1_read_motion_mode(sd, cc, sz), AV1_MM_SIMPLE, "motion_mode SIMPLE");
        assert_eq(av1_read_motion_mode(sd, cc, sz), AV1_MM_OBMC, "motion_mode OBMC");
        assert_eq(av1_read_motion_mode(sd, cc, sz), AV1_MM_LOCALWARP, "motion_mode LOCALWARP");
        sz = sz + 1;
    }
    return 0;
}
# adaptive CDFs — interp_filter + motion_mode adapt in lockstep.
fn test_interp_motion_adaptive() {
    var cce = av1_imcdf_new();
    var ccd = av1_imcdf_new();
    var enc = av1_sym_enc_init(32, 0);
    av1_write_interp_filter(enc, cce, 7, 2);
    av1_write_motion_mode(enc, cce, 9, AV1_MM_LOCALWARP);
    av1_write_use_obmc(enc, cce, 12, 1);
    var olen = 0;
    var out = av1_sym_enc_finish(enc, &olen);
    var sd = av1_sym_dec_init(out, olen, 0);
    assert_eq(av1_read_interp_filter(sd, ccd, 7), 2, "interp adaptive SHARP");
    assert_eq(av1_read_motion_mode(sd, ccd, 9), AV1_MM_LOCALWARP, "motion_mode adaptive LOCALWARP");
    assert_eq(av1_read_use_obmc(sd, ccd, 12), 1, "use_obmc adaptive OBMC");
    return 0;
}

# ================================================================
# The inter-intra reads (5.11.28): @@interintra / @@interintra_mode (both Size_Group[MiSize]-1
# indexed) + @@wedge_interintra / @@wedge_index (both MiSize indexed). A self-round-trip is
# value-blind, so every default CDF row is diffed per-value against spec 10 here.
# ================================================================
# 16-symbol row check {c0..c14, 32768}; the uniform default row helper.
fn av1_t_chk16(p, c0, c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14): i64 {
    assert_eq(load64(p + 0), c0, "wcdf c0");     assert_eq(load64(p + 8), c1, "wcdf c1");
    assert_eq(load64(p + 16), c2, "wcdf c2");    assert_eq(load64(p + 24), c3, "wcdf c3");
    assert_eq(load64(p + 32), c4, "wcdf c4");    assert_eq(load64(p + 40), c5, "wcdf c5");
    assert_eq(load64(p + 48), c6, "wcdf c6");    assert_eq(load64(p + 56), c7, "wcdf c7");
    assert_eq(load64(p + 64), c8, "wcdf c8");    assert_eq(load64(p + 72), c9, "wcdf c9");
    assert_eq(load64(p + 80), c10, "wcdf c10");  assert_eq(load64(p + 88), c11, "wcdf c11");
    assert_eq(load64(p + 96), c12, "wcdf c12");  assert_eq(load64(p + 104), c13, "wcdf c13");
    assert_eq(load64(p + 112), c14, "wcdf c14"); assert_eq(load64(p + 120), 32768, "wcdf 16-sym term");
    assert_eq(load64(p + 128), 0, "wcdf 16-sym count slot");
    return 0;
}
fn av1_t_chk_wunif(p): i64 {
    av1_t_chk16(p, 2048, 4096, 6144, 8192, 10240, 12288, 14336, 16384,
    18432, 20480, 22528, 24576, 26624, 28672, 30720);
    return 0;
}
# 4-symbol row check {c0, c1, c2, 32768, count}.
fn av1_t_chk4(p, c0, c1, c2): i64 {
    assert_eq(load64(p + 0), c0, "cdf4 c0");
    assert_eq(load64(p + 8), c1, "cdf4 c1");
    assert_eq(load64(p + 16), c2, "cdf4 c2");
    assert_eq(load64(p + 24), 32768, "cdf4 4-sym terminator");
    assert_eq(load64(p + 32), 0, "cdf4 4-sym count slot");
    return 0;
}
fn test_interintra_cdf() {
    var cc = av1_iicdf_blob();
    # Default_Inter_Intra_Cdf[3] — binary.
    av1_t_chk2(av1_iicdf_interintra(cc, 0), 26887);
    av1_t_chk2(av1_iicdf_interintra(cc, 1), 27597);
    av1_t_chk2(av1_iicdf_interintra(cc, 2), 30237);
    # Default_Inter_Intra_Mode_Cdf[3] — 4-symbol {c0,c1,c2,32768} (slot 16 is c2, not the term).
    av1_t_chk4(av1_iicdf_iimode(cc, 0), 1875, 11082, 27332);
    av1_t_chk4(av1_iicdf_iimode(cc, 1), 2473, 9996, 26388);
    av1_t_chk4(av1_iicdf_iimode(cc, 2), 4238, 11537, 25926);
    # Default_Wedge_Inter_Intra_Cdf[22] — binary (used 3..9; rest 16384).
    av1_t_chk2(av1_iicdf_wedgeii(cc, 0), 16384);
    av1_t_chk2(av1_iicdf_wedgeii(cc, 1), 16384);
    av1_t_chk2(av1_iicdf_wedgeii(cc, 2), 16384);
    av1_t_chk2(av1_iicdf_wedgeii(cc, 3), 20036);
