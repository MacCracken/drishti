# src/av1_decode.cyr — AV1 frame-level decode driver (the top of the decode
# pipeline). This bite is the IN-LOOP FILTER PIPELINE (spec 7.4 order): given a
# reconstructed tile frame, run deblocking (7.14) -> CDEF (7.15) -> loop
# restoration (7.17) in sequence, managing the intermediate CurrFrame/CdefFrame/
# LrFrame buffers. The full OBU -> seq/fh -> tile-assembly -> decode driver
# (which sets the CDEF context + LR params from the frame header, activating the
# decode-time reads) grows here in later bites (roadmap.md).
#
# FLAT module — wired last in src/main.cyr (after av1_cdef.cyr), so it can call
# every filter + tile function. Family av1_. Depends on: av1_deblock (av1_deblock),
# av1_cdef (av1_cdef_process / av1_cdef_frame_new), av1_lr (av1_lr_process /
# av1_lr_params_new), av1_residual (av1_tile_set_cdef_ctx / set_lr_params),
# av1_frame (av1_fh_* tile-info + UsesLr), av1_seq, bits (dr_br_*), frame, drishti.
#
# Also here: frame-header filter activation (av1_lr_params_from_fh /
# av1_activate_intra_filters), tile-group OBU parsing (av1_tile_group_parse,
# spec 5.11.1), av1_decode_frame — the single-tile frame-level driver that
# assembles + decodes a tile from parsed headers and runs the filter pipeline —
# and av1_decode_obus, the OBU-stream walk that parses seq/fh from raw bytes and
# drives av1_decode_frame (raw bitstream -> pixels).

# ================================================================
# apply_loop_filters: run the three in-loop filters over the tile's reconstructed
# frame in spec order and return the final filtered frame (writes *out_err).
#   1. Deblocking runs in place on the tile frame (no-op at loop_filter_level 0).
#   2. CDEF (if the sequence enables it) reads the deblocked frame and writes a
#      fresh CdefFrame; the tile's CdefIdx grid + fh strengths drive it.
#   3. Loop restoration (if the frame UsesLr) reads the deblocked frame (as
#      UpscaledCurrFrame) + the CdefFrame and writes a fresh LrFrame, per lr_params.
# CDEF requires the frames to cover the MI grid (border >= 8 / MI-aligned); the
# CdefFrame from av1_cdef_frame_new does, and the caller's decoded frame must too
# (av1_cdef_process rejects with DR_ERR_BOUNDS otherwise — never OOB).
# ================================================================
fn av1_apply_loop_filters(tile, fh, seq, lr_params, out_err): i64 {
    store64(out_err, DR_OK);
    var frame = load64(tile + AV1TILE_FRAME);
    # 1. deblocking (in place).
    av1_deblock(tile, fh);
    var result = frame;
    # 2. CDEF.
    var cdef_frame = frame;
    if (av1_seq_enable_cdef(seq) != 0) {
        cdef_frame = av1_cdef_frame_new(frame, out_err);
        if (cdef_frame == 0) { store64(out_err, DR_ERR_OOM); return 0; }
        var rc = av1_cdef_process(frame, cdef_frame, fh, tile);
        if (rc != DR_OK) { store64(out_err, rc); return 0; }
        result = cdef_frame;
    }
    # 2.5 superres upscaling (7.16): between CDEF and loop restoration, lift the
    #     reconstruction from FrameWidth to UpscaledWidth. LR runs at the upscaled width
    #     (its params carry UpscaledWidth) and reads BOTH the deblocked (curr) and CDEF
    #     frames, so both are upscaled — they alias when CDEF is disabled.
    var sr_curr = frame;
    var sr_cdef = cdef_frame;
    if (av1_fh_use_superres(fh) != 0) {
        var up_w = av1_fh_upscaled_width(fh);
        sr_curr = av1_superres_upscale_new(frame, up_w, out_err);
        if (sr_curr == 0) { return 0; }
        if (cdef_frame == frame) {
            sr_cdef = sr_curr;
        } else {
            sr_cdef = av1_superres_upscale_new(cdef_frame, up_w, out_err);
            if (sr_cdef == 0) { return 0; }
        }
        result = sr_cdef;
    }
    # 3. loop restoration (at the upscaled width).
    if ((av1_fh_uses_lr(fh) != 0) && (lr_params != 0)) {
        var lr_frame = av1_cdef_frame_new(sr_cdef, out_err);
        if (lr_frame == 0) { store64(out_err, DR_ERR_OOM); return 0; }
        av1_lr_process(sr_curr, sr_cdef, lr_frame, lr_params);
        result = lr_frame;
    }
    return result;
}

# ================================================================
# lr_params_from_fh: build the Av1LrParams for a frame from its parsed header
# (spec 5.9.20 lr_params + 7.17). Returns 0 (writing *out_err) when the frame
# uses NO loop restoration (UsesLr == 0) or on OOM; a fresh Av1LrParams otherwise.
#   uw / fh_h  — UpscaledWidth / FrameHeight (the LR grid spans the upscaled frame)
#   np         — plane count (mono = 1, else 3)
# The per-plane FrameRestorationType[] / LoopRestorationSize[] and the read_lr
# frame flags (allow_intrabc / use_superres / SuperresDenom) come straight from
# the header; subsampling comes from the sequence. Planes left RESTORE_NONE keep
# null grids (params_new default) so av1_lr_process never dispatches them.
# ================================================================
fn av1_lr_params_from_fh(fh, seq, uw, fh_h, np, out_err): i64 {
    store64(out_err, DR_OK);
    if (av1_fh_uses_lr(fh) == 0) { return 0; }
    var params = av1_lr_params_new(uw, fh_h, np, av1_seq_subsampling_x(seq),
    av1_seq_subsampling_y(seq), 1);
    if (params == 0) { store64(out_err, DR_ERR_OOM); return 0; }
    var plane = 0;
    while (plane < np) {
        var rtype = av1_fh_frame_restoration_type(fh, plane);
        if (rtype != AV1_RESTORE_NONE) {
            var rc = av1_lr_params_set_plane(params, plane, rtype,
            av1_fh_loop_restoration_size(fh, plane));
            if (rc != DR_OK) { store64(out_err, rc); return 0; }
        }
        plane = plane + 1;
    }
    av1_lr_params_set_frame_flags(params, av1_fh_allow_intrabc(fh),
    av1_fh_use_superres(fh), av1_fh_superres_denom(fh));
    return params;
}

# ================================================================
# activate_intra_filters: attach the decode-time in-loop-filter reads to a tile
# from the frame header. This is the step that turns the wired-but-inert CDEF/LR
# reads LIVE for a real bitstream:
#   * CDEF read context (read_cdef, spec 5.11.56) — set only when the sequence
#     enables CDEF; carries cdef_bits + the coded_lossless / allow_intrabc gates.
#   * LR params (read_lr, 5.11.57) — attached unconditionally (0 = frame uses no
#     LR, which leaves read_lr inert via its own null guard).
# After this, decode_intra_tile populates CdefIdx + the LR unit grids, which
# av1_apply_loop_filters then consumes. The tile's grids MUST already be
# allocated (av1_tile_grids_new) — set_cdef_ctx faults fast (DR_ERR_BOUNDS) on a
# null CdefIdx grid. Returns a DrErr code (set_cdef_ctx may OOM / bounds-fault).
# ================================================================
fn av1_activate_intra_filters(tile, seq, fh, lr_params): i64 {
    av1_tile_set_lr_params(tile, lr_params);
    if (av1_seq_enable_cdef(seq) != 0) {
        return av1_tile_set_cdef_ctx(tile, av1_seq_enable_cdef(seq),
        av1_fh_cdef_bits(fh), av1_fh_coded_lossless(fh), av1_fh_allow_intrabc(fh), 0);
    }
    return DR_OK;
}

# ================================================================
# The DECODE FRAME ALLOCATION EXTENT (0.7.114). Prediction writes a block's NOMINAL extent,
# which runs past the visible frame in two independent ways:
#   1. MiCols*MI_SIZE already exceeds FrameWidth by up to 7 samples (MiCols = 2*((W+7)>>3));
#   2. a block may legally overhang the MI grid by half-1 MI units on top of that, because
#      decode_partition only requires the block's HALF to be inside (has_rows / has_cols) —
#      7 MI = 28 luma samples for a BLOCK_64X64, the largest drishti admits.
# Allocating to the MI grid removes (1); AV1_DECODE_BORDER covers (2) with room to spare.
#
# This is not defensive padding, it is a correctness requirement: intra prediction writes that
# extent unclamped through the deliberately unchecked dr_frame_set, and the overhang band is
# then READ back by deblocking and CDEF into visible output. A 64x40 keyframe with one legal
# BLOCK_64X64 block wrote 2048 bytes past the plane and returned DR_OK before this landed.
# ================================================================
enum Av1DecodeAlloc {
    AV1_DECODE_BORDER = 32;   # >= 28, the worst-case block overhang past the MI grid
}

# MiCols/MiRows are DERIVED from the frame dims (5.9.9) so the MI extent normally covers them,
# but take the max anyway rather than trusting two header fields to agree: a header whose dims
# were overwritten out from under its MI counts must still allocate at least the visible frame.
fn av1_decode_alloc_w(fh): i64 {
    var v = av1_fh_mi_cols(fh) * AV1_MI_SIZE;
    if (v < av1_fh_frame_width(fh)) { v = av1_fh_frame_width(fh); }
    return v;
}
fn av1_decode_alloc_h(fh): i64 {
    var v = av1_fh_mi_rows(fh) * AV1_MI_SIZE;
    if (v < av1_fh_frame_height(fh)) { v = av1_fh_frame_height(fh); }
    return v;
}

# ================================================================
# le(n) — spec 4.10.4: read n bytes little-endian into an unsigned value. The
# tile-group parser calls this only after byte_alignment (byte-aligned), so it
# reads straight from the buffer; the caller guarantees n bytes exist. n is
# TileSizeBytes (1..4), so the result fits an i64 (max 2^32-1).
# ================================================================
fn av1_read_le(buf, n): i64 {
    var v = 0;
    var i = 0;
    while (i < n) {
        v = v + (load8(buf + i) << (i * 8));
        i = i + 1;
    }
    return v;
}

# ================================================================
# Av1TileGroup — the output of tile_group_obu (5.11.1) parsing: the group's tile
# range [tg_start, tg_end] plus, per whole-frame tile index (TileNum in
# 0..NumTiles-1), the byte offset + size of that tile's data within the OBU
# payload. Tiles outside [tg_start, tg_end] keep offset -1 (not in this group).
# The frame driver iterates TileNum from tg_start to tg_end and hands each
# (buf + offset, size) to decode_intra_tile.
# ================================================================
enum Av1TgOff {
    AV1TG_TGSTART  = 0;    # tg_start (first TileNum in the group)
    AV1TG_TGEND    = 8;    # tg_end   (last TileNum, inclusive)
    AV1TG_NUMTILES = 16;   # NumTiles = TileCols * TileRows (whole frame)
    AV1TG_TSBYTES  = 24;   # TileSizeBytes (1..4)
    AV1TG_CAP      = 32;   # capacity of the offset/size arrays
    AV1TG_OFFS     = 40;   # ptr to tile_offset[CAP] (byte offset in payload; -1 = absent)
    AV1TG_SIZES    = 48;   # ptr to tile_size[CAP]
    AV1TG_SIZE     = 56;
}

# Allocate an Av1TileGroup sized for up to max_tiles whole-frame tiles (offsets
# init -1 = absent). Returns 0 on bad arg / OOM.
fn av1_tile_group_new(max_tiles): i64 {
    if (max_tiles <= 0) { return 0; }
    var tg = alloc(AV1TG_SIZE);
    if (tg == 0) { return 0; }
    var offs = alloc(max_tiles * 8);
    var sizes = alloc(max_tiles * 8);
    if ((offs == 0) || (sizes == 0)) { return 0; }
    store64(tg + AV1TG_TGSTART, 0);
    store64(tg + AV1TG_TGEND, 0);
    store64(tg + AV1TG_NUMTILES, 0);
    store64(tg + AV1TG_TSBYTES, 0);
    store64(tg + AV1TG_CAP, max_tiles);
    store64(tg + AV1TG_OFFS, offs);
    store64(tg + AV1TG_SIZES, sizes);
    var i = 0;
    while (i < max_tiles) {
        store64(offs + (i * 8), 0 - 1);
        store64(sizes + (i * 8), 0);
        i = i + 1;
    }
    return tg;
}
fn av1_tg_start(tg): i64 { return load64(tg + AV1TG_TGSTART); }
fn av1_tg_end(tg): i64 { return load64(tg + AV1TG_TGEND); }
fn av1_tg_num_tiles(tg): i64 { return load64(tg + AV1TG_NUMTILES); }
# tiles carried by THIS group (tg_end - tg_start + 1).
fn av1_tg_count(tg): i64 { return (load64(tg + AV1TG_TGEND) - load64(tg + AV1TG_TGSTART)) + 1; }
fn av1_tg_tile_offset(tg, tile_num): i64 { return load64(load64(tg + AV1TG_OFFS) + (tile_num * 8)); }
fn av1_tg_tile_size(tg, tile_num): i64 { return load64(load64(tg + AV1TG_SIZES) + (tile_num * 8)); }
# tileRow / tileCol from TileNum (5.11.1): row-major over the TileCols x TileRows grid.
fn av1_tg_tile_row(tile_num, tile_cols): i64 { return tile_num / tile_cols; }
fn av1_tg_tile_col(tile_num, tile_cols): i64 { return tile_num % tile_cols; }

# ================================================================
# tile_group_obu (spec 5.11.1) — parse a tile-group OBU payload buf[0..sz): the
# group header (tile_start_and_end_present_flag + tg_start/tg_end) then, for each
# TileNum in [tg_start, tg_end], the tile's byte range. Non-last tiles carry a
# tile_size_minus_1 = le(TileSizeBytes) prefix; the last tile takes the remaining
# bytes. Fills `tg` (allocated by av1_tile_group_new with cap >= NumTiles) and
# returns the tile count in the group, or 0 (writing *out_err) on any fault.
#
# Trust no input byte: NumTiles is capped at MAX_TILE_COLS*ROWS, TileSizeBytes to
# 1..4, tg_start/tg_end validated against NumTiles, and every size field / tile
# extent bounds-checked against sz — a lying or truncated size is rejected
# (DR_ERR_TRUNCATED / DR_ERR_BAD_HEADER), never an OOB read.
# ================================================================
fn av1_tile_group_parse(tg, buf, sz, fh, out_err): i64 {
    store64(out_err, DR_OK);
    if ((tg == 0) || (buf == 0) || (sz < 0)) { store64(out_err, DR_ERR_BOUNDS); return 0; }
    var tile_cols = av1_fh_tile_cols(fh);
    var tile_rows = av1_fh_tile_rows(fh);
    if ((tile_cols <= 0) || (tile_rows <= 0)
    || (tile_cols > AV1_MAX_TILE_COLS) || (tile_rows > AV1_MAX_TILE_ROWS)) {
        store64(out_err, DR_ERR_BOUNDS); return 0;
    }
    var num_tiles = tile_cols * tile_rows;
    if (num_tiles > load64(tg + AV1TG_CAP)) { store64(out_err, DR_ERR_BOUNDS); return 0; }
    var tsbytes = av1_fh_tile_size_bytes(fh);
    if ((tsbytes < 1) || (tsbytes > 4)) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
    # --- tile-group header (5.11.1) ---
    var br = dr_br_init(buf, sz);
    if (br == 0) { store64(out_err, DR_ERR_OOM); return 0; }
    var present = 0;
    if (num_tiles > 1) { present = dr_br_read_bit(br); }
    var tg_start = 0;
    var tg_end = num_tiles - 1;
    if ((num_tiles > 1) && (present != 0)) {
        var tilebits = av1_fh_tile_cols_log2(fh) + av1_fh_tile_rows_log2(fh);
        tg_start = dr_br_read_bits(br, tilebits);
        tg_end = dr_br_read_bits(br, tilebits);
    }
    dr_br_byte_align(br);
    if (dr_br_err(br) != DR_OK) { store64(out_err, DR_ERR_TRUNCATED); return 0; }
    # validate the group range (trust no input)
    if ((tg_start < 0) || (tg_end < tg_start) || (tg_end > (num_tiles - 1))) {
        store64(out_err, DR_ERR_BAD_HEADER); return 0;
    }
    store64(tg + AV1TG_TGSTART, tg_start);
    store64(tg + AV1TG_TGEND, tg_end);
    store64(tg + AV1TG_NUMTILES, num_tiles);
    store64(tg + AV1TG_TSBYTES, tsbytes);
    var offs = load64(tg + AV1TG_OFFS);
    var sizes = load64(tg + AV1TG_SIZES);
    var cursor = dr_br_byte_pos(br);
    # --- per-tile byte ranges ---
    var tn = tg_start;
    while (tn <= tg_end) {
        var tsize = 0;
        if (tn == tg_end) {
            # last tile: the remaining payload bytes.
            if (cursor > sz) { store64(out_err, DR_ERR_TRUNCATED); return 0; }
            tsize = sz - cursor;
        } else {
            # tile_size_minus_1 = le(TileSizeBytes), then tileSize bytes of data.
            if ((cursor + tsbytes) > sz) { store64(out_err, DR_ERR_TRUNCATED); return 0; }
            tsize = av1_read_le(buf + cursor, tsbytes) + 1;
            cursor = cursor + tsbytes;
            if ((cursor + tsize) > sz) { store64(out_err, DR_ERR_TRUNCATED); return 0; }
        }
        store64(offs + (tn * 8), cursor);
        store64(sizes + (tn * 8), tsize);
        cursor = cursor + tsize;
        tn = tn + 1;
    }
    return (tg_end - tg_start) + 1;
}

# ================================================================
# Av1FrameDec — the frame-decode context that persists across tile-group OBUs so a
# frame split into MULTIPLE tile groups (each carrying a TileNum sub-range) can be
# assembled incrementally: the reconstruction frame + the SHARED frame-sized MI grids
# (owned by TILE0) + the LR params live here, and each group decodes its tiles into
# the shared grids. TILES_DONE tracks the next expected TileNum (groups must arrive
# in TileNum order); when it reaches NUM_TILES the frame is complete and the in-loop
# filters run once over the whole frame. (spec 5.11.1 general_tile_group_obu.)
# ================================================================
enum Av1FrameDec {
    AV1FDEC_FRAME      = 0;    # the DrFrame under construction
    AV1FDEC_TILE0      = 8;    # grid-owner tile (persists; 0 until the first tile)
    AV1FDEC_LR_PARAMS  = 16;   # loop-restoration params (built once in _new)
    AV1FDEC_SEQ        = 24;   # active Av1Seq
    AV1FDEC_FH         = 32;   # active Av1FrameHeader
    AV1FDEC_NUM_TILES  = 40;   # TileCols * TileRows (frame total)
    AV1FDEC_TILES_DONE = 48;   # tiles decoded so far == next expected TileNum
    AV1FDEC_DPB        = 56;   # Av1Dpb (0 = intra-only decode; inter frames need it)
    AV1FDEC_REFS       = 64;   # Av1RefState (paired with DPB)
    AV1FDEC_SIZE       = 72;
}

# av1_frame_dec_new — begin a frame decode: validate scope, create the reconstruction
# frame at the header dims (border 8 for CDEF/LR), build the LR params once, and stash
# the cross-group state. Returns the context (or 0, *out_err set). The reconstruction
# frame is created at FrameWidth (the downscaled/coded width); when use_superres is set
# the in-loop pipeline (av1_apply_loop_filters) upscales it to UpscaledWidth (7.16)
# between CDEF and LR, and the LR params carry UpscaledWidth. dr_frame_new validates
# BitDepth in {8,10,12} and writes the precise cause.
fn av1_frame_dec_new(seq, fh, out_err): i64 {
    store64(out_err, DR_OK);
    if ((seq == 0) || (fh == 0)) { store64(out_err, DR_ERR_BOUNDS); return 0; }
    # use_128x128_superblock (spec 5.5.1) DECODES as of 0.7.126 (E2a): the SB loop drives
    # sbSize/sbSize4 off AV1TILE_SB128, the partition tree has the W128 CDF + its 8-symbol
    # alphabet, residual() splits a >64 block into 64x64 chunks, and every SB-relative
    # coordinate uses sbMask (31 vs 15). libaom DEFAULTS to 128x128 superblocks, so this
    # gate was rejecting essentially every real-world AV1 stream.
    # ---- SILENT-MIS-DECODE REJECTS (0.7.116) ----
    # Each of these is a frame-header feature drishti PARSES but does not IMPLEMENT. Parsing
    # without implementing is the worst of both worlds: the stream is accepted, decoding
    # proceeds, and the output is wrong with no error — exactly what "trust no input byte"
    # (CLAUDE.md) forbids. They are rejected at the one chokepoint every decode path shares.
    # Each is a tracked gap (roadmap.md), and each becomes an un-gating bite when implemented.
    #
    # primary_ref_frame != NONE now INHERITS the ref slot's saved CDFs (C1, 7.20/7.21 — see
    # av1_tile_inherit_cdfs + the save in av1_frame_dec_finish). A primary_ref that selects a slot
    # with no saved CDFs is caught at the tile inherit (malformed -> DR_ERR_UNSUPPORTED). One reject
    # remains: an ADAPTING frame (disable_frame_end_update_cdf == 0, i.e. it saves its adapted CDFs)
    # whose context_update_tile_id names a tile OTHER than tile0 cannot be saved correctly — the
    # frame-decode context retains only tile0's adapted CDFs (roadmap.md C1 follow-on: retain the
    # named context tile). A single-tile frame forces context_update_tile_id = 0, and a non-adapting
    # frame's saved CDFs are its (tile-independent) initial context, so both are handled.
    if ((av1_fh_disable_frame_end_update_cdf(fh) == 0)
    && (av1_fh_context_update_tile_id(fh) != 0)) {
        store64(out_err, DR_ERR_UNSUPPORTED);
        return 0;
    }
    # segmentation (0.7.125 D1): the DECODABLE configs (spatial map read, per-segment qindex) now
    # decode on BOTH lanes (av1_intra_segment_id / av1_inter_segment_id). av1_seg_supported gates the
    # rest — temporal-predicted / copied maps + feature-data inheritance (need a DPB-saved seg map) and
    # a lossless-boundary-crossing segment — which still REJECT cleanly (trust no input byte). delta-q/lf
    # remain fully rejected (an entropy desync on the intra path, not merely wrong pixels).
    if (av1_seg_supported(fh) == 0) { store64(out_err, DR_ERR_UNSUPPORTED); return 0; }
    if (av1_fh_delta_q_present(fh) != 0) { store64(out_err, DR_ERR_UNSUPPORTED); return 0; }
    if (av1_fh_delta_lf_present(fh) != 0) { store64(out_err, DR_ERR_UNSUPPORTED); return 0; }
    # allow_intrabc (5.11.6) and the palette tools gated by allow_screen_content_tools
    # (5.11.46) are read by neither path; a screen-content stream would desync.
    if (av1_fh_allow_intrabc(fh) != 0) { store64(out_err, DR_ERR_UNSUPPORTED); return 0; }
    if (av1_fh_allow_screen_content_tools(fh) != 0) {
        store64(out_err, DR_ERR_UNSUPPORTED);
        return 0;
    }
    var num_planes = av1_seq_num_planes(seq);
    # Allocate to the MI GRID, not the visible frame. Prediction writes a block's NOMINAL
    # extent, which runs past FrameWidth/FrameHeight in two independent ways: MiCols*MI_SIZE
    # already exceeds FrameWidth by up to 7 samples (MiCols = 2*((W+7)>>3)), and a block may
    # legally overhang the MI grid by half-1 MI units on top of that — 7 MI = 28 luma samples
    # for a BLOCK_64X64, since decode_partition only requires the block's HALF to be inside.
    #
    # An 8-sample border did NOT cover that. A 64x40 keyframe with one legal BLOCK_64X64
    # intra block wrote 2048 bytes past the plane allocation and the decode returned DR_OK;
    # nothing caught it because every fixture was a multiple of 64 and so nothing overhung.
    # MI-aligning the allocation removes the first term and the 32-sample border covers the
    # second with room to spare. Reported plane dims are unchanged, so CDEF, loop restoration,
    # superres and the output crop all still measure the VISIBLE frame.
    var frame = dr_frame_new_ext(av1_fh_frame_width(fh), av1_fh_frame_height(fh),
    av1_decode_alloc_w(fh), av1_decode_alloc_h(fh),
    num_planes, av1_seq_subsampling_x(seq), av1_seq_subsampling_y(seq),
    av1_seq_bitdepth(seq), AV1_DECODE_BORDER, out_err);
    if (frame == 0) { return 0; }   # dr_frame_new already wrote the precise cause
    var terr = 0;
    var lr_params = av1_lr_params_from_fh(fh, seq, av1_fh_upscaled_width(fh),
    av1_fh_frame_height(fh), num_planes, &terr);
    if (terr != DR_OK) { store64(out_err, terr); return 0; }
    var fdc = alloc(AV1FDEC_SIZE);   # AV1FDEC_SIZE bytes
    if (fdc == 0) { store64(out_err, DR_ERR_OOM); return 0; }
    store64(fdc + AV1FDEC_FRAME, frame);
    store64(fdc + AV1FDEC_TILE0, 0);
    store64(fdc + AV1FDEC_LR_PARAMS, lr_params);
    store64(fdc + AV1FDEC_SEQ, seq);
    store64(fdc + AV1FDEC_FH, fh);
    store64(fdc + AV1FDEC_NUM_TILES, av1_fh_tile_cols(fh) * av1_fh_tile_rows(fh));
    store64(fdc + AV1FDEC_TILES_DONE, 0);
    store64(fdc + AV1FDEC_DPB, 0);
    store64(fdc + AV1FDEC_REFS, 0);
    return fdc;
}
# wire the reference state an INTER frame needs (0.7.84): the DPB the MC reads and
# the ref-frame metadata. Without them a non-intra frame is rejected UNSUPPORTED.
fn av1_frame_dec_set_inter(fdc, dpb, refs): i64 {
    store64(fdc + AV1FDEC_DPB, dpb);
    store64(fdc + AV1FDEC_REFS, refs);
    return DR_OK;
}

# av1_frame_dec_group — decode one tile group's payload (buf[0..sz)) into the shared
# frame grids. Returns 1 if the frame is now complete, 0 if more groups are expected,
# or -1 on error (*out_err set). The group must start exactly where the previous one
# ended (in-order, tile-contiguous — trust no input). The first tile overall allocates
# the shared grids and becomes TILE0; every later tile shares them.
fn av1_frame_dec_group(fdc, buf, sz, out_err): i64 {
    store64(out_err, DR_OK);
    var seq = load64(fdc + AV1FDEC_SEQ);
    var fh = load64(fdc + AV1FDEC_FH);
    var frame = load64(fdc + AV1FDEC_FRAME);
    var num_planes = av1_seq_num_planes(seq);
    var num_tiles = load64(fdc + AV1FDEC_NUM_TILES);
    var tg = av1_tile_group_new(av1_max(1, num_tiles));
    if (tg == 0) { store64(out_err, DR_ERR_OOM); return 0 - 1; }
    var terr = 0;
    av1_tile_group_parse(tg, buf, sz, fh, &terr);
    if (terr != DR_OK) { store64(out_err, terr); return 0 - 1; }
    # this group must continue the frame exactly at the next expected TileNum.
    if (av1_tg_start(tg) != load64(fdc + AV1FDEC_TILES_DONE)) {
        store64(out_err, DR_ERR_UNSUPPORTED); return 0 - 1;
    }
    var fmi_cols = av1_fh_mi_cols(fh);
    var fmi_rows = av1_fh_mi_rows(fh);
    var tile_cols = av1_fh_tile_cols(fh);
    var lr_params = load64(fdc + AV1FDEC_LR_PARAMS);
    var enable_ef = load64(seq + AV1_SEQ_ENABLE_INTRA_EDGE);
    var enable_fi = load64(seq + AV1_SEQ_ENABLE_FILTER_INTRA);
    var base_q = av1_fh_base_q_idx(fh);
    var reduced_tx = av1_fh_reduced_tx_set(fh);
    var tx_mode = av1_fh_tx_mode(fh);
    var disable_cdf = av1_fh_disable_cdf_update(fh);
    var tn = av1_tg_start(tg);
    while (tn <= av1_tg_end(tg)) {
        var tcol = av1_tg_tile_col(tn, tile_cols);
        var trow = av1_tg_tile_row(tn, tile_cols);
        var col_start = av1_fh_mi_col_start(fh, tcol);
        var col_end = av1_fh_mi_col_start(fh, tcol + 1);
        var row_start = av1_fh_mi_row_start(fh, trow);
        var row_end = av1_fh_mi_row_start(fh, trow + 1);
        var tile = av1_tile_new(frame, col_end - col_start, row_end - row_start,
        base_q, enable_ef, reduced_tx, num_planes);
        if (tile == 0) { store64(out_err, DR_ERR_OOM); return 0 - 1; }
        store64(tile + AV1TILE_TX_MODE, tx_mode);
        store64(tile + AV1TILE_ENABLE_FI, enable_fi);
        store64(tile + AV1TILE_SEG_FH, fh);   # segmentation lookups on BOTH lanes (0.7.125 D1)
        av1_tile_set_sb128(tile, av1_seq_use_128x128(seq));   # 128x128 superblocks (0.7.126 E2a)
        av1_tile_set_frame_mi(tile, fmi_cols, fmi_rows);
        var tile0 = load64(fdc + AV1FDEC_TILE0);
        if (tile0 == 0) {
            if (av1_tile_grids_new(tile) != DR_OK) { store64(out_err, DR_ERR_OOM); return 0 - 1; }
            store64(fdc + AV1FDEC_TILE0, tile);
        } else {
            av1_tile_share_grids(tile, tile0);
        }
        av1_tile_set_window(tile, col_start, row_start, col_end, row_end);
        var ar = av1_activate_intra_filters(tile, seq, fh, lr_params);
        if (ar != DR_OK) { store64(out_err, ar); return 0 - 1; }
        if (av1_fh_frame_is_intra(fh) == 0) {
            # an INTER frame (0.7.84): needs the DPB + ref state for MC.
            var idpb = load64(fdc + AV1FDEC_DPB);
            var irefs = load64(fdc + AV1FDEC_REFS);
            if ((idpb == 0) || (irefs == 0)) { store64(out_err, DR_ERR_UNSUPPORTED); return 0 - 1; }
            var ir = av1_tile_set_inter_ctx(tile, fh, irefs, seq, idpb);
            if (ir != DR_OK) { store64(out_err, ir); return 0 - 1; }
            var dri = av1_decode_inter_tile(tile, buf + av1_tg_tile_offset(tg, tn),
            av1_tg_tile_size(tg, tn), disable_cdf);
            if (dri != DR_OK) { store64(out_err, dri); return 0 - 1; }
            tn = tn + 1;
        } else {
            var dr = av1_decode_intra_tile(tile, buf + av1_tg_tile_offset(tg, tn),
            av1_tg_tile_size(tg, tn), disable_cdf);
            if (dr != DR_OK) { store64(out_err, dr); return 0 - 1; }
            tn = tn + 1;
        }
    }
    store64(fdc + AV1FDEC_TILES_DONE, av1_tg_end(tg) + 1);
    if ((av1_tg_end(tg) + 1) == num_tiles) { return 1; }
    return 0;
}

# av1_frame_dec_finish — the frame is fully decoded: run the in-loop filters over the
# WHOLE frame (they cross tile boundaries by design) by reusing TILE0 (the shared-grid
# owner) with its window reset to the full frame, and return the filtered frame.
fn av1_frame_dec_finish(fdc, out_err): i64 {
    store64(out_err, DR_OK);
    var tile0 = load64(fdc + AV1FDEC_TILE0);
    if (tile0 == 0) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }   # no tiles decoded
    var seq = load64(fdc + AV1FDEC_SEQ);
    var fh = load64(fdc + AV1FDEC_FH);
    av1_tile_set_window(tile0, 0, 0, av1_fh_mi_cols(fh), av1_fh_mi_rows(fh));
    var ferr = 0;
    var result = av1_apply_loop_filters(tile0, fh, seq, load64(fdc + AV1FDEC_LR_PARAMS), &ferr);
    if (ferr != DR_OK) { store64(out_err, ferr); return 0; }
    # TEMPORAL-MV PRODUCER (0.7.102, spec 7.19/7.20): save this inter frame's per-8x8 motion field into the
    # DPB slots it refreshes, so a FUTURE frame's motion_field_estimation (7.9) can read it. Output-neutral
    # — nothing reads AV1REF_SAVED_MF yet (the estimation + scan are 0.7.103/104). Intra/key frames leave
    # the slots null (no MVs to save). One arena buffer is aliased into every refreshed slot (never freed;
    # no later frame mutates it — the reducer allocs a fresh buffer per frame). The MI grid lives on tile0
    # (the loop filters do not mutate it, so this after-filter placement is fine).
    var refs = load64(fdc + AV1FDEC_REFS);
    if ((refs != 0) && (av1_fh_frame_is_intra(fh) == 0)) {
        var grid = load64(tile0 + AV1TILE_MVGRID);
        if (grid != 0) {
            var fmi_cols = av1_fh_mi_cols(fh);
            var fmi_rows = av1_fh_mi_rows(fh);
            var buf = alloc(16 + ((fmi_rows >> 1) * (fmi_cols >> 1) * 24));
            if (buf != 0) {
                av1_mv_save_field(grid, fmi_cols, fmi_rows, seq, fh, buf);
                var rff = av1_fh_refresh_frame_flags(fh);
                var i = 0;
                while (i < 8) {
                    if (((rff >> i) & 1) != 0) { av1_ref_set_saved_mf(refs, i, buf); }
                    i = i + 1;
                }
            }
        }
    }
    # CDF SAVE (C1, 7.20): save the frame's exit CDF context into every refreshed DPB slot, so a future
    # non-key frame whose primary_ref_frame selects one inherits it (7.21). Two cases per spec:
    #  - disable_frame_end_update_cdf == 0: save the ADAPTED context tile (tile0; a non-tile0
    #    context_update_tile_id is rejected in av1_frame_dec_new since only tile0 is retained).
    #  - disable_frame_end_update_cdf == 1: save the frame's INITIAL CDFs, NOT the adapted ones — the
    #    q-bucketed defaults (primary_ref_frame == NONE) or the inherited source bundle (otherwise).
    #    Reconstructed here (tile-independent), so this needs no per-tile pre-decode snapshot.
    # Runs for intra + inter (a keyframe's CDFs are inheritable). One bundle is aliased into every
    # refreshed slot — never mutated after (the inherit COPIES out of it).
    if (refs != 0) {
        var cdfb = av1_cdf_bundle_new();
        if (cdfb == 0) { store64(out_err, DR_ERR_OOM); return 0; }
        var serr = DR_OK;
        if (av1_fh_disable_frame_end_update_cdf(fh) == 0) {
            serr = av1_cdf_bundle_save(cdfb, tile0);
        } else {
            var pr = av1_fh_primary_ref_frame(fh);
            if (pr == AV1_PRIMARY_REF_NONE) {
                serr = av1_cdf_bundle_defaults(cdfb, av1_coeff_cdf_qbucket(load64(tile0 + AV1TILE_BASE_Q)));
            } else {
                var src = av1_ref_saved_cdf(refs, av1_fh_ref_frame_idx(fh, pr));
                if (src == 0) { serr = DR_ERR_UNSUPPORTED; } else { av1_cdf_copy_words(cdfb, src, 7244); }
            }
        }
        if (serr != DR_OK) { store64(out_err, serr); return 0; }
        var crff = av1_fh_refresh_frame_flags(fh);
        var ci = 0;
        while (ci < 8) {
            if (((crff >> ci) & 1) != 0) { av1_ref_set_saved_cdf(refs, ci, cdfb); }
            ci = ci + 1;
        }
    }
    return result;
}

# ================================================================
# av1_decode_frame — decode ONE intra (key) frame from its already-parsed headers
# + a SINGLE tile-group payload (the common case: all tiles in one group), returning
# the final in-loop-filtered frame (writes *out_err). Thin wrapper over the frame-decode
# context: new -> group -> finish. A frame split across multiple tile-group OBUs (a
# partial group here) is driven by av1_decode_obus instead and rejected DR_ERR_UNSUPPORTED
# by this single-group entry. 8/10/12-bit + superres supported. Returns the
# filtered (and, under use_superres, upscaled) frame or 0.
# ================================================================
fn av1_decode_frame(seq, fh, buf, sz, out_err): i64 {
    return av1_decode_frame_ref(seq, fh, 0, 0, buf, sz, out_err);
}
# av1_decode_frame with the inter reference state threaded (0.7.84): dpb/refs = 0
# keeps the intra-only behavior (a non-intra frame then rejects UNSUPPORTED).
fn av1_decode_frame_ref(seq, fh, dpb, refs, buf, sz, out_err): i64 {
    store64(out_err, DR_OK);
    if ((seq == 0) || (fh == 0) || (buf == 0) || (sz < 0)) {
        store64(out_err, DR_ERR_BOUNDS); return 0;
    }
    var fdc = av1_frame_dec_new(seq, fh, out_err);
    if (fdc == 0) { return 0; }   # av1_frame_dec_new already wrote the precise cause
    av1_frame_dec_set_inter(fdc, dpb, refs);
    var done = av1_frame_dec_group(fdc, buf, sz, out_err);
    if (done < 0) { return 0; }   # error, *out_err set
    # a single-group entry: the one group must cover the whole frame. A partial group
    # (frame split across tile-group OBUs) is driven by av1_decode_obus, not here.
    if (done == 0) { store64(out_err, DR_ERR_UNSUPPORTED); return 0; }
    return av1_frame_dec_finish(fdc, out_err);
}

# ================================================================
# av1_decode_obus — walk an AV1 OBU stream buf[0..sz) and decode the first coded
# frame to pixels (writes *out_err). This closes the raw-bitstream -> pixels loop:
# it iterates OBUs (av1_obu_next) and dispatches by type —
#   SEQUENCE_HEADER -> av1_seq_parse (the active sequence),
#   FRAME_HEADER    -> av1_frame_parse_uncompressed_header (the active fh; tid/sid
#                      from the OBU extension header),
#   FRAME (type 6)  -> parse the embedded frame_header, split off the tile group at
#                      the byte-aligned header end (5.10), and decode it,
#   TILE_GROUP      -> feed a frame-decode context (av1_frame_dec_*); a frame may
#                      span SEVERAL tile-group OBUs, so accumulate until complete,
#                      then return the decoded + filtered frame,
# and skips temporal_delimiter / metadata / padding / redundant_frame_header /
# tile_list. Returns when a frame completes (embedded FRAME OBU, or the last of its
# standalone tile groups).
#
# SCOPE: single-frame keyframe streams, both the separate-OBU form (SEQUENCE_HEADER
# / FRAME_HEADER / one-or-more TILE_GROUP OBUs) and the combined FRAME OBU (the common
# real-stream form, one embedded tile group); 8/10/12-bit, single- and multi-tile,
# multi-tile-group. A stream with no tile group returns DR_ERR_BAD_HEADER.
# ================================================================
fn av1_decode_obus(buf, sz, out_err): i64 {
    store64(out_err, DR_OK);
    if ((buf == 0) || (sz < 0)) { store64(out_err, DR_ERR_BOUNDS); return 0; }
    var it = av1_obu_iter_init(buf, sz);
    if (it == 0) { store64(out_err, DR_ERR_OOM); return 0; }
    var refs = av1_ref_state_new();
    if (refs == 0) { store64(out_err, DR_ERR_OOM); return 0; }
    var seq = 0;
    var fh = 0;
    var fdc = 0;   # frame-decode context, created lazily at the first TILE_GROUP OBU
    var otype = 0;
    var ooff = 0;
    var osize = 0;
    var rc = av1_obu_next(it, &otype, &ooff, &osize);
    while (rc == DR_OK) {
        if (otype == AV1_OBU_SEQUENCE_HEADER) {
            var serr = 0;
            seq = av1_seq_parse(buf + ooff, osize, &serr);
            if (serr != DR_OK) { store64(out_err, serr); return 0; }
            if (seq == 0) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
        }
        if (otype == AV1_OBU_FRAME_HEADER) {
            if (seq == 0) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
            var o = av1_obu_iter_obu(it);
            var ferr = 0;
            fh = av1_frame_parse_uncompressed_header(seq, refs, av1_obu_tid(o),
            av1_obu_sid(o), buf + ooff, osize, &ferr);
            if (ferr != DR_OK) { store64(out_err, ferr); return 0; }
            if (fh == 0) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
        }
        # combined FRAME OBU (spec 5.10 frame_obu): frame_header_obu() then
        # byte_alignment() then tile_group_obu(). Parse the fh, split at the
        # byte-aligned header end (headerBytes = ceil(bits_consumed / 8)), and decode
        # the embedded tile group at buf+ooff+headerBytes.
        if (otype == AV1_OBU_FRAME) {
            if (seq == 0) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
            var of = av1_obu_iter_obu(it);
            var frr = 0;
            var ffh = av1_frame_parse_uncompressed_header(seq, refs, av1_obu_tid(of),
            av1_obu_sid(of), buf + ooff, osize, &frr);
            if (frr != DR_OK) { store64(out_err, frr); return 0; }
            if (ffh == 0) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
            # headerBytes = ceil(bits_consumed / 8): the byte_alignment() after the
            # frame_header rounds the pre-alignment bit position UP to the next byte
            # boundary. (bits + 7) >> 3 is that ceiling — NOT (bits >> 3) + 1, which
            # would over-round a header ending on an exact byte and shift the tile
            # start a byte late.
            var hbytes = (av1_fh_bits_consumed(ffh) + 7) >> 3;
            # Defensive: a successful parse cannot consume past the payload (the
            # bounded reader caps at osize*8), so hbytes <= osize always — but guard
            # anyway rather than pass a negative size downstream.
            if (hbytes > osize) { store64(out_err, DR_ERR_TRUNCATED); return 0; }
            return av1_decode_frame(seq, ffh, buf + ooff + hbytes, osize - hbytes, out_err);
        }
        # standalone TILE_GROUP OBU(s): a frame may be split into several, each carrying
        # a TileNum sub-range (spec 5.11.1). Create the frame-decode context at the first,
        # feed each group into it, and return the filtered frame when the last group
        # completes the frame; otherwise keep walking for the next group.
        if (otype == AV1_OBU_TILE_GROUP) {
            if ((seq == 0) || (fh == 0)) { store64(out_err, DR_ERR_BAD_HEADER); return 0; }
            if (fdc == 0) {
                fdc = av1_frame_dec_new(seq, fh, out_err);
                if (fdc == 0) { return 0; }
            }
            var gdone = av1_frame_dec_group(fdc, buf + ooff, osize, out_err);
            if (gdone < 0) { return 0; }
            if (gdone == 1) { return av1_frame_dec_finish(fdc, out_err); }
        }
        rc = av1_obu_next(it, &otype, &ooff, &osize);
    }
    # loop ended: a clean end (AV1_OBU_END) with no tile group, or a parse fault.
    if (rc != AV1_OBU_END) { store64(out_err, rc); return 0; }
    store64(out_err, DR_ERR_BAD_HEADER);
    return 0;
}
