# src/av1_intermode.cyr — AV1 inter mode-info (spec 5.11.23+). The bitstream-read
# layer for inter blocks: mode / reference / motion-vector decode via the symbol
# coder, producing the Mv[] + RefFrame[] + YMode the MI grid holds (which the
# MV-prediction scans in av1_mv.cyr then read for the NEXT block).
#
# Bites so far:
#   * (0.7.66) the MOTION-VECTOR component decode — read_mv / read_mv_component
#     (spec 5.11.32) — plus its nine-CDF family and the paired encoder. read_mv
#     decodes a motion-vector DIFFERENCE (a joint symbol, then per non-zero
#     component a sign / class / magnitude split) and adds it to the predicted MV.
#   * (0.7.67) the SINGLE-PREDICTION inter mode reads — read_inter_mode
#     (new_mv / zero_mv / ref_mv → NEWMV / GLOBALMV / NEARESTMV / NEARMV, from the
#     find_mv_stack contexts), read_drl_idx (the DRL predictor index from
#     DrlCtxStack + NumMvFound), and assign_mv (compose PredMv from RefStackMv /
#     GlobalMvs + read_mv for NEWMV → the block's Mv) — plus their four CDFs and
#     paired encoders. This is where the MV-prediction arc (find_mv_stack contexts
#     + candidate stack, av1_mv.cyr) and read_mv COMPOSE into a decoded inter MV.
#   * (0.7.68) the REFERENCE-SELECTION reads (single) — read_is_inter (5.11.30) +
#     read_single_ref (the single_ref_p1..p6 tree → RefFrame[0]) + the Is_Inter /
#     Single_Ref CDFs; the neighbour-count CDF contexts (spec 8.3) are caller inputs.
#   * (0.7.69) the COMPOUND reference path — read_comp_mode + read_compound_ref (the
#     comp_ref_type / uni_comp_ref / comp_ref / comp_bwdref tree → the 16 compound
#     reference pairs) + the Comp_Mode / Comp_Ref_Type / Comp_Ref / Comp_Bwd_Ref /
#     Uni_Comp_Ref CDFs.
#   * (0.7.70) the COMPOUND mode path — read_compound_mode (the 8-symbol compound_mode
#     → YMode) + get_mode (per-list mode) + the two-list assign_mv; plus read_drl_idx
#     extended to the compound NEW/NEAR modes.
#   * (0.7.71) interp_filter (5.11.30) + motion_mode (5.11.27, via use_obmc /
#     motion_mode) — the remaining per-symbol inter mode-info reads + their CDFs
#     (Interp_Filter / Motion_Mode / Use_Obmc, §10). (The gating that decides whether
#     each is coded landed in 0.7.78 for interp_filter; motion_mode's is still open.)
#   * (0.7.72) the INTER-INTRA reads (5.11.28) — read_interintra (binary),
#     read_interintra_mode (INTERINTRA_MODES=4), read_wedge_interintra (binary),
#     read_wedge_index (WEDGE_TYPES=16) + their CDFs (Inter_Intra / Inter_Intra_Mode /
#     Wedge_Inter_Intra / Wedge_Index, §10). interintra / mode ctx = Size_Group[MiSize]-1;
#     wedge* are MiSize-indexed. (Their gating landed in 0.7.78.)
#   * (0.7.73) read_compound_type (5.11.29) — the LAST inter mode-info read, and the
#     first full spec DRIVER here: @@comp_group_idx / @@compound_idx / @@compound_type
#     (+ their §10 CDFs) composed with 5.11.28's @@wedge_index and the @@wedge_sign /
#     @@mask_type L(1) literals, resolving compound_type on every branch — including the
#     non-compound one, where it falls out of interintra / wedge_interintra with no
#     symbol read. Wedge_Bits[MiSize]==0 forces COMPOUND_DIFFWTD.
#   * (0.7.75-0.7.77) THE NEIGHBOUR CDF CONTEXTS — av1_nbctx_setup (the 5.11.15
#     preamble) + check_backward / count_refs / ref_count_ctx + is_inter / comp_mode +
#     the reference-context family (seven ref_count_ctx derivations + comp_ref_type, with
#     single_ref_p2..p6 / uni_comp_ref / uni_comp_ref_p2 as the spec's ALIASES) +
#     comp_group_idx / compound_idx / interp_filter. EVERY inter CDF context is now
#     derived from the MI grid; the caller supplies only frame-level state the spec also
#     treats that way (AvailU/AvailL, the order-hint distances).
#   * (0.7.78) THE GATING ORCHESTRATORS — read_interintra_mode (the full 5.11.28 gate)
#     + needs_interp_filter / read_interp_filters (the 5.11.23 tail).
# Every path round-trips through the symbol encoder.
#
# STATUS: every inter mode-info SYMBOL READ is in, and so are the CDF contexts. What is
# NOT: the ORCHESTRATORS that compose them — read_ref_frames (5.11.25), read_motion_mode's
# gating (5.11.27, needs is_scaled + 0.7.79's warp samples), inter_block_mode_info
# (5.11.23) and inter_frame_mode_info (5.11.15) — and the inter tile decode (roadmap.md).
#
# FLAT module — wired after src/av1_mv.cyr (it consumes the find_mv_stack context
# + candidate stack and produces the Mv the grid stores). Family av1_. Depends on:
# av1_symbol (av1_sym_read_symbol / av1_sym_encode_symbol), av1_mv (AV1MV_ROW /
# AV1MV_COL, the Av1MvCtx accessors + AV1_NEARESTMV..AV1_NEW_NEWMV modes + av1_min),
# drishti (DR_OK).
#
# Derived from the AV1 spec §5.11.32 (MV syntax + inter_block_mode_info + assign_mv +
# get_mode) + §5.11.25 (read_ref_frames) + the CDF selection (§9 parsing process) +
# the default CDF tables (§10 annex). Cross-checked against libaom (entropymv.c /
# decodemv.c) + dav1d (decode.c). With 0.7.73 every inter mode-info syntax element is
# read; the MI-grid population + inter tile decode that CONSUME them are the next
# bites (roadmap.md).

# ================================================================
# MV syntax constants (spec 3 symbols + 07 semantics enum).
# ================================================================
enum Av1MvReadConst {
    AV1_MV_CONTEXTS     = 2;     # MV_CONTEXTS (0 = normal, 1 = intrabc)
    AV1_MV_INTRABC_CTX  = 1;     # MV_INTRABC_CONTEXT
    AV1_MV_JOINTS       = 4;     # MV_JOINTS
    AV1_MV_CLASSES      = 11;    # MV_CLASSES
    AV1_MV_CLASS0_SIZE  = 2;     # CLASS0_SIZE
    AV1_MV_OFFSET_BITS  = 10;    # MV_OFFSET_BITS
    AV1_MV_FP_SIZE      = 4;     # fractional-part symbols (mv_fr / mv_class0_fr)
    # mv_joint values (07 semantics): which components are non-zero.
    AV1_MV_JOINT_ZERO   = 0;     # both zero
    AV1_MV_JOINT_HNZVZ  = 1;     # col (comp 1) non-zero, row zero
    AV1_MV_JOINT_HZVNZ  = 2;     # row (comp 0) non-zero, col zero
    AV1_MV_JOINT_HNZVNZ = 3;     # both non-zero
    AV1_MV_CLASS_0      = 0;     # MV_CLASS_0
}

# ================================================================
# The MV CDF context — a mutable per-tile blob holding every MV symbol's CDF,
# indexed as the spec's Tile*Cdf arrays. 286 i64 entries (each CDF: N cumulative
# probs ending 1<<15, then the adaptation count). Layout (entry offsets):
#   joint      [ctx]              base 0,   ctx*5                 (4-sym)
#   sign       [ctx][comp]        base 10,  ctx*6 + comp*3        (2-sym)
#   class      [ctx][comp]        base 22,  ctx*24 + comp*12      (11-sym)
#   class0_bit [ctx][comp]        base 70,  ctx*6 + comp*3        (2-sym)
#   class0_fr  [ctx][comp][cl0b]  base 82,  ctx*20 + comp*10 + cl0b*5  (4-sym)
#   class0_hp  [ctx][comp]        base 122, ctx*6 + comp*3        (2-sym)
#   fr         [ctx][comp]        base 134, ctx*10 + comp*5       (4-sym)
#   hp         [ctx][comp]        base 154, ctx*6 + comp*3        (2-sym)
#   bit        [ctx][comp][i]     base 166, ctx*60 + comp*30 + i*3 (2-sym, i 0..9)
# The default values (§10) are identical across ctx (and comp, except the per-i
# bit CDFs), so every [ctx][comp] copy starts from the same default — they then
# adapt independently at runtime.
# ================================================================
enum Av1MvCdfOff { AV1MVCDF_SIZE = 286; }

fn av1_mvcdf_joint(cc, ctx): i64 { return cc + ((0 + (ctx * 5)) * 8); }
fn av1_mvcdf_sign(cc, ctx, comp): i64 { return cc + ((10 + (ctx * 6) + (comp * 3)) * 8); }
fn av1_mvcdf_class(cc, ctx, comp): i64 { return cc + ((22 + (ctx * 24) + (comp * 12)) * 8); }
fn av1_mvcdf_class0_bit(cc, ctx, comp): i64 { return cc + ((70 + (ctx * 6) + (comp * 3)) * 8); }
fn av1_mvcdf_class0_fr(cc, ctx, comp, cl0bit): i64 {
    return cc + ((82 + (ctx * 20) + (comp * 10) + (cl0bit * 5)) * 8);
}
fn av1_mvcdf_class0_hp(cc, ctx, comp): i64 { return cc + ((122 + (ctx * 6) + (comp * 3)) * 8); }
fn av1_mvcdf_fr(cc, ctx, comp): i64 { return cc + ((134 + (ctx * 10) + (comp * 5)) * 8); }
fn av1_mvcdf_hp(cc, ctx, comp): i64 { return cc + ((154 + (ctx * 6) + (comp * 3)) * 8); }
fn av1_mvcdf_bit(cc, ctx, comp, i): i64 {
    return cc + ((166 + (ctx * 60) + (comp * 30) + (i * 3)) * 8);
}

# put a 2-symbol cdf {c0, 32768, count=0}; a 4-symbol cdf {c0,c1,c2,32768,0}.
fn av1_mvcdf_put2(p, c0): i64 {
    store64(p + 0, c0); store64(p + 8, 32768); store64(p + 16, 0); return DR_OK;
}
fn av1_mvcdf_put4(p, c0, c1, c2): i64 {
    store64(p + 0, c0); store64(p + 8, c1); store64(p + 16, c2);
    store64(p + 24, 32768); store64(p + 32, 0); return DR_OK;
}
# the 11-symbol mv_class cdf (Default_Mv_Class_Cdf, identical both comps).
fn av1_mvcdf_put_class(p): i64 {
    store64(p + 0, 28672);  store64(p + 8, 30976);  store64(p + 16, 31858);
    store64(p + 24, 32320); store64(p + 32, 32551); store64(p + 40, 32656);
    store64(p + 48, 32740); store64(p + 56, 32757); store64(p + 64, 32762);
    store64(p + 72, 32767); store64(p + 80, 32768); store64(p + 88, 0);
    return DR_OK;
}
# Default_Mv_Bit_Cdf[10]: the per-offset-bit probabilities (values * 128), lazily
# cached in a global scalar (global array literals do not initialize in cyrius).
var AV1_MVBIT_VALS = 0;
fn av1_mvbit_vals(): i64 {
    if (AV1_MVBIT_VALS != 0) { return AV1_MVBIT_VALS; }
    var p = alloc(10 * 8);
    store64(p + 0, 17408);  store64(p + 8, 17920);  store64(p + 16, 18944);
    store64(p + 24, 20480); store64(p + 32, 22528); store64(p + 40, 24576);
    store64(p + 48, 28672); store64(p + 56, 29952); store64(p + 64, 29952);
    store64(p + 72, 30720);
    AV1_MVBIT_VALS = p;
    return p;
}

# fill a 286-entry MV CDF blob at cc with the §10 defaults.
fn av1_mvcdf_fill(cc): i64 {
    var ctx = 0;
    while (ctx < AV1_MV_CONTEXTS) {
        av1_mvcdf_put4(av1_mvcdf_joint(cc, ctx), 4096, 11264, 19328);
        var comp = 0;
        while (comp < 2) {
            av1_mvcdf_put2(av1_mvcdf_sign(cc, ctx, comp), 16384);          # 128*128
            av1_mvcdf_put_class(av1_mvcdf_class(cc, ctx, comp));
            av1_mvcdf_put2(av1_mvcdf_class0_bit(cc, ctx, comp), 27648);    # 216*128
            av1_mvcdf_put4(av1_mvcdf_class0_fr(cc, ctx, comp, 0), 16384, 24576, 26624);
            av1_mvcdf_put4(av1_mvcdf_class0_fr(cc, ctx, comp, 1), 12288, 21248, 24128);
            av1_mvcdf_put2(av1_mvcdf_class0_hp(cc, ctx, comp), 20480);     # 160*128
            av1_mvcdf_put4(av1_mvcdf_fr(cc, ctx, comp), 8192, 17408, 21248);
            av1_mvcdf_put2(av1_mvcdf_hp(cc, ctx, comp), 16384);           # 128*128
            var bv = av1_mvbit_vals();
            var i = 0;
            while (i < AV1_MV_OFFSET_BITS) {
                av1_mvcdf_put2(av1_mvcdf_bit(cc, ctx, comp, i), load64(bv + (i * 8)));
                i = i + 1;
            }
            comp = comp + 1;
        }
        ctx = ctx + 1;
    }
    return DR_OK;
}

# av1_mvcdf_new — a fresh mutable MV CDF context (for the adaptive path). Or 0 on OOM.
fn av1_mvcdf_new(): i64 {
    var cc = alloc(AV1MVCDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_mvcdf_fill(cc);
    return cc;
}
# av1_mvcdf_blob — the shared read-only default blob (for disable_cdf_update).
var AV1_MVCDF_BLOB = 0;
fn av1_mvcdf_blob(): i64 {
    if (AV1_MVCDF_BLOB != 0) { return AV1_MVCDF_BLOB; }
    var cc = alloc(AV1MVCDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_mvcdf_fill(cc);
    AV1_MVCDF_BLOB = cc;
    return cc;
}

# ================================================================
# read_mv_component (spec 5.11.32) — decode one signed motion-vector-difference
# component. `sd` symbol decoder, `cc` MV CDF context, `mv_ctx` MvCtx (0 / 1),
# `comp` 0=row/1=col, `allow_hp` allow_high_precision_mv, `force_int`
# force_integer_mv. Returns the signed difference (magnitude >= 1).
# ================================================================
fn av1_read_mv_component(sd, cc, mv_ctx, comp, allow_hp, force_int): i64 {
    var mv_sign = av1_sym_read_symbol(sd, av1_mvcdf_sign(cc, mv_ctx, comp), 2);
    var mv_class = av1_sym_read_symbol(sd, av1_mvcdf_class(cc, mv_ctx, comp), AV1_MV_CLASSES);
    var mag = 0;
    if (mv_class == AV1_MV_CLASS_0) {
        var bit = av1_sym_read_symbol(sd, av1_mvcdf_class0_bit(cc, mv_ctx, comp), 2);
        var fr = 3;
        if (force_int == 0) {
            fr = av1_sym_read_symbol(sd, av1_mvcdf_class0_fr(cc, mv_ctx, comp, bit), AV1_MV_FP_SIZE);
        }
        var hp = 1;
        if (allow_hp != 0) { hp = av1_sym_read_symbol(sd, av1_mvcdf_class0_hp(cc, mv_ctx, comp), 2); }
        mag = (((bit << 3) | (fr << 1)) | hp) + 1;
    } else {
        var d = 0;
        var i = 0;
        while (i < mv_class) {
            var b = av1_sym_read_symbol(sd, av1_mvcdf_bit(cc, mv_ctx, comp, i), 2);
            d = d | (b << i);
            i = i + 1;
        }
        mag = AV1_MV_CLASS0_SIZE << (mv_class + 2);
        var fr = 3;
        if (force_int == 0) {
            fr = av1_sym_read_symbol(sd, av1_mvcdf_fr(cc, mv_ctx, comp), AV1_MV_FP_SIZE);
        }
        var hp = 1;
        if (allow_hp != 0) { hp = av1_sym_read_symbol(sd, av1_mvcdf_hp(cc, mv_ctx, comp), 2); }
        mag = mag + ((((d << 3) | (fr << 1)) | hp) + 1);
    }
    if (mv_sign != 0) { return 0 - mag; }
    return mag;
}

# ================================================================
# read_mv (spec 5.11.32) — decode a motion-vector difference (mv_joint, then the
# non-zero components) and add it to PredMv to form the block's Mv. Writes the
# (row, col) result into out_mv (an Av1Mv). `mv_ctx` = MV_INTRABC_CONTEXT for
# intrabc, else 0.
# ================================================================
fn av1_read_mv(sd, cc, mv_ctx, allow_hp, force_int, pred_row, pred_col, out_mv): i64 {
    var diff_row = 0;
    var diff_col = 0;
    var joint = av1_sym_read_symbol(sd, av1_mvcdf_joint(cc, mv_ctx), AV1_MV_JOINTS);
    if ((joint == AV1_MV_JOINT_HZVNZ) || (joint == AV1_MV_JOINT_HNZVNZ)) {
        diff_row = av1_read_mv_component(sd, cc, mv_ctx, 0, allow_hp, force_int);
    }
    if ((joint == AV1_MV_JOINT_HNZVZ) || (joint == AV1_MV_JOINT_HNZVNZ)) {
        diff_col = av1_read_mv_component(sd, cc, mv_ctx, 1, allow_hp, force_int);
    }
    store64(out_mv + AV1MV_ROW, pred_row + diff_row);
    store64(out_mv + AV1MV_COL, pred_col + diff_col);
    return DR_OK;
}

# ================================================================
# write_mv_component — the inverse encode of read_mv_component: decompose a signed
# difference (magnitude >= 1) into sign / class / magnitude fields and emit them.
# The class is the range the magnitude falls in: class 0 covers |diff| 1..16,
# class c (c>=1) covers (2^(c+3), 2^(c+4)]. Under force_int the fractional part is
# 3 (not coded); under !allow_hp the hp bit is 1 (not coded) — the caller must
# hand a difference consistent with those (as a real decode always produces).
# ================================================================
fn av1_write_mv_component(enc, cc, mv_ctx, comp, allow_hp, force_int, diff): i64 {
    var sign = 0;
    var mag = diff;
    if (diff < 0) { sign = 1; mag = 0 - diff; }
    av1_sym_encode_symbol(enc, av1_mvcdf_sign(cc, mv_ctx, comp), 2, sign);
    var offset = mag - 1;
    var mv_class = AV1_MV_CLASS_0;
    if (offset >= (AV1_MV_CLASS0_SIZE << 3)) {
        var m = offset;                # floor(log2(offset)) via bit-length
        var hb = 0;
        while (m > 1) { m = m >> 1; hb = hb + 1; }
        mv_class = hb - 3;
    }
    # A valid decode caps mv_class at MV_CLASSES-1 (10), so a representable
    # |diff| never exceeds 16384 and mv_class never exceeds 10. Clamp defensively
    # (matching libaom's MV_CLASS_10 cap) so a hostile/buggy out-of-range diff
    # from a future caller can never index the class symbol or the bit CDF out of
    # bounds — a no-op for every representable difference.
    if (mv_class > (AV1_MV_CLASSES - 1)) { mv_class = AV1_MV_CLASSES - 1; }
    av1_sym_encode_symbol(enc, av1_mvcdf_class(cc, mv_ctx, comp), AV1_MV_CLASSES, mv_class);
    if (mv_class == AV1_MV_CLASS_0) {
        var bit = (offset >> 3) & 1;
        var fr = (offset >> 1) & 3;
        var hp = offset & 1;
        av1_sym_encode_symbol(enc, av1_mvcdf_class0_bit(cc, mv_ctx, comp), 2, bit);
        if (force_int == 0) {
            av1_sym_encode_symbol(enc, av1_mvcdf_class0_fr(cc, mv_ctx, comp, bit), AV1_MV_FP_SIZE, fr);
        }
        if (allow_hp != 0) {
            av1_sym_encode_symbol(enc, av1_mvcdf_class0_hp(cc, mv_ctx, comp), 2, hp);
        }
    } else {
        var base = AV1_MV_CLASS0_SIZE << (mv_class + 2);
        var inner = (mag - 1) - base;   # (d<<3)|(fr<<1)|hp
        var d = inner >> 3;
        var fr2 = (inner >> 1) & 3;
        var hp2 = inner & 1;
        var i = 0;
        while (i < mv_class) {
            av1_sym_encode_symbol(enc, av1_mvcdf_bit(cc, mv_ctx, comp, i), 2, (d >> i) & 1);
            i = i + 1;
        }
        if (force_int == 0) {
            av1_sym_encode_symbol(enc, av1_mvcdf_fr(cc, mv_ctx, comp), AV1_MV_FP_SIZE, fr2);
        }
        if (allow_hp != 0) {
            av1_sym_encode_symbol(enc, av1_mvcdf_hp(cc, mv_ctx, comp), 2, hp2);
        }
    }
    return DR_OK;
}

# write_mv — the inverse encode of read_mv: emit mv_joint then the non-zero
# components of (diff_row, diff_col).
fn av1_write_mv(enc, cc, mv_ctx, allow_hp, force_int, diff_row, diff_col): i64 {
    var joint = AV1_MV_JOINT_ZERO;
    if ((diff_row != 0) && (diff_col != 0)) { joint = AV1_MV_JOINT_HNZVNZ; }
    else {
        if (diff_row != 0) { joint = AV1_MV_JOINT_HZVNZ; }
        else {
            if (diff_col != 0) { joint = AV1_MV_JOINT_HNZVZ; }
        }
    }
    av1_sym_encode_symbol(enc, av1_mvcdf_joint(cc, mv_ctx), AV1_MV_JOINTS, joint);
    if ((joint == AV1_MV_JOINT_HZVNZ) || (joint == AV1_MV_JOINT_HNZVNZ)) {
        av1_write_mv_component(enc, cc, mv_ctx, 0, allow_hp, force_int, diff_row);
    }
    if ((joint == AV1_MV_JOINT_HNZVZ) || (joint == AV1_MV_JOINT_HNZVNZ)) {
        av1_write_mv_component(enc, cc, mv_ctx, 1, allow_hp, force_int, diff_col);
    }
    return DR_OK;
}

# ================================================================
# THE INTER MODE READS (spec 5.11.32 inter_block_mode_info + assign_mv). Given a
# find_mv_stack context (av1_mv.cyr's Av1MvCtx — the entropy contexts + the
# candidate stack RefStackMv + GlobalMvs + NumMvFound), decode:
#   1. read_inter_mode / read_compound_mode — the inter YMode (single via new_mv /
#      zero_mv / ref_mv; compound via the 8-symbol compound_mode);
#   2. read_drl_idx — the DRL predictor index (RefMvIdx) via drl_mode;
#   3. assign_mv (single / compound) — the block's Mv(s): per list, get_mode picks
#      the per-list mode, PredMv from RefStackMv[pos][list] (or GlobalMvs[list]),
#      then read_mv for NEWMV (else Mv = PredMv).
# CDF families (§10): New_Mv / Zero_Mv / Ref_Mv / Drl_Mode (binary) + Compound_Mode
# (8-symbol), each indexed by its find_mv_stack context. use_intrabc (intra block
# copy) is a later bite (roadmap.md).
# ================================================================
enum Av1InterModeConst {
    AV1_NEW_MV_CONTEXTS       = 6;
    AV1_ZERO_MV_CONTEXTS      = 2;
    AV1_REF_MV_CONTEXTS       = 6;
    AV1_DRL_MODE_CONTEXTS     = 3;
    AV1_COMPOUND_MODES        = 8;    # COMPOUND_MODES (compound_mode symbol alphabet)
    AV1_COMPOUND_MODE_CONTEXTS = 8;   # COMPOUND_MODE_CONTEXTS
    AV1_COMP_NEWMV_CTXS       = 5;    # COMP_NEWMV_CTXS (NewMvContext clamp for the ctx map)
    AV1_INTERP_FILTERS        = 3;    # INTERP_FILTERS (interp_filter symbol alphabet)
    AV1_INTERP_FILTER_CONTEXTS = 16;  # INTERP_FILTER_CONTEXTS
    AV1_MOTION_MODES          = 3;    # MOTION_MODES (motion_mode symbol alphabet)
    AV1_BLOCK_SIZES           = 22;   # BLOCK_SIZES (motion_mode / use_obmc are MiSize-indexed)
    # motion mode values (03 symbols)
    AV1_MM_SIMPLE             = 0;    # SIMPLE
    AV1_MM_OBMC               = 1;    # OBMC
    AV1_MM_LOCALWARP          = 2;    # LOCALWARP
    # interintra (5.11.28)
    AV1_INTERINTRA_MODES      = 4;    # INTERINTRA_MODES (interintra_mode alphabet)
    AV1_BLOCK_SIZE_GROUPS     = 4;    # BLOCK_SIZE_GROUPS (interintra/mode ctx = Size_Group-1, 0..2)
    AV1_WEDGE_TYPES           = 16;   # WEDGE_TYPES (wedge_index alphabet)
    # interintra_mode values (03 symbols)
    AV1_II_DC_PRED            = 0;    # II_DC_PRED
    AV1_II_V_PRED             = 1;    # II_V_PRED
    AV1_II_H_PRED             = 2;    # II_H_PRED
    AV1_II_SMOOTH_PRED        = 3;    # II_SMOOTH_PRED
    # block-size bounds of the interintra gate (07 semantics) + the default interp filter
    AV1_BLOCK_8X8             = 3;    # BLOCK_8X8
    AV1_BLOCK_32X32           = 9;    # BLOCK_32X32
    AV1_EIGHTTAP              = 0;    # EIGHTTAP (the filter an ungated dir takes)
    # BILINEAR is signalled ONLY by the frame header's interpolation_filter f(2); the
    # SWITCHABLE per-block symbol has a 3-value alphabet (EIGHTTAP/SMOOTH/SHARP) and can
    # never code it. av1_read_interp_filters copies the frame-level value to both dirs.
    AV1_BILINEAR              = 3;    # BILINEAR
    # compound type (5.11.29)
    AV1_COMPOUND_TYPES        = 2;    # COMPOUND_TYPES (the @@compound_type alphabet: WEDGE/DIFFWTD)
    AV1_COMP_GROUP_IDX_CONTEXTS = 6;  # COMP_GROUP_IDX_CONTEXTS
    AV1_COMPOUND_IDX_CONTEXTS = 6;    # COMPOUND_IDX_CONTEXTS
    # compound_type values (07 semantics) — only WEDGE/DIFFWTD are directly signalled.
    AV1_COMPOUND_WEDGE        = 0;    # COMPOUND_WEDGE
    AV1_COMPOUND_DIFFWTD      = 1;    # COMPOUND_DIFFWTD
    AV1_COMPOUND_AVERAGE      = 2;    # COMPOUND_AVERAGE
    AV1_COMPOUND_INTRA        = 3;    # COMPOUND_INTRA
    AV1_COMPOUND_DISTANCE     = 4;    # COMPOUND_DISTANCE
    # mask_type values (07 semantics)
    AV1_UNIFORM_45            = 0;    # UNIFORM_45
    AV1_UNIFORM_45_INV        = 1;    # UNIFORM_45_INV
}
# the read_compound_type output record (6 i64 fields).
enum Av1CompTypeRec {
    AV1CT_TYPE      = 0;      # compound_type (COMPOUND_WEDGE..COMPOUND_DISTANCE)
    AV1CT_GROUPIDX  = 8;      # comp_group_idx
    AV1CT_COMPIDX   = 16;     # compound_idx
    # wedge_index / wedge_sign are read ONLY on the isCompound + COMPOUND_WEDGE path. A
    # NON-compound block can also resolve to COMPOUND_WEDGE (via wedge_interintra), and
    # there both stay 0 — read_interintra_mode (5.11.28) already read the interintra wedge.
    AV1CT_WEDGEIDX  = 24;     # wedge_index  (valid when isCompound && type == COMPOUND_WEDGE)
    AV1CT_WEDGESIGN = 32;     # wedge_sign   (valid when isCompound && type == COMPOUND_WEDGE)
    AV1CT_MASKTYPE  = 40;     # mask_type    (valid when type == COMPOUND_DIFFWTD)
    AV1CT_SIZE      = 48;     # bytes
}

# The inter-mode CDF blob (341 i64): four binary + one 8-symbol + interp_filter /
# motion_mode (3-symbol) + use_obmc (binary), entry offsets —
#   new_mv       [ctx 0..5]   base 0,   ctx*3   -> [0,18)
#   zero_mv      [ctx 0..1]   base 18,  ctx*3   -> [18,24)
#   ref_mv       [ctx 0..5]   base 24,  ctx*3   -> [24,42)
#   drl          [ctx 0..2]   base 42,  ctx*3   -> [42,51)
#   compound_mode[ctx 0..7]   base 51,  ctx*9   -> [51,123)   (8-sym, 9 slots)
#   interp_filter[ctx 0..15]  base 123, ctx*4   -> [123,187)  (3-sym, 4 slots)
#   motion_mode  [MiSize 0..21] base 187, sz*4  -> [187,275)  (3-sym, 4 slots)
#   use_obmc     [MiSize 0..21] base 275, sz*3  -> [275,341)  (binary, 3 slots)
enum Av1ImCdfOff { AV1IMCDF_SIZE = 341; }
fn av1_imcdf_newmv(cc, ctx): i64 { return cc + ((0 + (ctx * 3)) * 8); }
fn av1_imcdf_zeromv(cc, ctx): i64 { return cc + ((18 + (ctx * 3)) * 8); }
fn av1_imcdf_refmv(cc, ctx): i64 { return cc + ((24 + (ctx * 3)) * 8); }
fn av1_imcdf_drl(cc, ctx): i64 { return cc + ((42 + (ctx * 3)) * 8); }
fn av1_imcdf_compmode(cc, ctx): i64 { return cc + ((51 + (ctx * 9)) * 8); }
fn av1_imcdf_interp(cc, ctx): i64 { return cc + ((123 + (ctx * 4)) * 8); }
fn av1_imcdf_motionmode(cc, mi_size): i64 { return cc + ((187 + (mi_size * 4)) * 8); }
fn av1_imcdf_useobmc(cc, mi_size): i64 { return cc + ((275 + (mi_size * 3)) * 8); }

# put an 8-symbol cdf {c0..c6, 32768, count=0} (9 i64 slots).
fn av1_imcdf_put8(p, c0, c1, c2, c3, c4, c5, c6): i64 {
    store64(p + 0, c0); store64(p + 8, c1); store64(p + 16, c2); store64(p + 24, c3);
    store64(p + 32, c4); store64(p + 40, c5); store64(p + 48, c6);
    store64(p + 56, 32768); store64(p + 64, 0);
    return DR_OK;
}
# put a 3-symbol cdf {c0, c1, 32768, count=0} (4 i64 slots).
fn av1_imcdf_put3(p, c0, c1): i64 {
    store64(p + 0, c0); store64(p + 8, c1); store64(p + 16, 32768); store64(p + 24, 0);
    return DR_OK;
}

# fill the inter-mode CDF blob with the §10 defaults (each row {v, 32768, 0}).
fn av1_imcdf_fill(cc): i64 {
    # Default_New_Mv_Cdf[6]
    av1_mvcdf_put2(av1_imcdf_newmv(cc, 0), 24035);
    av1_mvcdf_put2(av1_imcdf_newmv(cc, 1), 16630);
    av1_mvcdf_put2(av1_imcdf_newmv(cc, 2), 15339);
    av1_mvcdf_put2(av1_imcdf_newmv(cc, 3), 8386);
    av1_mvcdf_put2(av1_imcdf_newmv(cc, 4), 12222);
    av1_mvcdf_put2(av1_imcdf_newmv(cc, 5), 4676);
    # Default_Zero_Mv_Cdf[2]
    av1_mvcdf_put2(av1_imcdf_zeromv(cc, 0), 2175);
    av1_mvcdf_put2(av1_imcdf_zeromv(cc, 1), 1054);
    # Default_Ref_Mv_Cdf[6]
    av1_mvcdf_put2(av1_imcdf_refmv(cc, 0), 23974);
    av1_mvcdf_put2(av1_imcdf_refmv(cc, 1), 24188);
    av1_mvcdf_put2(av1_imcdf_refmv(cc, 2), 17848);
    av1_mvcdf_put2(av1_imcdf_refmv(cc, 3), 28622);
    av1_mvcdf_put2(av1_imcdf_refmv(cc, 4), 24312);
    av1_mvcdf_put2(av1_imcdf_refmv(cc, 5), 19923);
    # Default_Drl_Mode_Cdf[3]
    av1_mvcdf_put2(av1_imcdf_drl(cc, 0), 13104);
    av1_mvcdf_put2(av1_imcdf_drl(cc, 1), 24560);
    av1_mvcdf_put2(av1_imcdf_drl(cc, 2), 18945);
    # Default_Compound_Mode_Cdf[8][9] — 8-symbol.
    av1_imcdf_put8(av1_imcdf_compmode(cc, 0), 7760, 13823, 15808, 17641, 19156, 20666, 26891);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 1), 10730, 19452, 21145, 22749, 24039, 25131, 28724);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 2), 10664, 20221, 21588, 22906, 24295, 25387, 28436);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 3), 13298, 16984, 20471, 24182, 25067, 25736, 26422);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 4), 18904, 23325, 25242, 27432, 27898, 28258, 30758);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 5), 10725, 17454, 20124, 22820, 24195, 25168, 26046);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 6), 17125, 24273, 25814, 27492, 28214, 28704, 30592);
    av1_imcdf_put8(av1_imcdf_compmode(cc, 7), 13046, 23214, 24505, 25942, 27435, 28442, 29330);
    # Default_Interp_Filter_Cdf[16][4] — 3-symbol (EIGHTTAP / _SMOOTH / _SHARP).
    av1_imcdf_put3(av1_imcdf_interp(cc, 0), 31935, 32720);
    av1_imcdf_put3(av1_imcdf_interp(cc, 1), 5568, 32719);
    av1_imcdf_put3(av1_imcdf_interp(cc, 2), 422, 2938);
    av1_imcdf_put3(av1_imcdf_interp(cc, 3), 28244, 32608);
    av1_imcdf_put3(av1_imcdf_interp(cc, 4), 31206, 31953);
    av1_imcdf_put3(av1_imcdf_interp(cc, 5), 4862, 32121);
    av1_imcdf_put3(av1_imcdf_interp(cc, 6), 770, 1152);
    av1_imcdf_put3(av1_imcdf_interp(cc, 7), 20889, 25637);
    av1_imcdf_put3(av1_imcdf_interp(cc, 8), 31910, 32724);
    av1_imcdf_put3(av1_imcdf_interp(cc, 9), 4120, 32712);
    av1_imcdf_put3(av1_imcdf_interp(cc, 10), 305, 2247);
    av1_imcdf_put3(av1_imcdf_interp(cc, 11), 27403, 32636);
    av1_imcdf_put3(av1_imcdf_interp(cc, 12), 31022, 32009);
    av1_imcdf_put3(av1_imcdf_interp(cc, 13), 2963, 32093);
    av1_imcdf_put3(av1_imcdf_interp(cc, 14), 601, 943);
    av1_imcdf_put3(av1_imcdf_interp(cc, 15), 14969, 21398);
    # Default_Motion_Mode_Cdf[22][4] — 3-symbol (SIMPLE / OBMC / LOCALWARP), MiSize-indexed.
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 0), 10923, 21845);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 1), 10923, 21845);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 2), 10923, 21845);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 3), 7651, 24760);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 4), 4738, 24765);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 5), 5391, 25528);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 6), 19419, 26810);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 7), 5123, 23606);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 8), 11606, 24308);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 9), 26260, 29116);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 10), 20360, 28062);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 11), 21679, 26830);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 12), 29516, 30701);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 13), 28898, 30397);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 14), 30878, 31335);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 15), 32507, 32558);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 16), 10923, 21845);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 17), 10923, 21845);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 18), 28799, 31390);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 19), 26431, 30774);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 20), 28973, 31594);
    av1_imcdf_put3(av1_imcdf_motionmode(cc, 21), 29742, 31203);
    # Default_Use_Obmc_Cdf[22][3] — binary, MiSize-indexed.
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 0), 16384);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 1), 16384);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 2), 16384);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 3), 10437);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 4), 9371);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 5), 9301);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 6), 17432);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 7), 14423);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 8), 15142);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 9), 25817);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 10), 22823);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 11), 22083);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 12), 30128);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 13), 31014);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 14), 31560);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 15), 32638);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 16), 16384);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 17), 16384);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 18), 23664);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 19), 20901);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 20), 24008);
    av1_mvcdf_put2(av1_imcdf_useobmc(cc, 21), 26879);
    return DR_OK;
}
fn av1_imcdf_new(): i64 {
    var cc = alloc(AV1IMCDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_imcdf_fill(cc);
    return cc;
}
var AV1_IMCDF_BLOB = 0;
fn av1_imcdf_blob(): i64 {
    if (AV1_IMCDF_BLOB != 0) { return AV1_IMCDF_BLOB; }
    var cc = alloc(AV1IMCDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_imcdf_fill(cc);
    AV1_IMCDF_BLOB = cc;
    return cc;
}

# ================================================================
# read_inter_mode (spec 5.11.32) — the SINGLE-prediction inter YMode. Reads
# new_mv (NewMvContext); if set, GLOBALMV/NEARESTMV/NEARMV via zero_mv
# (ZeroMvContext) then ref_mv (RefMvContext). skip_mode / segment-forced modes
# are the caller's concern (handled before this is invoked).
# ================================================================
fn av1_read_inter_mode(sd, cc, mvctx): i64 {
    var new_mv = av1_sym_read_symbol(sd, av1_imcdf_newmv(cc, av1_mvctx_newmv_context(mvctx)), 2);
    if (new_mv == 0) { return AV1_NEWMV; }
    var zero_mv = av1_sym_read_symbol(sd, av1_imcdf_zeromv(cc, av1_mvctx_zero_context(mvctx)), 2);
    if (zero_mv == 0) { return AV1_GLOBALMV; }
    var ref_mv = av1_sym_read_symbol(sd, av1_imcdf_refmv(cc, av1_mvctx_refmv_context(mvctx)), 2);
    if (ref_mv == 0) { return AV1_NEARESTMV; }
    return AV1_NEARMV;
}

# has_nearmv (spec 5.11.32) — 1 iff the mode uses a NEAR predictor for at least one
# component (NEARMV single; the three compound modes carrying a NEAR half).
fn av1_has_nearmv(y_mode): i64 {
    if ((y_mode == AV1_NEARMV) || (y_mode == AV1_NEAR_NEARMV)
    || (y_mode == AV1_NEAR_NEWMV) || (y_mode == AV1_NEW_NEARMV)) {
        return 1;
    }
    return 0;
}

# read_drl_idx (spec 5.11.32) — the DRL predictor index (RefMvIdx). NEWMV / NEW_NEWMV
# scan drl_mode over idx 0..1; a has_nearmv mode (NEARMV / NEAR_NEARMV / NEAR_NEWMV /
# NEW_NEARMV) starts at 1 and scans idx 1..2. Each drl_mode is read only when the
# stack has a candidate past idx (NumMvFound > idx + 1); a 0 selects that idx (stop),
# a 1 advances. Handles both single and compound modes.
fn av1_read_drl_idx(sd, cc, mvctx, y_mode): i64 {
    var mvs = load64(mvctx + AV1MVC_STACK);
    var num = av1_mv_stack_num(mvs);
    var ref_mv_idx = 0;
    if ((y_mode == AV1_NEWMV) || (y_mode == AV1_NEW_NEWMV)) {
        var idx = 0;
        while (idx < 2) {
            if (num > (idx + 1)) {
                var drl = av1_sym_read_symbol(sd, av1_imcdf_drl(cc, av1_mvctx_drl_context(mvctx, idx)), 2);
                if (drl == 0) { ref_mv_idx = idx; break; }
                ref_mv_idx = idx + 1;
            }
            idx = idx + 1;
        }
    }
    if (av1_has_nearmv(y_mode) != 0) {
        ref_mv_idx = 1;
        var idx2 = 1;
        while (idx2 < 3) {
            if (num > (idx2 + 1)) {
                var drl2 = av1_sym_read_symbol(sd, av1_imcdf_drl(cc, av1_mvctx_drl_context(mvctx, idx2)), 2);
                if (drl2 == 0) { ref_mv_idx = idx2; break; }
                ref_mv_idx = idx2 + 1;
            }
            idx2 = idx2 + 1;
        }
    }
    return ref_mv_idx;
}

# ================================================================
# get_mode (spec 5.11.32) — map the block's YMode to the per-list single mode for
# reference list `ref_list` (0 or 1). For single prediction (YMode < NEAREST_NEARESTMV)
# refList 0 returns YMode itself; the compound modes split into a NEWMV/NEARESTMV/
# NEARMV/GLOBALMV per list.
# ================================================================
fn av1_get_mode(y_mode, ref_list): i64 {
    if (ref_list == 0) {
        if (y_mode < AV1_NEAREST_NEARESTMV) { return y_mode; }
        if ((y_mode == AV1_NEW_NEWMV) || (y_mode == AV1_NEW_NEARESTMV) || (y_mode == AV1_NEW_NEARMV)) {
            return AV1_NEWMV;
        }
        if ((y_mode == AV1_NEAREST_NEARESTMV) || (y_mode == AV1_NEAREST_NEWMV)) { return AV1_NEARESTMV; }
        if ((y_mode == AV1_NEAR_NEARMV) || (y_mode == AV1_NEAR_NEWMV)) { return AV1_NEARMV; }
        return AV1_GLOBALMV;
    }
    if ((y_mode == AV1_NEW_NEWMV) || (y_mode == AV1_NEAREST_NEWMV) || (y_mode == AV1_NEAR_NEWMV)) {
        return AV1_NEWMV;
    }
    if ((y_mode == AV1_NEAREST_NEARESTMV) || (y_mode == AV1_NEW_NEARESTMV)) { return AV1_NEARESTMV; }
    if ((y_mode == AV1_NEAR_NEARMV) || (y_mode == AV1_NEW_NEARMV)) { return AV1_NEARMV; }
    return AV1_GLOBALMV;
}

# assign_mv, one reference list (spec 5.11.32) — compute Mv[ref_list] into out_mv.
# GLOBALMV takes GlobalMvs[ref_list]; otherwise the predictor is RefStackMv[pos][ref_list]
# with pos = 0 for NEARESTMV, RefMvIdx for NEARMV, RefMvIdx (or 0 if NumMvFound <= 1) for
# NEWMV. NEWMV adds the decoded MV difference (read_mv, MV CDF `mvcc`); else copies the
# predictor. `comp_mode` is the per-list mode from get_mode; mv_ctx = 0 (non-intrabc).
fn av1_assign_mv_list(sd, mvcc, mvctx, comp_mode, ref_mv_idx, ref_list, mv_ctx, allow_hp, force_int, out_mv): i64 {
    var mvs = load64(mvctx + AV1MVC_STACK);
    var num = av1_mv_stack_num(mvs);
    var pred_row = 0;
    var pred_col = 0;
    if (comp_mode == AV1_GLOBALMV) {
        if (ref_list == 0) {
            pred_row = load64(mvctx + AV1MVC_GMV0_ROW);
            pred_col = load64(mvctx + AV1MVC_GMV0_COL);
        } else {
            pred_row = load64(mvctx + AV1MVC_GMV1_ROW);
            pred_col = load64(mvctx + AV1MVC_GMV1_COL);
        }
    } else {
        var pos = ref_mv_idx;
        if (comp_mode == AV1_NEARESTMV) { pos = 0; }
        if ((comp_mode == AV1_NEWMV) && (num <= 1)) { pos = 0; }
        pred_row = av1_mv_stack_row(mvs, pos, ref_list);
        pred_col = av1_mv_stack_col(mvs, pos, ref_list);
    }
    if (comp_mode == AV1_NEWMV) {
        av1_read_mv(sd, mvcc, mv_ctx, allow_hp, force_int, pred_row, pred_col, out_mv);
    } else {
        store64(out_mv + AV1MV_ROW, pred_row);
        store64(out_mv + AV1MV_COL, pred_col);
    }
    return DR_OK;
}

# assign_mv, SINGLE prediction — Mv[0] into out_mv (get_mode(YMode, 0) == YMode).
fn av1_assign_mv_single(sd, mvcc, mvctx, y_mode, ref_mv_idx, mv_ctx, allow_hp, force_int, out_mv): i64 {
    return av1_assign_mv_list(sd, mvcc, mvctx, av1_get_mode(y_mode, 0), ref_mv_idx, 0,
    mv_ctx, allow_hp, force_int, out_mv);
}

# assign_mv, COMPOUND prediction — Mv[0]/Mv[1] into out_mv0/out_mv1. Each list gets
# its per-list mode via get_mode; the two NEWMV reads (if any) are decoded in list
# order (0 then 1) through the same MV CDF context.
fn av1_assign_mv_compound(sd, mvcc, mvctx, y_mode, ref_mv_idx, mv_ctx, allow_hp, force_int, out_mv0, out_mv1): i64 {
    av1_assign_mv_list(sd, mvcc, mvctx, av1_get_mode(y_mode, 0), ref_mv_idx, 0,
    mv_ctx, allow_hp, force_int, out_mv0);
    av1_assign_mv_list(sd, mvcc, mvctx, av1_get_mode(y_mode, 1), ref_mv_idx, 1,
    mv_ctx, allow_hp, force_int, out_mv1);
    return DR_OK;
}

# ================================================================
# Paired encoders (round-trip). write_inter_mode emits new_mv/zero_mv/ref_mv for a
# given single-prediction YMode; write_drl_idx emits the drl_mode bits selecting
# RefMvIdx; assign_mv's encode is av1_write_mv (for NEWMV).
# ================================================================
fn av1_write_inter_mode(enc, cc, mvctx, y_mode): i64 {
    var new_mv = 1;
    if (y_mode == AV1_NEWMV) { new_mv = 0; }
    av1_sym_encode_symbol(enc, av1_imcdf_newmv(cc, av1_mvctx_newmv_context(mvctx)), 2, new_mv);
    if (new_mv != 0) {
        var zero_mv = 1;
        if (y_mode == AV1_GLOBALMV) { zero_mv = 0; }
        av1_sym_encode_symbol(enc, av1_imcdf_zeromv(cc, av1_mvctx_zero_context(mvctx)), 2, zero_mv);
        if (zero_mv != 0) {
            var ref_mv = 1;
            if (y_mode == AV1_NEARESTMV) { ref_mv = 0; }
            av1_sym_encode_symbol(enc, av1_imcdf_refmv(cc, av1_mvctx_refmv_context(mvctx)), 2, ref_mv);
        }
    }
    return DR_OK;
}
fn av1_write_drl_idx(enc, cc, mvctx, y_mode, ref_mv_idx): i64 {
    var mvs = load64(mvctx + AV1MVC_STACK);
    var num = av1_mv_stack_num(mvs);
    if ((y_mode == AV1_NEWMV) || (y_mode == AV1_NEW_NEWMV)) {
        var idx = 0;
        while (idx < 2) {
            if (num > (idx + 1)) {
                var bit = 1;
                if (ref_mv_idx == idx) { bit = 0; }
                av1_sym_encode_symbol(enc, av1_imcdf_drl(cc, av1_mvctx_drl_context(mvctx, idx)), 2, bit);
                if (bit == 0) { break; }
            }
            idx = idx + 1;
        }
    }
    if (av1_has_nearmv(y_mode) != 0) {
        var idx2 = 1;
        while (idx2 < 3) {
            if (num > (idx2 + 1)) {
                var bit2 = 1;
                if (ref_mv_idx == idx2) { bit2 = 0; }
                av1_sym_encode_symbol(enc, av1_imcdf_drl(cc, av1_mvctx_drl_context(mvctx, idx2)), 2, bit2);
                if (bit2 == 0) { break; }
            }
            idx2 = idx2 + 1;
        }
    }
    return DR_OK;
}

# ================================================================
# THE REFERENCE-SELECTION READS — read_is_inter (5.11.30) + read_ref_frames
# (5.11.25). is_inter picks intra vs inter for a block. read_ref_frames picks the
# reference frame(s): comp_mode (single vs compound) gates the two trees —
#   * SINGLE (0.7.68): the single_ref_p1..p6 tree picks RefFrame[0] from the seven
#     references (four forward LAST/LAST2/LAST3/GOLDEN + three backward BWDREF/
#     ALTREF2/ALTREF); RefFrame[1] = NONE.
#   * COMPOUND (0.7.69): comp_ref_type picks unidirectional vs bidirectional. Unidir
#     yields one of four same-direction pairs (LAST+LAST2, LAST+LAST3, LAST+GOLDEN,
#     BWDREF+ALTREF); bidir picks a forward RefFrame[0] (comp_ref / _p1 / _p2) and a
#     backward RefFrame[1] (comp_bwdref / _p1).
# CDF families (all §10): Is_Inter[4], Single_Ref[3][6], Comp_Mode[5],
# Comp_Ref_Type[5], Comp_Ref[3][3], Comp_Bwd_Ref[3][2], Uni_Comp_Ref[3][3]. Every
# per-symbol CDF CONTEXT derives from a count of the neighbours' reference usage
# (spec 8.3/9). Those were caller inputs when this landed at 0.7.69 because the MI grid
# held nothing; av1_comp_ref_ctxs (0.7.76) now derives them from an Av1NbCtx, and the
# records below are still accepted directly for tests and bespoke callers.
# ================================================================
enum Av1RefReadConst {
    AV1_IS_INTER_CONTEXTS      = 4;    # IS_INTER_CONTEXTS
    AV1_REF_CONTEXTS           = 3;    # REF_CONTEXTS (single_ref / comp_ref / ...)
    AV1_SINGLE_REFS            = 7;    # SINGLE_REFS (SINGLE_REFS-1 = 6 sub-CDFs p1..p6)
    AV1_COMP_INTER_CONTEXTS    = 5;    # COMP_INTER_CONTEXTS (comp_mode)
    AV1_COMP_REF_TYPE_CONTEXTS = 5;    # COMP_REF_TYPE_CONTEXTS
    AV1_FWD_REFS               = 4;    # FWD_REFS (FWD_REFS-1 = 3 comp_ref sub-CDFs)
    AV1_BWD_REFS               = 3;    # BWD_REFS (BWD_REFS-1 = 2 comp_bwdref sub-CDFs)
    AV1_UNIDIR_COMP_REFS       = 4;    # UNIDIR_COMP_REFS (-1 = 3 uni_comp_ref sub-CDFs)
    # comp_mode values (07 semantics)
    AV1_SINGLE_REFERENCE       = 0;
    AV1_COMPOUND_REFERENCE     = 1;
    # comp_ref_type values
    AV1_UNIDIR_COMP_REFERENCE  = 0;
    AV1_BIDIR_COMP_REFERENCE   = 1;
}
var AV1_REF_NONE = 0 - 1;         # NONE (enums reject negative literals)

# ================================================================
# THE NEIGHBOUR CONTEXT (spec 5.11.15 inter_frame_mode_info preamble + 9 CDF selection)
# ----------------------------------------------------------------
# Every inter CDF context is derived from the ABOVE and LEFT neighbours' reference
# frames. Those reads were caller inputs from 0.7.68 onward because the MI grid held no
# decoded data; 0.7.74's storage loops changed that, so the derivations can land for real.
#
# inter_frame_mode_info opens by snapshotting eight values from the grid:
#   Left/AboveRefFrame[0] = Avail ? RefFrames[nb][0] : INTRA_FRAME
#   Left/AboveRefFrame[1] = Avail ? RefFrames[nb][1] : NONE
#   Left/AboveIntra       = RefFrame[0] <= INTRA_FRAME
#   Left/AboveSingle      = RefFrame[1] <= INTRA_FRAME
# Note the ASYMMETRY of the unavailable defaults: RefFrame[0] falls back to INTRA_FRAME
# (so an unavailable neighbour reads as intra) but RefFrame[1] falls back to NONE (so it
# reads as single). Both are `<= INTRA_FRAME` tests, which is why NONE = -1 works for
# Single while INTRA_FRAME = 0 works for Intra.
#
# AvailU / AvailL are the caller's (decode_block computes them as is_inside(r-1, c) /
# is_inside(r, c-1) — tile bounds; raster order guarantees an in-tile above/left neighbour
# is already decoded). 0.7.75 landed the foundation + is_inter / comp_mode; the single_ref
# / comp_ref family followed in 0.7.76, and comp_group_idx / compound_idx / interp_filter
# (with the grid fields they read) in 0.7.77 — all below.
# ================================================================
enum Av1NbCtxOff {
    AV1NB_AVAILU  = 0;     # AvailU
    AV1NB_AVAILL  = 8;     # AvailL
    AV1NB_AREF0   = 16;    # AboveRefFrame[0]
    AV1NB_AREF1   = 24;    # AboveRefFrame[1]
    AV1NB_LREF0   = 32;    # LeftRefFrame[0]
    AV1NB_LREF1   = 40;    # LeftRefFrame[1]
    AV1NB_AINTRA  = 48;    # AboveIntra
    AV1NB_LINTRA  = 56;    # LeftIntra
    AV1NB_ASINGLE = 64;    # AboveSingle
    AV1NB_LSINGLE = 72;    # LeftSingle
    # (0.7.77) the neighbour grid values the last three contexts read. The spec reads
    # these straight from the grid at ctx time rather than snapshotting them in the
    # 5.11.15 preamble; caching them here keeps every ctx a pure function of the record
    # (as 0.7.75/0.7.76 established) and is equivalent — each read is Avail-guarded, so an
    # unavailable neighbour's cached value is never consulted.
    AV1NB_ACOMPGRP = 80;   # CompGroupIdxs[MiRow-1][MiCol]
    AV1NB_LCOMPGRP = 88;   # CompGroupIdxs[MiRow][MiCol-1]
    AV1NB_ACOMPIDX = 96;   # CompoundIdxs[MiRow-1][MiCol]
    AV1NB_LCOMPIDX = 104;  # CompoundIdxs[MiRow][MiCol-1]
    AV1NB_AINTERP0 = 112;  # InterpFilters[MiRow-1][MiCol][0]
    AV1NB_AINTERP1 = 120;  # InterpFilters[MiRow-1][MiCol][1]
    AV1NB_LINTERP0 = 128;  # InterpFilters[MiRow][MiCol-1][0]
    AV1NB_LINTERP1 = 136;  # InterpFilters[MiRow][MiCol-1][1]
    AV1NB_SIZE    = 144;
}
fn av1_nbctx_new(): i64 {
    var nb = alloc(AV1NB_SIZE);
    if (nb == 0) { return 0; }
    memset(nb, 0, AV1NB_SIZE);
    return nb;
}
fn av1_nbctx_availu(nb): i64 { return load64(nb + AV1NB_AVAILU); }
fn av1_nbctx_availl(nb): i64 { return load64(nb + AV1NB_AVAILL); }
fn av1_nbctx_aref(nb, list): i64 { return load64(nb + AV1NB_AREF0 + (list * 8)); }
fn av1_nbctx_lref(nb, list): i64 { return load64(nb + AV1NB_LREF0 + (list * 8)); }
fn av1_nbctx_aintra(nb): i64 { return load64(nb + AV1NB_AINTRA); }
fn av1_nbctx_lintra(nb): i64 { return load64(nb + AV1NB_LINTRA); }
fn av1_nbctx_asingle(nb): i64 { return load64(nb + AV1NB_ASINGLE); }
fn av1_nbctx_lsingle(nb): i64 { return load64(nb + AV1NB_LSINGLE); }

# av1_nbctx_setup (spec 5.11.15) — snapshot the above/left neighbours from the MI grid.
# avail_u / avail_l are the caller's is_inside(r-1, c) / is_inside(r, c-1).
fn av1_nbctx_setup(nb, grid, fmi_cols, mi_row, mi_col, avail_u, avail_l): i64 {
    if (nb == 0) { return DR_ERR_BOUNDS; }
    store64(nb + AV1NB_AVAILU, avail_u != 0);   # normalize a caller truthy to 0/1
    store64(nb + AV1NB_AVAILL, avail_l != 0);
    # unavailable: RefFrame[0] reads as INTRA_FRAME, RefFrame[1] as NONE (spec 5.11.15).
    var aref0 = AV1_INTRA_FRAME;
    var aref1 = AV1_REF_NONE;
    var lref0 = AV1_INTRA_FRAME;
    var lref1 = AV1_REF_NONE;
    # The cached grid values default to 0 and are written UNCONDITIONALLY below. They must
    # not be left to the `avail` branches: setup is called once PER BLOCK on a REUSED
    # record (the tile decode holds one), so an unavailable neighbour would otherwise
    # inherit the PREVIOUS block's neighbour — the stale-field class read_compound_type
    # guards against too.
    var agrp = 0; var aidx = 0; var ai0 = 0; var ai1 = 0;
    var lgrp = 0; var lidx = 0; var li0 = 0; var li1 = 0;
    if (avail_u != 0) {
        var acell = av1_mv_grid_cell(grid, fmi_cols, mi_row - 1, mi_col);
        aref0 = load64(acell + AV1MIR_REF0);
        aref1 = load64(acell + AV1MIR_REF1);
        agrp = load64(acell + AV1MIR_COMPGRP);
        aidx = load64(acell + AV1MIR_COMPIDX);
        ai0 = load64(acell + AV1MIR_INTERP0);
        ai1 = load64(acell + AV1MIR_INTERP1);
    }
    if (avail_l != 0) {
        var lcell = av1_mv_grid_cell(grid, fmi_cols, mi_row, mi_col - 1);
        lref0 = load64(lcell + AV1MIR_REF0);
        lref1 = load64(lcell + AV1MIR_REF1);
        lgrp = load64(lcell + AV1MIR_COMPGRP);
        lidx = load64(lcell + AV1MIR_COMPIDX);
        li0 = load64(lcell + AV1MIR_INTERP0);
        li1 = load64(lcell + AV1MIR_INTERP1);
    }
    store64(nb + AV1NB_ACOMPGRP, agrp);
    store64(nb + AV1NB_ACOMPIDX, aidx);
    store64(nb + AV1NB_AINTERP0, ai0);
    store64(nb + AV1NB_AINTERP1, ai1);
    store64(nb + AV1NB_LCOMPGRP, lgrp);
    store64(nb + AV1NB_LCOMPIDX, lidx);
    store64(nb + AV1NB_LINTERP0, li0);
    store64(nb + AV1NB_LINTERP1, li1);
    store64(nb + AV1NB_AREF0, aref0);
    store64(nb + AV1NB_AREF1, aref1);
    store64(nb + AV1NB_LREF0, lref0);
    store64(nb + AV1NB_LREF1, lref1);
    # the <= INTRA_FRAME tests. NONE = -1 <= 0, so an unavailable/single neighbour is Single.
    store64(nb + AV1NB_AINTRA, aref0 <= AV1_INTRA_FRAME);
    store64(nb + AV1NB_LINTRA, lref0 <= AV1_INTRA_FRAME);
    store64(nb + AV1NB_ASINGLE, aref1 <= AV1_INTRA_FRAME);
    store64(nb + AV1NB_LSINGLE, lref1 <= AV1_INTRA_FRAME);
    return DR_OK;
}

# check_backward (spec 9) — is refFrame one of the backward references?
fn av1_check_backward(ref_frame): i64 {
    return (ref_frame >= AV1_BWDREF_FRAME) && (ref_frame <= AV1_ALTREF_FRAME);
}
# count_refs (spec 9) — how many of the (up to 4) neighbour reference slots are frameType.
fn av1_count_refs(nb, frame_type): i64 {
    var c = 0;
    if (av1_nbctx_availu(nb) != 0) {
        if (av1_nbctx_aref(nb, 0) == frame_type) { c = c + 1; }
        if (av1_nbctx_aref(nb, 1) == frame_type) { c = c + 1; }
    }
    if (av1_nbctx_availl(nb) != 0) {
        if (av1_nbctx_lref(nb, 0) == frame_type) { c = c + 1; }
        if (av1_nbctx_lref(nb, 1) == frame_type) { c = c + 1; }
    }
    return c;
}
# ref_count_ctx (spec 9) — compare two counts into a 3-way context.
fn av1_ref_count_ctx(counts0, counts1): i64 {
    if (counts0 < counts1) { return 0; }
    if (counts0 == counts1) { return 1; }
    return 2;
}

# is_inter ctx (spec 9) — feeds av1_read_is_inter (0.7.68).
fn av1_is_inter_ctx(nb): i64 {
    var au = av1_nbctx_availu(nb);
    var al = av1_nbctx_availl(nb);
    var ai = av1_nbctx_aintra(nb);
    var li = av1_nbctx_lintra(nb);
    if ((au != 0) && (al != 0)) {
        if ((li != 0) && (ai != 0)) { return 3; }
        return (li != 0) || (ai != 0);
    }
    if ((au != 0) || (al != 0)) {
        if (au != 0) { return 2 * ai; }
        return 2 * li;
    }
    return 0;
}

# comp_mode ctx (spec 9) — feeds av1_read_comp_mode (0.7.69).
fn av1_comp_mode_ctx(nb): i64 {
    var au = av1_nbctx_availu(nb);
    var al = av1_nbctx_availl(nb);
    var asg = av1_nbctx_asingle(nb);
    var lsg = av1_nbctx_lsingle(nb);
    var abw = av1_check_backward(av1_nbctx_aref(nb, 0));
    var lbw = av1_check_backward(av1_nbctx_lref(nb, 0));
    if ((au != 0) && (al != 0)) {
        if ((asg != 0) && (lsg != 0)) { return abw ^ lbw; }
        if (asg != 0) { return 2 + ((abw != 0) || (av1_nbctx_aintra(nb) != 0)); }
        if (lsg != 0) { return 2 + ((lbw != 0) || (av1_nbctx_lintra(nb) != 0)); }
        return 4;
    }
    if (au != 0) {
        if (asg != 0) { return abw; }
        return 3;
    }
    if (al != 0) {
        if (lsg != 0) { return lbw; }
        return 3;
    }
    return 1;
}

# ----------------------------------------------------------------
# THE REFERENCE-CONTEXT FAMILY (spec 9)
#
# Fifteen symbols, but only EIGHT distinct derivations: seven are ref_count_ctx over a
# pair of count_refs sums, and the spec wires the rest up as aliases ("ctx is computed as
# in the CDF selection process for X"):
#   single_ref_p2 = comp_bwdref      single_ref_p3 = comp_ref
#   single_ref_p4 = comp_ref_p1      single_ref_p5 = comp_ref_p2
#   single_ref_p6 = comp_bwdref_p1   uni_comp_ref  = single_ref_p1
#   uni_comp_ref_p2 = comp_ref_p2
# The aliases are expressed by CALLING the aliased function, not by duplicating its body,
# so the spec's "same as" is structural rather than a copy that can drift.
# comp_ref_type is the eighth and is its own thing (below).
# ----------------------------------------------------------------
fn av1_comp_ref_ctx(nb): i64 {
    var last12 = av1_count_refs(nb, AV1_LAST_FRAME) + av1_count_refs(nb, AV1_LAST2_FRAME);
    var last3gold = av1_count_refs(nb, AV1_LAST3_FRAME) + av1_count_refs(nb, AV1_GOLDEN_FRAME);
    return av1_ref_count_ctx(last12, last3gold);
}
fn av1_comp_ref_p1_ctx(nb): i64 {
    return av1_ref_count_ctx(av1_count_refs(nb, AV1_LAST_FRAME), av1_count_refs(nb, AV1_LAST2_FRAME));
}
fn av1_comp_ref_p2_ctx(nb): i64 {
    return av1_ref_count_ctx(av1_count_refs(nb, AV1_LAST3_FRAME), av1_count_refs(nb, AV1_GOLDEN_FRAME));
}
fn av1_comp_bwdref_ctx(nb): i64 {
    var brfarf2 = av1_count_refs(nb, AV1_BWDREF_FRAME) + av1_count_refs(nb, AV1_ALTREF2_FRAME);
    return av1_ref_count_ctx(brfarf2, av1_count_refs(nb, AV1_ALTREF_FRAME));
}
fn av1_comp_bwdref_p1_ctx(nb): i64 {
    return av1_ref_count_ctx(av1_count_refs(nb, AV1_BWDREF_FRAME), av1_count_refs(nb, AV1_ALTREF2_FRAME));
}
fn av1_single_ref_p1_ctx(nb): i64 {
    var fwd = av1_count_refs(nb, AV1_LAST_FRAME) + av1_count_refs(nb, AV1_LAST2_FRAME)
    + av1_count_refs(nb, AV1_LAST3_FRAME) + av1_count_refs(nb, AV1_GOLDEN_FRAME);
    var bwd = av1_count_refs(nb, AV1_BWDREF_FRAME) + av1_count_refs(nb, AV1_ALTREF2_FRAME)
    + av1_count_refs(nb, AV1_ALTREF_FRAME);
    return av1_ref_count_ctx(fwd, bwd);
}
fn av1_uni_comp_ref_p1_ctx(nb): i64 {
    var last3gold = av1_count_refs(nb, AV1_LAST3_FRAME) + av1_count_refs(nb, AV1_GOLDEN_FRAME);
    return av1_ref_count_ctx(av1_count_refs(nb, AV1_LAST2_FRAME), last3gold);
}

# is_samedir_ref_pair (spec 9) — are both refs on the same side of the BWDREF split?
fn av1_is_samedir_ref_pair(ref0, ref1): i64 {
    return (ref0 >= AV1_BWDREF_FRAME) == (ref1 >= AV1_BWDREF_FRAME);
}

# comp_ref_type ctx (spec 9) — the one derivation that is not a count comparison.
fn av1_comp_ref_type_ctx(nb): i64 {
    var above0 = av1_nbctx_aref(nb, 0);
    var above1 = av1_nbctx_aref(nb, 1);
    var left0 = av1_nbctx_lref(nb, 0);
    var left1 = av1_nbctx_lref(nb, 1);
    var au = av1_nbctx_availu(nb);
    var al = av1_nbctx_availl(nb);
    var aintra = av1_nbctx_aintra(nb);
    var lintra = av1_nbctx_lintra(nb);
    var above_comp_inter = (au != 0) && (aintra == 0) && (av1_nbctx_asingle(nb) == 0);
    var left_comp_inter = (al != 0) && (lintra == 0) && (av1_nbctx_lsingle(nb) == 0);
    var above_uni = (above_comp_inter != 0) && (av1_is_samedir_ref_pair(above0, above1) != 0);
    var left_uni = (left_comp_inter != 0) && (av1_is_samedir_ref_pair(left0, left1) != 0);
    if ((au != 0) && (aintra == 0) && (al != 0) && (lintra == 0)) {
        var samedir = av1_is_samedir_ref_pair(above0, left0);
        if ((above_comp_inter == 0) && (left_comp_inter == 0)) { return 1 + (2 * samedir); }
        if (above_comp_inter == 0) {
            if (left_uni == 0) { return 1; }
            return 3 + samedir;
        }
        if (left_comp_inter == 0) {
            if (above_uni == 0) { return 1; }
            return 3 + samedir;
        }
        if ((above_uni == 0) && (left_uni == 0)) { return 0; }
        if ((above_uni == 0) || (left_uni == 0)) { return 2; }
        return 3 + ((above0 == AV1_BWDREF_FRAME) == (left0 == AV1_BWDREF_FRAME));
    }
    if ((au != 0) && (al != 0)) {
        if (above_comp_inter != 0) { return 1 + (2 * above_uni); }
        if (left_comp_inter != 0) { return 1 + (2 * left_uni); }
        return 2;
    }
    if (above_comp_inter != 0) { return 4 * above_uni; }
    if (left_comp_inter != 0) { return 4 * left_uni; }
    return 2;
}

# av1_single_ref_ctxs — fill the six-slot `refctx` av1_read_single_ref (0.7.68) consumes.
# refctx[j] is the context for single_ref_p(j+1). This is the un-deferral: that record was
# a caller input purely because the grid was empty.
fn av1_single_ref_ctxs(nb, out): i64 {
    if (out == 0) { return DR_ERR_BOUNDS; }
    store64(out + 0, av1_single_ref_p1_ctx(nb));       # p1: fwd vs bwd
    store64(out + 8, av1_comp_bwdref_ctx(nb));         # p2 = comp_bwdref
    store64(out + 16, av1_comp_ref_ctx(nb));           # p3 = comp_ref
    store64(out + 24, av1_comp_ref_p1_ctx(nb));        # p4 = comp_ref_p1
    store64(out + 32, av1_comp_ref_p2_ctx(nb));        # p5 = comp_ref_p2
    store64(out + 40, av1_comp_bwdref_p1_ctx(nb));     # p6 = comp_bwdref_p1
    return DR_OK;
}
# av1_comp_ref_ctxs — fill the nine-slot Av1CompCtxIdx record av1_read_compound_ref
# (0.7.69) consumes. Same un-deferral.
fn av1_comp_ref_ctxs(nb, out): i64 {
    if (out == 0) { return DR_ERR_BOUNDS; }
    store64(out + AV1CCTX_REF_TYPE, av1_comp_ref_type_ctx(nb));
    store64(out + AV1CCTX_UNI, av1_single_ref_p1_ctx(nb));       # uni_comp_ref = single_ref_p1
    store64(out + AV1CCTX_UNI_P1, av1_uni_comp_ref_p1_ctx(nb));
    store64(out + AV1CCTX_UNI_P2, av1_comp_ref_p2_ctx(nb));      # uni_comp_ref_p2 = comp_ref_p2
    store64(out + AV1CCTX_REF, av1_comp_ref_ctx(nb));
    store64(out + AV1CCTX_REF_P1, av1_comp_ref_p1_ctx(nb));
    store64(out + AV1CCTX_REF_P2, av1_comp_ref_p2_ctx(nb));
    store64(out + AV1CCTX_BWDREF, av1_comp_bwdref_ctx(nb));
    store64(out + AV1CCTX_BWDREF_P1, av1_comp_bwdref_p1_ctx(nb));
    return DR_OK;
}

# ----------------------------------------------------------------
# THE LAST THREE CONTEXTS (spec 9) — comp_group_idx / compound_idx / interp_filter.
# These read grid fields the MI record only started carrying in 0.7.77, which is why they
# outlived the other un-deferrals.
# ----------------------------------------------------------------
fn av1_nbctx_acompgrp(nb): i64 { return load64(nb + AV1NB_ACOMPGRP); }
fn av1_nbctx_lcompgrp(nb): i64 { return load64(nb + AV1NB_LCOMPGRP); }
fn av1_nbctx_acompidx(nb): i64 { return load64(nb + AV1NB_ACOMPIDX); }
fn av1_nbctx_lcompidx(nb): i64 { return load64(nb + AV1NB_LCOMPIDX); }
# dir is masked to 0/1: the spec's own ctx term is `(dir & 1)`, and callers only ever loop
# dir = 0..1, so masking the array index too is faithful for every legal input and keeps a
# stray dir from reading a neighbouring field of the record.
fn av1_nbctx_ainterp(nb, dir): i64 { return load64(nb + AV1NB_AINTERP0 + ((dir & 1) * 8)); }
fn av1_nbctx_linterp(nb, dir): i64 { return load64(nb + AV1NB_LINTERP0 + ((dir & 1) * 8)); }

# comp_group_idx ctx (spec 9) — feeds av1_read_comp_group_idx (0.7.73). A COMPOUND
# neighbour contributes its own comp_group_idx; a SINGLE neighbour contributes 3 only when
# its RefFrame[0] is ALTREF. Clamped to 5 (COMP_GROUP_IDX_CONTEXTS = 6).
fn av1_comp_group_idx_ctx(nb): i64 {
    var ctx = 0;
    if (av1_nbctx_availu(nb) != 0) {
        if (av1_nbctx_asingle(nb) == 0) {
            ctx = ctx + av1_nbctx_acompgrp(nb);
        } else {
            if (av1_nbctx_aref(nb, 0) == AV1_ALTREF_FRAME) { ctx = ctx + 3; }
        }
    }
    if (av1_nbctx_availl(nb) != 0) {
        if (av1_nbctx_lsingle(nb) == 0) {
            ctx = ctx + av1_nbctx_lcompgrp(nb);
        } else {
            if (av1_nbctx_lref(nb, 0) == AV1_ALTREF_FRAME) { ctx = ctx + 3; }
        }
    }
    return av1_min(5, ctx);
}

# compound_idx ctx (spec 9) — feeds av1_read_compound_idx (0.7.73). Same neighbour shape as
# comp_group_idx but the single-neighbour ALTREF bump is 1 rather than 3, and there is NO
# Min clamp — the spec relies on the maximum falling out at 5 (3 + 1 + 1).
#
# `fwd_eq_bck` is the caller's: the spec computes
#     fwd = Abs(get_relative_dist(OrderHints[RefFrame[0]], OrderHint))
#     bck = Abs(get_relative_dist(OrderHints[RefFrame[1]], OrderHint))
#     ctx = (fwd == bck) ? 3 : 0
# which is FRAME-level order-hint state, not neighbour state — deferred to the caller (roadmap.md)
# exactly like AvailU/AvailL (roadmap.md).
fn av1_compound_idx_ctx(nb, fwd_eq_bck): i64 {
    var ctx = 0;
    if (fwd_eq_bck != 0) { ctx = 3; }
    if (av1_nbctx_availu(nb) != 0) {
        if (av1_nbctx_asingle(nb) == 0) {
            ctx = ctx + av1_nbctx_acompidx(nb);
        } else {
            if (av1_nbctx_aref(nb, 0) == AV1_ALTREF_FRAME) { ctx = ctx + 1; }
        }
    }
    if (av1_nbctx_availl(nb) != 0) {
        if (av1_nbctx_lsingle(nb) == 0) {
            ctx = ctx + av1_nbctx_lcompidx(nb);
        } else {
            if (av1_nbctx_lref(nb, 0) == AV1_ALTREF_FRAME) { ctx = ctx + 1; }
        }
    }
    return ctx;
}

# interp_filter ctx (spec 9) — feeds av1_read_interp_filter (0.7.71), per direction.
# The base picks one of four 4-wide banks from (dir, is-compound); the offset is the
# neighbours' agreed filter type, where 3 means "no usable neighbour". A neighbour only
# counts if it SHARES this block's RefFrame[0] in either of its own reference slots.
fn av1_interp_filter_ctx(nb, dir, ref0, ref1): i64 {
    var ctx = (((dir & 1) * 2) + (ref1 > AV1_INTRA_FRAME)) * 4;
    var left_type = 3;
    var above_type = 3;
    if (av1_nbctx_availl(nb) != 0) {
        if ((av1_nbctx_lref(nb, 0) == ref0) || (av1_nbctx_lref(nb, 1) == ref0)) {
            left_type = av1_nbctx_linterp(nb, dir);
        }
    }
    if (av1_nbctx_availu(nb) != 0) {
        if ((av1_nbctx_aref(nb, 0) == ref0) || (av1_nbctx_aref(nb, 1) == ref0)) {
            above_type = av1_nbctx_ainterp(nb, dir);
        }
    }
    if (left_type == above_type) { return ctx + left_type; }
    if (left_type == 3) { return ctx + above_type; }
    if (above_type == 3) { return ctx + left_type; }
    return ctx + 3;
}

# Compound-reference context slots — filled by av1_comp_ref_ctxs (0.7.76) from an
# Av1NbCtx; still accepted as a caller input for tests / bespoke callers.
enum Av1CompCtxIdx {
    AV1CCTX_REF_TYPE  = 0;    # comp_ref_type   (0..COMP_REF_TYPE_CONTEXTS-1)
    AV1CCTX_UNI       = 8;    # uni_comp_ref    (0..REF_CONTEXTS-1)
    AV1CCTX_UNI_P1    = 16;   # uni_comp_ref_p1
    AV1CCTX_UNI_P2    = 24;   # uni_comp_ref_p2
    AV1CCTX_REF       = 32;   # comp_ref
    AV1CCTX_REF_P1    = 40;   # comp_ref_p1
    AV1CCTX_REF_P2    = 48;   # comp_ref_p2
    AV1CCTX_BWDREF    = 56;   # comp_bwdref
    AV1CCTX_BWDREF_P1 = 64;   # comp_bwdref_p1
    AV1CCTX_SIZE      = 72;
}

# The reference CDF blob (168 i64):
#   is_inter      [ctx 0..3]        base 0   ctx*3                -> [0,12)
#   single_ref    [ctx 0..2][j 0..5] base 12 (ctx*6 + j)*3        -> [12,66)
#   comp_mode     [ctx 0..4]        base 66  ctx*3                -> [66,81)
#   comp_ref_type [ctx 0..4]        base 81  ctx*3                -> [81,96)
#   comp_ref      [ctx 0..2][j 0..2] base 96 (ctx*3 + j)*3        -> [96,123)
#   comp_bwd_ref  [ctx 0..2][j 0..1] base 123 (ctx*2 + j)*3       -> [123,141)
#   uni_comp_ref  [ctx 0..2][j 0..2] base 141 (ctx*3 + j)*3       -> [141,168)
enum Av1RefCdfOff { AV1REFCDF_SIZE = 177; }   # +9: skip_mode [168,177) (0.7.83)
fn av1_refcdf_isinter(cc, ctx): i64 { return cc + ((0 + (ctx * 3)) * 8); }
fn av1_refcdf_singleref(cc, ctx, j): i64 { return cc + ((12 + (((ctx * 6) + j) * 3)) * 8); }
fn av1_refcdf_compmode(cc, ctx): i64 { return cc + ((66 + (ctx * 3)) * 8); }
fn av1_refcdf_skipmode(cc, ctx): i64 { return cc + ((168 + (ctx * 3)) * 8); }
fn av1_refcdf_comprftype(cc, ctx): i64 { return cc + ((81 + (ctx * 3)) * 8); }
fn av1_refcdf_compref(cc, ctx, j): i64 { return cc + ((96 + (((ctx * 3) + j) * 3)) * 8); }
fn av1_refcdf_compbwdref(cc, ctx, j): i64 { return cc + ((123 + (((ctx * 2) + j) * 3)) * 8); }
fn av1_refcdf_unicompref(cc, ctx, j): i64 { return cc + ((141 + (((ctx * 3) + j) * 3)) * 8); }

fn av1_refcdf_fill(cc): i64 {
    # Default_Is_Inter_Cdf[4]
    av1_mvcdf_put2(av1_refcdf_isinter(cc, 0), 806);
    av1_mvcdf_put2(av1_refcdf_isinter(cc, 1), 16662);
    av1_mvcdf_put2(av1_refcdf_isinter(cc, 2), 20186);
    av1_mvcdf_put2(av1_refcdf_isinter(cc, 3), 26538);
    # Default_Single_Ref_Cdf[3][6] — ctx 0..2, j (p-index-1) 0..5.
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 0, 0), 4897);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 0, 1), 1555);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 0, 2), 4236);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 0, 3), 8650);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 0, 4), 904);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 0, 5), 1444);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 1, 0), 16973);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 1, 1), 16751);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 1, 2), 19647);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 1, 3), 24773);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 1, 4), 11014);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 1, 5), 15087);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 2, 0), 29744);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 2, 1), 30279);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 2, 2), 31194);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 2, 3), 31895);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 2, 4), 26875);
    av1_mvcdf_put2(av1_refcdf_singleref(cc, 2, 5), 30304);
    # Default_Comp_Mode_Cdf[5]
    av1_mvcdf_put2(av1_refcdf_compmode(cc, 0), 26828);
    av1_mvcdf_put2(av1_refcdf_compmode(cc, 1), 24035);
    av1_mvcdf_put2(av1_refcdf_compmode(cc, 2), 12031);
    av1_mvcdf_put2(av1_refcdf_compmode(cc, 3), 10640);
    av1_mvcdf_put2(av1_refcdf_compmode(cc, 4), 2901);
    # Default_Comp_Ref_Type_Cdf[5]
    av1_mvcdf_put2(av1_refcdf_comprftype(cc, 0), 1198);
    av1_mvcdf_put2(av1_refcdf_comprftype(cc, 1), 2070);
    av1_mvcdf_put2(av1_refcdf_comprftype(cc, 2), 9166);
    av1_mvcdf_put2(av1_refcdf_comprftype(cc, 3), 7499);
    av1_mvcdf_put2(av1_refcdf_comprftype(cc, 4), 22475);
    # Default_Comp_Ref_Cdf[3][3] — ctx 0..2, j (comp_ref/_p1/_p2) 0..2.
    av1_mvcdf_put2(av1_refcdf_compref(cc, 0, 0), 4946);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 0, 1), 9468);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 0, 2), 1503);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 1, 0), 19891);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 1, 1), 22441);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 1, 2), 15160);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 2, 0), 30731);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 2, 1), 31059);
    av1_mvcdf_put2(av1_refcdf_compref(cc, 2, 2), 27544);
    # Default_Comp_Bwd_Ref_Cdf[3][2] — ctx 0..2, j (comp_bwdref/_p1) 0..1.
    av1_mvcdf_put2(av1_refcdf_compbwdref(cc, 0, 0), 2235);
    av1_mvcdf_put2(av1_refcdf_compbwdref(cc, 0, 1), 1423);
    av1_mvcdf_put2(av1_refcdf_compbwdref(cc, 1, 0), 17182);
    av1_mvcdf_put2(av1_refcdf_compbwdref(cc, 1, 1), 15175);
    av1_mvcdf_put2(av1_refcdf_compbwdref(cc, 2, 0), 30606);
    av1_mvcdf_put2(av1_refcdf_compbwdref(cc, 2, 1), 30489);
    # Default_Uni_Comp_Ref_Cdf[3][3] — ctx 0..2, j (uni/_p1/_p2) 0..2.
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 0, 0), 5284);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 0, 1), 3865);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 0, 2), 3128);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 1, 0), 23152);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 1, 1), 14173);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 1, 2), 15270);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 2, 0), 31774);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 2, 1), 25120);
    av1_mvcdf_put2(av1_refcdf_unicompref(cc, 2, 2), 26710);
    # Default_Skip_Mode_Cdf[3] (spec 10) — ctx 0..2 (AboveSkipMode + LeftSkipMode).
    av1_mvcdf_put2(av1_refcdf_skipmode(cc, 0), 32621);
    av1_mvcdf_put2(av1_refcdf_skipmode(cc, 1), 20708);
    av1_mvcdf_put2(av1_refcdf_skipmode(cc, 2), 8127);
    return DR_OK;
}
fn av1_refcdf_new(): i64 {
    var cc = alloc(AV1REFCDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_refcdf_fill(cc);
    return cc;
}
var AV1_REFCDF_BLOB = 0;
fn av1_refcdf_blob(): i64 {
    if (AV1_REFCDF_BLOB != 0) { return AV1_REFCDF_BLOB; }
    var cc = alloc(AV1REFCDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_refcdf_fill(cc);
    AV1_REFCDF_BLOB = cc;
    return cc;
}

# read_is_inter (spec 5.11.30) — the @@is_inter symbol (0 = intra, 1 = inter), CDF
# Is_Inter[ctx]. The skip_mode / segment-forced branches (which bypass this symbol)
# are the caller's concern.
fn av1_read_is_inter_sym(sd, cc, ctx): i64 {
    return av1_sym_read_symbol(sd, av1_refcdf_isinter(cc, ctx), 2);
}
fn av1_write_is_inter_sym(enc, cc, ctx, is_inter): i64 {
    av1_sym_encode_symbol(enc, av1_refcdf_isinter(cc, ctx), 2, is_inter);
    return DR_OK;
}

# ================================================================
# read_single_ref (spec 5.11.25 single-reference path) — decode RefFrame[0] via the
# single_ref_p1..p6 binary tree; writes RefFrame[0..1] into out_ref (2 i64; [1] =
# NONE for single prediction) and returns RefFrame[0]. `refctx` points to the six
# per-symbol contexts (refctx[j] = ctx for single_ref_p(j+1), each in 0..REF_CONTEXTS-1).
#   p1: forward vs backward     p2: ALTREF vs {BWDREF,ALTREF2}   p6: ALTREF2 vs BWDREF
#   p3: {LAST3,GOLDEN} vs {LAST,LAST2}   p5: GOLDEN vs LAST3   p4: LAST2 vs LAST
# ================================================================
fn av1_read_single_ref(sd, cc, refctx, out_ref): i64 {
    var rf = AV1_LAST_FRAME;
    var p1 = av1_sym_read_symbol(sd, av1_refcdf_singleref(cc, load64(refctx + 0), 0), 2);
    if (p1 != 0) {
        var p2 = av1_sym_read_symbol(sd, av1_refcdf_singleref(cc, load64(refctx + 8), 1), 2);
        if (p2 != 0) {
            rf = AV1_ALTREF_FRAME;
        } else {
            var p6 = av1_sym_read_symbol(sd, av1_refcdf_singleref(cc, load64(refctx + 40), 5), 2);
            if (p6 != 0) { rf = AV1_ALTREF2_FRAME; } else { rf = AV1_BWDREF_FRAME; }
        }
    } else {
        var p3 = av1_sym_read_symbol(sd, av1_refcdf_singleref(cc, load64(refctx + 16), 2), 2);
        if (p3 != 0) {
            var p5 = av1_sym_read_symbol(sd, av1_refcdf_singleref(cc, load64(refctx + 32), 4), 2);
            if (p5 != 0) { rf = AV1_GOLDEN_FRAME; } else { rf = AV1_LAST3_FRAME; }
        } else {
            var p4 = av1_sym_read_symbol(sd, av1_refcdf_singleref(cc, load64(refctx + 24), 3), 2);
            if (p4 != 0) { rf = AV1_LAST2_FRAME; } else { rf = AV1_LAST_FRAME; }
        }
    }
    store64(out_ref + 0, rf);
    store64(out_ref + 8, AV1_REF_NONE);
    return rf;
}

# write_single_ref — the inverse: emit the p1..p6 tree for a given RefFrame[0]
# (LAST..ALTREF). Forward refs (LAST/LAST2/LAST3/GOLDEN, <BWDREF) code p1=0; the
# backward refs (BWDREF/ALTREF2/ALTREF) code p1=1.
fn av1_write_single_ref(enc, cc, refctx, rf): i64 {
    if (rf >= AV1_BWDREF_FRAME) {
        av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 0), 0), 2, 1);
        if (rf == AV1_ALTREF_FRAME) {
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 8), 1), 2, 1);
        } else {
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 8), 1), 2, 0);
            var p6 = 0;
            if (rf == AV1_ALTREF2_FRAME) { p6 = 1; }
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 40), 5), 2, p6);
        }
    } else {
        av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 0), 0), 2, 0);
        if (rf >= AV1_LAST3_FRAME) {
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 16), 2), 2, 1);
            var p5 = 0;
            if (rf == AV1_GOLDEN_FRAME) { p5 = 1; }
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 32), 4), 2, p5);
        } else {
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 16), 2), 2, 0);
            var p4 = 0;
            if (rf == AV1_LAST2_FRAME) { p4 = 1; }
            av1_sym_encode_symbol(enc, av1_refcdf_singleref(cc, load64(refctx + 24), 3), 2, p4);
        }
    }
    return DR_OK;
}

# ================================================================
# read_comp_mode (spec 5.11.25) — the @@comp_mode symbol: SINGLE_REFERENCE (0) vs
# COMPOUND_REFERENCE (1), CDF Comp_Mode[ctx]. Read only when reference_select and
# Min(bw4, bh4) >= 2 (the caller's gate; otherwise comp_mode is forced SINGLE).
# ================================================================
fn av1_read_comp_mode(sd, cc, ctx): i64 {
    return av1_sym_read_symbol(sd, av1_refcdf_compmode(cc, ctx), 2);
}
fn av1_write_comp_mode(enc, cc, ctx, comp_mode): i64 {
    av1_sym_encode_symbol(enc, av1_refcdf_compmode(cc, ctx), 2, comp_mode);
    return DR_OK;
}

# ================================================================
# read_compound_ref (spec 5.11.25 compound-reference path) — decode a compound
# reference PAIR into out_ref (2 i64: RefFrame[0] forward-ish, RefFrame[1]). First
# comp_ref_type (unidir vs bidir), then the matching tree. `cctx` points to an
# Av1CompCtx (the per-symbol contexts, AV1CCTX_*).
#   UNIDIR: uni_comp_ref==1 -> (BWDREF, ALTREF); else uni_comp_ref_p1==0 ->
#     (LAST, LAST2); p1==1, p2==1 -> (LAST, GOLDEN); p1==1, p2==0 -> (LAST, LAST3).
#   BIDIR: RefFrame[0] from comp_ref (0 -> comp_ref_p1: LAST2/LAST; 1 -> comp_ref_p2:
#     GOLDEN/LAST3); RefFrame[1] from comp_bwdref (1 -> ALTREF; 0 -> comp_bwdref_p1:
#     ALTREF2/BWDREF).
# ================================================================
fn av1_read_compound_ref(sd, cc, cctx, out_ref): i64 {
    var r0 = 0;
    var r1 = 0;
    var comp_ref_type = av1_sym_read_symbol(sd,
    av1_refcdf_comprftype(cc, load64(cctx + AV1CCTX_REF_TYPE)), 2);
    if (comp_ref_type == AV1_UNIDIR_COMP_REFERENCE) {
        var uni = av1_sym_read_symbol(sd, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI), 0), 2);
        if (uni != 0) {
            r0 = AV1_BWDREF_FRAME;
            r1 = AV1_ALTREF_FRAME;
        } else {
            var up1 = av1_sym_read_symbol(sd, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI_P1), 1), 2);
            if (up1 != 0) {
                var up2 = av1_sym_read_symbol(sd, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI_P2), 2), 2);
                r0 = AV1_LAST_FRAME;
                if (up2 != 0) { r1 = AV1_GOLDEN_FRAME; } else { r1 = AV1_LAST3_FRAME; }
            } else {
                r0 = AV1_LAST_FRAME;
                r1 = AV1_LAST2_FRAME;
            }
        }
    } else {
        var comp_ref = av1_sym_read_symbol(sd, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF), 0), 2);
        if (comp_ref == 0) {
            var cp1 = av1_sym_read_symbol(sd, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF_P1), 1), 2);
            if (cp1 != 0) { r0 = AV1_LAST2_FRAME; } else { r0 = AV1_LAST_FRAME; }
        } else {
            var cp2 = av1_sym_read_symbol(sd, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF_P2), 2), 2);
            if (cp2 != 0) { r0 = AV1_GOLDEN_FRAME; } else { r0 = AV1_LAST3_FRAME; }
        }
        var comp_bwdref = av1_sym_read_symbol(sd, av1_refcdf_compbwdref(cc, load64(cctx + AV1CCTX_BWDREF), 0), 2);
        if (comp_bwdref == 0) {
            var bp1 = av1_sym_read_symbol(sd, av1_refcdf_compbwdref(cc, load64(cctx + AV1CCTX_BWDREF_P1), 1), 2);
            if (bp1 != 0) { r1 = AV1_ALTREF2_FRAME; } else { r1 = AV1_BWDREF_FRAME; }
        } else {
            r1 = AV1_ALTREF_FRAME;
        }
    }
    store64(out_ref + 0, r0);
    store64(out_ref + 8, r1);
    return DR_OK;
}

# write_compound_ref — the inverse: classify the (r0, r1) pair as unidir vs bidir
# and emit the tree. Unidir pairs: (BWDREF,ALTREF) + the three (LAST, {LAST2, LAST3,
# GOLDEN}); everything else (forward r0 + backward r1) is bidir.
fn av1_write_compound_ref(enc, cc, cctx, r0, r1): i64 {
    var is_unidir = 0;
    if ((r0 == AV1_BWDREF_FRAME) && (r1 == AV1_ALTREF_FRAME)) { is_unidir = 1; }
    if (r0 == AV1_LAST_FRAME) {
        if ((r1 == AV1_LAST2_FRAME) || (r1 == AV1_LAST3_FRAME) || (r1 == AV1_GOLDEN_FRAME)) { is_unidir = 1; }
    }
    if (is_unidir != 0) {
        av1_sym_encode_symbol(enc, av1_refcdf_comprftype(cc, load64(cctx + AV1CCTX_REF_TYPE)),
        2, AV1_UNIDIR_COMP_REFERENCE);
        if ((r0 == AV1_BWDREF_FRAME) && (r1 == AV1_ALTREF_FRAME)) {
            av1_sym_encode_symbol(enc, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI), 0), 2, 1);
        } else {
            av1_sym_encode_symbol(enc, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI), 0), 2, 0);
            if (r1 == AV1_LAST2_FRAME) {
                av1_sym_encode_symbol(enc, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI_P1), 1), 2, 0);
            } else {
                av1_sym_encode_symbol(enc, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI_P1), 1), 2, 1);
                var up2 = 0;
                if (r1 == AV1_GOLDEN_FRAME) { up2 = 1; }
                av1_sym_encode_symbol(enc, av1_refcdf_unicompref(cc, load64(cctx + AV1CCTX_UNI_P2), 2), 2, up2);
            }
        }
    } else {
        av1_sym_encode_symbol(enc, av1_refcdf_comprftype(cc, load64(cctx + AV1CCTX_REF_TYPE)),
        2, AV1_BIDIR_COMP_REFERENCE);
        if ((r0 == AV1_LAST_FRAME) || (r0 == AV1_LAST2_FRAME)) {
            av1_sym_encode_symbol(enc, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF), 0), 2, 0);
            var cp1 = 0;
            if (r0 == AV1_LAST2_FRAME) { cp1 = 1; }
            av1_sym_encode_symbol(enc, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF_P1), 1), 2, cp1);
        } else {
            av1_sym_encode_symbol(enc, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF), 0), 2, 1);
            var cp2 = 0;
            if (r0 == AV1_GOLDEN_FRAME) { cp2 = 1; }
            av1_sym_encode_symbol(enc, av1_refcdf_compref(cc, load64(cctx + AV1CCTX_REF_P2), 2), 2, cp2);
        }
        if (r1 == AV1_ALTREF_FRAME) {
            av1_sym_encode_symbol(enc, av1_refcdf_compbwdref(cc, load64(cctx + AV1CCTX_BWDREF), 0), 2, 1);
        } else {
            av1_sym_encode_symbol(enc, av1_refcdf_compbwdref(cc, load64(cctx + AV1CCTX_BWDREF), 0), 2, 0);
            var bp1 = 0;
            if (r1 == AV1_ALTREF2_FRAME) { bp1 = 1; }
            av1_sym_encode_symbol(enc, av1_refcdf_compbwdref(cc, load64(cctx + AV1CCTX_BWDREF_P1), 1), 2, bp1);
        }
    }
    return DR_OK;
}

# ================================================================
# Compound_Mode_Ctx_Map[3][COMP_NEWMV_CTXS] (spec 9 parsing) — maps (RefMvContext>>1,
# Min(NewMvContext, COMP_NEWMV_CTXS-1)) to the compound_mode CDF context. Lazily
# cached (global array literals do not initialize in cyrius).
# ================================================================
var AV1_COMPMODE_CTXMAP = 0;
fn av1_compmode_ctxmap(): i64 {
    if (AV1_COMPMODE_CTXMAP != 0) { return AV1_COMPMODE_CTXMAP; }
    var p = alloc(3 * AV1_COMP_NEWMV_CTXS * 8);
    store64(p + 0, 0);  store64(p + 8, 1);  store64(p + 16, 1); store64(p + 24, 1); store64(p + 32, 1);
    store64(p + 40, 1); store64(p + 48, 2); store64(p + 56, 3); store64(p + 64, 4); store64(p + 72, 4);
    store64(p + 80, 4); store64(p + 88, 4); store64(p + 96, 5); store64(p + 104, 6); store64(p + 112, 7);
    AV1_COMPMODE_CTXMAP = p;
    return p;
}
# av1_compound_mode_ctx — the compound_mode CDF context from RefMvContext + NewMvContext.
fn av1_compound_mode_ctx(ref_mv_ctx, new_mv_ctx): i64 {
    var col = av1_min(new_mv_ctx, AV1_COMP_NEWMV_CTXS - 1);
    return load64(av1_compmode_ctxmap() + ((((ref_mv_ctx >> 1) * AV1_COMP_NEWMV_CTXS) + col) * 8));
}

# ================================================================
# read_compound_mode (spec 5.11.32) — the COMPOUND-prediction inter YMode. Reads
# the 8-symbol compound_mode (context Compound_Mode_Ctx_Map[RefMvContext>>1][Min(
# NewMvContext, COMP_NEWMV_CTXS-1)]) and returns YMode = NEAREST_NEARESTMV +
# compound_mode (one of the eight compound modes). skip_mode / segment-forced modes
# are the caller's concern.
# ================================================================
fn av1_read_compound_mode(sd, cc, mvctx): i64 {
    var ctx = av1_compound_mode_ctx(av1_mvctx_refmv_context(mvctx), av1_mvctx_newmv_context(mvctx));
    var compound_mode = av1_sym_read_symbol(sd, av1_imcdf_compmode(cc, ctx), AV1_COMPOUND_MODES);
    return AV1_NEAREST_NEARESTMV + compound_mode;
}
fn av1_write_compound_mode(enc, cc, mvctx, y_mode): i64 {
    var ctx = av1_compound_mode_ctx(av1_mvctx_refmv_context(mvctx), av1_mvctx_newmv_context(mvctx));
    av1_sym_encode_symbol(enc, av1_imcdf_compmode(cc, ctx), AV1_COMPOUND_MODES,
    y_mode - AV1_NEAREST_NEARESTMV);
    return DR_OK;
}

# ================================================================
# THE REMAINING INTER MODE-INFO READS — interp_filter (5.11.30) + motion_mode
# (5.11.27, via use_obmc / motion_mode). These are the per-symbol bitstream reads;
# the GATING that decides whether each is coded (interpolation_filter == SWITCHABLE
# + needs_interp_filter; skip_mode / is_motion_mode_switchable / block-size /
# GLOBALMV-warp / has_overlappable_candidates / find_warp_samples / is_scaled) is
# the caller's / a later bite's concern (roadmap.md — it needs frame + neighbour state). Compound
# type + interintra are a later bite (roadmap.md).
# ================================================================

# read_interp_filter (spec 5.11.30) — one 3-symbol interp_filter (EIGHTTAP=0 /
# EIGHTTAP_SMOOTH=1 / EIGHTTAP_SHARP=2), CDF Interp_Filter[ctx]. `ctx` is a
# neighbour-derived context (0..INTERP_FILTER_CONTEXTS-1), a caller input.
fn av1_read_interp_filter(sd, cc, ctx): i64 {
    return av1_sym_read_symbol(sd, av1_imcdf_interp(cc, ctx), AV1_INTERP_FILTERS);
}
fn av1_write_interp_filter(enc, cc, ctx, filt): i64 {
    av1_sym_encode_symbol(enc, av1_imcdf_interp(cc, ctx), AV1_INTERP_FILTERS, filt);
    return DR_OK;
}

# read_use_obmc (spec 5.11.27) — the @@use_obmc binary symbol (motion_mode = OBMC
# if 1, else SIMPLE), CDF Use_Obmc[MiSize]. Read on the warp-disabled branch.
fn av1_read_use_obmc(sd, cc, mi_size): i64 {
    return av1_sym_read_symbol(sd, av1_imcdf_useobmc(cc, mi_size), 2);
}
fn av1_write_use_obmc(enc, cc, mi_size, use_obmc): i64 {
    av1_sym_encode_symbol(enc, av1_imcdf_useobmc(cc, mi_size), 2, use_obmc);
    return DR_OK;
}

# read_motion_mode leaf (spec 5.11.27) — the @@motion_mode 3-symbol (SIMPLE / OBMC /
# LOCALWARP), CDF Motion_Mode[MiSize]. Read on the warp-allowed branch. Leaf = _sym
# suffix; the plain name is the 5.11.27 gating DRIVER below (the 0.7.78 convention —
# cyrius silently shadows duplicate fn names, last-def-wins).
fn av1_read_motion_mode_sym(sd, cc, mi_size): i64 {
    return av1_sym_read_symbol(sd, av1_imcdf_motionmode(cc, mi_size), AV1_MOTION_MODES);
}
fn av1_write_motion_mode_sym(enc, cc, mi_size, motion_mode): i64 {
    av1_sym_encode_symbol(enc, av1_imcdf_motionmode(cc, mi_size), AV1_MOTION_MODES, motion_mode);
    return DR_OK;
}

# ================================================================
# THE INTER-INTRA READS (spec 5.11.28 read_interintra_mode)
# ----------------------------------------------------------------
# The inter-intra prediction signalling: an inter block (single-prediction only,
# BLOCK_8X8..BLOCK_32X32) may additionally blend with an INTRA predictor. The four
# entropy-coded reads are @@interintra (binary), @@interintra_mode (INTERINTRA_MODES=4:
# II_DC/V/H/SMOOTH), @@wedge_interintra (binary), @@wedge_index (WEDGE_TYPES=16). The
# interintra / interintra_mode CDF context is Size_Group[MiSize]-1 (09.parsing 1566/1572,
# ∈ 0..2 since the read is gated to size groups 1..3); wedge_interintra / wedge_index are
# MiSize-indexed. The GATING (!skip_mode && enable_interintra_compound && !isCompound &&
# BLOCK_8X8<=MiSize<=BLOCK_32X32) is caller-level. compound_type (5.11.29) — which reuses
# the Wedge_Index CDF here and branches on wedge_interintra — is a later bite (roadmap.md).
# ================================================================

# The inter-intra / compound-type CDF blob (566 i64) — one family: read_interintra_mode
# (5.11.28) + read_compound_type (5.11.29) share the wedge_index CDF.
#   inter_intra       [ctx 0..2]        base 0   ctx*3               -> [0,9)     binary
#   inter_intra_mode  [ctx 0..2]        base 9   ctx*5               -> [9,24)    4-symbol
#   wedge_interintra  [MiSize 0..21]    base 24  sz*3                -> [24,90)   binary
#   wedge_index       [MiSize 0..21]    base 90  sz*17               -> [90,464)  16-symbol
#   comp_group_idx    [ctx 0..5]        base 464 ctx*3               -> [464,482) binary
#   compound_idx      [ctx 0..5]        base 482 ctx*3               -> [482,500) binary
#   compound_type     [MiSize 0..21]    base 500 sz*3                -> [500,566) binary
enum Av1IiCdfOff { AV1IICDF_SIZE = 566; }
fn av1_iicdf_interintra(cc, ctx): i64 { return cc + ((0 + (ctx * 3)) * 8); }
fn av1_iicdf_iimode(cc, ctx): i64 { return cc + ((9 + (ctx * 5)) * 8); }
fn av1_iicdf_wedgeii(cc, mi_size): i64 { return cc + ((24 + (mi_size * 3)) * 8); }
fn av1_iicdf_wedgeidx(cc, mi_size): i64 { return cc + ((90 + (mi_size * 17)) * 8); }
fn av1_iicdf_groupidx(cc, ctx): i64 { return cc + ((464 + (ctx * 3)) * 8); }
fn av1_iicdf_compidx(cc, ctx): i64 { return cc + ((482 + (ctx * 3)) * 8); }
fn av1_iicdf_comptype(cc, mi_size): i64 { return cc + ((500 + (mi_size * 3)) * 8); }

# put a 16-symbol cdf {c0..c14, 32768, count=0} (17 i64 slots).
fn av1_iicdf_put16(p, c0, c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14): i64 {
    store64(p + 0, c0);    store64(p + 8, c1);    store64(p + 16, c2);   store64(p + 24, c3);
    store64(p + 32, c4);   store64(p + 40, c5);   store64(p + 48, c6);   store64(p + 56, c7);
    store64(p + 64, c8);   store64(p + 72, c9);   store64(p + 80, c10);  store64(p + 88, c11);
    store64(p + 96, c12);  store64(p + 104, c13); store64(p + 112, c14);
    store64(p + 120, 32768); store64(p + 128, 0);
    return DR_OK;
}
# the uniform wedge_index row {2048,4096,...,30720, 32768, 0} (the never-used MiSizes).
fn av1_iicdf_wedge_unif(p): i64 {
    av1_iicdf_put16(p, 2048, 4096, 6144, 8192, 10240, 12288, 14336, 16384,
    18432, 20480, 22528, 24576, 26624, 28672, 30720);
    return DR_OK;
}

# fill the inter-intra CDF blob with the §10 defaults.
fn av1_iicdf_fill(cc): i64 {
    # Default_Inter_Intra_Cdf[BLOCK_SIZE_GROUPS-1=3] — binary, ctx = Size_Group-1.
    av1_mvcdf_put2(av1_iicdf_interintra(cc, 0), 26887);
    av1_mvcdf_put2(av1_iicdf_interintra(cc, 1), 27597);
    av1_mvcdf_put2(av1_iicdf_interintra(cc, 2), 30237);
    # Default_Inter_Intra_Mode_Cdf[3] — 4-symbol.
    av1_mvcdf_put4(av1_iicdf_iimode(cc, 0), 1875, 11082, 27332);
    av1_mvcdf_put4(av1_iicdf_iimode(cc, 1), 2473, 9996, 26388);
    av1_mvcdf_put4(av1_iicdf_iimode(cc, 2), 4238, 11537, 25926);
    # Default_Wedge_Inter_Intra_Cdf[22] — binary (only 3..9 used; rest are 16384).
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 0), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 1), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 2), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 3), 20036);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 4), 24957);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 5), 26704);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 6), 27530);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 7), 29564);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 8), 29444);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 9), 26872);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 10), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 11), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 12), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 13), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 14), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 15), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 16), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 17), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 18), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 19), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 20), 16384);
    av1_mvcdf_put2(av1_iicdf_wedgeii(cc, 21), 16384);
    # Default_Wedge_Index_Cdf[22] — 16-symbol (used: 3..9, 18..19; rest uniform).
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 0));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 1));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 2));
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 3), 2438, 4440, 6599, 8663, 11005, 12874, 15751, 18094,
    20359, 22362, 24127, 25702, 27752, 29450, 31171);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 4), 806, 3266, 6005, 6738, 7218, 7367, 7771, 14588,
    16323, 17367, 18452, 19422, 22839, 26127, 29629);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 5), 2779, 3738, 4683, 7213, 7775, 8017, 8655, 14357,
    17939, 21332, 24520, 27470, 29456, 30529, 31656);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 6), 1684, 3625, 5675, 7108, 9302, 11274, 14429, 17144,
    19163, 20961, 22884, 24471, 26719, 28714, 30877);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 7), 1142, 3491, 6277, 7314, 8089, 8355, 9023, 13624,
    15369, 16730, 18114, 19313, 22521, 26012, 29550);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 8), 2742, 4195, 5727, 8035, 8980, 9336, 10146, 14124,
    17270, 20533, 23434, 25972, 27944, 29570, 31416);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 9), 1727, 3948, 6101, 7796, 9841, 12344, 15766, 18944,
    20638, 22038, 23963, 25311, 26988, 28766, 31012);
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 10));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 11));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 12));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 13));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 14));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 15));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 16));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 17));
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 18), 154, 987, 1925, 2051, 2088, 2111, 2151, 23033,
    23703, 24284, 24985, 25684, 27259, 28883, 30911);
    av1_iicdf_put16(av1_iicdf_wedgeidx(cc, 19), 1135, 1322, 1493, 2635, 2696, 2737, 2770, 21016,
    22935, 25057, 27251, 29173, 30089, 30960, 31933);
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 20));
    av1_iicdf_wedge_unif(av1_iicdf_wedgeidx(cc, 21));
    # Default_Comp_Group_Idx_Cdf[6] — binary.
    av1_mvcdf_put2(av1_iicdf_groupidx(cc, 0), 26607);
    av1_mvcdf_put2(av1_iicdf_groupidx(cc, 1), 22891);
    av1_mvcdf_put2(av1_iicdf_groupidx(cc, 2), 18840);
    av1_mvcdf_put2(av1_iicdf_groupidx(cc, 3), 24594);
    av1_mvcdf_put2(av1_iicdf_groupidx(cc, 4), 19934);
    av1_mvcdf_put2(av1_iicdf_groupidx(cc, 5), 22674);
    # Default_Compound_Idx_Cdf[6] — binary.
    av1_mvcdf_put2(av1_iicdf_compidx(cc, 0), 18244);
    av1_mvcdf_put2(av1_iicdf_compidx(cc, 1), 12865);
    av1_mvcdf_put2(av1_iicdf_compidx(cc, 2), 7053);
    av1_mvcdf_put2(av1_iicdf_compidx(cc, 3), 13259);
    av1_mvcdf_put2(av1_iicdf_compidx(cc, 4), 9334);
    av1_mvcdf_put2(av1_iicdf_compidx(cc, 5), 4644);
    # Default_Compound_Type_Cdf[22] — binary (used 3..9, 18..19; rest 16384).
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 0), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 1), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 2), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 3), 23431);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 4), 13171);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 5), 11470);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 6), 9770);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 7), 9100);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 8), 8233);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 9), 6172);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 10), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 11), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 12), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 13), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 14), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 15), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 16), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 17), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 18), 11820);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 19), 7701);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 20), 16384);
    av1_mvcdf_put2(av1_iicdf_comptype(cc, 21), 16384);
    return DR_OK;
}
fn av1_iicdf_new(): i64 {
    var cc = alloc(AV1IICDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_iicdf_fill(cc);
    return cc;
}
var AV1_IICDF_BLOB = 0;
fn av1_iicdf_blob(): i64 {
    if (AV1_IICDF_BLOB != 0) { return AV1_IICDF_BLOB; }
    var cc = alloc(AV1IICDF_SIZE * 8);
    if (cc == 0) { return 0; }
    av1_iicdf_fill(cc);
    AV1_IICDF_BLOB = cc;
    return cc;
}

# read_interintra (spec 5.11.28) — the @@interintra binary symbol (1 = blend the inter
# block with an intra predictor), CDF Inter_Intra[Size_Group[MiSize]-1].
fn av1_read_interintra(sd, cc, mi_size): i64 {
    var ctx = av1_size_group(mi_size) - 1;
    return av1_sym_read_symbol(sd, av1_iicdf_interintra(cc, ctx), 2);
}
fn av1_write_interintra(enc, cc, mi_size, interintra): i64 {
    var ctx = av1_size_group(mi_size) - 1;
    av1_sym_encode_symbol(enc, av1_iicdf_interintra(cc, ctx), 2, interintra);
    return DR_OK;
}

# the @@interintra_mode 4-symbol LEAF read (II_DC_PRED / II_V_PRED / II_H_PRED /
# II_SMOOTH_PRED), CDF Inter_Intra_Mode[Size_Group[MiSize]-1]. The `_sym` suffix keeps it
# distinct from av1_read_interintra_mode, the 5.11.28 DRIVER below that calls it — cyrius
# silently shadows duplicate fn names (last-def-wins), so the names must not collide.
fn av1_read_interintra_mode_sym(sd, cc, mi_size): i64 {
    var ctx = av1_size_group(mi_size) - 1;
    return av1_sym_read_symbol(sd, av1_iicdf_iimode(cc, ctx), AV1_INTERINTRA_MODES);
}
fn av1_write_interintra_mode_sym(enc, cc, mi_size, ii_mode): i64 {
    var ctx = av1_size_group(mi_size) - 1;
    av1_sym_encode_symbol(enc, av1_iicdf_iimode(cc, ctx), AV1_INTERINTRA_MODES, ii_mode);
    return DR_OK;
}

# read_wedge_interintra (spec 5.11.28) — the @@wedge_interintra binary symbol (1 = wedge
# blending, 0 = intra blending), CDF Wedge_Inter_Intra[MiSize].
fn av1_read_wedge_interintra(sd, cc, mi_size): i64 {
    return av1_sym_read_symbol(sd, av1_iicdf_wedgeii(cc, mi_size), 2);
}
fn av1_write_wedge_interintra(enc, cc, mi_size, wedge_ii): i64 {
    av1_sym_encode_symbol(enc, av1_iicdf_wedgeii(cc, mi_size), 2, wedge_ii);
    return DR_OK;
}

# read_wedge_index (spec 5.11.28 / 5.11.29) — the @@wedge_index 16-symbol (the wedge mask
# direction/offset), CDF Wedge_Index[MiSize]. Shared by interintra + compound_type wedge.
fn av1_read_wedge_index(sd, cc, mi_size): i64 {
    return av1_sym_read_symbol(sd, av1_iicdf_wedgeidx(cc, mi_size), AV1_WEDGE_TYPES);
}
fn av1_write_wedge_index(enc, cc, mi_size, wedge_idx): i64 {
    av1_sym_encode_symbol(enc, av1_iicdf_wedgeidx(cc, mi_size), AV1_WEDGE_TYPES, wedge_idx);
    return DR_OK;
}

# ================================================================
# THE COMPOUND-TYPE READ (spec 5.11.29 read_compound_type)
# ----------------------------------------------------------------
# How a compound block's two predictors are BLENDED. Unlike the leaf reads above this
# is the full spec driver: it composes three new symbols (@@comp_group_idx,
# @@compound_idx, @@compound_type) with the shared @@wedge_index (5.11.28, above) and
# two L(1) literals (@@wedge_sign, @@mask_type), and resolves compound_type across
# every branch — including the NON-compound branch, where compound_type falls out of
# read_interintra_mode's interintra / wedge_interintra with no symbol read at all.
#
# Caller inputs (all decoded upstream / frame-level): is_compound, skip_mode, MiSize,
# enable_masked_compound + enable_jnt_comp (sequence header), interintra +
# wedge_interintra (from read_interintra_mode), and the two neighbour-derived CDF
# contexts (spec 9: comp_group_idx ctx from CompGroupIdxs/AboveRefFrame + Min(5,..);
# compound_idx ctx from the order-hint distances + CompoundIdxs) — deferred as caller (roadmap.md)
# inputs exactly like the single-ref / compound-ref neighbour counts (0.7.68/0.7.69).
# ================================================================

# Wedge_Bits[MiSize] (spec 10) — the wedge-index bit count; 0 means the block size has
# no wedge codebook, which FORCES COMPOUND_DIFFWTD (no @@compound_type symbol is read).
var AV1_WEDGE_BITS_TBL = 0;
fn av1_wedge_bits_tbl(): i64 {
    if (AV1_WEDGE_BITS_TBL != 0) { return AV1_WEDGE_BITS_TBL; }
    var t = alloc(AV1_BLOCK_SIZES * 8);
    if (t == 0) { return 0; }
    # {0,0,0, 4,4,4,4,4,4,4, 0,0,0,0,0,0,0,0, 4,4, 0,0}
    store64(t + 0, 0);   store64(t + 8, 0);   store64(t + 16, 0);  store64(t + 24, 4);
    store64(t + 32, 4);  store64(t + 40, 4);  store64(t + 48, 4);  store64(t + 56, 4);
    store64(t + 64, 4);  store64(t + 72, 4);  store64(t + 80, 0);  store64(t + 88, 0);
    store64(t + 96, 0);  store64(t + 104, 0); store64(t + 112, 0); store64(t + 120, 0);
    store64(t + 128, 0); store64(t + 136, 0); store64(t + 144, 4); store64(t + 152, 4);
    store64(t + 160, 0); store64(t + 168, 0);
    AV1_WEDGE_BITS_TBL = t;
    return t;
}
fn av1_wedge_bits(mi_size): i64 { return load64(av1_wedge_bits_tbl() + (mi_size * 8)); }

# the read_compound_type output record.
fn av1_comptype_new(): i64 {
    var r = alloc(AV1CT_SIZE);
    if (r == 0) { return 0; }
    store64(r + AV1CT_TYPE, AV1_COMPOUND_AVERAGE);
    store64(r + AV1CT_GROUPIDX, 0);
    store64(r + AV1CT_COMPIDX, 1);
    store64(r + AV1CT_WEDGEIDX, 0);
    store64(r + AV1CT_WEDGESIGN, 0);
    store64(r + AV1CT_MASKTYPE, 0);
    return r;
}
fn av1_comptype_type(r): i64 { return load64(r + AV1CT_TYPE); }
fn av1_comptype_group_idx(r): i64 { return load64(r + AV1CT_GROUPIDX); }
fn av1_comptype_comp_idx(r): i64 { return load64(r + AV1CT_COMPIDX); }
fn av1_comptype_wedge_idx(r): i64 { return load64(r + AV1CT_WEDGEIDX); }
fn av1_comptype_wedge_sign(r): i64 { return load64(r + AV1CT_WEDGESIGN); }
fn av1_comptype_mask_type(r): i64 { return load64(r + AV1CT_MASKTYPE); }

# the three new leaf symbols.
fn av1_read_comp_group_idx(sd, cc, ctx): i64 {
    return av1_sym_read_symbol(sd, av1_iicdf_groupidx(cc, ctx), 2);
}
fn av1_write_comp_group_idx(enc, cc, ctx, v): i64 {
    av1_sym_encode_symbol(enc, av1_iicdf_groupidx(cc, ctx), 2, v);
    return DR_OK;
}
fn av1_read_compound_idx(sd, cc, ctx): i64 {
    return av1_sym_read_symbol(sd, av1_iicdf_compidx(cc, ctx), 2);
}
fn av1_write_compound_idx(enc, cc, ctx, v): i64 {
    av1_sym_encode_symbol(enc, av1_iicdf_compidx(cc, ctx), 2, v);
    return DR_OK;
}
# the @@compound_type symbol — COMPOUND_TYPES=2, and the symbol value IS the enum
# (COMPOUND_WEDGE=0 / COMPOUND_DIFFWTD=1), so no remap.
fn av1_read_compound_type_sym(sd, cc, mi_size): i64 {
    return av1_sym_read_symbol(sd, av1_iicdf_comptype(cc, mi_size), AV1_COMPOUND_TYPES);
}
fn av1_write_compound_type_sym(enc, cc, mi_size, v): i64 {
    av1_sym_encode_symbol(enc, av1_iicdf_comptype(cc, mi_size), AV1_COMPOUND_TYPES, v);
    return DR_OK;
}

# read_compound_type (spec 5.11.29) — fills `out` (an av1_comptype_new record) with
# compound_type + the syntax elements it implies. Returns DR_OK.
fn av1_read_compound_type(sd, cc, out, is_compound, skip_mode, mi_size, en_masked, en_jnt,
interintra, wedge_ii, group_ctx, comp_ctx): i64 {
    store64(out + AV1CT_GROUPIDX, 0);            # comp_group_idx = 0
    store64(out + AV1CT_COMPIDX, 1);             # compound_idx = 1
    store64(out + AV1CT_WEDGEIDX, 0);
    store64(out + AV1CT_WEDGESIGN, 0);
    store64(out + AV1CT_MASKTYPE, 0);
    if (skip_mode != 0) {
        store64(out + AV1CT_TYPE, AV1_COMPOUND_AVERAGE);
        return DR_OK;
    }
    if (is_compound == 0) {
        # no symbol is read: compound_type falls out of the interintra decision.
        store64(out + AV1CT_TYPE, AV1_COMPOUND_AVERAGE);
        if (interintra != 0) {
            store64(out + AV1CT_TYPE, AV1_COMPOUND_INTRA);
            if (wedge_ii != 0) { store64(out + AV1CT_TYPE, AV1_COMPOUND_WEDGE); }
        }
        return DR_OK;
    }
    var n = av1_wedge_bits(mi_size);
    if (en_masked != 0) {
        store64(out + AV1CT_GROUPIDX, av1_read_comp_group_idx(sd, cc, group_ctx));
    }
    if (load64(out + AV1CT_GROUPIDX) == 0) {
        store64(out + AV1CT_TYPE, AV1_COMPOUND_AVERAGE);
        if (en_jnt != 0) {
            var ci = av1_read_compound_idx(sd, cc, comp_ctx);
            store64(out + AV1CT_COMPIDX, ci);
            if (ci == 0) { store64(out + AV1CT_TYPE, AV1_COMPOUND_DISTANCE); }
        }
    } else {
        store64(out + AV1CT_TYPE, AV1_COMPOUND_DIFFWTD);
        if (n != 0) {
            store64(out + AV1CT_TYPE, av1_read_compound_type_sym(sd, cc, mi_size));
        }
    }
    # the two branches below are DISJOINT (compound_type is one value).
    if (load64(out + AV1CT_TYPE) == AV1_COMPOUND_WEDGE) {
        store64(out + AV1CT_WEDGEIDX, av1_read_wedge_index(sd, cc, mi_size));
        store64(out + AV1CT_WEDGESIGN, av1_sym_read_literal(sd, 1));
    }
    if (load64(out + AV1CT_TYPE) == AV1_COMPOUND_DIFFWTD) {
        store64(out + AV1CT_MASKTYPE, av1_sym_read_literal(sd, 1));
    }
    return DR_OK;
}

# write_compound_type — the encoder inverse: emits exactly the symbols read_compound_type
# would consume, in the same order, driven by the values already in `out`.
fn av1_write_compound_type(enc, cc, out, is_compound, skip_mode, mi_size, en_masked, en_jnt,
interintra, wedge_ii, group_ctx, comp_ctx): i64 {
    if (skip_mode != 0) { return DR_OK; }        # nothing is coded
    if (is_compound == 0) { return DR_OK; }      # nothing is coded
    var n = av1_wedge_bits(mi_size);
    if (en_masked != 0) {
        av1_write_comp_group_idx(enc, cc, group_ctx, load64(out + AV1CT_GROUPIDX));
    }
    if (load64(out + AV1CT_GROUPIDX) == 0) {
        if (en_jnt != 0) {
            av1_write_compound_idx(enc, cc, comp_ctx, load64(out + AV1CT_COMPIDX));
        }
    } else {
        if (n != 0) {
            av1_write_compound_type_sym(enc, cc, mi_size, load64(out + AV1CT_TYPE));
        }
    }
    if (load64(out + AV1CT_TYPE) == AV1_COMPOUND_WEDGE) {
        av1_write_wedge_index(enc, cc, mi_size, load64(out + AV1CT_WEDGEIDX));
        av1_sym_encode_literal(enc, load64(out + AV1CT_WEDGESIGN), 1);
    }
    if (load64(out + AV1CT_TYPE) == AV1_COMPOUND_DIFFWTD) {
        av1_sym_encode_literal(enc, load64(out + AV1CT_MASKTYPE), 1);
    }
    return DR_OK;
}

# ================================================================
# THE GATING ORCHESTRATORS (spec 5.11.28 read_interintra_mode + the 5.11.23 interp_filter
# tail). 0.7.71/0.7.72 landed these symbols' LEAF reads and left the gating that decides
# whether each is coded "the caller's concern"; this is that caller.
# ================================================================

# The read_interintra_mode output record. RefFrame[1] / AngleDelta* / use_filter_intra are
# the block-level side-effects the spec assigns inside the interintra branch — surfaced
# here rather than written through, since this layer owns no block record yet.
enum Av1InterIntraRec {
    AV1II_INTERINTRA = 0;    # interintra
    AV1II_MODE       = 8;    # interintra_mode (valid when interintra)
    AV1II_WEDGE      = 16;   # wedge_interintra (valid when interintra)
    AV1II_WEDGEIDX   = 24;   # wedge_index     (valid when interintra && wedge_interintra)
    AV1II_WEDGESIGN  = 32;   # wedge_sign — the spec forces 0 on this path
    AV1II_SETREF1    = 40;   # 1 = the caller must set RefFrame[1] = INTRA_FRAME,
    #     AngleDeltaY = AngleDeltaUV = 0, use_filter_intra = 0
    AV1II_SIZE       = 48;
}
fn av1_interintra_new(): i64 {
    var r = alloc(AV1II_SIZE);
    if (r == 0) { return 0; }
    memset(r, 0, AV1II_SIZE);
    return r;
}
fn av1_interintra_on(r): i64 { return load64(r + AV1II_INTERINTRA); }
fn av1_interintra_mode(r): i64 { return load64(r + AV1II_MODE); }
fn av1_interintra_wedge(r): i64 { return load64(r + AV1II_WEDGE); }
fn av1_interintra_wedge_idx(r): i64 { return load64(r + AV1II_WEDGEIDX); }
fn av1_interintra_wedge_sign(r): i64 { return load64(r + AV1II_WEDGESIGN); }
fn av1_interintra_set_ref1(r): i64 { return load64(r + AV1II_SETREF1); }

# read_interintra_mode (spec 5.11.28) — the full function. The gate is
# !skip_mode && enable_interintra_compound && !isCompound && BLOCK_8X8 <= MiSize <= BLOCK_32X32;
# everything outside it leaves interintra = 0 and reads NOTHING.
fn av1_read_interintra_mode(sd, cc, out, is_compound, skip_mode, mi_size, en_interintra): i64 {
    if (out == 0) { return DR_ERR_BOUNDS; }
    memset(out, 0, AV1II_SIZE);
    if (skip_mode != 0) { return DR_OK; }
    if (en_interintra == 0) { return DR_OK; }
    if (is_compound != 0) { return DR_OK; }
    if (mi_size < AV1_BLOCK_8X8 || mi_size > AV1_BLOCK_32X32) { return DR_OK; }
    var ii = av1_read_interintra(sd, cc, mi_size);
    store64(out + AV1II_INTERINTRA, ii);
    if (ii == 0) { return DR_OK; }
    store64(out + AV1II_MODE, av1_read_interintra_mode_sym(sd, cc, mi_size));
    # the spec's side-effects: RefFrame[1] = INTRA_FRAME, AngleDeltaY/UV = 0,
    # use_filter_intra = 0. Flagged for the caller that owns the block record.
    store64(out + AV1II_SETREF1, 1);
    var w = av1_read_wedge_interintra(sd, cc, mi_size);
    store64(out + AV1II_WEDGE, w);
    if (w != 0) {
        store64(out + AV1II_WEDGEIDX, av1_read_wedge_index(sd, cc, mi_size));
        store64(out + AV1II_WEDGESIGN, 0);      # the spec forces wedge_sign = 0 here
    }
    return DR_OK;
}
# the encoder inverse — emits exactly the symbols the reader consumes, in order.
fn av1_write_interintra_mode(enc, cc, out, is_compound, skip_mode, mi_size, en_interintra): i64 {
    if (skip_mode != 0) { return DR_OK; }
    if (en_interintra == 0) { return DR_OK; }
    if (is_compound != 0) { return DR_OK; }
    if (mi_size < AV1_BLOCK_8X8 || mi_size > AV1_BLOCK_32X32) { return DR_OK; }
    var ii = load64(out + AV1II_INTERINTRA);
    av1_write_interintra(enc, cc, mi_size, ii);
    if (ii == 0) { return DR_OK; }
    av1_write_interintra_mode_sym(enc, cc, mi_size, load64(out + AV1II_MODE));
    var w = load64(out + AV1II_WEDGE);
    av1_write_wedge_interintra(enc, cc, mi_size, w);
    if (w != 0) { av1_write_wedge_index(enc, cc, mi_size, load64(out + AV1II_WEDGEIDX)); }
    return DR_OK;
}

# needs_interp_filter (spec 5.11.23) — whether interp_filter[dir] is actually coded.
# GLOBAL(_GLOBAL)MV on a large block only needs a filter when the global model is a plain
# TRANSLATION; a warp model carries its own filtering. gm0/gm1 are GmType[RefFrame[0..1]].
fn av1_needs_interp_filter(skip_mode, motion_mode, mi_size, y_mode, gm0, gm1): i64 {
    if (skip_mode != 0) { return 0; }
    if (motion_mode == AV1_MM_LOCALWARP) { return 0; }
    var large = av1_min(av1_block_width(mi_size), av1_block_height(mi_size)) >= 8;
    if (large != 0) {
        if (y_mode == AV1_GLOBALMV) { return gm0 == AV1_GM_TRANSLATION; }
        if (y_mode == AV1_GLOBAL_GLOBALMV) {
            return (gm0 == AV1_GM_TRANSLATION) || (gm1 == AV1_GM_TRANSLATION);
        }
    }
    return 1;
}

# read_interp_filters (spec 5.11.23 tail) — the per-direction loop. Fills out[0..1].
#   interpolation_filter != SWITCHABLE -> both dirs take it, nothing is coded.
#   SWITCHABLE -> code (enable_dual_filter ? 2 : 1) dirs, each gated by needs_interp_filter;
#                 an ungated dir is EIGHTTAP, and without dual filter dir 1 mirrors dir 0.
fn av1_read_interp_filters(sd, cc, out, interp_filter_fh, en_dual, ctx0, ctx1,
skip_mode, motion_mode, mi_size, y_mode, gm0, gm1): i64 {
    if (out == 0) { return DR_ERR_BOUNDS; }
    if (interp_filter_fh != AV1_INTERP_SWITCHABLE) {
        store64(out + 0, interp_filter_fh);
        store64(out + 8, interp_filter_fh);
        return DR_OK;
    }
    var ndirs = 1;
    if (en_dual != 0) { ndirs = 2; }
    var needs = av1_needs_interp_filter(skip_mode, motion_mode, mi_size, y_mode, gm0, gm1);
    var dir = 0;
    while (dir < ndirs) {
        var ctx = ctx0;
        if (dir != 0) { ctx = ctx1; }
        var v = AV1_EIGHTTAP;
        if (needs != 0) { v = av1_read_interp_filter(sd, cc, ctx); }
        store64(out + (dir * 8), v);
        dir = dir + 1;
    }
    if (en_dual == 0) { store64(out + 8, load64(out + 0)); }
    return DR_OK;
}
fn av1_write_interp_filters(enc, cc, out, interp_filter_fh, en_dual, ctx0, ctx1,
skip_mode, motion_mode, mi_size, y_mode, gm0, gm1): i64 {
    if (interp_filter_fh != AV1_INTERP_SWITCHABLE) { return DR_OK; }   # nothing is coded
    if (av1_needs_interp_filter(skip_mode, motion_mode, mi_size, y_mode, gm0, gm1) == 0) {
        return DR_OK;                                                   # every dir is EIGHTTAP
    }
    var ndirs = 1;
    if (en_dual != 0) { ndirs = 2; }
    var dir = 0;
    while (dir < ndirs) {
        var ctx = ctx0;
        if (dir != 0) { ctx = ctx1; }
        av1_write_interp_filter(enc, cc, ctx, load64(out + (dir * 8)));
        dir = dir + 1;
    }
    return DR_OK;
}

# ================================================================
# read_motion_mode (spec 5.11.27) — the full gating DRIVER over the 0.7.71 leaf reads
# (av1_read_motion_mode_sym / av1_read_use_obmc) and the 0.7.79 warp-sample leaves
# (av1_has_overlappable_candidates / av1_find_warp_samples, av1_mv.cyr). The gate:
#   skip_mode / !is_motion_mode_switchable / min(w,h) < 8             -> SIMPLE, no symbol
#   GLOBALMV-family block whose global model is beyond TRANSLATION
#     (only tested when !force_integer_mv)                            -> SIMPLE, no symbol
#   compound / inter-intra (RefFrame[1] == INTRA_FRAME) / no
#     overlappable inter neighbour                                    -> SIMPLE, no symbol
#   then find_warp_samples() runs (NumSamples also feeds warp_estimation later), and
#   force_integer_mv || NumSamples == 0 || !allow_warped_motion ||
#     is_scaled(RefFrame[0])                                          -> @@use_obmc
#   else                                                              -> @@motion_mode
# ctx is the block's Av1MvCtx (grid + tile + mi_row/col/size + refs) exactly as
# configured for find_mv_stack; MiSize is read from it so the gate and the warp scan
# share one geometry. ws is the caller-owned Av1WarpSamples record — zeroed here, filled
# only when the gate reaches find_warp_samples (safe: warp_estimation only runs for
# LOCALWARP, which is only decodable after find_warp_samples ran). mv_row/mv_col are the
# block's Mv[0] (assign_mv's output). ref1 / is_compound are the CURRENT RefFrame[1] /
# isCompound — post-interintra, since 5.11.28 may have set RefFrame[1] = INTRA_FRAME.
# out[0] <- motion_mode (SIMPLE / OBMC / LOCALWARP).
# ================================================================
fn av1_read_motion_mode(sd, cc, out, ctx, ws, fh, refs, skip_mode, y_mode, ref0, ref1,
is_compound, mv_row, mv_col): i64 {
    if ((out == 0) || (ws == 0)) { return DR_ERR_BOUNDS; }
    store64(out + 0, AV1_MM_SIMPLE);
    memset(ws, 0, AV1WS_SIZE);
    # hostile guards (not part of the spec gate; no symbol is consumed before them):
    # ref0 indexes GmType[ref-1] and ref_frame_idx[ref-1], mi_size the 22-entry tables.
    if ((ref0 < AV1_LAST_FRAME) || (ref0 > AV1_ALTREF_FRAME)) { return DR_ERR_BOUNDS; }
    var mi_size = load64(ctx + AV1MVC_MI_SIZE);
    if ((mi_size < 0) || (mi_size >= AV1_BLOCK_SIZES)) { return DR_ERR_BOUNDS; }
    if (skip_mode != 0) { return DR_OK; }
    if (av1_fh_is_motion_mode_switchable(fh) == 0) { return DR_OK; }
    if (av1_min(av1_block_width(mi_size), av1_block_height(mi_size)) < 8) { return DR_OK; }
    if (av1_fh_force_integer_mv(fh) == 0) {
        if ((y_mode == AV1_GLOBALMV) || (y_mode == AV1_GLOBAL_GLOBALMV)) {
            if (av1_fh_gm_type(fh, ref0) > AV1_GM_TRANSLATION) { return DR_OK; }
        }
    }
    if ((is_compound != 0) || (ref1 == AV1_INTRA_FRAME)) { return DR_OK; }
    if (av1_has_overlappable_candidates(ctx) == 0) { return DR_OK; }
    var e = av1_find_warp_samples(ctx, ws, mv_row, mv_col);
    if (e != DR_OK) { return e; }
    if ((av1_fh_force_integer_mv(fh) != 0) || (av1_warp_num(ws) == 0)
    || (av1_fh_allow_warped_motion(fh) == 0) || (av1_is_scaled(fh, refs, ref0) != 0)) {
        var mm = AV1_MM_SIMPLE;
        if (av1_read_use_obmc(sd, cc, mi_size) != 0) { mm = AV1_MM_OBMC; }
        store64(out + 0, mm);
        return DR_OK;
    }
    store64(out + 0, av1_read_motion_mode_sym(sd, cc, mi_size));
    return DR_OK;
}
# the encoder inverse — replays the gate and emits exactly the symbol (if any) the
# reader consumes: @@use_obmc on the warp-disabled branch (use_obmc = motion_mode ==
# OBMC; LOCALWARP is not representable there), @@motion_mode on the warp-allowed one.
fn av1_write_motion_mode(enc, cc, ctx, ws, fh, refs, skip_mode, y_mode, ref0, ref1,
is_compound, mv_row, mv_col, motion_mode): i64 {
    if (ws == 0) { return DR_ERR_BOUNDS; }
    memset(ws, 0, AV1WS_SIZE);
    if ((ref0 < AV1_LAST_FRAME) || (ref0 > AV1_ALTREF_FRAME)) { return DR_ERR_BOUNDS; }
    var mi_size = load64(ctx + AV1MVC_MI_SIZE);
    if ((mi_size < 0) || (mi_size >= AV1_BLOCK_SIZES)) { return DR_ERR_BOUNDS; }
    if (skip_mode != 0) { return DR_OK; }
    if (av1_fh_is_motion_mode_switchable(fh) == 0) { return DR_OK; }
    if (av1_min(av1_block_width(mi_size), av1_block_height(mi_size)) < 8) { return DR_OK; }
    if (av1_fh_force_integer_mv(fh) == 0) {
        if ((y_mode == AV1_GLOBALMV) || (y_mode == AV1_GLOBAL_GLOBALMV)) {
            if (av1_fh_gm_type(fh, ref0) > AV1_GM_TRANSLATION) { return DR_OK; }
        }
    }
    if ((is_compound != 0) || (ref1 == AV1_INTRA_FRAME)) { return DR_OK; }
    if (av1_has_overlappable_candidates(ctx) == 0) { return DR_OK; }
    var e = av1_find_warp_samples(ctx, ws, mv_row, mv_col);
    if (e != DR_OK) { return e; }
    if ((av1_fh_force_integer_mv(fh) != 0) || (av1_warp_num(ws) == 0)
    || (av1_fh_allow_warped_motion(fh) == 0) || (av1_is_scaled(fh, refs, ref0) != 0)) {
        av1_write_use_obmc(enc, cc, mi_size, motion_mode == AV1_MM_OBMC);
        return DR_OK;
    }
    av1_write_motion_mode_sym(enc, cc, mi_size, motion_mode);
    return DR_OK;
}

# ================================================================
# read_ref_frames (spec 5.11.25) — the DISPATCHER over the reference reads. Three
# no-symbol paths: skip_mode takes the frame header's SkipModeFrame pair (5.9.23);
# an active SEG_LVL_REF_FRAME feature takes its (parse-clipped, 5.9.14) FeatureData
# ref + NONE; an active SEG_LVL_SKIP or SEG_LVL_GLOBALMV forces LAST + NONE. Otherwise
# @@comp_mode is read only when reference_select && min(bw4, bh4) >= 2 (else forced
# SINGLE), then the compound (0.7.69) or single (0.7.68) tree runs with every CDF
# context derived from the neighbour record (0.7.75/0.7.76). `nb` is the block's
# Av1NbCtx exactly as set up by av1_nbctx_setup for the 5.11.15 preamble; segment_id
# is the block's decoded segment id. out_ref[0..1] <- RefFrame.
# ================================================================
# persistent ctx scratch (refctx[6] fits inside AV1CCTX_SIZE) — lazily allocated ONCE;
# a per-call arena alloc in a per-block path would grow without bound (the 0.7.60 lesson).
var AV1RRF_SCRATCH = 0;
fn av1_rrf_scratch(): i64 {
    if (AV1RRF_SCRATCH != 0) { return AV1RRF_SCRATCH; }
    AV1RRF_SCRATCH = alloc(AV1CCTX_SIZE);
    return AV1RRF_SCRATCH;
}
fn av1_read_ref_frames(sd, cc, out_ref, nb, fh, skip_mode, segment_id, mi_size): i64 {
    if (out_ref == 0) { return DR_ERR_BOUNDS; }
    # the spec's two fixed-assignment paths both land on LAST + NONE for RefFrame[1];
    # store the LAST + NONE default up front so every no-read path is covered.
    store64(out_ref + 0, AV1_LAST_FRAME);
    store64(out_ref + 8, AV1_REF_NONE);
    # hostile guards (no symbol is consumed before them): segment_id indexes the
    # 8x8 FeatureEnabled/FeatureData tables, mi_size the 22-entry Num_4x4 tables.
    if ((segment_id < 0) || (segment_id >= AV1_MAX_SEGMENTS)) { return DR_ERR_BOUNDS; }
    if ((mi_size < 0) || (mi_size >= AV1_BLOCK_SIZES)) { return DR_ERR_BOUNDS; }
    if (skip_mode != 0) {
        store64(out_ref + 0, av1_fh_skip_mode_frame(fh, 0));
        store64(out_ref + 8, av1_fh_skip_mode_frame(fh, 1));
        return DR_OK;
    }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != 0) {
        store64(out_ref + 0, av1_fh_feature_data(fh, segment_id, AV1_SEG_LVL_REF_FRAME));
        return DR_OK;
    }
    if ((av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_SKIP) != 0)
    || (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0)) {
        return DR_OK;      # LAST + NONE (stored above)
    }
    var comp_mode = AV1_SINGLE_REFERENCE;
    if (av1_fh_reference_select(fh) != 0) {
        if (av1_min(av1_num_4x4_w(mi_size), av1_num_4x4_h(mi_size)) >= 2) {
            comp_mode = av1_read_comp_mode(sd, cc, av1_comp_mode_ctx(nb));
        }
    }
    var scr = av1_rrf_scratch();
    if (scr == 0) { return DR_ERR_OOM; }
    if (comp_mode == AV1_COMPOUND_REFERENCE) {
        av1_comp_ref_ctxs(nb, scr);
        return av1_read_compound_ref(sd, cc, scr, out_ref);
    }
    av1_single_ref_ctxs(nb, scr);
    av1_read_single_ref(sd, cc, scr, out_ref);
    return DR_OK;
}
# the encoder inverse — replays the dispatch and emits exactly the symbols the reader
# consumes: NOTHING on the skip_mode / segmentation paths (the pair is implied by frame
# state), else comp_mode (when gated on) + the matching tree. A compound pair is
# UNREPRESENTABLE when the comp_mode gate is closed (the reader forces SINGLE and parses
# the single tree) — that precondition violation is surfaced as DR_ERR_BOUNDS rather than
# silently emitting a stream the reader cannot parse.
fn av1_write_ref_frames(enc, cc, nb, fh, skip_mode, segment_id, mi_size, r0, r1): i64 {
    if ((segment_id < 0) || (segment_id >= AV1_MAX_SEGMENTS)) { return DR_ERR_BOUNDS; }
    if ((mi_size < 0) || (mi_size >= AV1_BLOCK_SIZES)) { return DR_ERR_BOUNDS; }
    if (skip_mode != 0) { return DR_OK; }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != 0) { return DR_OK; }
    if ((av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_SKIP) != 0)
    || (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0)) {
        return DR_OK;
    }
    var is_comp = AV1_SINGLE_REFERENCE;
    if (r1 > AV1_INTRA_FRAME) { is_comp = AV1_COMPOUND_REFERENCE; }
    var gate_open = 0;
    if (av1_fh_reference_select(fh) != 0) {
        if (av1_min(av1_num_4x4_w(mi_size), av1_num_4x4_h(mi_size)) >= 2) { gate_open = 1; }
    }
    if ((gate_open == 0) && (is_comp == AV1_COMPOUND_REFERENCE)) { return DR_ERR_BOUNDS; }
    if (gate_open != 0) {
        av1_write_comp_mode(enc, cc, av1_comp_mode_ctx(nb), is_comp);
    }
    var scr = av1_rrf_scratch();
    if (scr == 0) { return DR_ERR_OOM; }
    if (is_comp == AV1_COMPOUND_REFERENCE) {
        av1_comp_ref_ctxs(nb, scr);
        return av1_write_compound_ref(enc, cc, scr, r0, r1);
    }
    av1_single_ref_ctxs(nb, scr);
    return av1_write_single_ref(enc, cc, scr, r0);
}

# ================================================================
# inter_block_mode_info (spec 5.11.23) — THE INTER MODE-INFO ORCHESTRATOR. Pure
# composition, in the spec's exact read order:
#   read_ref_frames (5.11.25, 0.7.81) -> isCompound -> find_mv_stack (7.10.2, 0.7.65)
#   -> YMode (skip_mode NEAREST_NEARESTMV / seg SKIP|GLOBALMV fixed GLOBALMV /
#      @@compound_mode 0.7.70 / @@new_mv-@@zero_mv-@@ref_mv 0.7.67)
#   -> the DRL loops (read_drl_idx 0.7.67/0.7.70) -> assign_mv (5.11.32, 0.7.67/0.7.70)
#   -> read_interintra_mode (5.11.28, 0.7.78; may set RefFrame[1] = INTRA_FRAME)
#   -> read_motion_mode (5.11.27, 0.7.80; sees the POST-interintra RefFrame[1])
#   -> read_compound_type (5.11.29, 0.7.73) -> the interp-filter tail (0.7.78).
# `ctx` is the block's Av1MvCtx with grid/tile/block/precision configured by the caller;
# the REFS and GLOBAL-MV candidates are set HERE (they depend on the decoded refs).
# `nb` is the caller's Av1NbCtx (the 5.11.15 preamble). `ws` is caller-owned warp
# samples. fwd_eq_bck is the frame-level order-hint state compound_idx's ctx needs
# (0.7.77). PaletteSizeY/UV = 0 is intra-layer state (palette is roadmap-deferred) —
# nothing to store here. out is an Av1InterBlock.
# ================================================================
enum Av1InterBlockOff {
    AV1IB_REF0       = 0;     # RefFrame[0] (LAST..ALTREF)
    AV1IB_REF1       = 8;     # RefFrame[1] — POST-interintra (INTRA_FRAME if 5.11.28 fired)
    AV1IB_ISCOMP     = 16;    # isCompound (from the PRE-interintra pair, as the spec's local)
    AV1IB_YMODE      = 24;    # YMode (spec numbering, 14..25 inter)
    AV1IB_REFMVIDX   = 32;    # RefMvIdx
    AV1IB_MV0        = 40;    # Mv[0], an Av1Mv (row, col) — 16 bytes
    AV1IB_MV1        = 56;    # Mv[1] (compound only)      — 16 bytes
    AV1IB_MOTIONMODE = 72;    # motion_mode (SIMPLE / OBMC / LOCALWARP)
    AV1IB_INTERP     = 80;    # interp_filter[0..1]        — 16 bytes
    AV1IB_II         = 96;    # embedded Av1InterIntraRec  (AV1II_SIZE = 48)
    AV1IB_CT         = 144;   # embedded compound-type rec (AV1CT_SIZE = 48)
    AV1IB_SIZE       = 192;
}
fn av1_interblock_new(): i64 {
    var b = alloc(AV1IB_SIZE);
    if (b == 0) { return 0; }
    memset(b, 0, AV1IB_SIZE);
    return b;
}
fn av1_ib_ref(b, i): i64 { return load64(b + AV1IB_REF0 + (i * 8)); }
fn av1_ib_is_comp(b): i64 { return load64(b + AV1IB_ISCOMP); }
fn av1_ib_ymode(b): i64 { return load64(b + AV1IB_YMODE); }
fn av1_ib_ref_mv_idx(b): i64 { return load64(b + AV1IB_REFMVIDX); }
fn av1_ib_mv(b, list): i64 { return b + AV1IB_MV0 + (list * 16); }
fn av1_ib_motion_mode(b): i64 { return load64(b + AV1IB_MOTIONMODE); }
fn av1_ib_interp(b, dir): i64 { return load64(b + AV1IB_INTERP + (dir * 8)); }
fn av1_ib_ii(b): i64 { return b + AV1IB_II; }
fn av1_ib_ct(b): i64 { return b + AV1IB_CT; }

# persistent global-MV scratch (two Av1Mv records) — same no-arena-growth rule as
# av1_rrf_scratch.
var AV1IBMI_SCRATCH = 0;
fn av1_ibmi_scratch(): i64 {
    if (AV1IBMI_SCRATCH != 0) { return AV1IBMI_SCRATCH; }
    AV1IBMI_SCRATCH = alloc(32);
    return AV1IBMI_SCRATCH;
}
fn av1_inter_block_mode_info(sd, cc_ref, cc_im, cc_ii, cc_mv, out, ctx, nb, ws, fh, refs, s,
skip_mode, segment_id, fwd_eq_bck): i64 {
    if ((out == 0) || (ctx == 0) || (ws == 0)) { return DR_ERR_BOUNDS; }
    memset(out, 0, AV1IB_SIZE);
    var mi_size = load64(ctx + AV1MVC_MI_SIZE);
    var e = av1_read_ref_frames(sd, cc_ref, out + AV1IB_REF0, nb, fh, skip_mode, segment_id, mi_size);
    if (e != DR_OK) { return e; }
    var ref0 = load64(out + AV1IB_REF0);
    var ref1 = load64(out + AV1IB_REF1);
    # an inter block's RefFrame[0] is always a real reference; a hostile seg REF_FRAME
    # datum of 0 (INTRA) belongs to the INTRA path (5.11.15 derives is_inter = 0 from
    # it), so reaching here with it is a caller/stream violation — reject, sticky.
    if ((ref0 < AV1_LAST_FRAME) || (ref0 > AV1_ALTREF_FRAME)) { return DR_ERR_BOUNDS; }
    var is_comp = 0;
    if (ref1 > AV1_INTRA_FRAME) { is_comp = 1; }
    store64(out + AV1IB_ISCOMP, is_comp);
    # the block's refs + the global-motion candidates feed the scans (both depend on
    # the refs just decoded — which is why the ORCHESTRATOR sets them, not the caller).
    av1_mvctx_set_refs(ctx, ref0, ref1);
    var gm = av1_ibmi_scratch();
    if (gm == 0) { return DR_ERR_OOM; }
    var mi_row = load64(ctx + AV1MVC_MI_ROW);
    var mi_col = load64(ctx + AV1MVC_MI_COL);
    av1_setup_global_mv(gm, fh, ref0, mi_col, mi_row, mi_size);
    var gt0 = av1_fh_gm_type(fh, ref0);
    var g1r = 0;
    var g1c = 0;
    var gt1 = 0;
    if (ref1 >= AV1_LAST_FRAME) {
        av1_setup_global_mv(gm + 16, fh, ref1, mi_col, mi_row, mi_size);
        g1r = load64(gm + 16 + AV1MV_ROW);
        g1c = load64(gm + 16 + AV1MV_COL);
        gt1 = av1_fh_gm_type(fh, ref1);
    }
    av1_mvctx_set_global(ctx, load64(gm + AV1MV_ROW), load64(gm + AV1MV_COL), g1r, g1c, gt0, gt1);
    av1_find_mv_stack(ctx, is_comp);
    # YMode: two fixed paths, then the compound/single symbol trees.
    var y_mode = AV1_NEAREST_NEARESTMV;
    var mode_done = 0;
    if (skip_mode != 0) { mode_done = 1; }
    if (mode_done == 0) {
        if ((av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_SKIP) != 0)
        || (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0)) {
            y_mode = AV1_GLOBALMV;
            mode_done = 1;
        }
    }
    if (mode_done == 0) {
        if (is_comp != 0) {
            y_mode = av1_read_compound_mode(sd, cc_im, ctx);
        } else {
            y_mode = av1_read_inter_mode(sd, cc_im, ctx);
        }
    }
    store64(out + AV1IB_YMODE, y_mode);
    var ref_mv_idx = av1_read_drl_idx(sd, cc_im, ctx, y_mode);
    store64(out + AV1IB_REFMVIDX, ref_mv_idx);
    var allow_hp = av1_fh_allow_high_precision_mv(fh);
    var force_int = av1_fh_force_integer_mv(fh);
    if (is_comp != 0) {
        av1_assign_mv_compound(sd, cc_mv, ctx, y_mode, ref_mv_idx, 0, allow_hp, force_int,
        out + AV1IB_MV0, out + AV1IB_MV1);
    } else {
        av1_assign_mv_single(sd, cc_mv, ctx, y_mode, ref_mv_idx, 0, allow_hp, force_int,
        out + AV1IB_MV0);
    }
    av1_read_interintra_mode(sd, cc_ii, out + AV1IB_II, is_comp, skip_mode, mi_size,
    av1_seq_enable_interintra_compound(s));
    if (av1_interintra_set_ref1(out + AV1IB_II) != 0) {
        ref1 = AV1_INTRA_FRAME;                # the 5.11.28 side-effect, applied HERE
        store64(out + AV1IB_REF1, AV1_INTRA_FRAME);
    }
    var e2 = av1_read_motion_mode(sd, cc_im, out + AV1IB_MOTIONMODE, ctx, ws, fh, refs,
    skip_mode, y_mode, ref0, ref1, is_comp,
    load64(out + AV1IB_MV0 + AV1MV_ROW), load64(out + AV1IB_MV0 + AV1MV_COL));
    if (e2 != DR_OK) { return e2; }
    av1_read_compound_type(sd, cc_ii, out + AV1IB_CT, is_comp, skip_mode, mi_size,
    av1_seq_enable_masked_compound(s), av1_seq_enable_jnt_comp(s),
    av1_interintra_on(out + AV1IB_II), av1_interintra_wedge(out + AV1IB_II),
    av1_comp_group_idx_ctx(nb), av1_compound_idx_ctx(nb, fwd_eq_bck));
    # the interp-filter tail: GmType[RefFrame[1]] is only consulted for
    # GLOBAL_GLOBALMV (compound), but guard the post-interintra INTRA_FRAME anyway.
    var gt1n = 0;
    if (ref1 >= AV1_LAST_FRAME) { gt1n = av1_fh_gm_type(fh, ref1); }
    av1_read_interp_filters(sd, cc_im, out + AV1IB_INTERP, av1_fh_interpolation_filter(fh),
    av1_seq_enable_dual_filter(s), av1_interp_filter_ctx(nb, 0, ref0, ref1),
    av1_interp_filter_ctx(nb, 1, ref0, ref1), skip_mode, load64(out + AV1IB_MOTIONMODE),
    mi_size, y_mode, gt0, gt1n);
    return DR_OK;
}

# assign_mv encoder inverses — mirror av1_assign_mv_list's predictor derivation and
# emit the NEWMV difference (everything else codes nothing; the mv must equal its
# predictor, which is the round-trip's invariant, not re-checked here).
fn av1_write_assign_mv_list(enc, mvcc, mvctx, comp_mode, ref_mv_idx, ref_list, mv_ctx,
allow_hp, force_int, mv): i64 {
    if (comp_mode != AV1_NEWMV) { return DR_OK; }
    var mvs = load64(mvctx + AV1MVC_STACK);
    var num = av1_mv_stack_num(mvs);
    var pos = ref_mv_idx;
    if (num <= 1) { pos = 0; }
    var pred_row = av1_mv_stack_row(mvs, pos, ref_list);
    var pred_col = av1_mv_stack_col(mvs, pos, ref_list);
    av1_write_mv(enc, mvcc, mv_ctx, allow_hp, force_int,
    load64(mv + AV1MV_ROW) - pred_row, load64(mv + AV1MV_COL) - pred_col);
    return DR_OK;
}
fn av1_write_assign_mv_single(enc, mvcc, mvctx, y_mode, ref_mv_idx, mv_ctx, allow_hp,
force_int, mv): i64 {
    return av1_write_assign_mv_list(enc, mvcc, mvctx, av1_get_mode(y_mode, 0), ref_mv_idx,
    0, mv_ctx, allow_hp, force_int, mv);
}
fn av1_write_assign_mv_compound(enc, mvcc, mvctx, y_mode, ref_mv_idx, mv_ctx, allow_hp,
force_int, mv0, mv1): i64 {
    av1_write_assign_mv_list(enc, mvcc, mvctx, av1_get_mode(y_mode, 0), ref_mv_idx, 0,
    mv_ctx, allow_hp, force_int, mv0);
    av1_write_assign_mv_list(enc, mvcc, mvctx, av1_get_mode(y_mode, 1), ref_mv_idx, 1,
    mv_ctx, allow_hp, force_int, mv1);
    return DR_OK;
}
# the 5.11.23 encoder inverse — replays the whole orchestration on the SAME ctx/nb/ws
# and emits exactly the symbols the reader consumes. `blk` carries the SOURCE values
# with REF1 as the PRE-interintra pair (NONE for a single-ref interintra block — the
# writer applies the 5.11.28 side-effect internally for the later steps, exactly as
# the reader does).
fn av1_write_inter_block_mode_info(enc, cc_ref, cc_im, cc_ii, cc_mv, blk, ctx, nb, ws, fh,
refs, s, skip_mode, segment_id, fwd_eq_bck): i64 {
    if ((blk == 0) || (ctx == 0) || (ws == 0)) { return DR_ERR_BOUNDS; }
    var mi_size = load64(ctx + AV1MVC_MI_SIZE);
    var ref0 = load64(blk + AV1IB_REF0);
    var ref1 = load64(blk + AV1IB_REF1);
    if ((ref0 < AV1_LAST_FRAME) || (ref0 > AV1_ALTREF_FRAME)) { return DR_ERR_BOUNDS; }
    var e = av1_write_ref_frames(enc, cc_ref, nb, fh, skip_mode, segment_id, mi_size, ref0, ref1);
    if (e != DR_OK) { return e; }
    var is_comp = 0;
    if (ref1 > AV1_INTRA_FRAME) { is_comp = 1; }
    av1_mvctx_set_refs(ctx, ref0, ref1);
    var gm = av1_ibmi_scratch();
    if (gm == 0) { return DR_ERR_OOM; }
    var mi_row = load64(ctx + AV1MVC_MI_ROW);
    var mi_col = load64(ctx + AV1MVC_MI_COL);
    av1_setup_global_mv(gm, fh, ref0, mi_col, mi_row, mi_size);
    var gt0 = av1_fh_gm_type(fh, ref0);
    var g1r = 0;
    var g1c = 0;
    var gt1 = 0;
    if (ref1 >= AV1_LAST_FRAME) {
        av1_setup_global_mv(gm + 16, fh, ref1, mi_col, mi_row, mi_size);
        g1r = load64(gm + 16 + AV1MV_ROW);
        g1c = load64(gm + 16 + AV1MV_COL);
        gt1 = av1_fh_gm_type(fh, ref1);
    }
    av1_mvctx_set_global(ctx, load64(gm + AV1MV_ROW), load64(gm + AV1MV_COL), g1r, g1c, gt0, gt1);
    av1_find_mv_stack(ctx, is_comp);
    var y_mode = load64(blk + AV1IB_YMODE);
    var mode_coded = 1;
    if (skip_mode != 0) { mode_coded = 0; }
    if ((av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_SKIP) != 0)
    || (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0)) {
        mode_coded = 0;
    }
    if (mode_coded != 0) {
        if (is_comp != 0) {
            av1_write_compound_mode(enc, cc_im, ctx, y_mode);
        } else {
            av1_write_inter_mode(enc, cc_im, ctx, y_mode);
        }
    }
    var ref_mv_idx = load64(blk + AV1IB_REFMVIDX);
    av1_write_drl_idx(enc, cc_im, ctx, y_mode, ref_mv_idx);
    var allow_hp = av1_fh_allow_high_precision_mv(fh);
    var force_int = av1_fh_force_integer_mv(fh);
    if (is_comp != 0) {
        av1_write_assign_mv_compound(enc, cc_mv, ctx, y_mode, ref_mv_idx, 0, allow_hp,
        force_int, blk + AV1IB_MV0, blk + AV1IB_MV1);
    } else {
        av1_write_assign_mv_single(enc, cc_mv, ctx, y_mode, ref_mv_idx, 0, allow_hp,
        force_int, blk + AV1IB_MV0);
    }
    av1_write_interintra_mode(enc, cc_ii, blk + AV1IB_II, is_comp, skip_mode, mi_size,
    av1_seq_enable_interintra_compound(s));
    # the 5.11.28 side-effect keys on interintra itself (SETREF1 is a READER output the
    # source record does not carry) — and fires ONLY when the FULL coding gate is open,
    # exactly as the reader's. An interintra record the gate cannot code is surfaced as
    # DR_ERR_BOUNDS (the av1_write_ref_frames unrepresentable-pair convention), never a
    # silently desynced stream.
    if (av1_interintra_on(blk + AV1IB_II) != 0) {
        var ii_ok = 1;
        if (skip_mode != 0) { ii_ok = 0; }
        if (av1_seq_enable_interintra_compound(s) == 0) { ii_ok = 0; }
        if (is_comp != 0) { ii_ok = 0; }
        if ((mi_size < AV1_BLOCK_8X8) || (mi_size > AV1_BLOCK_32X32)) { ii_ok = 0; }
        if (ii_ok == 0) { return DR_ERR_BOUNDS; }
        ref1 = AV1_INTRA_FRAME;
    }
    var e2 = av1_write_motion_mode(enc, cc_im, ctx, ws, fh, refs, skip_mode, y_mode, ref0,
    ref1, is_comp, load64(blk + AV1IB_MV0 + AV1MV_ROW), load64(blk + AV1IB_MV0 + AV1MV_COL),
    load64(blk + AV1IB_MOTIONMODE));
    if (e2 != DR_OK) { return e2; }
    av1_write_compound_type(enc, cc_ii, blk + AV1IB_CT, is_comp, skip_mode, mi_size,
    av1_seq_enable_masked_compound(s), av1_seq_enable_jnt_comp(s),
    av1_interintra_on(blk + AV1IB_II), av1_interintra_wedge(blk + AV1IB_II),
    av1_comp_group_idx_ctx(nb), av1_compound_idx_ctx(nb, fwd_eq_bck));
    var gt1n = 0;
    if (ref1 >= AV1_LAST_FRAME) { gt1n = av1_fh_gm_type(fh, ref1); }
    av1_write_interp_filters(enc, cc_im, blk + AV1IB_INTERP, av1_fh_interpolation_filter(fh),
    av1_seq_enable_dual_filter(s), av1_interp_filter_ctx(nb, 0, ref0, ref1),
    av1_interp_filter_ctx(nb, 1, ref0, ref1), skip_mode, load64(blk + AV1IB_MOTIONMODE),
    mi_size, y_mode, gt0, gt1n);
    return DR_OK;
}

# ================================================================
# inter_frame_mode_info (spec 5.11.15) — THE OUTER DISPATCH, and its leaves:
# read_skip_mode (5.11.11, the @@skip_mode symbol + its full gate) and the 5.11.15
# is_inter selection over the 0.7.68 leaf (renamed av1_read_is_inter_sym).
# SCOPE — deferred with the feature-gated list (roadmap.md): the segmentation READS
# (inter_segment_id beyond the segmentation_enabled == 0 path), the delta-q/lf reads,
# and the intra fork (intra_block_mode_info) gate hard as DR_ERR_UNSUPPORTED. The
# read_cdef splice mirrors the intra orchestrator's cdef_ctx record (0.7.32).
# ================================================================
# skip_mode leaf — the @@skip_mode binary symbol, CDF Skip_Mode[ctx]; ctx (0..2) is
# AboveSkipMode + LeftSkipMode, caller-derived from the SkipModes grid the tile decode
# owns (the same caller-input convention the 0.7.68 reads began with; roadmap.md).
fn av1_read_skip_mode_sym(sd, cc, ctx): i64 {
    return av1_sym_read_symbol(sd, av1_refcdf_skipmode(cc, ctx), 2);
}
fn av1_write_skip_mode_sym(enc, cc, ctx, v): i64 {
    av1_sym_encode_symbol(enc, av1_refcdf_skipmode(cc, ctx), 2, v);
    return DR_OK;
}
# read_skip_mode (5.11.11) — any of the three segment features, no skip_mode_present,
# or a sub-8 block dimension forces skip_mode = 0 with NO symbol. Preconditions
# (validated by the outer driver): segment_id in [0, MAX_SEGMENTS), mi_size in range.
fn av1_read_skip_mode(sd, cc, ctx, fh, segment_id, mi_size): i64 {
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_SKIP) != 0) { return 0; }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != 0) { return 0; }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0) { return 0; }
    if (av1_fh_skip_mode_present(fh) == 0) { return 0; }
    if (av1_block_width(mi_size) < 8) { return 0; }
    if (av1_block_height(mi_size) < 8) { return 0; }
    return av1_read_skip_mode_sym(sd, cc, ctx);
}
fn av1_write_skip_mode(enc, cc, ctx, fh, segment_id, mi_size, skip_mode): i64 {
    var codeable = 1;
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_SKIP) != 0) { codeable = 0; }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != 0) { codeable = 0; }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0) { codeable = 0; }
    if (av1_fh_skip_mode_present(fh) == 0) { codeable = 0; }
    if (av1_block_width(mi_size) < 8) { codeable = 0; }
    if (av1_block_height(mi_size) < 8) { codeable = 0; }
    if (codeable == 0) {
        # the gate forces skip_mode = 0: a record claiming 1 is UNREPRESENTABLE —
        # surfaced as a bounds error (the av1_write_ref_frames convention), never a
        # silently desynced stream.
        if (skip_mode != 0) { return DR_ERR_BOUNDS; }
        return DR_OK;
    }
    return av1_write_skip_mode_sym(enc, cc, ctx, skip_mode);
}
# read_is_inter (5.11.15) — the dispatch over the leaf: skip_mode and an active
# SEG_LVL_GLOBALMV force inter; an active SEG_LVL_REF_FRAME derives is_inter from its
# parse-clipped datum; only the fall-through codes @@is_inter (ctx from the nb record).
fn av1_read_is_inter(sd, cc, nb, fh, skip_mode, segment_id): i64 {
    if (skip_mode != 0) { return 1; }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != 0) {
        return av1_fh_feature_data(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != AV1_INTRA_FRAME;
    }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0) { return 1; }
    return av1_read_is_inter_sym(sd, cc, av1_is_inter_ctx(nb));
}
fn av1_write_is_inter(enc, cc, nb, fh, skip_mode, segment_id, is_inter): i64 {
    # every forced path checks the record AGREES with the forced value — an
    # inconsistent record is unrepresentable, surfaced, never silently desynced.
    if (skip_mode != 0) {
        if (is_inter != 1) { return DR_ERR_BOUNDS; }
        return DR_OK;
    }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != 0) {
        var forced = av1_fh_feature_data(fh, segment_id, AV1_SEG_LVL_REF_FRAME) != AV1_INTRA_FRAME;
        if (is_inter != forced) { return DR_ERR_BOUNDS; }
        return DR_OK;
    }
    if (av1_seg_feature_active(fh, segment_id, AV1_SEG_LVL_GLOBALMV) != 0) {
        if (is_inter != 1) { return DR_ERR_BOUNDS; }
        return DR_OK;
    }
    return av1_write_is_inter_sym(enc, cc, av1_is_inter_ctx(nb), is_inter);
}
# The inter_frame_mode_info output: the frame-level block fields + the embedded
# Av1InterBlock (valid when ISINTER).
enum Av1BlockInfoOff {
    AV1FB_SEGID    = 0;     # segment_id, read by inter_segment_id (5.11.10) as of 0.7.125 D1
    AV1FB_SKIPMODE = 8;
    AV1FB_SKIP     = 16;
    AV1FB_ISINTER  = 24;
    AV1FB_IB       = 32;    # embedded Av1InterBlock (AV1IB_SIZE = 192)
    AV1FB_RESID    = 224;   # encode-only: residual-coeff plan ptr (0 = zero residual)
    AV1FB_VARTX    = 232;   # encode-only: var-tx plan ptr (0 = uniform tx)
    AV1FB_MI       = 240;   # embedded Av1ModeInfo (AV1MI_SIZE=80) — the intra-fork mode fields (5.11.24)
    AV1FB_SIZE     = 320;
}
fn av1_blockinfo_new(): i64 {
    var b = alloc(AV1FB_SIZE);
    if (b == 0) { return 0; }
    memset(b, 0, AV1FB_SIZE);
    return b;
}
fn av1_fb_segment_id(b): i64 { return load64(b + AV1FB_SEGID); }
fn av1_fb_skip_mode(b): i64 { return load64(b + AV1FB_SKIPMODE); }
fn av1_fb_skip(b): i64 { return load64(b + AV1FB_SKIP); }
fn av1_fb_is_inter(b): i64 { return load64(b + AV1FB_ISINTER); }
fn av1_fb_ib(b): i64 { return b + AV1FB_IB; }
# encode-only residual plan (0 = zero residual). Layout: [0]=luma TxType,
# then per plane p a pair at [1 + p*2]=eob, [2 + p*2]=coeff-buffer ptr.
fn av1_fb_resid(b): i64 { return load64(b + AV1FB_RESID); }
fn av1_fb_set_resid(b, plan): i64 { store64(b + AV1FB_RESID, plan); return 0; }
# var-tx plan (encode-only): [0]=target InterTxSizes grid, [1]=leaf cursor, [2]=leaf
# count, [3]=luma leaf array ({tx_type,eob,coeff} x N), [4..7]=chroma {eob,coeff} pairs.
fn av1_fb_vartx(b): i64 { return load64(b + AV1FB_VARTX); }
fn av1_fb_set_vartx(b, plan): i64 { store64(b + AV1FB_VARTX, plan); return 0; }
# inter_frame_mode_info (5.11.15) — the outer driver. The neighbour cache
# (av1_nbctx_setup) is built HERE, at the spec's preamble position, from the ctx's
# grid; ctx carries the block geometry as for 5.11.23. above_skip/left_skip and
# skip_mode_ctx are tile-grid neighbour state (caller-derived; roadmap.md);
# cdef_ctx is the intra path's splice record (0 to skip). Deferred features gate
# hard rather than desync: segmentation reads / delta-q/lf / the intra fork
# (roadmap.md).
fn av1_inter_frame_mode_info(sd, cc_ref, cc_im, cc_ii, cc_mv, ncc, out, ctx, nb, ws,
fh, refs, s, avail_u, avail_l, above_skip, left_skip, skip_mode_ctx, cdef_ctx,
fwd_eq_bck, has_chroma, enable_filter_intra, lossless, segids): i64 {
    if ((out == 0) || (ctx == 0) || (nb == 0) || (ws == 0)) { return DR_ERR_BOUNDS; }
    memset(out, 0, AV1FB_SIZE);
    var mi_size = load64(ctx + AV1MVC_MI_SIZE);
    if ((mi_size < 0) || (mi_size >= AV1_BLOCK_SIZES)) { return DR_ERR_BOUNDS; }
    if (av1_seg_supported(fh) == 0) { return DR_ERR_UNSUPPORTED; }   # unsupported seg config (0.7.125 D1)
    if (av1_fh_delta_q_present(fh) != 0) { return DR_ERR_UNSUPPORTED; }        # roadmap.md
    if (av1_fh_delta_lf_present(fh) != 0) { return DR_ERR_UNSUPPORTED; }       # roadmap.md
    var seg_enabled = av1_fh_segmentation_enabled(fh);
    if ((seg_enabled != 0) && (segids == 0)) { return DR_ERR_BOUNDS; }   # caller must supply the map grid
    var mi_row = load64(ctx + AV1MVC_MI_ROW);
    var mi_col = load64(ctx + AV1MVC_MI_COL);
    var fmi_cols = load64(ctx + AV1MVC_FMI_COLS);
    # the 5.11.15 preamble: the neighbour reference cache.
    av1_nbctx_setup(nb, load64(ctx + AV1MVC_GRID), fmi_cols, mi_row, mi_col, avail_u, avail_l);
    # inter_segment_id(1) (5.11.10): a SegIdPreSkip frame reads the segment BEFORE skip (skip=0 then);
    # otherwise the read is DEFERRED to the inter_segment_id(0) call after skip. Only the decodable spatial
    # config reaches here (av1_seg_supported gated temporal / !update_map / !update_data upstream).
    var seg_pre = 0;
    if (seg_enabled != 0) { seg_pre = av1_fh_seg_id_pre_skip(fh); }
    var segment_id = 0;
    if ((seg_enabled != 0) && (seg_pre != 0)) {
        segment_id = av1_read_segment_id(sd, ncc, fh, segids, fmi_cols, mi_row, mi_col, avail_u, avail_l, 0);
    }
    store64(out + AV1FB_SEGID, segment_id);
    var skip_mode = av1_read_skip_mode(sd, cc_ref, skip_mode_ctx, fh, segment_id, mi_size);
    store64(out + AV1FB_SKIPMODE, skip_mode);
    var skip = 1;
    if (skip_mode == 0) {
        skip = av1_read_skip(sd, ncc, av1_skip_ctx(avail_u, above_skip, avail_l, left_skip));
    }
    store64(out + AV1FB_SKIP, skip);
    # inter_segment_id(0) (5.11.10): the !SegIdPreSkip case reads the segment AFTER skip (read_segment_id
    # short-circuits to pred when skip). is_inter / ref_frames below then see the FINAL segment_id — the
    # features they consult (SKIP/REF_FRAME/GLOBALMV, all j>=SEG_LVL_REF_FRAME) force SegIdPreSkip=1, so a
    # !SegIdPreSkip frame has none of them active and segment_id=0 for those reads is equivalent.
    if ((seg_enabled != 0) && (seg_pre == 0)) {
        segment_id = av1_read_segment_id(sd, ncc, fh, segids, fmi_cols, mi_row, mi_col, avail_u, avail_l, skip);
        store64(out + AV1FB_SEGID, segment_id);
    }
    # Lossless is tile-layer state, exactly as on the intra path. read_cdef (5.11.56) splice:
    if (cdef_ctx != 0) {
        var ce = load64(cdef_ctx + 0);
        var cb = load64(cdef_ctx + 8);
        var cl = load64(cdef_ctx + 16);
        var ci = load64(cdef_ctx + 24);
        var cg = load64(cdef_ctx + 32);
        var cs = load64(cdef_ctx + 40);
        av1_read_cdef(sd, cg, cs, mi_row, mi_col, mi_size, skip, ce, cb, cl, ci);
    }
    # read_delta_qindex / read_delta_lf: delta_q/lf_present are gated OFF above, and
    # with them disabled the spec reads nothing here (roadmap.md).
    var is_inter = av1_read_is_inter(sd, cc_ref, nb, fh, skip_mode, segment_id);
    store64(out + AV1FB_ISINTER, is_inter);
    if (is_inter == 0) {
        # intra_block_mode_info (5.11.24): RefFrame[0]=INTRA_FRAME, RefFrame[1]=NONE; fill the embedded
        # Av1ModeInfo. Reconstruction (intra predict + residual) is the coupled follow-on (roadmap.md C2).
        store64((out + AV1FB_IB) + AV1IB_REF0, AV1_INTRA_FRAME);
        store64((out + AV1FB_IB) + AV1IB_REF1, AV1_REF_NONE);
        return av1_read_intra_block_mode_info(sd, ncc, out + AV1FB_MI, mi_size, has_chroma,
        enable_filter_intra, av1_seq_subsampling_x(s), av1_seq_subsampling_y(s), lossless);
    }
    return av1_inter_block_mode_info(sd, cc_ref, cc_im, cc_ii, cc_mv, out + AV1FB_IB,
    ctx, nb, ws, fh, refs, s, skip_mode, segment_id, fwd_eq_bck);
}
# the encoder inverse — replays the dispatch on the same state. blk is an
# Av1BlockInfo whose IB region carries the 5.11.23 source (REF1 pre-interintra).
fn av1_write_inter_frame_mode_info(enc, cc_ref, cc_im, cc_ii, cc_mv, ncc, blk, ctx, nb,
ws, fh, refs, s, avail_u, avail_l, above_skip, left_skip, skip_mode_ctx, cdef_ctx,
fwd_eq_bck, has_chroma, enable_filter_intra, lossless, segids): i64 {
    if ((blk == 0) || (ctx == 0) || (nb == 0) || (ws == 0)) { return DR_ERR_BOUNDS; }
    var mi_size = load64(ctx + AV1MVC_MI_SIZE);
    if ((mi_size < 0) || (mi_size >= AV1_BLOCK_SIZES)) { return DR_ERR_BOUNDS; }
    if (av1_seg_supported(fh) == 0) { return DR_ERR_UNSUPPORTED; }   # unsupported seg config (0.7.125 D1)
    if (av1_fh_delta_q_present(fh) != 0) { return DR_ERR_UNSUPPORTED; }        # roadmap.md
    if (av1_fh_delta_lf_present(fh) != 0) { return DR_ERR_UNSUPPORTED; }       # roadmap.md
    var seg_enabled = av1_fh_segmentation_enabled(fh);
    if ((seg_enabled != 0) && (segids == 0)) { return DR_ERR_BOUNDS; }
    var mi_row = load64(ctx + AV1MVC_MI_ROW);
    var mi_col = load64(ctx + AV1MVC_MI_COL);
    var fmi_cols = load64(ctx + AV1MVC_FMI_COLS);
    av1_nbctx_setup(nb, load64(ctx + AV1MVC_GRID), fmi_cols, mi_row, mi_col, avail_u, avail_l);
    # inter_segment_id (5.11.10) mirror — same SegIdPreSkip ordering as decode. seg_before is the value
    # the skip_mode/is_inter feature gates see (segid iff SegIdPreSkip, else 0 — equivalent, as those
    # gates only consult j>=SEG_LVL_REF_FRAME features which force SegIdPreSkip=1).
    var seg_pre = 0;
    if (seg_enabled != 0) { seg_pre = av1_fh_seg_id_pre_skip(fh); }
    var segid = load64(blk + AV1FB_SEGID);
    var seg_before = 0;
    if (seg_pre != 0) { seg_before = segid; }
    if ((seg_enabled != 0) && (seg_pre != 0)) {
        var sp = av1_write_segment_id(enc, ncc, fh, segids, fmi_cols, mi_row, mi_col, avail_u, avail_l, 0, segid);
        if (sp != DR_OK) { return sp; }
    }
    var skip_mode = load64(blk + AV1FB_SKIPMODE);
    # skip_mode forces skip = 1 (5.11.15) — an inconsistent record would desync the
    # cdef splice and the 5.11.23 form downstream; surfaced, never silent.
    if ((skip_mode != 0) && (load64(blk + AV1FB_SKIP) == 0)) { return DR_ERR_BOUNDS; }
    var e = av1_write_skip_mode(enc, cc_ref, skip_mode_ctx, fh, seg_before, mi_size, skip_mode);
    if (e != DR_OK) { return e; }
    if (skip_mode == 0) {
        av1_write_skip(enc, ncc, av1_skip_ctx(avail_u, above_skip, avail_l, left_skip),
        load64(blk + AV1FB_SKIP));
    }
    if ((seg_enabled != 0) && (seg_pre == 0)) {
        var sp0 = av1_write_segment_id(enc, ncc, fh, segids, fmi_cols, mi_row, mi_col, avail_u, avail_l,
        load64(blk + AV1FB_SKIP), segid);
        if (sp0 != DR_OK) { return sp0; }
    }
    if (cdef_ctx != 0) {
        var ce = load64(cdef_ctx + 0);
        var cb = load64(cdef_ctx + 8);
        var cl = load64(cdef_ctx + 16);
        var ci = load64(cdef_ctx + 24);
        var cg = load64(cdef_ctx + 32);
        var cs = load64(cdef_ctx + 40);
        var cp = load64(cdef_ctx + 48);
        av1_write_cdef(enc, cg, cp, cs, mi_row, mi_col, mi_size,
        load64(blk + AV1FB_SKIP), ce, cb, cl, ci);
    }
    var is_inter = load64(blk + AV1FB_ISINTER);
    var e2 = av1_write_is_inter(enc, cc_ref, nb, fh, skip_mode, segid, is_inter);
    if (e2 != DR_OK) { return e2; }
    if (is_inter == 0) {
        # intra_block_mode_info (5.11.24) inverse — write the intra mode-info from the embedded Av1ModeInfo.
        return av1_write_intra_block_mode_info(enc, ncc, blk + AV1FB_MI, mi_size, has_chroma,
        enable_filter_intra, av1_seq_subsampling_x(s), av1_seq_subsampling_y(s), lossless);
    }
    return av1_write_inter_block_mode_info(enc, cc_ref, cc_im, cc_ii, cc_mv,
    blk + AV1FB_IB, ctx, nb, ws, fh, refs, s, skip_mode, segid, fwd_eq_bck);
}
