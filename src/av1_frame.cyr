# @public — drishti AV1: uncompressed frame header (5.9.2) + the
# reference-frame state machine. Turns a frame_header_obu / frame_obu
# payload into an Av1FrameHeader record (frame type, dimensions,
# superres, quant/segmentation/tile/cdef/lr/loop-filter/global-motion/
# film-grain parameters) and maintains the eight-slot RefValid /
# RefOrderHint / RefFrameId / Ref{Upscaled,Frame,Render}{Width,Height} /
# RefFrameType / SavedGmParams state the header both reads from and
# updates.
#
# FLAT module (no includes) — wiring in src/main.cyr. Depends on
# src/drishti.cyr (DR_ERR_*), src/bits.cyr (DrBr, f/su/ns descriptors),
# and src/av1_seq.cyr (Av1Seq accessors + AV1_ERR_BAD_FRAME).
#
# Derived from the "AV1 Bitstream & Decoding Process Specification"
# v1.0.0 with Errata 1 (AOMedia) — section numbers cited inline. The
# whole uncompressed_header is parsed CURSOR-TRUE for every frame type
# (key / inter / intra-only / switch / show_existing): every
# bit-affecting derivation (OrderHintBits, CodedLossless via get_qindex,
# skipModeAllowed, set_frame_refs, ref-order-hint invalidation) is
# computed so the reader always lands exactly at byte_alignment().
# Sections used: 5.9.2 uncompressed_header, 5.9.4 get_relative_dist,
# 5.9.5 frame_size, 5.9.6 render_size, 5.9.7 frame_size_with_refs,
# 5.9.8 superres_params, 5.9.9 compute_image_size, 5.9.10
# read_interpolation_filter, 5.9.11 loop_filter_params, 5.9.12
# quantization_params, 5.9.13 read_delta_q, 5.9.14 segmentation_params,
# 5.9.15 tile_info, 5.9.3 tile_log2, 5.9.17 delta_q_params, 5.9.18
# delta_lf_params, 5.9.19 cdef_params, 5.9.20 lr_params, 5.9.21
# read_tx_mode, 5.9.22 frame_reference_mode, 5.9.23 skip_mode_params,
# 5.9.24 global_motion_params, 5.9.25 read_global_param, 5.9.26-28
# subexp, 5.9.30 film_grain_params, 5.9.31 temporal_point_info; 7.8
# set_frame_refs; 7.20 reference frame update; 7.21 reference frame
# loading; 7.12.2 get_qindex.
# Cross-checked against dav1d src/obu.c (parse_frame_hdr) and libaom
# av1/decoder/decodeframe.c (read_uncompressed_header) — field order and
# every conditional branch match both.
#
# SCOPE (0.7.x frame-header bite): the header is parsed and every field
# stored or (for film-grain point/AR-coefficient arrays) consumed
# bit-exactly. Cross-frame CDF / loop-filter-delta / segment-id
# inheritance via load_previous (primary_ref_frame != PRIMARY_REF_NONE)
# is a decode-state concern (deferred; docs/development/roadmap.md 0.7.x).
# The ref state machine tracks the dimension/order-hint/gm slots the
# header itself consults, which is what set_frame_refs and
# frame_size_with_refs need.

# ================================================================
# Spec constants (5.9 semantics + section 3 symbols).
# ================================================================
enum Av1FrameConst {
    AV1_KEY_FRAME                   = 0;
    AV1_INTER_FRAME                 = 1;
    AV1_INTRA_ONLY_FRAME            = 2;
    AV1_SWITCH_FRAME                = 3;
    AV1_NUM_REF_FRAMES              = 8;
    AV1_REFS_PER_FRAME              = 7;
    AV1_PRIMARY_REF_NONE            = 7;
    AV1_SELECT_SCREEN_CONTENT_TOOLS = 2;
    AV1_SELECT_INTEGER_MV           = 2;
    AV1_SUPERRES_NUM                = 8;
    AV1_SUPERRES_DENOM_MIN          = 9;
    AV1_SUPERRES_DENOM_BITS         = 3;
    # reference frame indices (INTRA + 7 inter)
    AV1_INTRA_FRAME                 = 0;
    AV1_LAST_FRAME                  = 1;
    AV1_LAST2_FRAME                 = 2;
    AV1_LAST3_FRAME                 = 3;
    AV1_GOLDEN_FRAME                = 4;
    AV1_BWDREF_FRAME                = 5;
    AV1_ALTREF2_FRAME               = 6;
    AV1_ALTREF_FRAME                = 7;
    # restoration types (post Remap_Lr_Type)
    AV1_RESTORE_NONE                = 0;
    AV1_RESTORE_WIENER              = 1;
    AV1_RESTORE_SGRPROJ             = 2;
    AV1_RESTORE_SWITCHABLE          = 3;
    # interpolation filter sentinel
    AV1_INTERP_SWITCHABLE           = 4;
    # tx modes
    AV1_ONLY_4X4                    = 0;
    AV1_TX_MODE_LARGEST             = 1;
    AV1_TX_MODE_SELECT              = 2;
    # warp model types
    AV1_GM_IDENTITY                 = 0;
    AV1_GM_TRANSLATION              = 1;
    AV1_GM_ROTZOOM                  = 2;
    AV1_GM_AFFINE                   = 3;
    AV1_WARPEDMODEL_PREC_BITS       = 16;
    AV1_GM_ABS_TRANS_BITS           = 12;
    AV1_GM_ABS_TRANS_ONLY_BITS      = 9;
    AV1_GM_ABS_ALPHA_BITS           = 12;
    AV1_GM_ALPHA_PREC_BITS          = 15;
    AV1_GM_TRANS_PREC_BITS          = 6;
    AV1_GM_TRANS_ONLY_PREC_BITS     = 3;
    # segmentation
    AV1_MAX_SEGMENTS                = 8;
    AV1_SEG_LVL_MAX                 = 8;
    AV1_SEG_LVL_ALT_Q               = 0;
    AV1_SEG_LVL_REF_FRAME           = 5;
    AV1_MAX_LOOP_FILTER             = 63;
    # tiles
    AV1_MAX_TILE_WIDTH              = 4096;
    AV1_MAX_TILE_AREA               = 9437184;   # MAX_TILE_WIDTH * 2304
    AV1_MAX_TILE_COLS               = 64;
    AV1_MAX_TILE_ROWS               = 64;
    AV1_RESTORATION_TILESIZE_MAX    = 256;
}

# ================================================================
# Av1FrameHeader byte offsets. Scalar block first (0..656), then the
# fixed-size arrays. AV1FH_SIZE bytes, memset-zeroed at parse.
# ================================================================
enum Av1FhOff {
    AV1FH_SHOW_EXISTING          = 0;
    AV1FH_FRAME_TO_SHOW          = 8;
    AV1FH_FRAME_TYPE             = 16;
    AV1FH_FRAME_IS_INTRA         = 24;
    AV1FH_SHOW_FRAME             = 32;
    AV1FH_SHOWABLE_FRAME         = 40;
    AV1FH_ERROR_RESILIENT        = 48;
    AV1FH_DISABLE_CDF_UPDATE     = 56;
    AV1FH_ALLOW_SCT              = 64;    # allow_screen_content_tools
    AV1FH_FORCE_INT_MV           = 72;    # force_integer_mv (frame level)
    AV1FH_CURRENT_FRAME_ID       = 80;
    AV1FH_FRAME_SIZE_OVERRIDE    = 88;
    AV1FH_ORDER_HINT             = 96;
    AV1FH_PRIMARY_REF_FRAME      = 104;
    AV1FH_REFRESH_FRAME_FLAGS    = 112;
    AV1FH_DISABLE_FE_UPDATE_CDF  = 120;   # disable_frame_end_update_cdf
    AV1FH_FRAME_WIDTH            = 128;
    AV1FH_FRAME_HEIGHT           = 136;
    AV1FH_UPSCALED_WIDTH         = 144;
    AV1FH_RENDER_WIDTH           = 152;
    AV1FH_RENDER_HEIGHT          = 160;
    AV1FH_SUPERRES_DENOM         = 168;
    AV1FH_USE_SUPERRES           = 176;
    AV1FH_MI_COLS                = 184;
    AV1FH_MI_ROWS                = 192;
    AV1FH_ALLOW_INTRABC          = 200;
    AV1FH_ALLOW_HIGH_PREC_MV     = 208;
    AV1FH_USE_REF_FRAME_MVS      = 216;
    AV1FH_MOTION_MODE_SWITCHABLE = 224;
    AV1FH_INTERP_FILTER          = 232;
    AV1FH_SHORT_SIGNALING        = 240;   # frame_refs_short_signaling
    AV1FH_BASE_Q_IDX             = 248;
    AV1FH_DELTA_Q_Y_DC           = 256;
    AV1FH_DELTA_Q_U_DC           = 264;
    AV1FH_DELTA_Q_U_AC           = 272;
    AV1FH_DELTA_Q_V_DC           = 280;
    AV1FH_DELTA_Q_V_AC           = 288;
    AV1FH_USING_QMATRIX          = 296;
    AV1FH_QM_Y                   = 304;
    AV1FH_QM_U                   = 312;
    AV1FH_QM_V                   = 320;
    AV1FH_DIFF_UV_DELTA          = 328;
    AV1FH_DELTA_Q_PRESENT        = 336;
    AV1FH_DELTA_Q_RES            = 344;
    AV1FH_DELTA_LF_PRESENT       = 352;
    AV1FH_DELTA_LF_RES           = 360;
    AV1FH_DELTA_LF_MULTI         = 368;
    AV1FH_CODED_LOSSLESS         = 376;
    AV1FH_ALL_LOSSLESS           = 384;
    AV1FH_LF_SHARPNESS           = 392;
    AV1FH_LF_DELTA_ENABLED       = 400;
    AV1FH_LF_DELTA_UPDATE        = 408;
    AV1FH_CDEF_DAMPING           = 416;
    AV1FH_CDEF_BITS              = 424;
    AV1FH_USES_LR                = 432;
    AV1FH_TX_MODE                = 440;
    AV1FH_REFERENCE_SELECT       = 448;
    AV1FH_SKIP_MODE_PRESENT      = 456;
    AV1FH_ALLOW_WARPED           = 464;
    AV1FH_REDUCED_TX_SET         = 472;
    AV1FH_SEG_ENABLED            = 480;
    AV1FH_SEG_UPDATE_MAP         = 488;
    AV1FH_SEG_TEMPORAL_UPDATE    = 496;
    AV1FH_SEG_UPDATE_DATA        = 504;
    AV1FH_TILE_COLS              = 512;
    AV1FH_TILE_ROWS              = 520;
    AV1FH_TILE_COLS_LOG2         = 528;
    AV1FH_TILE_ROWS_LOG2         = 536;
    AV1FH_TILE_SIZE_BYTES        = 544;
    AV1FH_CONTEXT_UPDATE_TILE_ID = 552;
    AV1FH_UNIFORM_TILE           = 560;
    AV1FH_APPLY_GRAIN            = 568;
    AV1FH_GRAIN_SEED             = 576;
    AV1FH_UPDATE_GRAIN           = 584;
    AV1FH_GRAIN_REF_IDX          = 592;
    AV1FH_NUM_Y_POINTS           = 600;
    AV1FH_CHROMA_SCALE_FROM_LUMA = 608;
    AV1FH_NUM_CB_POINTS          = 616;
    AV1FH_NUM_CR_POINTS          = 624;
    AV1FH_SKIP_MODE_FRAME0       = 632;
    AV1FH_SKIP_MODE_FRAME1       = 640;
    AV1FH_BITS_CONSUMED          = 648;   # reader bit position at header end
    # arrays
    AV1FH_LF_LEVEL               = 704;   # [4]           -> 736
    AV1FH_LF_REF_DELTAS          = 736;   # [8] signed    -> 800
    AV1FH_LF_MODE_DELTAS         = 800;   # [2] signed    -> 816
    AV1FH_CDEF_Y_PRI             = 816;   # [8]           -> 880
    AV1FH_CDEF_Y_SEC             = 880;   # [8]           -> 944
    AV1FH_CDEF_UV_PRI            = 944;   # [8]           -> 1008
    AV1FH_CDEF_UV_SEC            = 1008;  # [8]           -> 1072
    AV1FH_FRAME_RESTORATION_TYPE = 1072;  # [3]           -> 1096
    AV1FH_LR_SIZE                = 1096;  # [3]           -> 1120
    AV1FH_REF_FRAME_IDX          = 1120;  # [7]           -> 1176
    AV1FH_ORDER_HINTS            = 1176;  # [8] by refFrame-> 1240
    AV1FH_GM_TYPE                = 1240;  # [7] (ref-1)   -> 1296
    AV1FH_GM_PARAMS              = 1296;  # [7*6=42]      -> 1632
    AV1FH_FEATURE_ENABLED        = 1632;  # [8*8=64]      -> 2144
    AV1FH_FEATURE_DATA           = 2144;  # [8*8=64] sign -> 2656
    AV1FH_MI_COL_STARTS          = 2656;  # [65]          -> 3176
    AV1FH_MI_ROW_STARTS          = 3176;  # [65]          -> 3696
    AV1FH_SIZE                   = 3712;
}

# ================================================================
# Av1RefState byte offsets — eight reference slots. Only the fields the
# frame header consults (7.20 subset) are tracked; frame samples, MVs,
# and CDFs live in the decoder proper.
# ================================================================
enum Av1RefOff {
    AV1REF_VALID              = 0;      # [8]
    AV1REF_FRAME_ID           = 64;     # [8]
    AV1REF_UPSCALED_W         = 128;    # [8]
    AV1REF_FRAME_W            = 192;    # [8]
    AV1REF_FRAME_H            = 256;    # [8]
    AV1REF_RENDER_W           = 320;    # [8]
    AV1REF_RENDER_H           = 384;    # [8]
    AV1REF_MI_COLS            = 448;    # [8]
    AV1REF_MI_ROWS            = 512;    # [8]
    AV1REF_FRAME_TYPE         = 576;    # [8]
    AV1REF_SUBX               = 640;    # [8]
    AV1REF_SUBY               = 704;    # [8]
    AV1REF_BITDEPTH           = 768;    # [8]
    AV1REF_ORDER_HINT         = 832;    # [8]
    AV1REF_SAVED_ORDER_HINTS  = 896;    # [8][8]  -> 1408
    AV1REF_SAVED_GM           = 1408;   # [8][7][6] -> 4096
    AV1REF_SIZE               = 4096;
}

# ================================================================
# Small integer helpers (av1_ prefixed — cyrius has no module scoping).
# ================================================================
fn av1_min(a, b): i64 { if (a < b) { return a; } return b; }
fn av1_max(a, b): i64 { if (a > b) { return a; } return b; }
fn av1_clip3(lo, hi, v): i64 {
    if (v < lo) { return lo; }
    if (v > hi) { return hi; }
    return v;
}

# tile_log2(blkSize, target) — 5.9.3: smallest k with (blkSize << k) >= target.
fn av1_tile_log2(blk_size, target): i64 {
    var k = 0;
    while ((blk_size << k) < target) { k = k + 1; }
    return k;
}

# inverse_recenter(r, v) — 5.9.29 (used by subexp decode).
fn av1_inverse_recenter(r, v): i64 {
    if (v > (2 * r)) { return v; }
    if (v & 1) { return r - ((v + 1) >> 1); }
    return r + (v >> 1);
}
# recenter(r, x) — the exact inverse of av1_inverse_recenter (maps an actual value
# x back to its coded delta v), used by the subexp encode mirrors.
fn av1_recenter(r, x): i64 {
    if (x > (2 * r)) { return x; }
    if (x > r) { return 2 * (x - r); }
    if (x < r) { return (2 * (r - x)) - 1; }
    return 0;
}

# get_relative_dist(a, b) — 5.9.4. Needs the sequence header for
# enable_order_hint / OrderHintBits.
fn av1_get_relative_dist(s, a, b): i64 {
    if (av1_seq_enable_order_hint(s) == 0) { return 0; }
    var diff = a - b;
    var m = 1 << (av1_seq_order_hint_bits(s) - 1);
    diff = (diff & (m - 1)) - (diff & m);
    return diff;
}

# Segmentation feature tables (5.9.14): Segmentation_Feature_Bits /
# _Signed / _Max, indexed by feature j in [0, SEG_LVL_MAX).
fn av1_seg_feature_bits(j): i64 {
    if (j == 0) { return 8; }
    if (j == 5) { return 3; }
    if (j >= 6) { return 0; }
    return 6;                      # j in 1..4
}
fn av1_seg_feature_signed(j): i64 {
    if (j <= 4) { return 1; }
    return 0;
}
fn av1_seg_feature_max(j): i64 {
    if (j == 0) { return 255; }
    if (j == 5) { return 7; }
    if (j >= 6) { return 0; }
    return AV1_MAX_LOOP_FILTER;    # j in 1..4
}

# Remap_Lr_Type[4] — 5.9.20.
fn av1_remap_lr_type(t): i64 {
    if (t == 0) { return AV1_RESTORE_NONE; }
    if (t == 1) { return AV1_RESTORE_SWITCHABLE; }
    if (t == 2) { return AV1_RESTORE_WIENER; }
    return AV1_RESTORE_SGRPROJ;
}

# ================================================================
# Av1RefState — allocate + zero (fresh decoder: all slots invalid, order
# hints 0). Returns the handle or 0 on OOM.
# ================================================================
fn av1_ref_state_new(): i64 {
    var r = alloc(AV1REF_SIZE);
    if (r == 0) { return 0; }
    memset(r, 0, AV1REF_SIZE);
    return r;
}

fn av1_ref_valid(r, i): i64 { return load64(r + AV1REF_VALID + (i * 8)); }
fn av1_ref_frame_id(r, i): i64 { return load64(r + AV1REF_FRAME_ID + (i * 8)); }
fn av1_ref_upscaled_width(r, i): i64 { return load64(r + AV1REF_UPSCALED_W + (i * 8)); }
fn av1_ref_frame_width(r, i): i64 { return load64(r + AV1REF_FRAME_W + (i * 8)); }
fn av1_ref_frame_height(r, i): i64 { return load64(r + AV1REF_FRAME_H + (i * 8)); }
fn av1_ref_render_width(r, i): i64 { return load64(r + AV1REF_RENDER_W + (i * 8)); }
fn av1_ref_render_height(r, i): i64 { return load64(r + AV1REF_RENDER_H + (i * 8)); }
fn av1_ref_mi_cols(r, i): i64 { return load64(r + AV1REF_MI_COLS + (i * 8)); }
fn av1_ref_mi_rows(r, i): i64 { return load64(r + AV1REF_MI_ROWS + (i * 8)); }
fn av1_ref_frame_type(r, i): i64 { return load64(r + AV1REF_FRAME_TYPE + (i * 8)); }
fn av1_ref_order_hint(r, i): i64 { return load64(r + AV1REF_ORDER_HINT + (i * 8)); }
fn av1_ref_saved_order_hint(r, i, refFrame): i64 {
    return load64(r + AV1REF_SAVED_ORDER_HINTS + ((i * 8 + refFrame) * 8));
}
fn av1_ref_saved_gm(r, i, ref, idx): i64 {
    return load64(r + AV1REF_SAVED_GM + (((i * 7 + (ref - 1)) * 6 + idx) * 8));
}

# ================================================================
# is_scaled (spec 5.11.27) — does refFrame use a scaled reference? The stored ref's
# UpscaledWidth / FrameHeight are compared against the CURRENT frame's FrameWidth /
# FrameHeight as ratios at REF_SCALE_SHIFT precision; "unscaled" is exactly
# 1 << REF_SCALE_SHIFT on BOTH axes. The width/height asymmetry is the spec's:
# the ref contributes its UPSCALED width (superres never changes height, and MC
# reads the upscaled plane) while the current frame contributes its pre-superres
# FrameWidth. No overflow: dims are parse-capped at 2^16, << 14 stays under 2^31.
# ================================================================
enum Av1RefScale {
    AV1_REF_SCALE_SHIFT = 14;    # REF_SCALE_SHIFT (spec section 3 symbols)
}
fn av1_is_scaled(fh, refs, ref_frame): i64 {
    # hostile guards: a refFrame outside LAST..ALTREF or an unset/lying slot index
    # must not index fh/refs OOB — report "scaled" (the conservative branch: the
    # caller falls to the OBMC/SIMPLE read and scaled-ref MC is rejected anyway).
    if (ref_frame < AV1_LAST_FRAME || ref_frame > AV1_ALTREF_FRAME) { return 1; }
    var ref_idx = av1_fh_ref_frame_idx(fh, ref_frame - AV1_LAST_FRAME);
    if (ref_idx < 0 || ref_idx > 7) { return 1; }
    var fw = av1_fh_frame_width(fh);
    var fht = av1_fh_frame_height(fh);
    if (fw < 1 || fht < 1) { return 1; }    # dimension-bomb backstop: no divide-by-zero
    var x_scale = ((av1_ref_upscaled_width(refs, ref_idx) << AV1_REF_SCALE_SHIFT) + (fw / 2)) / fw;
    var y_scale = ((av1_ref_frame_height(refs, ref_idx) << AV1_REF_SCALE_SHIFT) + (fht / 2)) / fht;
    var no_scale = 1 << AV1_REF_SCALE_SHIFT;
    return (x_scale != no_scale) || (y_scale != no_scale);
}

# ================================================================
# Av1FrameHeader accessors.
# ================================================================
fn av1_fh_show_existing_frame(fh): i64 { return load64(fh + AV1FH_SHOW_EXISTING); }
fn av1_fh_frame_to_show(fh): i64 { return load64(fh + AV1FH_FRAME_TO_SHOW); }
