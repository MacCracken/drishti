    av1_mcfill8(t, 0, 12, 0, 1, 0 - 4, 14, 58, 0 - 6, 1, 0);
    av1_mcfill8(t, 0, 13, 0, 0, 0 - 2, 9, 61, 0 - 5, 1, 0);
    av1_mcfill8(t, 0, 14, 0, 0, 0 - 1, 4, 63, 0 - 3, 1, 0);
    av1_mcfill8(t, 1,  0, 0, 1, 14, 31, 17, 1, 0, 0);
    av1_mcfill8(t, 1,  1, 0, 0, 13, 31, 18, 2, 0, 0);
    av1_mcfill8(t, 1,  2, 0, 0, 11, 31, 20, 2, 0, 0);
