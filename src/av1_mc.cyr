# ================================================================
# av1_mc.cyr — AV1 inter prediction (motion compensation), table layer.
#
# First module of the inter-prediction arc (the last of the four AV1-decode
# capabilities). Landed so far: the sub-pel interpolation FILTER TABLE, the 8-tap
# motion-compensation kernel (put_8tap), the frame-boundary block fetch (emu_edge), and
# the MC DRIVER (av1_mc_pred_block — spec 7.11.3.1 steps 10+13 for the single-reference,
# translation-only, unscaled case: MV -> integer + 1/16-pel split, clamped ref-block
# gather via emu_edge, put_8tap into the DrFrame). The reference-frame buffer/DPB,
# MV prediction, and inter mode-info grow in the next bites (roadmap.md).
#
# Subpel_Filters (spec 7.11.3.4) — 6 filter sets x 15 sub-pel phases x 8 taps.
# Sourced from dav1d's dav1d_mc_subpel_filters (src/tables.c) in dav1d's convention, which
# differs from the spec's in two INDEPENDENT ways, both purely notational:
#   (a) HALVED COEFFICIENTS. Every dav1d phase row sums to 64, the spec's to 128 — each
#       coefficient is exactly half the spec's (the spec notes all its taps are even, so the
#       halving is exact and loses nothing), and put_8tap correspondingly rounds by one bit
#       LESS at every shift. Round2(2*s, n) == Round2(s, n-1) for the arithmetic-shift
#       av1_round2, so the two conventions are BIT-IDENTICAL, not merely close.
#   (b) 15 PHASES, NOT 16. dav1d drops the spec's phase-0 identity row (which no filter path
#       ever consults — an integer position is a copy), so drishti phase index p is the
#       spec's phase p+1. See the accessor note below.
# Separately, dav1d's 2-pass path carries `intermediate_bits` of EXTRA precision in its mid
# buffer; that is a property of the kernel, not of this table, and put_8tap mirrors it.
# Set order (drishti/dav1d index -> spec index):
#   0 REGULAR(spec 0)  1 SMOOTH(spec 1)  2 SHARP(spec 2)
#   3 REGULAR/4-tap(spec 4)   4 SMOOTH/4-tap(spec 5)   5 BILINEAR(spec 3)
# Set 5 is a genuine 2-tap linear kernel — row p is {0,0,0, 64-4p, 4p, 0,0,0} — reached only
# when the frame header's interpolation_filter is BILINEAR (SWITCHABLE's coded alphabet is
# 3 symbols and can never signal it).
# Verified by the suite: every one of the 90 phase rows sums to 64; mirror symmetry
# Subpel_Filters[s][p] == reverse(Subpel_Filters[s][14-p]) holds in all 6 sets; and a
# per-(set,phase) position-weighted checksum against goldens transcribed INDEPENDENTLY
# from dav1d (pins tap order) — so a transcription or sign slip fails the build.
# ================================================================

enum Av1Mc {
    AV1_SUBPEL_SETS    = 6;
    AV1_SUBPEL_PHASES  = 15;   # sub-pel positions per set (integer phase 0 is handled
    # separately by the kernel, so index p maps to mx/my p+1)
    AV1_SUBPEL_TAPS    = 8;
}

# lazily-built Subpel_Filters blob (6*15*8 i64), cyrius global-array literals do not
# initialize reliably (same pattern as av1_scan / av1_superres).
var Av1_SubpelFilters = 0;   # module-global pointer (6*15*8*8 bytes once built)

fn av1_mcfill8(t, set, phase, v0, v1, v2, v3, v4, v5, v6, v7) {
    var o = t + ((((set * AV1_SUBPEL_PHASES) + phase) * AV1_SUBPEL_TAPS) * 8);
    store64(o + 0, v0);   store64(o + 8, v1);   store64(o + 16, v2);  store64(o + 24, v3);
    store64(o + 32, v4);  store64(o + 40, v5);  store64(o + 48, v6);  store64(o + 56, v7);
    return 0;
}

# Build (once) and return the Subpel_Filters[6][15][8] blob (dav1d order + convention).
fn av1_subpel_filters_blob(): i64 {
    if (Av1_SubpelFilters != 0) { return Av1_SubpelFilters; }
    var t = alloc(AV1_SUBPEL_SETS * AV1_SUBPEL_PHASES * AV1_SUBPEL_TAPS * 8);
    if (t == 0) { return 0; }
    av1_mcfill8(t, 0,  0, 0, 1, 0 - 3, 63, 4, 0 - 1, 0, 0);
    av1_mcfill8(t, 0,  1, 0, 1, 0 - 5, 61, 9, 0 - 2, 0, 0);
    av1_mcfill8(t, 0,  2, 0, 1, 0 - 6, 58, 14, 0 - 4, 1, 0);
