# Subpel_Filters[set][phase][tap] — set 0..5, phase 0..14, tap 0..7 (dav1d convention).
fn av1_subpel_filter(set, phase, tap): i64 {
    return load64(av1_subpel_filters_blob() +
    ((((set * AV1_SUBPEL_PHASES) + phase) * AV1_SUBPEL_TAPS) + tap) * 8);
}

# byte address of one 8-tap filter row (set, phase) in the blob.
fn av1_mc_subpel_row(set, phase): i64 {
    return av1_subpel_filters_blob() + (((set * AV1_SUBPEL_PHASES) + phase) * AV1_SUBPEL_TAPS * 8);
}

# ================================================================
# Warped_Filters[193][8] (spec 7.11.3.5) — the warp interpolation filter, indexed by the
# 1/64 sub-pixel warp offset offs in [0,192] (offs = Round2(sx, WARPEDDIFF_PREC_BITS) +
# WARPEDPIXEL_PREC_SHIFTS). Signed 8-tap rows, each summing to 128 (FILTER_BITS=7). dav1d
# stores it SPEC-LITERAL (positive centre) — UNLIKE resize (negated) / subpel (halved, 64).
# Transcribed DETERMINISTICALLY from dav1d src/tables.c (MD5 c764ff07aecee5aba2348072f285059b
# as fetched 2026-07-18; that branch has since moved — a 2026-07-19 re-fetch of master gives
# MD5 fbf72ee5f4e84f34c22af8b839852aed, and the warp + subpel rows are byte-identical in it,
# so the pin is stale provenance, not a data divergence),
# machine-generated; oracle scripts/refs/warp_filter_ref.py. Three regions: rows 0..63 peak
# tap 2, 64..127 peak tap 3, 128..191 peak tap 4; row 192 duplicates 191 (guard-tail sentinel).
# ================================================================
enum Av1WarpFilterConst {
    AV1_WARP_FILTER_ROWS        = 193;   # WARPEDPIXEL_PREC_SHIFTS*3 + 1
    AV1_WARP_FILTER_TAPS        = 8;
    AV1_WARPEDPIXEL_PREC_SHIFTS = 64;    # 1 << 6
    AV1_WARPEDDIFF_PREC_BITS    = 10;
}
var Av1_WarpFilter = 0;   # module-global pointer (193*8 i64, built once)
fn av1_wfill8(t, row, v0, v1, v2, v3, v4, v5, v6, v7) {
    var o = t + ((row * AV1_WARP_FILTER_TAPS) * 8);
    store64(o + 0, v0);   store64(o + 8, v1);   store64(o + 16, v2);  store64(o + 24, v3);
    store64(o + 32, v4);  store64(o + 40, v5);  store64(o + 48, v6);  store64(o + 56, v7);
    return 0;
}
fn av1_warp_filter_tbl(): i64 {
    if (Av1_WarpFilter != 0) { return Av1_WarpFilter; }
    var t = alloc(AV1_WARP_FILTER_ROWS * AV1_WARP_FILTER_TAPS * 8);
    if (t == 0) { return 0; }
    av1_wfill8(t,   0, 0, 0, 127, 1, 0, 0, 0, 0);
    av1_wfill8(t,   1, 0, 0 - 1, 127, 2, 0, 0, 0, 0);
    av1_wfill8(t,   2, 1, 0 - 3, 127, 4, 0 - 1, 0, 0, 0);
    av1_wfill8(t,   3, 1, 0 - 4, 126, 6, 0 - 2, 1, 0, 0);
    av1_wfill8(t,   4, 1, 0 - 5, 126, 8, 0 - 3, 1, 0, 0);
    av1_wfill8(t,   5, 1, 0 - 6, 125, 11, 0 - 4, 1, 0, 0);
    av1_wfill8(t,   6, 1, 0 - 7, 124, 13, 0 - 4, 1, 0, 0);
    av1_wfill8(t,   7, 2, 0 - 8, 123, 15, 0 - 5, 1, 0, 0);
    av1_wfill8(t,   8, 2, 0 - 9, 122, 18, 0 - 6, 1, 0, 0);
    av1_wfill8(t,   9, 2, 0 - 10, 121, 20, 0 - 6, 1, 0, 0);
    av1_wfill8(t,  10, 2, 0 - 11, 120, 22, 0 - 7, 2, 0, 0);
    av1_wfill8(t,  11, 2, 0 - 12, 119, 25, 0 - 8, 2, 0, 0);
    av1_wfill8(t,  12, 3, 0 - 13, 117, 27, 0 - 8, 2, 0, 0);
