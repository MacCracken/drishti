# Warped_Filters[offs][tap] — offs 0..192, tap 0..7.
fn av1_warp_filter(offs, tap): i64 {
    return load64(av1_warp_filter_tbl() + (((offs * AV1_WARP_FILTER_TAPS) + tap) * 8));
}
# byte address of the 8-tap filter row for a warp offset (offs 0..192).
fn av1_warp_filter_row(offs): i64 {
    return av1_warp_filter_tbl() + ((offs * AV1_WARP_FILTER_TAPS) * 8);
}

# one 8-tap dot product: sum_k f[k] * src[base + (k-3)*stride], src an i64 sample array,
# base/stride in ELEMENT units, f a filter-row byte address (av1_mc_subpel_row).
fn av1_mc_8tap(src, base, stride, f): i64 {
    var s = 0;
    var k = 0;
    while (k < 8) {
        s = s + (load64(f + (k * 8)) * load64(src + (((base + ((k - 3) * stride))) * 8)));
        k = k + 1;
    }
    return s;
}

# Subpel_Filters SET selection (spec 7.11.3.4). `filt` is ONE axis's interpolation filter
# (EIGHTTAP 0 / EIGHTTAP_SMOOTH 1 / EIGHTTAP_SHARP 2), `dim` that axis's PLANE-LOCAL block
# extent — predW = Block_Width[MiSize] >> subX (6.10.22), so `dim` can be as small as 2 (a
# BLOCK_4X4 luma block's 4:2:0 chroma), not merely 4. A block <= 4 samples wide/tall uses the
# narrow 4-tap variant of its filter: REGULAR and SHARP both map to set 3, SMOOTH to set 4
# (drishti indices — see the set-order note in the module header).
#
# TOTAL BY CONSTRUCTION: the leading `& 3` means every input, however hostile, yields a set in
# 0..4 — strictly inside AV1_SUBPEL_SETS. That masking is load-bearing, not decorative: the
# blob is exactly 6*15*8 i64 and av1_mc_subpel_row does no bounds check of its own, so an
# out-of-range set index reads off the end. put_8tap's horizontal call site was already masked
# (`filter_type & 3`); the VERTICAL one was a bare `filter_type >> 2` — folding both through
# this leaf closes that asymmetry.
fn av1_mc_filter_set(filt, dim): i64 {
    var f = filt & 3;
    # BILINEAR is NOT remapped at small extents — the spec's narrow-block branch has no `else`
    # (7.11.3.4: EIGHTTAP/SHARP -> 4, SMOOTH -> 5, and BILINEAR falls through unchanged), so
    # this test MUST precede the dim check. Reordering the two silently turns a 4-wide bilinear
    # block into 4-tap SMOOTH: plausible-looking wrong pixels, no error code.
    if (f == 3) { return 5; }
    if (dim <= 4) { return 3 + (f & 1); }
    return f;
}

# av1_mc_put_8tap (spec 7.11.3.4 / dav1d put_8tap_c) — motion-compensated prediction of a
# w x h block into dst[doff..] (row stride dstride) from the reference samples in the i64
# array `src` (row stride sstride), the block's top-left at element `soff`. The caller pads
# src by >=3 left/top and >=4 right/bottom so the 8-tap (taps -3..+4) stays in bounds. mx/my
# are the sub-pel positions (0..15; 0 = no sub-pel filter in that dimension). filter_type =
# h_set | (v_set << 2), each 0..2 (REGULAR/SMOOTH/SHARP); w<=4 / h<=4 use the w<=4 variant
# sets. Matches dav1d's intermediate precision (intermediate_bits = 4 for 8/10-bit, 2 for
# 12-bit): the H+V path filters horizontally into a (h+7)-row mid buffer at reduced shift,
# then vertically at higher shift; the 1D paths go straight to output precision. Returns
# DR_OK / DR_ERR_OOM.
# compound=0: the final per-ref prediction (Round2 to pixel + Clip1), as before.
# compound=1: the INTERMEDIATE (prep) prediction at bit_depth+ib precision — the V/1D
# rounds drop the extra ib bits and Clip1 (both applied by the compound combine). Spec
# 7.11.3.2 InterRound1 = 7 vs 11; dav1d prep_8tap; 3-source verified (compound_mc.md).
fn av1_mc_put_8tap(dst, doff, dstride, src, soff, sstride, w, h, mx, my, filter_type, bit_depth, compound): i64 {
    var ib = 4;
    if (bit_depth == 12) { ib = 2; }
    var irnd = 32 + ((1 << (6 - ib)) >> 1);   # dav1d intermediate_rnd (h-only path)
    var fh = 0;
    if (mx != 0) {
        fh = av1_mc_subpel_row(av1_mc_filter_set(filter_type, w), mx - 1);
    }
    var fv = 0;
    if (my != 0) {
        fv = av1_mc_subpel_row(av1_mc_filter_set(filter_type >> 2, h), my - 1);
    }
    if ((fh != 0) && (fv != 0)) {
        # 2-pass: horizontal into mid[(h+7) x w] (rows from src -3..h+3), then vertical.
        # The mid buffer comes from a lazily-built PERSISTENT module-global scratch, not a
        # per-call alloc: this kernel runs once per inter block, and the arena is never freed,
        # so per-call allocation would grow memory unbounded across a frame (the same reason
        # the MC driver keeps persistent scratch). Sized for the largest block; each call
        # fully writes the (h+7)*w cells it then reads.
        var mid = av1_mc_mid_scratch();
        if (mid == 0) { return DR_ERR_OOM; }
        var r = 0;
        while (r < (h + 7)) {
            var x = 0;
            while (x < w) {
                var hs = av1_mc_8tap(src, (soff + ((r - 3) * sstride)) + x, 1, fh);
                store64(mid + (((r * w) + x) * 8), av1_round2(hs, 6 - ib));
                x = x + 1;
            }
            r = r + 1;
        }
        r = 0;
        while (r < h) {
            var x = 0;
            while (x < w) {
                var vs = av1_mc_8tap(mid, ((r + 3) * w) + x, w, fv);
                var o2 = dr_clip1(av1_round2(vs, 6 + ib), bit_depth);
                if (compound != 0) { o2 = av1_round2(vs, 6); }
                store64(dst + (((doff + (r * dstride)) + x) * 8), o2);
                x = x + 1;
            }
            r = r + 1;
        }
        return DR_OK;
    }
    if (fh != 0) {
        # horizontal only.
        var r = 0;
        while (r < h) {
            var x = 0;
            while (x < w) {
                var hs = av1_mc_8tap(src, (soff + (r * sstride)) + x, 1, fh);
                var oh = dr_clip1((hs + irnd) >>> 6, bit_depth);
                if (compound != 0) { oh = av1_round2(hs, 6 - ib); }
                store64(dst + (((doff + (r * dstride)) + x) * 8), oh);
                x = x + 1;
            }
            r = r + 1;
        }
        return DR_OK;
    }
    if (fv != 0) {
        # vertical only.
        var r = 0;
        while (r < h) {
            var x = 0;
            while (x < w) {
                var vs = av1_mc_8tap(src, (soff + (r * sstride)) + x, sstride, fv);
                var ov = dr_clip1(av1_round2(vs, 6), bit_depth);
                if (compound != 0) { ov = av1_round2(vs, 6 - ib); }
                store64(dst + (((doff + (r * dstride)) + x) * 8), ov);
                x = x + 1;
            }
            r = r + 1;
        }
        return DR_OK;
    }
    # integer position: copy the block (compound: the intermediate is pixel << ib).
    var r = 0;
    while (r < h) {
        var x = 0;
        while (x < w) {
            var oi = load64(src + (((soff + (r * sstride)) + x) * 8));
            if (compound != 0) { oi = oi << ib; }
            store64(dst + (((doff + (r * dstride)) + x) * 8), oi);
            x = x + 1;
        }
        r = r + 1;
    }
    return DR_OK;
}

# ================================================================
# The SCALED convolve (spec 7.11.3.4 with a non-unit step) — motion compensation from a
# reference whose dimensions differ from the current frame's. Verified STANDALONE like
# put_8tap and the warp kernel; NOT yet wired into av1_mc_pred_core (roadmap.md).
#
# WHY IT IS A SEPARATE KERNEL AND NOT A put_8tap FLAG: when the step is not 1024, the
# sub-pel PHASE changes from output sample to output sample, so the filter row must be
# re-selected inside both loops rather than chosen once per block. That also means the
# source window is no longer a fixed (w+7) x (h+7) rectangle — at the 2x-upscale bound a
# 128-wide block reads 262 source samples — so the emu_edge gather that serves the unscaled
# path (Av1_McRect / Av1_McGather, sized AV1_MC_MAX_GATHER = 135) CANNOT be reused. This
# kernel therefore clamps PER TAP with av1_clip3 straight out of the DrFrame, exactly as
# the spec writes it, and needs no gather buffer at all.
# ================================================================

# Largest intermediate array the scaled H pass can produce:
#   ((AV1_MC_MAX_BLK - 1) * AV1_MC_MAX_STEP + 1023) >> 10) + 8  ==  ((127 * 2048 + 1023) >> 10) + 8
# The vertical pass reads mid[(p >> 10) + t] up to index AV1_MC_MAX_MID - 1 EXACTLY, for every
# legal step — the buffer is tight with ZERO slack, so a one-row sizing error is an immediate
# out-of-bounds read, not a latent one. tests/av1_mc.tcyr pins both the value and the fact
# that av1_mc_scaled_mid_h never exceeds it over the whole legal (h, step) space.
enum Av1McScaledBuf {
    AV1_MC_MAX_MID = 262;
}

# Kept OUT of av1_mc_drv_scratch deliberately: that function's OOM check is one big
# disjunction, and a partial failure there would return DR_OK with this pointer still 0,
# turning every store into a wild write to address 0. A dedicated lazy allocator whose
# caller null-checks the result (the av1_mc_mid_scratch precedent) also keeps 268 KB off the
# heap for the overwhelmingly common streams that never use a scaled reference.
#
# The caller's `mid == 0 -> DR_ERR_OOM` branch is UNWITNESSED by the suite: alloc never fails
# under test and drishti has no allocator fault-injection harness, so deleting that check
# leaves every test green. That is the same posture as every other lazy scratch in this file
# (av1_mc_mid_scratch, av1_mc_drv_scratch) and repo-wide — no DR_ERR_OOM branch anywhere is
# mutation-covered. Recorded rather than glossed: it is a real coverage gap, not a proof.
var Av1_McScaledMid = 0;
fn av1_mc_scaled_mid_scratch(): i64 {
    if (Av1_McScaledMid != 0) { return Av1_McScaledMid; }
    Av1_McScaledMid = alloc((AV1_MC_MAX_MID * AV1_MC_MAX_BLK) * 8);
    return Av1_McScaledMid;
}

# One 8-tap dot product against a reference plane ROW, clamping each tap's column to
# [0, lastX] (spec 7.11.3.4 reads ref[plane][Clip3(0,lastY,..)][Clip3(0,lastX,..)]).
# `sy` must ALREADY be clamped by the caller. dr_frame_get bounds-checks nothing, so these
# two clamps are the whole memory-safety story for the scaled path's reference reads.
# The clip is INSIDE the tap loop: hoisting it (clamping the base, then adding t) would read
# past the plane edge for any block whose window straddles it.
fn av1_mc_8tap_clipped(ref, plane, sy, sx0, lastx, f): i64 {
    var s = 0;
    var t = 0;
    while (t < 8) {
        var sx = av1_clip3(0, lastx, (sx0 + t) - 3);
        s = s + (load64(f + (t * 8)) * dr_frame_get(ref, plane, sx, sy));
        t = t + 1;
    }
    return s;
}

# av1_mc_put_8tap_scaled (spec 7.11.3.4) — predict a w x h block into out[doff..] (row
# stride dstride) from reference frame `ref` plane `plane`, given the 7.11.3.3 geometry
# (startX/startY and stepX/stepY, all in 1/1024 sample; av1_mc_scaled_start / _scaled_step).
# filt_x / filt_y are the interpolation filters 0..3. compound=0 gives the final Clip1'd
# pixel, compound=1 the bit_depth+ib intermediate for the compound combine — the same
# contract as av1_mc_put_8tap, whose rounding family (6-ib / 6+ib / 6) this mirrors exactly
# so the scaled and unscaled paths agree bit-for-bit at step 1024.
#
# lastX / lastY come from the REFERENCE's own plane dims rather than being passed in: making
# the clamp depend on a dimension the caller supplies would put every reference read's memory
# safety at the mercy of a check three call frames up.
#
# Phase 0 is handled INLINE in both passes rather than by a table row, because drishti's
# Subpel_Filters (dav1d convention) drops the spec's phase-0 identity row — index p here is
# the spec's phase p+1. At phase 0 the identity row {0,0,0,64,0,0,0,0} makes the H dot
# Round2(64*px, 6-ib) == px << ib and the V dot Round2(64*m, 6+ib) == av1_round2(m, ib), and
# the sample used is the CENTRE tap (t == 3).
fn av1_mc_put_8tap_scaled(out, doff, dstride, ref, plane, startx, starty, stepx, stepy,
w, h, filt_x, filt_y, bit_depth, compound): i64 {
    if ((out == 0) || (ref == 0)) { return DR_ERR_BOUNDS; }
    if ((plane < 0) || (plane >= dr_frame_num_planes(ref))) { return DR_ERR_BOUNDS; }
    # These caps are NOT redundant with the caller's. (h - 1) * stepy is an i64 multiply that
    # WRAPS: a hostile h near 2^54 with stepy 1024 wraps the product to 0, making
    # intermediateHeight 8 — which would sail past any bound check on the height alone while
    # the vertical loop ran 2^54 iterations off the end of the buffer. Bound the INPUTS.
    if ((w < 1) || (h < 1) || (w > AV1_MC_MAX_BLK) || (h > AV1_MC_MAX_BLK)) { return DR_ERR_BOUNDS; }
    if ((stepx < 1) || (stepy < 1) || (stepx > AV1_MC_MAX_STEP) || (stepy > AV1_MC_MAX_STEP)) {
        return DR_ERR_BOUNDS;
    }
    # av1_mc_subpel_row does no bounds check and the blob is exactly 6*15*8 i64; the filter
    # set must land inside it. av1_mc_filter_set is total, but reject junk here anyway so a
    # caller cannot quietly get set 3 for a filter it never meant.
    if ((filt_x < 0) || (filt_x > 3) || (filt_y < 0) || (filt_y > 3)) { return DR_ERR_BOUNDS; }
    var mid = av1_mc_scaled_mid_scratch();
    if (mid == 0) { return DR_ERR_OOM; }
    var ib = 4;
    if (bit_depth == 12) { ib = 2; }
    var lastx = dr_frame_plane_width(ref, plane) - 1;
    var lasty = dr_frame_plane_height(ref, plane) - 1;
    if ((lastx < 0) || (lasty < 0)) { return DR_ERR_BOUNDS; }
    var inter_h = av1_mc_scaled_mid_h(h, stepy);
    if (inter_h > AV1_MC_MAX_MID) { return DR_ERR_BOUNDS; }   # defence in depth
    var hset = av1_mc_filter_set(filt_x, w);
    var vset = av1_mc_filter_set(filt_y, h);

    # ---- horizontal pass: intermediate[inter_h][w], source rows (starty >> 10) + r - 3 ----
    var r = 0;
    while (r < inter_h) {
        var sy = av1_clip3(0, lasty, ((starty >>> AV1_SCALE_SUBPEL_BITS) + r) - 3);
        var c = 0;
        while (c < w) {
            var p = startx + (stepx * c);
            var ph = (p >>> 6) & AV1_SUBPEL_MASK;
            var sx0 = p >>> AV1_SCALE_SUBPEL_BITS;
            var v = 0;
            if (ph == 0) {
                v = dr_frame_get(ref, plane, av1_clip3(0, lastx, sx0), sy) << ib;
            } else {
                v = av1_round2(av1_mc_8tap_clipped(ref, plane, sy, sx0, lastx,
                av1_mc_subpel_row(hset, ph - 1)), 6 - ib);
            }
            store64(mid + (((r * w) + c) * 8), v);
            c = c + 1;
        }
        r = r + 1;
    }

    # ---- vertical pass: only the FRACTIONAL part of starty is used here, because its
    # integer part was already consumed as the horizontal pass's row origin. ----
    r = 0;
    while (r < h) {
        var p = (starty & 1023) + (stepy * r);
        var ph = (p >>> 6) & AV1_SUBPEL_MASK;
        var row = p >>> AV1_SCALE_SUBPEL_BITS;
        var c = 0;
        while (c < w) {
            var o = 0;
            if (ph == 0) {
                var m = load64(mid + ((((row + 3) * w) + c) * 8));
                o = m;
                if (compound == 0) { o = dr_clip1(av1_round2(m, ib), bit_depth); }
            } else {
                var vs = av1_mc_8tap(mid, ((row + 3) * w) + c, w, av1_mc_subpel_row(vset, ph - 1));
                o = av1_round2(vs, 6);
                if (compound == 0) { o = dr_clip1(av1_round2(vs, 6 + ib), bit_depth); }
            }
            store64(out + (((doff + (r * dstride)) + c) * 8), o);
            c = c + 1;
        }
        r = r + 1;
    }
    return DR_OK;
}

# av1_warp_affine_8x8 (spec 7.11.3.5 / dav1d warp_affine_8x8_c) — the per-8x8 warp KERNEL:
# a two-pass separable filter of the padded reference block `src` (top-left of THIS 8x8 at
# element `soff`, row stride sstride) into the 8x8 output dst[doff..] (row stride dstride),
# using the shear params alpha/beta/gamma/delta (0.7.94 setup_shear) and the sub-pixel phase
# seeds mx/my. Reuses Warped_Filters (0.7.95) via av1_warp_filter_row + av1_mc_8tap.
#   Horizontal (15 rows x 8 cols -> the signed `mid` buffer): per row the phase is mx+beta*r,
#   per col it steps by alpha; offs = 64 + Round2(tmx, 10) (arithmetic — tmx may go slightly
#   negative), the 8-tap dot rounds Round2(., 7-ib). Vertical (8x8): phase my+delta*r stepping
#   by gamma per col, dot over mid rows r..r+7, Round2(., 7+ib) then Clip1.
# CRITICAL: the warp table is SPEC-LITERAL (rows sum to 128), so the rounds are the FULL 7-ib /
# 7+ib — NOT put_8tap's 6-ib / 6+ib (whose subpel table is halved to 64). ib = 4 (8/10-bit) or
# 2 (12-bit). The kernel does NO Clip3 of source coords — it trusts the caller's emu_edge gather
# (it reads rows/cols dy-3..dy+11 / dx-3..dx+11). Standalone-verified like av1_mc_put_8tap; the
# mx/my derivation + the 8x8 sub-block loop + the emu_edge gather + the LOCALWARP un-gate are the
# next bite. Returns DR_OK / DR_ERR_OOM (the shared mid scratch).
fn av1_warp_affine_8x8(dst, doff, dstride, src, soff, sstride,
alpha, beta, gamma, delta, mx, my, bit_depth, compound): i64 {
    var ib = 4;
    if (bit_depth == 12) { ib = 2; }
    var mid = av1_mc_mid_scratch();         # 15*8 signed intermediates fit easily
    if (mid == 0) { return DR_ERR_OOM; }
    var r = 0;
    while (r < 15) {
        var tmx = mx + (beta * r);
        var c = 0;
        while (c < 8) {
            var offs = 64 + av1_round2(tmx, 10);
            var base = (soff + ((r - 3) * sstride)) + c;
            var hs = av1_mc_8tap(src, base, 1, av1_warp_filter_row(offs));
            store64(mid + (((r * 8) + c) * 8), av1_round2(hs, 7 - ib));
            tmx = tmx + alpha;
            c = c + 1;
        }
        r = r + 1;
    }
    r = 0;
    while (r < 8) {
        var tmy = my + (delta * r);
        var c2 = 0;
        while (c2 < 8) {
            var offs2 = 64 + av1_round2(tmy, 10);
            var base2 = (((r + 3) * 8) + c2);
            var vs = av1_mc_8tap(mid, base2, 8, av1_warp_filter_row(offs2));
            # single-ref: Clip1(Round2(vs, 7+ib)) = final pixel. compound (spec 7.11.3.5 isCompound==1,
            # 3-source confirmed): Round2(vs, 7) NO Clip1 -> a bit_depth+ib intermediate byte-identical in
            # scale to compound put_8tap's Round2(vs, 6), so the SAME combine consumes it.
            var ov = dr_clip1(av1_round2(vs, 7 + ib), bit_depth);
            if (compound != 0) { ov = av1_round2(vs, 7); }
            store64(dst + (((doff + (r * dstride)) + c2) * 8), ov);
            tmy = tmy + gamma;
            c2 = c2 + 1;
        }
        r = r + 1;
    }
    return DR_OK;
}

# av1_mc_emu_edge (dav1d emu_edge_c, src/mc_tmpl.c) — fetch a bw x bh block from the
# reference plane `ref` (visible size iw x ih, row stride rstride, plane origin roff, all in
# ELEMENT units of an i64 sample array) at source position (x, y), which MAY lie partly or
# wholly outside the frame. Out-of-bounds reads clamp to the nearest edge pixel (the AV1
# frame-boundary MC rule, spec 7.11.3.2): the visible portion is copied, then the top / bottom
# rows and left / right columns are replicated outward to fill the block. Writes into dst[doff..]
# (row stride dstride). This is the padded-block fetch that feeds av1_mc_put_8tap when a motion
# vector points near or past a frame edge; the MC driver (grows next; roadmap.md) is the caller.
# Precondition (as in dav1d): the block overlaps the frame by >=1 pixel in each axis, i.e.
# left+right < bw and top+bottom < bh — the MV clamp (spec 7.10.2.14) guarantees it. Returns DR_OK.
fn av1_mc_emu_edge(bw, bh, iw, ih, x, y, dst, doff, dstride, ref, roff, rstride): i64 {
    var ro = (roff + (av1_clip3(0, ih - 1, y) * rstride)) + av1_clip3(0, iw - 1, x);
    var left = av1_clip3(0, bw - 1, 0 - x);
    var right = av1_clip3(0, bw - 1, (x + bw) - iw);
    var top = av1_clip3(0, bh - 1, 0 - y);
    var bot = av1_clip3(0, bh - 1, (y + bh) - ih);
    var cw = (bw - left) - right;   # visible width  (>=1 by precondition)
    var ch = (bh - top) - bot;      # visible height (>=1 by precondition)
    # visible rows, each copied then extended left / right along the line.
    var cy = 0;
    while (cy < ch) {
        var db = doff + ((top + cy) * dstride);   # dst row base (element)
        var sb = ro + (cy * rstride);             # ref row base (element)
        var cx = 0;
        while (cx < cw) {
            store64(dst + ((db + (left + cx)) * 8), load64(ref + ((sb + cx) * 8)));
            cx = cx + 1;
        }
        var e = 0;
        while (e < left) {                        # extend left edge
            store64(dst + ((db + e) * 8), load64(dst + ((db + left) * 8)));
            e = e + 1;
        }
        e = 0;
        while (e < right) {                       # extend right edge
            store64(dst + ((db + ((left + cw) + e)) * 8), load64(dst + ((db + ((left + cw) - 1)) * 8)));
            e = e + 1;
        }
        cy = cy + 1;
    }
    # top rows replicate the first visible row (row index `top`, already edge-extended).
    var ty = 0;
    while (ty < top) {
        var srow = doff + (top * dstride);
        var drow = doff + (ty * dstride);
        var c = 0;
        while (c < bw) {
            store64(dst + ((drow + c) * 8), load64(dst + ((srow + c) * 8)));
            c = c + 1;
        }
        ty = ty + 1;
    }
    # bottom rows replicate the previous (already written) row.
    var by = 0;
    while (by < bot) {
        var r = (top + ch) + by;
        var drow = doff + (r * dstride);
        var prow = doff + ((r - 1) * dstride);
        var c = 0;
        while (c < bw) {
            store64(dst + ((drow + c) * 8), load64(dst + ((prow + c) * 8)));
            c = c + 1;
        }
        by = by + 1;
    }
    return DR_OK;
}

# ================================================================
# The MC DRIVER — av1_mc_pred_block (spec 7.11.3.1 steps 10 + 13 + the non-compound
# write-back), for the base inter case: single reference, translation-only (no warp),
# non-compound, UNSCALED (reference plane dims == current plane dims). It composes the
# two reference-tested leaf kernels: emu_edge gathers the (possibly out-of-frame,
# edge-clamped) padded reference block, put_8tap filters it into the destination frame.
#
# Geometry (spec 7.11.3.3 reduced to the unscaled case): with equal frame dims,
# xScale == yScale == 1 << REF_SCALE_SHIFT, so startX = ((x << 4) + ((2*mv) >> subX)) << 6
# + 32 and stepX = 1024 exactly. Every sample position p = startX + 1024*c then reduces to
#   pos16  = (x << 4) + ((2*mv) >> sub)      (1/16-pel block position; mv is 1/8 LUMA pel,
#                                             halved per axis for subsampled chroma planes)
#   integer top-left  = pos16 >> 4  =  (p >> 10) - c       (arithmetic shift: floor)
#   1/16-pel phase    = pos16 & 15  =  (p >> 6) & SUBPEL_MASK
# (the halfSample / off rounding terms of 7.11.3.3 cancel exactly at these two
# extractions — verified against a literal port of the full scaling process).
#
# Gather (spec 7.11.3.4): the reference reads are Clip3-clamped to the plane per sample.
# The driver copies the exact clamped read range [rx0..rx1] x [ry0..ry1] (a plain u16 ->
# i64 format copy, no geometry) and lets emu_edge replicate it outward — clamping to that
# rect's edges is pixel-identical to the spec's per-sample plane clamp, because the rect
# endpoints ARE the clamped extremes of the wanted window. The 8-tap window needs 3
# samples before / 4 after the block per axis, only when that axis has a nonzero phase.
# ================================================================

enum Av1McDrv {
    AV1_MC_MAX_BLK    = 128;   # largest inter block dimension (128x128 superblock)
    AV1_MC_MAX_GATHER = 135;   # MAX_BLK + 7 taps of padding per axis
}

# lazily-built driver scratch blobs (per-call allocation would grow the arena unbounded
# across a frame's blocks; sized for the largest block once).
var Av1_McRect = 0;     # visible-rect copy      (<= 135*135 i64)
var Av1_McGather = 0;   # padded gather block    (<= 135*135 i64)
var Av1_McOut = 0;      # filtered output block  (<= 128*128 i64)
var Av1_McMid = 0;      # put_8tap H+V mid pass  ((MAX_BLK+7)*MAX_BLK i64)
var Av1_McTmp = 0;      # 2nd compound intermediate (<= 128*128 i64)
var Av1_McMask = 0;     # DIFFWTD per-LUMA-pixel mask 0..64 (<= 128*128 i64); built on plane 0
var Av1_McMaskW = 0;    # luma mask build width  — chroma subsamples over the TRUE luma stride
var Av1_McMaskH = 0;    # luma mask build height
# Dedicated per-8x8 warp KERNEL output (64 i64), kept SEPARATE from McTmp/McOut so that
# av1_warp_pred_gen can write back into them (inter-intra -> McOut; compound -> BOTH).
var Av1_McWarp8 = 0;

# Persistent mid-pass scratch for av1_mc_put_8tap's 2-pass (H+V) path. Lazily built once,
# sized for the largest block ((h+7)*w with h,w <= AV1_MC_MAX_BLK). Called (via forward
# reference) from put_8tap, which fully writes the (h+7)*w cells before reading them.
fn av1_mc_mid_scratch(): i64 {
    if (Av1_McMid != 0) { return Av1_McMid; }
    Av1_McMid = alloc(((AV1_MC_MAX_BLK + 7) * AV1_MC_MAX_BLK) * 8);
    return Av1_McMid;
}

fn av1_mc_drv_scratch(): i64 {
    if (Av1_McOut != 0) { return DR_OK; }
    var g = AV1_MC_MAX_GATHER * AV1_MC_MAX_GATHER * 8;
    Av1_McRect = alloc(g);
    Av1_McGather = alloc(g);
    Av1_McOut = alloc(AV1_MC_MAX_BLK * AV1_MC_MAX_BLK * 8);
    Av1_McTmp = alloc(AV1_MC_MAX_BLK * AV1_MC_MAX_BLK * 8);   # 2nd compound intermediate
    Av1_McMask = alloc(AV1_MC_MAX_BLK * AV1_MC_MAX_BLK * 8);  # DIFFWTD luma mask
    Av1_McWarp8 = alloc(8 * 8 * 8);                           # per-8x8 warp kernel output
    if ((Av1_McRect == 0) || (Av1_McGather == 0) || (Av1_McOut == 0) || (Av1_McTmp == 0)
    || (Av1_McMask == 0) || (Av1_McWarp8 == 0)) {
        Av1_McOut = 0;
        return DR_ERR_OOM;
    }
    return DR_OK;
}

# Reference-frame COMPATIBILITY (sample format): a reference whose bit depth or subsampling
# differs from the current frame cannot be predicted from at all — the sample grids are not
# comparable, and no amount of scaling reconciles them. Returns 1 if compatible.
#
# Kept SEPARATE from av1_mc_ref_unscaled below because the two travel apart: format
# incompatibility is a permanent hard reject on every path, whereas dimension inequality is
# merely "this reference is scaled", which the translation MC path will eventually handle and
# the warp path never can (spec 7.11.3.1 step 7 forbids warp with a scaled reference).
fn av1_mc_ref_compat(ref, dst): i64 {
    if (dr_frame_bit_depth(ref) != dr_frame_bit_depth(dst)) { return 0; }
    if (dr_frame_subx(ref) != dr_frame_subx(dst)) { return 0; }
    if (dr_frame_suby(ref) != dr_frame_suby(dst)) { return 0; }
    return 1;
}

# Reference-frame UNSCALEDNESS: does `ref` share the current frame's geometry exactly, so that
# the 7.11.3.3 scaling collapses to the identity? Returns 1 if unscaled.
#
# Compares the LUMA frame dims, not just this plane's dims: spec 7.11.3.3 derives scaledness
# from luma (RefUpscaledWidth vs FrameWidth), and subsampled chroma planes COLLIDE across
# different luma sizes — e.g. luma 24x18 and 23x17 both give 12x9 chroma at 4:2:0 — so a
# plane-only check would silently accept a scaled reference and emit wrong chroma pixels.
# The plane-dim conjuncts are then implied (plane dims are derived from luma dims and
# subsampling, frame.cyr) but are kept explicit: they cost nothing and they document that the
# plane actually indexed is in range.
fn av1_mc_ref_unscaled(ref, dst, plane): i64 {
    if (dr_frame_width(ref) != dr_frame_width(dst)) { return 0; }
    if (dr_frame_height(ref) != dr_frame_height(dst)) { return 0; }
    if (dr_frame_plane_width(ref, plane) != dr_frame_plane_width(dst, plane)) { return 0; }
    if (dr_frame_plane_height(ref, plane) != dr_frame_plane_height(dst, plane)) { return 0; }
    return 1;
}

# 1/16-pel position of a block edge (spec 7.11.3.3, unscaled): x in plane samples, mv in
# 1/8 LUMA pel, sub the plane's subsampling in that axis. Arithmetic shift — mv may be
# negative and the split below needs floor semantics.
fn av1_mc_pos16(x, mv, sub): i64 {
    return (x << 4) + ((2 * mv) >>> sub);
}

# ================================================================
# The FULL 7.11.3.3 motion vector scaling process — the geometry a SCALED reference needs.
# Pure arithmetic leaves, KAT'd but not yet wired (roadmap.md: the scaled convolve consumes
# them in the next bite). The unscaled path keeps using av1_mc_pos16's collapsed form; these
# reduce to exactly that when the scale factor is 1 << REF_SCALE_SHIFT, which the KATs pin.
#
# Units: startX/startY and stepX/stepY are 1/1024 sample (SCALE_SUBPEL_BITS); av1_mc_pos16 is
# 1/16 sample (SUBPEL_BITS); mv is 1/8 LUMA sample.
# ================================================================
enum Av1McScale {
    AV1_SCALE_SUBPEL_BITS = 10;   # spec SCALE_SUBPEL_BITS — 1/1024 sample
    AV1_SUBPEL_BITS       = 4;    # spec SUBPEL_BITS       — 1/16 sample
    AV1_SUBPEL_MASK       = 15;   # spec SUBPEL_MASK       — (1 << SUBPEL_BITS) - 1
    # halfSample = 1 << (SUBPEL_BITS - 1): half a sample in 1/16 units.
    AV1_MC_HALF_SAMPLE    = 8;
    # off = (1 << (SCALE_SUBPEL_BITS - SUBPEL_BITS)) / 2: the filter-tap rounding offset.
    AV1_MC_SCALE_OFF      = 32;
    # The conformance bounds below cap stepX/stepY at 2048 (a 2x-larger reference) and floor
    # them at 64 (a 16x-smaller one). Every scaled buffer bound derives from the 2048 end.
    AV1_MC_MAX_STEP       = 2048;
}

# Conformance (7.11.3.3): "It is a requirement of bitstream conformance that all the
# following conditions are satisfied" — the reference may be at most TWICE the current
# frame's size, and the current frame at most SIXTEEN times the reference's. Returns 1 if
# the ratio is codeable. `ruw` is RefUpscaledWidth, `rfh` RefFrameHeight (the width/height
# asymmetry is the spec's — superres never changes height, and MC reads the upscaled plane).
fn av1_mc_scale_valid(ruw, rfh, fw, fht): i64 {
    if ((ruw < 1) || (rfh < 1) || (fw < 1) || (fht < 1)) { return 0; }
    if ((2 * fw) < ruw) { return 0; }
    if ((2 * fht) < rfh) { return 0; }
    if (fw > (16 * ruw)) { return 0; }
    if (fht > (16 * rfh)) { return 0; }
    return 1;
}

# stepX = Round2Signed( xScale, REF_SCALE_SHIFT - SCALE_SUBPEL_BITS )  — shift 4.
# The scale factor is always positive, so Round2Signed's away-from-zero branch never fires
# here; it is written faithfully anyway. What this DOES witness is the rounding bias: a bare
# arithmetic shift truncates and loses a step for any scale that is not a multiple of 16.
fn av1_mc_scaled_step(scale): i64 {
    return av1_round2_signed(scale, AV1_REF_SCALE_SHIFT - AV1_SCALE_SUBPEL_BITS);
}

# startX = Round2Signed( baseX, REF_SCALE_SHIFT + SUBPEL_BITS - SCALE_SUBPEL_BITS ) + off,
# where  origX = (x << SUBPEL_BITS) + ((2 * mv) >> subX) + halfSample   [= pos16 + 8]
# and    baseX = origX * xScale - (halfSample << REF_SCALE_SHIFT).
#
# The halfSample pair is what makes scaling sample-CENTRE-relative: it shifts into the centre
# of the top-left sample, scales, then shifts back. The two terms cancel each other JOINTLY
# when scale is exactly 1 << REF_SCALE_SHIFT — (p+8)*S - 8*(1<<14) reduces to p*S there — so
# dropping BOTH is invisible to any unscaled fixture and shows up only under real scaling,
# where the residue is 8*(scale - (1<<14)). (Dropping just ONE breaks the 1:1 case too, so
# that weaker slip is caught anywhere; it is the joint drop the scaled KATs are needed for.)
#
# Round2Signed (NOT plain Round2) is load-bearing here and only here: baseX goes negative for
# a block near the frame origin with a negative MV, and the spec's rounding is away from zero.
fn av1_mc_scaled_start(x, mv, sub, scale): i64 {
    var orig = av1_mc_pos16(x, mv, sub) + AV1_MC_HALF_SAMPLE;
    var base = (orig * scale) - (AV1_MC_HALF_SAMPLE << AV1_REF_SCALE_SHIFT);
    return av1_round2_signed(base,
    (AV1_REF_SCALE_SHIFT + AV1_SUBPEL_BITS) - AV1_SCALE_SUBPEL_BITS) + AV1_MC_SCALE_OFF;
}

# lastX = ((RefUpscaledWidth + subX) >> subX) - 1  (7.11.3.4) — the bottom-right sample of
# the REFERENCE plane, the per-tap Clip3 bound. Derive it from the REFERENCE's own dims and
# subsampling: making the clamp depend on the current frame's would put every reference read's
# memory safety at the mercy of a subsampling-match check three call frames away.
fn av1_mc_scaled_last(ref_dim, sub): i64 {
    return ((ref_dim + sub) >>> sub) - 1;
}

# intermediateHeight = (((h - 1) * yStep + (1 << SCALE_SUBPEL_BITS) - 1) >> SCALE_SUBPEL_BITS) + 8
# — the row count of the horizontal pass's intermediate array (7.11.3.4).
#
# THE CEILING IS LOAD-BEARING. The floor form under-allocates by one row whenever
# ((h-1) * yStep) is not a multiple of 1024, and the vertical pass reads mid[(p >> 10) + t]
# up to exactly intermediateHeight - 1 — the buffer is TIGHT, with zero slack, so a one-row
# sizing error is an immediate out-of-bounds read rather than a latent one.
fn av1_mc_scaled_mid_h(h, step_y): i64 {
    var span = ((h - 1) * step_y) + ((1 << AV1_SCALE_SUBPEL_BITS) - 1);
    return (span >>> AV1_SCALE_SUBPEL_BITS) + 8;
}

# av1_mc_pred_block — predict one w x h inter block into dst[plane] at plane coords
# (x, y), from the same-sized reference frame `ref`, motion vector (mv_row, mv_col) in
# 1/8 LUMA pel (spec mv[0]/mv[1]), interpolation filters filt_x / filt_y in 0..3
# (EIGHTTAP / EIGHTTAP_SMOOTH / EIGHTTAP_SHARP / BILINEAR — spec InterpFilters[..][1] /
# [..][0]; the w<=4 / h<=4 4-tap remap happens inside put_8tap, and does NOT apply to
# BILINEAR). Any MV is safe: out-of-frame reads clamp to the edge (7.11.3.4).
# Returns DR_OK, or
#   DR_ERR_UNSUPPORTED — scaled / mismatched reference (the last bite of the inter
#                        arc; roadmap.md)
#   DR_ERR_BOUNDS      — bad plane / block dims / block outside the destination plane
#   DR_ERR_OOM         — scratch allocation failure
# The MC CORE (7.11.3.3/4): produce one reference's prediction into `out` (a w*h
# buffer). compound=0 -> the final Clip1'd pixel; compound=1 -> the intermediate
# (bit_depth+ib precision) for the compound combine. Shared by the single-ref
# av1_mc_pred_block and the two-ref av1_mc_pred_compound. `dst` supplies the geometry
# (dims/bit-depth/subsampling); `ref` is the source reference frame.
fn av1_mc_pred_core(out, dst, ref, plane, x, y, w, h, mv_row, mv_col, filt_x, filt_y, compound): i64 {
    if ((dst == 0) || (ref == 0)) { return DR_ERR_BOUNDS; }
    if ((plane < 0) || (plane >= dr_frame_num_planes(dst)) || (plane >= dr_frame_num_planes(ref))) {
        return DR_ERR_BOUNDS;
    }
    if ((w < 1) || (h < 1) || (w > AV1_MC_MAX_BLK) || (h > AV1_MC_MAX_BLK)) { return DR_ERR_BOUNDS; }
    if ((filt_x < 0) || (filt_x > 3) || (filt_y < 0) || (filt_y > 3)) { return DR_ERR_BOUNDS; }
    var bd = dr_frame_bit_depth(dst);
    var pw = dr_frame_plane_width(dst, plane);
    var ph = dr_frame_plane_height(dst, plane);
    # Format incompatibility is permanent; unscaledness is a limitation for now (roadmap.md —
    # scaled-reference prediction is the last inter bite). Both reject here.
    if ((av1_mc_ref_compat(ref, dst) == 0) || (av1_mc_ref_unscaled(ref, dst, plane) == 0)) {
        return DR_ERR_UNSUPPORTED;
    }
    # overflow-safe block-inside-plane check: form the bound by SUBTRACTION (pw - w, ph - h
    # cannot overflow — w,h in [1,128], pw,ph in [1,16384]) rather than the addition x + w,
    # which would wrap for a hostile x near i64-max and slip an unclamped coord into the
    # write-back. x,y already proven >= 0 above, so a negative (pw - w) rejects everything.
    if ((x < 0) || (y < 0) || (x > (pw - w)) || (y > (ph - h))) { return DR_ERR_BOUNDS; }
    if (av1_mc_drv_scratch() != DR_OK) { return DR_ERR_OOM; }
    # ---- 7.11.3.3 (unscaled): integer top-left + 1/16-pel phase per axis ----
    var sx = 0;
    var sy = 0;
    if (plane > 0) {
        sx = dr_frame_subx(dst);
        sy = dr_frame_suby(dst);
    }
    var p16x = av1_mc_pos16(x, mv_col, sx);
    var p16y = av1_mc_pos16(y, mv_row, sy);
    var ix = p16x >>> 4;
    var fx = p16x & 15;
    var iy = p16y >>> 4;
    var fy = p16y & 15;
    var nh = 0;
    if (fx != 0) { nh = 1; }
    var nv = 0;
    if (fy != 0) { nv = 1; }
    var gx = ix - (3 * nh);
    var gw = w + (7 * nh);
    var gy = iy - (3 * nv);
    var gh = h + (7 * nv);
    # ---- 7.11.3.4 gather: exact clamped read range, format-copied, emu_edge-extended ----
    var rx0 = av1_clip3(0, pw - 1, gx);
    var rx1 = av1_clip3(0, pw - 1, (gx + gw) - 1);
    var ry0 = av1_clip3(0, ph - 1, gy);
    var ry1 = av1_clip3(0, ph - 1, (gy + gh) - 1);
    var rw = (rx1 - rx0) + 1;
    var rh = (ry1 - ry0) + 1;
    var rr = 0;
    while (rr < rh) {
        var rc = 0;
        while (rc < rw) {
            store64(Av1_McRect + (((rr * rw) + rc) * 8), dr_frame_get(ref, plane, rx0 + rc, ry0 + rr));
            rc = rc + 1;
        }
        rr = rr + 1;
    }
    av1_mc_emu_edge(gw, gh, rw, rh, gx - rx0, gy - ry0, Av1_McGather, 0, gw, Av1_McRect, 0, rw);
    # ---- put_8tap: block top-left sits (3*nv, 3*nh) into the padded gather ----
    return av1_mc_put_8tap(out, 0, w, Av1_McGather, ((3 * nv) * gw) + (3 * nh), gw,
    w, h, fx, fy, filt_x | (filt_y << 2), bd, compound);
}
# single-ref MC (7.11.3.1 non-compound): produce the final prediction and write it
# into the frame. Returns DR_OK / DR_ERR_* (see av1_mc_pred_core).
fn av1_mc_pred_block(dst, ref, plane, x, y, w, h, mv_row, mv_col, filt_x, filt_y): i64 {
    if (av1_mc_drv_scratch() != DR_OK) { return DR_ERR_OOM; }
    var e = av1_mc_pred_core(Av1_McOut, dst, ref, plane, x, y, w, h, mv_row, mv_col,
    filt_x, filt_y, 0);
    if (e != DR_OK) { return e; }
    var r = 0;
    while (r < h) {
        var c = 0;
        while (c < w) {
            dr_frame_set(dst, plane, x + c, y + r, load64(Av1_McOut + (((r * w) + c) * 8)));
            c = c + 1;
        }
        r = r + 1;
    }
    return DR_OK;
}
# av1_mc_out_buf — hand the driver's filtered-output scratch (Av1_McOut, <=128x128 i64, stride = the w
# passed to av1_mc_pred_core) to the OBMC path (av1_intertile), which MC's each neighbour overlap into it
# via av1_mc_pred_core(..., compound=0) then blends. Free scratch once the plane's own MC flushed to the
# frame. Returns 0 on OOM. (The driver's var is module-local to av1_mc; this is its cross-module handle.)
fn av1_mc_out_buf(): i64 {
    if (av1_mc_drv_scratch() != DR_OK) { return 0; }
    return Av1_McOut;
}
# av1_warp_pred_block (spec 7.11.3.5 driver / dav1d recon_tmpl.c warp_affine) — warp-MC
# prediction of a w x h plane block into `dst` from `ref` using the warp model `wm`
# (Av1WarpModel: wmmat[0..5] + shear alpha/beta/gamma/delta from setup_shear 0.7.94). Per 8x8
# sub-block it projects the block centre through the model to the integer source top-left
# (ix4-4, iy4-4) + the sub-pixel phase seeds mx/my (folded -4a-7b / -4g-4d & ~0x3f, matching
# dav1d/libaom), gathers a 15x15 padded reference block (rect-copy + emu_edge, like
# av1_mc_pred_core), calls av1_warp_affine_8x8 (0.7.96), and writes the 8x8 output back CROPPED
# to the block (so 4x4 chroma / non-multiple-of-8 extents write only their valid cells).
# NON-COMPOUND. Chroma lifts the centre <<sub into the LUMA grid the wmmat is defined in, then
# drops the projection >>>sub back to the plane grid. The caller (next bite) validates the model
# (warpValid), selects local-vs-global, and gates chroma-too-small; this predictor trusts them.
# (x,y,w,h) in the plane's subsampled coords. Returns DR_OK / DR_ERR_*.
# av1_warp_pred_gen — warp-predict a w x h block (spec 7.11.3.5). Write-back target is the FRAME dst[plane]
# at (x,y) when out_buf==0, else the block-relative buffer out_buf at stride out_stride (used by inter-intra
# to warp the inter part into Av1_McOut, and by compound to warp each ref into Av1_McTmp/Av1_McOut). compound
# selects the kernel's vertical precision (1 = intermediate, no Clip1). The per-8x8 kernel writes the dedicated
# Av1_McWarp8 (kept separate from McTmp/McOut so the write-back can target EITHER without a self-copy), then
# the cropped write-back copies to the chosen target. dst is still used for validation (bit depth / dims).
fn av1_warp_pred_gen(dst, ref, plane, x, y, w, h, wm, out_buf, out_stride, compound): i64 {
    if ((dst == 0) || (ref == 0) || (wm == 0)) { return DR_ERR_BOUNDS; }
    if ((plane < 0) || (plane >= dr_frame_num_planes(dst)) || (plane >= dr_frame_num_planes(ref))) {
        return DR_ERR_BOUNDS;
    }
    if ((w < 1) || (h < 1) || (w > AV1_MC_MAX_BLK) || (h > AV1_MC_MAX_BLK)) { return DR_ERR_BOUNDS; }
    var bd = dr_frame_bit_depth(dst);
    var pw = dr_frame_plane_width(dst, plane);
    var ph = dr_frame_plane_height(dst, plane);
    # Unscaled ref only — and here that is PERMANENT, not a limitation: spec 7.11.3.1 step 7
    # gates useWarp==2 on is_scaled(refFrame)==0, and read_motion_mode (5.11.27) refuses to
    # code the motion_mode symbol at all when is_scaled(RefFrame[0]), so LOCALWARP is
    # unreachable too. Warp never predicts from a scaled reference. Shares the leaves with
    # av1_mc_pred_core so the two gates cannot drift apart.
    if ((av1_mc_ref_compat(ref, dst) == 0) || (av1_mc_ref_unscaled(ref, dst, plane) == 0)) {
        return DR_ERR_UNSUPPORTED;
    }
    if ((x < 0) || (y < 0) || (x > (pw - w)) || (y > (ph - h))) { return DR_ERR_BOUNDS; }
    if (av1_mc_drv_scratch() != DR_OK) { return DR_ERR_OOM; }
    var m0 = av1_warp_model_param(wm, 0);
    var m1 = av1_warp_model_param(wm, 1);
    var m2 = av1_warp_model_param(wm, 2);
    var m3 = av1_warp_model_param(wm, 3);
    var m4 = av1_warp_model_param(wm, 4);
    var m5 = av1_warp_model_param(wm, 5);
    var alpha = av1_warp_model_alpha(wm);
    var beta = av1_warp_model_beta(wm);
    var gamma = av1_warp_model_gamma(wm);
    var delta = av1_warp_model_delta(wm);
    var subx = 0;
    var suby = 0;
    if (plane > 0) {
        subx = dr_frame_subx(ref);
        suby = dr_frame_suby(ref);
    }
    var irow = y;
    while (irow < (y + h)) {
        var jcol = x;
        while (jcol < (x + w)) {
            # ---- 7.11.3.5 setup: project the 8x8 centre through the warp model ----
            var src_x = (jcol + 4) << subx;              # centre, lifted to the luma grid
            var src_y = (irow + 4) << suby;
            var dst_x = ((m2 * src_x) + (m3 * src_y)) + m0;
            var dst_y = ((m4 * src_x) + (m5 * src_y)) + m1;
            var x4 = dst_x >>> subx;                     # ARITHMETIC (dst_x may be < 0)
            var y4 = dst_y >>> suby;
            var ix4 = x4 >>> 16;                         # integer col (floor)
            var sx4 = x4 & 65535;                        # 16-bit residue (two's-complement AND)
            var iy4 = y4 >>> 16;
            var sy4 = y4 & 65535;
            var mx = ((sx4 - (4 * alpha)) - (7 * beta)) & (0 - 64);     # ~0x3f = -64
            var my = ((sy4 - (4 * gamma)) - (4 * delta)) & (0 - 64);
            # ---- gather the 15x15 padded reference block at (ix4-7, iy4-7) ----
            var gx = ix4 - 7;
            var gy = iy4 - 7;
            var rx0 = av1_clip3(0, pw - 1, gx);
            var rx1 = av1_clip3(0, pw - 1, gx + 14);
            var ry0 = av1_clip3(0, ph - 1, gy);
            var ry1 = av1_clip3(0, ph - 1, gy + 14);
            var rw = (rx1 - rx0) + 1;
            var rh = (ry1 - ry0) + 1;
            var rr = 0;
            while (rr < rh) {
                var rc = 0;
                while (rc < rw) {
                    store64(Av1_McRect + (((rr * rw) + rc) * 8),
                    dr_frame_get(ref, plane, rx0 + rc, ry0 + rr));
                    rc = rc + 1;
                }
                rr = rr + 1;
            }
            av1_mc_emu_edge(15, 15, rw, rh, gx - rx0, gy - ry0, Av1_McGather, 0, 15, Av1_McRect, 0, rw);
            var e = av1_warp_affine_8x8(Av1_McWarp8, 0, 8, Av1_McGather, (3 * 15) + 3, 15,
            alpha, beta, gamma, delta, mx, my, bd, compound);
            if (e != DR_OK) { return e; }
            # ---- write-back, cropped to the block (4x4 chroma / non-multiple-of-8) ----
            var r2 = 0;
            while ((r2 < 8) && ((irow + r2) < (y + h))) {
                var c2 = 0;
                while ((c2 < 8) && ((jcol + c2) < (x + w))) {
                    var wv = load64(Av1_McWarp8 + (((r2 * 8) + c2) * 8));
                    if (out_buf == 0) {
                        dr_frame_set(dst, plane, jcol + c2, irow + r2, wv);
                    } else {
                        store64(out_buf + ((((((irow + r2) - y) * out_stride) + (jcol + c2)) - x) * 8), wv);
                    }
                    c2 = c2 + 1;
                }
                r2 = r2 + 1;
            }
            jcol = jcol + 8;
        }
        irow = irow + 8;
    }
    return DR_OK;
}
# av1_warp_pred_block — the frame-write form (spec 7.11.3.5): warp into dst[plane] at (x,y).
fn av1_warp_pred_block(dst, ref, plane, x, y, w, h, wm): i64 {
    return av1_warp_pred_gen(dst, ref, plane, x, y, w, h, wm, 0, 0, 0);   # frame write, final precision
}
# Quant_Dist_Weight[4][2] (spec 7.11.3.15), flat idx = i*2 + col. Only rows 0..2 are read
# (the ratio-search loop caps at i<3); row 3 {1,31} exists for spec fidelity. 31 =
# MAX_FRAME_DISTANCE (spec §3). 3-source verified (compound_distance.md) — NOT {2,5},{3,4}.
fn av1_quant_dist_weight(idx): i64 {
    if (idx == 0) { return 2; }
    if (idx == 1) { return 3; }
    if (idx == 2) { return 2; }
    if (idx == 3) { return 5; }
    if (idx == 4) { return 2; }
    if (idx == 5) { return 7; }
    if (idx == 6) { return 1; }
    return 31;
}
# Quant_Dist_Lookup[4][2] (spec 7.11.3.15), flat idx = i*2 + col. EVERY row sums to 16 =
# DIST_PRECISION. 3-source verified — NOT the hallucinated {8,8},{7,9},{6,10} (which also
# sum to 16 — pin the EXACT pair, not the sum).
fn av1_quant_dist_lookup(idx): i64 {
    if (idx == 0) { return 9; }
    if (idx == 1) { return 7; }
    if (idx == 2) { return 11; }
    if (idx == 3) { return 5; }
    if (idx == 4) { return 12; }
    if (idx == 5) { return 4; }
    if (idx == 6) { return 13; }
    return 3;
}
# av1_dist_wtd_fwd — FwdWeight for a distance-weighted (jnt) compound block (spec 7.11.3.15).
# Applied to preds[0] (ref0); BckWeight = 16 - FwdWeight applies to preds[1] (ref1). d0 =
# dist1, d1 = dist0 (THE SWAP: d0 is ref1's clamped abs distance). order = (d0 <= d1) doubles
# as the lookup column. Zero-distance OR loop-fell-through both use Lookup row 3. Cyrius:
# comparisons yield 0/1 (order / 1-order are direct column indices); no break, so a `found`
# flag caps the ratio search. Cross-checked vs libaom av1_dist_wtd_comp_weight_assign + dav1d.
fn av1_dist_wtd_fwd(s, fh, ref0, ref1): i64 {
    var dist0 = av1_ref_dist(s, fh, ref0);
    var dist1 = av1_ref_dist(s, fh, ref1);
    var d0 = dist1;
    var d1 = dist0;
    var order = d0 <= d1;
    var i = 3;                                 # default: zero-distance or loop fell through
    if ((d0 != 0) && (d1 != 0)) {
        var k = 0;
        var found = 0;
        while ((k < 3) && (found == 0)) {
            var c0 = av1_quant_dist_weight((k * 2) + order);
            var c1 = av1_quant_dist_weight((k * 2) + (1 - order));
            var hit = 0;
            if (order != 0) {
                if ((d0 * c0) > (d1 * c1)) { hit = 1; }
            } else {
                if ((d0 * c0) < (d1 * c1)) { hit = 1; }
            }
            if (hit != 0) {
                i = k;
                found = 1;
            }
            k = k + 1;
        }
    }
    return av1_quant_dist_lookup((i * 2) + order);
}
# DIFFWTD difference-weight mask (spec 7.11.3.12): per LUMA pixel, m = Clip3(0, 64, 38 +
# (Round2(Abs(t0-t1), (bd-8)+ib) >> 4)), inverted to (64-m) when mask_type != 0. t0=Av1_McTmp
# (ref0), t1=Av1_McOut (ref1) at bit_depth+ib. Fills Av1_McMask (stride w) + records the luma
# extent (Av1_McMaskW/H) so chroma can subsample over the true luma stride. The diff is a
# NON-NEGATIVE value (Abs), so `>> 4` (logical) is correct there; the combine sum is signed
# (av1_round2). 3-source verified (compound_diffwtd.md); base 38, DIFF_FACTOR 16, MAX_ALPHA 64.
fn av1_diffwtd_mask_build(w, h, mask_type, bd, ib): i64 {
    var nsh = (bd - 8) + ib;                    # 4 @8-bit, 6 @10/12-bit
    var r = 0;
    while (r < h) {
        var c = 0;
        while (c < w) {
            var k = ((r * w) + c) * 8;
            var d = load64(Av1_McTmp + k) - load64(Av1_McOut + k);
            var a = av1_max(d, 0 - d);          # Abs (two's-complement negate, not ~)
            var m = av1_clip3(0, 64, 38 + (av1_round2(a, nsh) >> 4));
            if (mask_type != 0) { m = 64 - m; }
            store64(Av1_McMask + k, m);
            c = c + 1;
        }
        r = r + 1;
    }
    Av1_McMaskW = w;
    Av1_McMaskH = h;
    return DR_OK;
}
# read the DIFFWTD mask for output pixel (r,c) of the current plane, subsampled from the luma
# mask by (sx,sy) (spec 7.11.3.14). 4:4:4 = direct; 4:2:0 = Round2 of the 2x2 luma block;
# 4:2:2 / vertical = Round2 of the 2x1 pair. Luma read indices are edge-clamped to the built
# extent — defensive; a conformant decode never overhangs (coded luma dims are MI-aligned).
fn av1_diffwtd_mask_at(r, c, sx, sy): i64 {
    var lw = Av1_McMaskW;
    # defense-in-depth: an unbuilt mask (lw/lh == 0) would make the edge-clamp below produce
    # a NEGATIVE index (lw-1 = -1) -> an OOB read. Unreachable (plane 0 always builds the mask
    # before any chroma read; coded luma dims are >= 4), but never trust the invariant blindly.
    if ((lw < 1) || (Av1_McMaskH < 1)) { return 32; }
    if ((sx == 0) && (sy == 0)) {
        return load64(Av1_McMask + (((r * lw) + c) * 8));
    }
    var lh = Av1_McMaskH;
    var r0 = r << sy;
    var c0 = c << sx;
    var sum = 0;
    var dr = 0;
    while (dr <= sy) {
        var rr = r0 + dr;
        if (rr > (lh - 1)) { rr = lh - 1; }
        var dc = 0;
        while (dc <= sx) {
            var cc = c0 + dc;
            if (cc > (lw - 1)) { cc = lw - 1; }
            sum = sum + load64(Av1_McMask + (((rr * lw) + cc) * 8));
            dc = dc + 1;
        }
        dr = dr + 1;
    }
    return av1_round2(sum, sx + sy);            # shift 1 (2:2/vert) or 2 (2:0); never 0 here
}
# ================================================================
# WEDGE masked compound (spec 7.11.3.11) — the mask CODEBOOK + per-block generation. The
# blend + chroma subsample are the SAME as DIFFWTD (av1_diffwtd_mask_at + the ib+6 loop); only
# the mask FILL is new. 3-source verified (compound_wedge.md). Lazy tables (av1_wedge_bits_tbl
# idiom): the 6x64x64 master + the 3x16 codebook build once. Ramps are 0..64 hard literals.
# ================================================================
# the three 1-D master ramps (0..64): zeros left, a short soft transition, 64s right.
fn av1_wm_even(i): i64 {
    if (i < 28) { return 0; }
    if (i > 35) { return 64; }
    if (i == 28) { return 1; }
    if (i == 29) { return 4; }
    if (i == 30) { return 11; }
    if (i == 31) { return 27; }
    if (i == 32) { return 46; }
    if (i == 33) { return 58; }
    if (i == 34) { return 62; }
    return 63;
}
fn av1_wm_odd(i): i64 {
    if (i < 28) { return 0; }
    if (i > 35) { return 64; }
    if (i == 28) { return 1; }
    if (i == 29) { return 2; }
    if (i == 30) { return 6; }
    if (i == 31) { return 18; }
    if (i == 32) { return 37; }
    if (i == 33) { return 53; }
    if (i == 34) { return 60; }
    return 63;
}
fn av1_wm_vert(i): i64 {
    if (i < 29) { return 0; }
    if (i > 34) { return 64; }
    if (i == 29) { return 2; }
    if (i == 30) { return 7; }
    if (i == 31) { return 21; }
    if (i == 32) { return 43; }
    if (i == 33) { return 57; }
    return 62;
}
# the 6x64x64 master planes (u64 slots, values 0..64). Index dir*4096 + row*64 + col. Direction
# enum: HORIZONTAL=0 VERTICAL=1 OBLIQUE27=2 OBLIQUE63=3 OBLIQUE117=4 OBLIQUE153=5. Built lazily.
var Av1_WedgeMaster = 0;
fn av1_wedge_master_tbl(): i64 {
    if (Av1_WedgeMaster != 0) { return Av1_WedgeMaster; }
    var m = alloc(6 * 64 * 64 * 8);
    if (m == 0) { return 0; }
    # Stage 1 (spec 7.11.3.11): OBLIQUE63 (dir 3) + VERTICAL (dir 1). shift decrements ONCE
    # between the even row and the odd row, and PERSISTS across the outer iteration (the slope).
    var shift = 16;
    var i = 0;
    while (i < 64) {
        var j = 0;
        while (j < 64) {
            store64(m + (((3 * 4096) + (i * 64) + j) * 8), av1_wm_even(av1_clip3(0, 63, j - shift)));
            j = j + 1;
        }
        shift = shift - 1;
        j = 0;
        while (j < 64) {
            store64(m + (((3 * 4096) + (((i + 1) * 64) + j)) * 8), av1_wm_odd(av1_clip3(0, 63, j - shift)));
            j = j + 1;
        }
        j = 0;
        while (j < 64) {
            store64(m + (((1 * 4096) + (i * 64) + j) * 8), av1_wm_vert(j));
            store64(m + (((1 * 4096) + (((i + 1) * 64) + j)) * 8), av1_wm_vert(j));
            j = j + 1;
        }
        i = i + 2;
    }
    # Stage 2: derive OBLIQUE27 (transpose), OBLIQUE117 (hflip+complement), OBLIQUE153
    # (transpose+hflip+complement), HORIZONTAL (transpose of VERTICAL). Index-form, literal.
    i = 0;
    while (i < 64) {
        var j2 = 0;
        while (j2 < 64) {
            var msk = load64(m + (((3 * 4096) + (i * 64) + j2) * 8));
            store64(m + (((2 * 4096) + (j2 * 64) + i) * 8), msk);
            store64(m + (((4 * 4096) + (i * 64) + (63 - j2)) * 8), 64 - msk);
            store64(m + (((5 * 4096) + ((63 - j2) * 64) + i) * 8), 64 - msk);
            store64(m + (((0 * 4096) + (j2 * 64) + i) * 8), load64(m + (((1 * 4096) + (i * 64) + j2) * 8)));
            j2 = j2 + 1;
        }
        i = i + 1;
    }
    Av1_WedgeMaster = m;
    return m;
}
# Wedge_Codebook[3][16] packed as dir*64 + xoff*8 + yoff (shape 0=TALL,1=WIDE,2=SQUARE; shape =
# (h>w)?0 : (h<w)?1 : 2). Offsets in eighths of the block dim. Lazy 48-entry blob.
var Av1_WedgeCb = 0;
fn av1_wedge_cb_tbl(): i64 {
    if (Av1_WedgeCb != 0) { return Av1_WedgeCb; }
    var t = alloc(48 * 8);
    if (t == 0) { return 0; }
    # shape 0 TALL
    store64(t + (0 * 8), 164);
    store64(t + (1 * 8), 228);
    store64(t + (2 * 8), 292);
    store64(t + (3 * 8), 356);
    store64(t + (4 * 8), 34);
    store64(t + (5 * 8), 36);
    store64(t + (6 * 8), 38);
    store64(t + (7 * 8), 100);
    store64(t + (8 * 8), 162);
    store64(t + (9 * 8), 166);
    store64(t + (10 * 8), 354);
    store64(t + (11 * 8), 358);
    store64(t + (12 * 8), 212);
    store64(t + (13 * 8), 244);
    store64(t + (14 * 8), 276);
    store64(t + (15 * 8), 308);
    # shape 1 WIDE
    store64(t + (16 * 8), 164);
    store64(t + (17 * 8), 228);
    store64(t + (18 * 8), 292);
    store64(t + (19 * 8), 356);
    store64(t + (20 * 8), 84);
    store64(t + (21 * 8), 100);
    store64(t + (22 * 8), 116);
    store64(t + (23 * 8), 36);
    store64(t + (24 * 8), 162);
    store64(t + (25 * 8), 166);
    store64(t + (26 * 8), 354);
    store64(t + (27 * 8), 358);
    store64(t + (28 * 8), 212);
    store64(t + (29 * 8), 244);
    store64(t + (30 * 8), 276);
    store64(t + (31 * 8), 308);
    # shape 2 SQUARE
    store64(t + (32 * 8), 164);
    store64(t + (33 * 8), 228);
    store64(t + (34 * 8), 292);
    store64(t + (35 * 8), 356);
    store64(t + (36 * 8), 34);
    store64(t + (37 * 8), 38);
    store64(t + (38 * 8), 84);
    store64(t + (39 * 8), 116);
    store64(t + (40 * 8), 162);
    store64(t + (41 * 8), 166);
    store64(t + (42 * 8), 354);
    store64(t + (43 * 8), 358);
    store64(t + (44 * 8), 212);
    store64(t + (45 * 8), 244);
    store64(t + (46 * 8), 276);
    store64(t + (47 * 8), 308);
    Av1_WedgeCb = t;
    return t;
}
# av1_wedge_mask_build — fill Av1_McMask (stride fill_w) with the wedge mask for (sub_size,
# wedge_idx, wedge_sign). Geometry (shape/dir/xoff/yoff/flipSign) uses the NOMINAL block dims
# (av1_block_width/height) — NOT the edge-clamped fill_w/fill_h, else frame-edge blocks corrupt.
# flipSign = (perimeter-average < 32) canonicalizes wedge_sign==0; the emitted mask is
# raw (or 64-raw) per inv = wedge_sign XOR flipSign. Records Av1_McMaskW/H = fill_w/h.
fn av1_wedge_mask_build(sub_size, wedge_idx, wedge_sign, fill_w, fill_h): i64 {
    var mtbl = av1_wedge_master_tbl();
    if (mtbl == 0) { return DR_ERR_OOM; }
    var cbtbl = av1_wedge_cb_tbl();
    if (cbtbl == 0) { return DR_ERR_OOM; }   # symmetric with the master OOM guard (review F1)
    var w = av1_block_width(sub_size);
    var h = av1_block_height(sub_size);
    var shape = 2;
    if (h > w) { shape = 0; }
    if (h < w) { shape = 1; }
    var packed = load64(cbtbl + (((shape * 16) + wedge_idx) * 8));
    var dir = packed >> 6;
    var xoff = 32 - (((((packed >> 3) & 7) * w)) >> 3);
    var yoff = 32 - ((((packed & 7) * h)) >> 3);
    var base = mtbl + ((dir * 4096) * 8);
    var sum = 0;
    var j = 0;
    while (j < w) {
        sum = sum + load64(base + (((yoff * 64) + (xoff + j)) * 8));
        j = j + 1;
    }
    var i = 1;
    while (i < h) {
        sum = sum + load64(base + ((((yoff + i) * 64) + xoff) * 8));
        i = i + 1;
    }
    var avg = (sum + ((w + h - 1) / 2)) / (w + h - 1);
    var flip = 0;
    if (avg < 32) { flip = 1; }
    var inv = wedge_sign ^ flip;
    var r = 0;
    while (r < fill_h) {
        var c = 0;
        while (c < fill_w) {
            var raw = load64(base + ((((yoff + r) * 64) + (xoff + c)) * 8));
            var mv = raw;
            if (inv != 0) { mv = 64 - raw; }
            store64(Av1_McMask + (((r * fill_w) + c) * 8), mv);
            c = c + 1;
        }
        r = r + 1;
    }
    Av1_McMaskW = fill_w;
    Av1_McMaskH = fill_h;
    return DR_OK;
}

# ================================================================
# INTER-INTRA prediction (spec 7.11.3.13 SMOOTH mask + 7.11.3.14 interintra blend). A single-ref
# inter block (interintra flag) blends its inter MC prediction with an INTRA prediction. 0.7.91 =
# SMOOTH interintra (wedge_interintra deferred to 0.7.92). CRITICAL: the blend is FINAL precision
# (both preds at pixel range) — Round2(m*intra + (64-m)*inter, 6), NO ib, NO Clip1 (unlike the
# compound ib+6/Clip1 combine). m weights the INTRA prediction. 3-source verified (interintra.md).
# ================================================================
# Ii_Weights_1d[128] (spec 7.11.3.13): the smooth-mask 1-D weights, monotone 60..1. Lazy blob.
var Av1_IiWeights = 0;
fn av1_iifill8(t, o, v0, v1, v2, v3, v4, v5, v6, v7) {
    store64(t + ((o + 0) * 8), v0);   store64(t + ((o + 1) * 8), v1);
    store64(t + ((o + 2) * 8), v2);   store64(t + ((o + 3) * 8), v3);
    store64(t + ((o + 4) * 8), v4);   store64(t + ((o + 5) * 8), v5);
    store64(t + ((o + 6) * 8), v6);   store64(t + ((o + 7) * 8), v7);
    return 0;
}
fn av1_ii_weight_tbl(): i64 {
    if (Av1_IiWeights != 0) { return Av1_IiWeights; }
    var t = alloc(128 * 8);
    if (t == 0) { return 0; }
    av1_iifill8(t, 0, 60, 58, 56, 54, 52, 50, 48, 47);
    av1_iifill8(t, 8, 45, 44, 42, 41, 39, 38, 37, 35);
    av1_iifill8(t, 16, 34, 33, 32, 31, 30, 29, 28, 27);
    av1_iifill8(t, 24, 26, 25, 24, 23, 22, 22, 21, 20);
    av1_iifill8(t, 32, 19, 19, 18, 18, 17, 16, 16, 15);
    av1_iifill8(t, 40, 15, 14, 14, 13, 13, 12, 12, 12);
    av1_iifill8(t, 48, 11, 11, 10, 10, 10, 9, 9, 9);
    av1_iifill8(t, 56, 8, 8, 8, 8, 7, 7, 7, 7);
    av1_iifill8(t, 64, 6, 6, 6, 6, 6, 5, 5, 5);
    av1_iifill8(t, 72, 5, 5, 4, 4, 4, 4, 4, 4);
    av1_iifill8(t, 80, 4, 4, 3, 3, 3, 3, 3, 3);
    av1_iifill8(t, 88, 3, 3, 3, 2, 2, 2, 2, 2);
    av1_iifill8(t, 96, 2, 2, 2, 2, 2, 2, 2, 2);
    av1_iifill8(t, 104, 2, 2, 1, 1, 1, 1, 1, 1);
    av1_iifill8(t, 112, 1, 1, 1, 1, 1, 1, 1, 1);
    av1_iifill8(t, 120, 1, 1, 1, 1, 1, 1, 1, 1);
    Av1_IiWeights = t;
    return t;
}
# av1_ii_weight(idx): Ii_Weights_1d[idx], clamped to [0,127] (trust-no-input; gated sizes keep
# idx <= 124 anyway).
fn av1_ii_weight(idx): i64 {
    var i = idx;
    if (i < 0) { i = 0; }
    if (i > 127) { i = 127; }
    return load64(av1_ii_weight_tbl() + (i * 8));
}
# Obmc_Mask (spec 7.11.3.9 get_obmc_mask) — the raised-cosine OVERLAP-BLEND weight table, one raw
# constant (no generation formula). SELF-INDEXED: the length-`len` mask (len in {2,4,8,16,32}) lives at
# blob[len .. len+len-1], so &blob[len] is the mask (O(1), matches dav1d's addressing). The values are the
# SPEC own-weights: the blend weights the CURRENT prediction by mask[d] and the neighbour by (64-mask[d]),
# where d is the distance INTO the overlap from the neighbour edge — so mask rises from ~36 (neighbour-heavy
# edge) to 64 (own-only, blend no-op). 64 - these == dav1d_obmc_masks byte-for-byte (KAT anchor). The
# trailing len/4 entries are exactly 64 (why dav1d only touches (len*3)>>2); drishti blends spec-literal.
# Blob is 64 i64: [0,1] pad; [2,3]=len2; [4..7]=len4; [8..15]=len8; [16..31]=len16; [32..63]=len32.
var Av1_ObmcMask = 0;
fn av1_obmc_mask_tbl(): i64 {
    if (Av1_ObmcMask != 0) { return Av1_ObmcMask; }
    var t = alloc(64 * 8);
    if (t == 0) { return 0; }
    av1_iifill8(t, 0, 0, 0, 45, 64, 39, 50, 59, 64);       # pad[0,1] + len2{45,64} + len4{39,50,59,64}
    av1_iifill8(t, 8, 36, 42, 48, 53, 57, 61, 64, 64);      # len8
    av1_iifill8(t, 16, 34, 37, 40, 43, 46, 49, 52, 54);     # len16[0..7]
    av1_iifill8(t, 24, 56, 58, 60, 61, 64, 64, 64, 64);     # len16[8..15]
    av1_iifill8(t, 32, 33, 35, 36, 38, 40, 41, 43, 44);     # len32[0..7]
    av1_iifill8(t, 40, 45, 47, 48, 50, 51, 52, 53, 55);     # len32[8..15]
    av1_iifill8(t, 48, 56, 57, 58, 59, 60, 60, 61, 62);     # len32[16..23]
    av1_iifill8(t, 56, 64, 64, 64, 64, 64, 64, 64, 64);     # len32[24..31]
    Av1_ObmcMask = t;
    return t;
}
# av1_obmc_mask(len, i): the own-weight at distance i into a length-`len` overlap. A non-mask length or an
# out-of-range i returns 64 (own-only -> the blend is a no-op; trust-no-input backstop).
fn av1_obmc_mask(len, i): i64 {
    if ((len != 2) && (len != 4) && (len != 8) && (len != 16) && (len != 32)) { return 64; }
    if ((i < 0) || (i >= len)) { return 64; }
    return load64(av1_obmc_mask_tbl() + ((len + i) * 8));
}
# av1_ii_smooth_mask_build — fill Av1_McMask (stride fill_w) with the SMOOTH interintra weights
# (spec 7.11.3.13). m weights INTRA. sizeScale = 128/Max(nom_w,nom_h) (NOMINAL plane dims). Per
# ii_mode: 0=DC (flat 32), 1=V (row-indexed), 2=H (col-indexed), 3=SMOOTH (Min(row,col)-indexed).
# REGENERATED per plane (call on every plane) — the interintra smooth mask is NOT subsampled.
fn av1_ii_smooth_mask_build(nom_w, nom_h, fill_w, fill_h, ii_mode): i64 {
    var mx = nom_w;
    if (nom_h > nom_w) { mx = nom_h; }
    var scale = 128 / mx;
    var r = 0;
    while (r < fill_h) {
        var c = 0;
        while (c < fill_w) {
            var m = 32;
            if (ii_mode == 1) {
                m = av1_ii_weight(r * scale);
            } else {
                if (ii_mode == 2) {
                    m = av1_ii_weight(c * scale);
                } else {
                    if (ii_mode == 3) {
                        var mn = r;
                        if (c < r) { mn = c; }
                        m = av1_ii_weight(mn * scale);
                    }
                }
            }
            store64(Av1_McMask + (((r * fill_w) + c) * 8), m);
            c = c + 1;
        }
        r = r + 1;
    }
    Av1_McMaskW = fill_w;
    Av1_McMaskH = fill_h;
    return DR_OK;
}
# av1_mc_pred_interintra — one plane of a SMOOTH interintra block. Inter -> Av1_McOut at FINAL
# precision (compound=0), intra -> frame (predict_intra writes it), then the final-precision blend
# reads intra back. sub_size = NOMINAL luma block size; w/h = the (equal, in-scope) fill extent.
# ii_mode 0/1/2/3; intra mode = ii_mode for 0/1/2, 9 (SMOOTH_PRED) for 3. angle_delta/filter = 0.
fn av1_mc_pred_interintra_w(dst, ref, plane, x, y, w, h, mv_row, mv_col, filt_x, filt_y,
ii_mode, is_wedge, wedge_idx, sub_size, have_l, have_u, mi_cols, mi_rows, wm, use_warp): i64 {
    if (av1_mc_drv_scratch() != DR_OK) { return DR_ERR_OOM; }
    # Inter part -> Av1_McOut at FINAL precision. Warp it (GLOBALWARP inter-intra, spec 7.11.3.1 step 12: the
    # useWarp derivation has no inter-intra exception, so a >TRANSLATION global model warps the inter part;
    # inter-intra is never LOCALWARP since read_motion_mode forces SIMPLE) when THIS plane warps (use_warp),
    # else translation MC. Both produce Clip1'd final pixels — for isCompound==0 InterPostRound==0, so the
    # inter part arrives at final precision either way and the mask blend below is byte-identical.
    var e = DR_OK;
    if ((use_warp != 0) && (wm != 0)) {
        e = av1_warp_pred_gen(dst, ref, plane, x, y, w, h, wm, Av1_McOut, w, 0);   # inter-intra: FINAL precision
    } else {
        e = av1_mc_pred_core(Av1_McOut, dst, ref, plane, x, y, w, h, mv_row, mv_col, filt_x, filt_y, 0);
    }
    if (e != DR_OK) { return e; }
    var imode = ii_mode;
    if (ii_mode == 3) { imode = 9; }                # II_SMOOTH_PRED -> AV1_SMOOTH_PRED
    var sx = 0;
    var sy = 0;
    if (plane > 0) {
        sx = dr_frame_subx(dst);
        sy = dr_frame_suby(dst);
    }
    var log2w = (av1_mi_width_log2(sub_size) + 2) - sx;
    var log2h = (av1_mi_height_log2(sub_size) + 2) - sy;
    e = av1_intra_predict(dst, plane, x, y, have_l, have_u, 0, 0, imode, 0, 0, 0, 0, 0,
    log2w, log2h, mi_cols, mi_rows);
    if (e != DR_OK) { return e; }
    # mask: WEDGE interintra (wedge_sign forced 0) builds the codebook mask on LUMA (plane 0) at
    # the NOMINAL block size and chroma SUBSAMPLES it (av1_diffwtd_mask_at, exactly like compound
    # wedge). SMOOTH interintra REGENERATES the mask at THIS plane's dims (no subsample).
    if (is_wedge != 0) {
        if (plane == 0) {
            if (av1_wedge_mask_build(sub_size, wedge_idx, 0, w, h) != DR_OK) { return DR_ERR_OOM; }
        }
    } else {
        if (av1_ii_smooth_mask_build(1 << log2w, 1 << log2h, w, h, ii_mode) != DR_OK) {
            return DR_ERR_OOM;
        }
    }
    var r = 0;
    while (r < h) {
        var c = 0;
        while (c < w) {
            var m = 0;
            if (is_wedge != 0) {
                m = av1_diffwtd_mask_at(r, c, sx, sy);
            } else {
                m = load64(Av1_McMask + (((r * w) + c) * 8));
            }
            var intra = dr_frame_get(dst, plane, x + c, y + r);
            var inter = load64(Av1_McOut + (((r * w) + c) * 8));
            dr_frame_set(dst, plane, x + c, y + r,
            av1_round2((m * intra) + ((64 - m) * inter), 6));
            c = c + 1;
        }
        r = r + 1;
    }
    return DR_OK;
}
# av1_mc_pred_interintra — the translation-inter form (no warp), the common case.
fn av1_mc_pred_interintra(dst, ref, plane, x, y, w, h, mv_row, mv_col, filt_x, filt_y,
ii_mode, is_wedge, wedge_idx, sub_size, have_l, have_u, mi_cols, mi_rows): i64 {
    return av1_mc_pred_interintra_w(dst, ref, plane, x, y, w, h, mv_row, mv_col, filt_x, filt_y,
    ii_mode, is_wedge, wedge_idx, sub_size, have_l, have_u, mi_cols, mi_rows, 0, 0);
}

# COMPOUND MC (7.11.3.1 isCompound): MC from BOTH references at intermediate precision, then a
# combine. comp_mode==0 = SCALAR (AVERAGE fwd=bck=8; DISTANCE FwdWeight/16-Fwd) ->
# Clip1(Round2(t0*fwd + t1*bck, ib+4)) (AVERAGE 8/8 is BIT-EXACT with the old ib+1 form).
# comp_mode==1 = DIFFWTD masked: build the per-pixel mask on luma (plane 0), subsample for
# chroma -> Clip1(Round2(t0*m + t1*(64-m), ib+6)); the 6 is AOM_BLEND_A64_ROUND_BITS (log2 of
# the mask-sum 64). dav1d w_avg/w_mask, PREP_BIAS=0. 3-source verified (compound_*.md).
fn av1_mc_pred_compound(dst, ref0, ref1, plane, x, y, w, h, mv0_row, mv0_col, mv1_row, mv1_col,
filt_x, filt_y, fwd, bck, comp_mode, mask_type, sub_size, wedge_idx, wedge_sign, wm0, wm1, use_warp0, use_warp1): i64 {
    if (av1_mc_drv_scratch() != DR_OK) { return DR_ERR_OOM; }
    # Each reference -> its INTERMEDIATE buffer at bit_depth+ib: a GLOBAL_GLOBALMV warp (spec 7.11.3.5
    # isCompound=1, into McTmp/McOut via the dedicated McWarp8 kernel scratch) when that ref warps (use_warp*
    # = its GmType>TRANSLATION global model, shear-valid, plane>=8x8 — computed by the dispatch), else
    # translation MC. Both producers land at the SAME scale (3-source confirmed) so the combine is shared; a
    # ref may warp while the other translation-MCs (mixed is reachable). The warps touch neither McTmp nor
    # McOut internally (kernel = McWarp8, gather = McRect/McGather, mid = McMid), so the two are independent.
    var e = DR_OK;
    if ((use_warp0 != 0) && (wm0 != 0)) {
        e = av1_warp_pred_gen(dst, ref0, plane, x, y, w, h, wm0, Av1_McTmp, w, 1);
    } else {
        e = av1_mc_pred_core(Av1_McTmp, dst, ref0, plane, x, y, w, h, mv0_row, mv0_col, filt_x, filt_y, 1);
    }
    if (e != DR_OK) { return e; }
    if ((use_warp1 != 0) && (wm1 != 0)) {
        e = av1_warp_pred_gen(dst, ref1, plane, x, y, w, h, wm1, Av1_McOut, w, 1);
    } else {
        e = av1_mc_pred_core(Av1_McOut, dst, ref1, plane, x, y, w, h, mv1_row, mv1_col, filt_x, filt_y, 1);
    }
    if (e != DR_OK) { return e; }
    var bd = dr_frame_bit_depth(dst);
    var ib = 4;
    if (bd == 12) { ib = 2; }
    if (comp_mode != 0) {
        # MASKED (comp_mode 1=DIFFWTD, 2=WEDGE): build the mask ONCE on luma; chroma reuses it
        # subsampled. Both fill Av1_McMask (stride w) so av1_diffwtd_mask_at + the blend are shared.
        if (plane == 0) {
            if (comp_mode == 2) {
                if (av1_wedge_mask_build(sub_size, wedge_idx, wedge_sign, w, h) != DR_OK) {
                    return DR_ERR_OOM;
                }
            } else {
                av1_diffwtd_mask_build(w, h, mask_type, bd, ib);
            }
        }
        var msx = 0;
        var msy = 0;
        if (plane > 0) {
            msx = dr_frame_subx(dst);
            msy = dr_frame_suby(dst);
        }
        var mr = 0;
        while (mr < h) {
            var mc = 0;
            while (mc < w) {
                var m = av1_diffwtd_mask_at(mr, mc, msx, msy);
                var mk = ((mr * w) + mc) * 8;
                var ms = (load64(Av1_McTmp + mk) * m) + (load64(Av1_McOut + mk) * (64 - m));
                dr_frame_set(dst, plane, x + mc, y + mr, dr_clip1(av1_round2(ms, ib + 6), bd));
                mc = mc + 1;
            }
            mr = mr + 1;
        }
        return DR_OK;
    }
    var r = 0;
    while (r < h) {
        var c = 0;
        while (c < w) {
            var s = (load64(Av1_McTmp + (((r * w) + c) * 8)) * fwd)
            + (load64(Av1_McOut + (((r * w) + c) * 8)) * bck);
            dr_frame_set(dst, plane, x + c, y + r, dr_clip1(av1_round2(s, ib + 4), bd));
            c = c + 1;
        }
        r = r + 1;
    }
    return DR_OK;
}
